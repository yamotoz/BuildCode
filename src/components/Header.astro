---
// Header.astro
---

<header class="sticky top-0 z-50 glass-panel border-b border-border-color px-4 py-3 sm:px-6 sm:py-4 md:px-8 lg:px-24">
  <div class="mx-auto relative flex max-w-[1440px] items-center justify-between">
    <a href="/" class="flex items-center gap-2 sm:gap-3 text-slate-100 hover:opacity-80 transition-opacity shrink-0">
      <img id="header-logo" src="/logo_backofff.png" data-dark="/logo_backofff.png" data-light="/Logowhitemodeloff.png" alt="BuildCode" class="h-7 sm:h-8 w-auto object-contain" width="136" height="32" loading="eager" fetchpriority="high" />
      <h2 class="font-display text-lg sm:text-xl font-bold tracking-tight text-white hidden sm:block">BuildCode</h2>
    </a>
    <nav class="hidden lg:flex gap-6 xl:gap-8 absolute left-1/2 -translate-x-1/2">
      <a class="text-slate-300 hover:text-primary transition-colors text-sm font-medium tracking-wide focus:outline-none focus:ring-2 focus:ring-primary rounded" href="https://migueloliveiradev.com.br" target="_blank" rel="noopener noreferrer" data-i18n="nav.criador">Criador</a>
      <a class="text-slate-300 hover:text-primary transition-colors text-sm font-medium tracking-wide focus:outline-none focus:ring-2 focus:ring-primary rounded" href="/precos" data-i18n="nav.precos">Preços</a>
      <a class="text-slate-300 hover:text-primary transition-colors text-sm font-medium tracking-wide focus:outline-none focus:ring-2 focus:ring-primary rounded" href="/analytics" data-i18n="nav.analytics">Analytics</a>
      <a class="text-slate-300 hover:text-primary transition-colors text-sm font-medium tracking-wide focus:outline-none focus:ring-2 focus:ring-primary rounded" href="/biblioteca" data-i18n="nav.biblioteca">Biblioteca</a>
      <a class="text-red-400 hover:text-red-300 transition-colors text-sm font-medium tracking-wide focus:outline-none focus:ring-2 focus:ring-red-500 rounded" href="/cyberdyne">CyberDyne</a>
    </nav>
    <div class="flex items-center gap-2 sm:gap-3 shrink-0">
      <!-- Language Switcher -->
      <button id="lang-toggle" type="button" class="hidden min-[1400px]:flex items-center gap-1.5 px-2.5 py-1.5 rounded-full border border-white/10 bg-white/[0.03] hover:bg-white/[0.08] hover:border-primary/30 transition-all text-xs font-bold text-slate-400 hover:text-white cursor-pointer" title="Switch language">
        <span class="material-symbols-outlined text-sm">translate</span>
        <span id="lang-label">PT</span>
      </button>

      <!-- Login button (visible when NOT authenticated) -->
      <a id="header-login-btn" href="/login" class="hidden lg:flex cursor-pointer items-center justify-center rounded-full border border-primary/40 px-4 py-2.5 min-h-[44px] text-secondary hover:bg-primary/10 transition-colors text-sm font-semibold tracking-wide focus:outline-none focus:ring-2 focus:ring-primary">
          <span data-i18n="nav.login">Login</span>
      </a>

      <a href="/app" class="flex cursor-pointer items-center justify-center rounded-full bg-white text-[#0e1214] hover:bg-primary hover:text-white transition-colors px-4 sm:px-6 py-2.5 text-xs sm:text-sm font-bold tracking-wide shadow-[0_0_15px_rgba(179,218,242,0.3)] focus:outline-none focus:ring-2 focus:ring-white whitespace-nowrap min-h-[44px]">
          <span data-i18n="nav.acessar">Acessar Sistema</span>
      </a>

      <!-- User pill with dropdown (visible when authenticated) -->
      <div id="header-user-btn" class="hidden relative">
        <button id="header-user-pill" type="button" class="flex items-center gap-2 cursor-pointer rounded-full border border-primary/20 pl-2.5 pr-1.5 py-1.5 hover:bg-primary/5 hover:border-primary/40 transition-all">
          <span id="header-user-name" class="text-xs sm:text-sm font-medium text-white max-w-[80px] sm:max-w-[120px] truncate"></span>
          <div class="w-7 h-7 rounded-full bg-primary/20 flex items-center justify-center overflow-hidden border border-primary/30 shrink-0">
            <img id="header-avatar-img" src="" alt="" class="w-full h-full object-cover hidden" width="32" height="32" />
            <span id="header-avatar-initials" class="text-[10px] font-bold text-primary"></span>
          </div>
        </button>
        <!-- Dropdown -->
        <div id="header-user-dropdown" class="hidden absolute right-0 top-full mt-2 w-48 rounded-xl overflow-hidden shadow-xl z-50" style="background: #1a1a1a; border: 1px solid #2A3135;">
          <a href="/perfil" id="header-link-perfil" class="flex items-center gap-3 px-4 py-3 text-sm text-slate-300 hover:text-white hover:bg-white/[0.05] transition-all">
            <span class="material-symbols-outlined text-lg text-primary">person</span>
            Perfil
          </a>
          <a href="/perfil#plano" id="header-link-plano" class="flex items-center gap-3 px-4 py-3 text-sm text-slate-300 hover:text-white hover:bg-white/[0.05] transition-all border-t border-white/5">
            <span class="material-symbols-outlined text-lg text-cta">credit_card</span>
            Plano
          </a>
          <a href="/marketing" id="header-link-marketing" class="hidden items-center gap-3 px-4 py-3 text-sm text-slate-300 hover:text-white hover:bg-white/[0.05] transition-all border-t border-white/5">
            <span class="material-symbols-outlined text-lg text-orange-400">campaign</span>
            Marketing
          </a>
          <button id="header-logout-btn" type="button" class="flex items-center gap-3 px-4 py-3 text-sm text-red-400 hover:text-red-300 hover:bg-red-500/5 transition-all border-t border-white/5 w-full text-left cursor-pointer">
            <span class="material-symbols-outlined text-lg">logout</span>
            Sair
          </button>
        </div>
      </div>

      <!-- Mobile hamburger menu button -->
      <button id="mobile-menu-btn" type="button" class="lg:hidden flex items-center justify-center w-11 h-11 rounded-lg border border-white/10 bg-white/[0.03] hover:bg-white/[0.08] transition-all cursor-pointer" aria-label="Menu">
        <span id="mobile-menu-icon" class="material-symbols-outlined text-xl text-slate-300">menu</span>
      </button>
    </div>
  </div>

  <!-- Mobile menu drawer -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-border-color">
    <nav class="flex flex-col py-3 px-2 gap-1">
      <a class="text-slate-300 hover:text-primary hover:bg-white/[0.04] transition-all text-sm font-medium tracking-wide rounded-lg px-4 py-3" href="https://migueloliveiradev.com.br" target="_blank" rel="noopener noreferrer" data-i18n="nav.criador">Criador</a>
      <a class="text-slate-300 hover:text-primary hover:bg-white/[0.04] transition-all text-sm font-medium tracking-wide rounded-lg px-4 py-3" href="/precos" data-i18n="nav.precos">Preços</a>
      <a class="text-slate-300 hover:text-primary hover:bg-white/[0.04] transition-all text-sm font-medium tracking-wide rounded-lg px-4 py-3" href="/analytics" data-i18n="nav.analytics">Analytics</a>
      <a class="text-slate-300 hover:text-primary hover:bg-white/[0.04] transition-all text-sm font-medium tracking-wide rounded-lg px-4 py-3" href="/biblioteca" data-i18n="nav.biblioteca">Biblioteca</a>
      <a class="text-red-400 hover:text-red-300 hover:bg-red-500/5 transition-all text-sm font-medium tracking-wide rounded-lg px-4 py-3" href="/cyberdyne">CyberDyne</a>
      <div class="border-t border-white/5 my-1"></div>
      <a id="mobile-login-link" class="text-slate-300 hover:text-primary hover:bg-white/[0.04] transition-all text-sm font-medium tracking-wide rounded-lg px-4 py-3" href="/login" data-i18n="nav.login">Login</a>
    </nav>
  </div>
</header>

<script>
  import { supabase, getProfile } from '../lib/supabase';

  async function updateHeaderAuth() {
    const loginBtn = document.getElementById('header-login-btn');
    const userBtn = document.getElementById('header-user-btn');
    const userName = document.getElementById('header-user-name');
    const avatarImg = document.getElementById('header-avatar-img');
    const avatarInitials = document.getElementById('header-avatar-initials');

    if (!loginBtn || !userBtn) return;

    try {
      const { data: { session } } = await supabase.auth.getSession();

      const mobileLoginLink = document.getElementById('mobile-login-link');

      if (session) {
        loginBtn.classList.add('hidden');
        loginBtn.classList.remove('lg:flex');
        userBtn.classList.remove('hidden');
        userBtn.classList.add('flex');
        if (mobileLoginLink) mobileLoginLink.classList.add('hidden');

        const profile = await getProfile(session.user.id);
        const displayName = profile?.full_name || session.user.email?.split('@')[0] || 'Usuário';

        if (userName) userName.textContent = displayName;

        if (profile?.avatar_url && avatarImg) {
          (avatarImg as HTMLImageElement).src = profile.avatar_url;
          avatarImg.classList.remove('hidden');
          if (avatarInitials) avatarInitials.classList.add('hidden');
        } else if (avatarInitials) {
          const initials = displayName.split(' ').map((w) => w[0]).join('').toUpperCase().slice(0, 2);
          avatarInitials.textContent = initials;
          avatarInitials.classList.remove('hidden');
          if (avatarImg) avatarImg.classList.add('hidden');
        }

        // Show marketing link if user has permission
        if (profile?.role === 'master' || (profile as any)?.can_access_marketing) {
          const mktLink = document.getElementById('header-link-marketing');
          if (mktLink) { mktLink.classList.remove('hidden'); mktLink.classList.add('flex'); }
        }

        // Apply user theme preference (default is light)
        if (profile?.theme === 'dark') {
          document.documentElement.classList.remove('light');
          document.documentElement.classList.add('dark');
          localStorage.setItem('bc-theme', 'dark');
        }
        updateLogo();
      } else {
        loginBtn.classList.remove('hidden');
        loginBtn.classList.add('lg:flex');
        userBtn.classList.add('hidden');
        userBtn.classList.remove('flex');
      }
    } catch {
      // Supabase not configured yet — keep default state
    }
  }

  function updateLogo() {
    const logo = document.getElementById('header-logo') as HTMLImageElement | null;
    if (!logo) return;
    const isLight = document.documentElement.classList.contains('light');
    logo.src = isLight ? (logo.dataset.light || logo.src) : (logo.dataset.dark || logo.src);
    // Also update footer logo if present
    const footerLogo = document.getElementById('footer-logo') as HTMLImageElement | null;
    if (footerLogo) {
      footerLogo.src = isLight ? (footerLogo.dataset.light || footerLogo.src) : (footerLogo.dataset.dark || footerLogo.src);
    }
  }

  // Expose for theme toggle usage
  (window as any).bcUpdateLogo = updateLogo;

  // User dropdown toggle
  const userPill = document.getElementById('header-user-pill');
  const userDropdown = document.getElementById('header-user-dropdown');
  if (userPill && userDropdown) {
    userPill.addEventListener('click', (e) => {
      e.stopPropagation();
      userDropdown.classList.toggle('hidden');
    });
    // Close on click outside
    document.addEventListener('click', () => {
      userDropdown.classList.add('hidden');
    });
    userDropdown.addEventListener('click', (e) => {
      e.stopPropagation();
    });
  }

  // Perfil link — if already on /perfil, switch to perfil view
  const perfilLink = document.getElementById('header-link-perfil');
  if (perfilLink) {
    perfilLink.addEventListener('click', (e) => {
      if (window.location.pathname === '/perfil') {
        e.preventDefault();
        window.history.replaceState(null, '', '/perfil');
        if (typeof (window as any).switchProfileTab === 'function') {
          (window as any).switchProfileTab('perfil');
        }
        userDropdown?.classList.add('hidden');
      }
    });
  }

  // Plano link — navigate to perfil and switch tab
  const planoLink = document.getElementById('header-link-plano');
  if (planoLink) {
    planoLink.addEventListener('click', (e) => {
      // If already on /perfil, just switch tab
      if (window.location.pathname === '/perfil') {
        e.preventDefault();
        window.history.replaceState(null, '', '/perfil#plano');
        if (typeof (window as any).switchProfileTab === 'function') {
          (window as any).switchProfileTab('plano');
        }
        userDropdown?.classList.add('hidden');
      }
      // Otherwise let the href navigate with hash
    });
  }

  // Logout button
  const logoutBtn = document.getElementById('header-logout-btn');
  if (logoutBtn) {
    logoutBtn.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = '/login';
    });
  }

  // Mobile menu toggle
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileIcon = document.getElementById('mobile-menu-icon');
  if (mobileBtn && mobileMenu && mobileIcon) {
    mobileBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      if (isOpen) {
        mobileMenu.classList.add('hidden');
        mobileIcon.textContent = 'menu';
      } else {
        mobileMenu.classList.remove('hidden');
        mobileIcon.textContent = 'close';
      }
    });
  }

  updateHeaderAuth();
  updateLogo();

  supabase.auth.onAuthStateChange(() => {
    updateHeaderAuth();
  });

  // Watch for theme class changes
  const observer = new MutationObserver(() => updateLogo());
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
</script>
