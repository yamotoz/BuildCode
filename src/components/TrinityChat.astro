---
// TrinityChat.astro — Floating chat widget for the landing page only
---

<div id="trinity-widget" class="fixed bottom-6 right-6 z-[9990]">
  <!-- Chat Panel -->
  <div id="trinity-panel" class="hidden absolute bottom-20 right-0 w-80 sm:w-96 rounded-2xl overflow-hidden shadow-2xl border border-white/10" style="background: #0e1214; height: 28rem;">
    <!-- Header -->
    <div class="flex items-center gap-3 px-4 py-3 border-b border-white/10" style="background: linear-gradient(135deg, #111416, #1a1d20);">
      <div class="relative w-9 h-9 rounded-full overflow-hidden border-2 border-primary/40 shrink-0">
        <img src="/Foto_Base trinity.png" alt="Trinity" class="w-full h-full object-cover" />
        <div class="w-full h-full bg-primary/20 items-center justify-center text-primary text-xs font-bold hidden absolute inset-0">T</div>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-white text-sm font-semibold leading-tight">Trinity</p>
        <p class="text-emerald-400 text-[10px] font-medium">Online</p>
      </div>
      <button id="trinity-close" type="button" class="text-slate-500 hover:text-white transition-colors cursor-pointer p-1">
        <span class="material-symbols-outlined text-lg">close</span>
      </button>
    </div>

    <!-- Chat area -->
    <div id="trinity-chat-area" class="flex flex-col h-[calc(100%-52px)]">
      <div id="trinity-messages" class="flex-1 overflow-y-auto p-4 space-y-3" style="scrollbar-width: thin; scrollbar-color: #2a2d30 transparent;"></div>
      <div class="border-t border-white/10 px-3 py-2.5 flex gap-2" style="background: #111416;">
        <input id="trinity-input" type="text" placeholder="Digite sua dúvida..." maxlength="300" class="flex-1 bg-white/5 border border-white/10 rounded-full px-4 py-2 text-sm text-white placeholder-slate-500 outline-none focus:border-primary/50 transition-colors" />
        <button id="trinity-send" type="button" class="w-9 h-9 rounded-full bg-primary hover:bg-primary/80 flex items-center justify-center transition-colors cursor-pointer shrink-0">
          <span class="material-symbols-outlined text-white text-base">send</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Toggle Button — video plays inside the circle -->
  <button id="trinity-toggle" type="button" class="group size-16 rounded-full overflow-hidden shadow-[0_4px_20px_rgba(46,116,139,0.35)] hover:shadow-[0_4px_30px_rgba(46,116,139,0.5)] transition-all cursor-pointer hover:scale-105 active:scale-95 border-2 border-primary/40 relative">
    <video autoplay muted loop playsinline disablepictureinpicture class="absolute inset-0 w-full h-full object-cover object-top" style="object-position: center 20%;">
      <source src="/img/trinity-apresentacao.mp4" type="video/mp4" />
    </video>
  </button>
  <!-- Notification dot -->
  <span id="trinity-dot" class="absolute -top-0.5 -right-0.5 size-4 rounded-full bg-red-500 border-2 border-[#0e1214] animate-pulse pointer-events-none hidden"></span>
  <!-- Speech bubble -->
  <div id="trinity-bubble" class="hidden absolute bottom-full right-0 mb-3 mr-1 pointer-events-none" style="animation: trinityBubbleIn 0.4s ease-out forwards;">
    <div class="relative bg-white text-[#1a1a2e] text-xs font-medium px-4 py-2.5 rounded-xl shadow-lg whitespace-nowrap">
      Qualquer dúvida, estou disponível 😊
      <div class="absolute -bottom-1.5 right-5 w-3 h-3 bg-white rotate-45 rounded-sm"></div>
    </div>
  </div>
</div>

<script>
  const widget = document.getElementById('trinity-widget');
  const panel = document.getElementById('trinity-panel');
  const toggle = document.getElementById('trinity-toggle');
  const closeBtn = document.getElementById('trinity-close');
  const messagesEl = document.getElementById('trinity-messages');
  const input = document.getElementById('trinity-input') as HTMLInputElement;
  const sendBtn = document.getElementById('trinity-send');
  const dot = document.getElementById('trinity-dot');

  let chatHistory: { role: string; content: string }[] = [];
  let chatStarted = false;
  let isSending = false;

  function openPanel() {
    panel?.classList.remove('hidden');
    dot?.classList.add('hidden');
    document.getElementById('trinity-bubble')?.classList.add('hidden');
    if (!chatStarted) {
      chatStarted = true;
      addMessage('trinity', 'Oi! Eu sou a Trinity, assistente do BuildCode 😊 Precisa de alguma ajuda? Pode me perguntar qualquer coisa sobre a plataforma!');
    }
    input?.focus();
  }

  function closePanel() {
    panel?.classList.add('hidden');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = !panel?.classList.contains('hidden');
    if (isOpen) closePanel(); else openPanel();
  });

  closeBtn?.addEventListener('click', closePanel);

  function addMessage(sender: 'user' | 'trinity', text: string) {
    if (!messagesEl) return;
    const div = document.createElement('div');
    div.className = sender === 'user'
      ? 'flex justify-end'
      : 'flex justify-start';

    const bubble = document.createElement('div');
    bubble.className = sender === 'user'
      ? 'max-w-[80%] px-3.5 py-2.5 rounded-2xl rounded-br-md text-sm text-white leading-relaxed'
      : 'max-w-[80%] px-3.5 py-2.5 rounded-2xl rounded-bl-md text-sm text-slate-200 leading-relaxed';
    bubble.style.background = sender === 'user' ? '#2E748B' : '#1a1d20';

    // Escape HTML to prevent XSS
    const escaped = text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    bubble.innerHTML = escaped.replace(/\n/g, '<br>');

    div.appendChild(bubble);
    messagesEl.appendChild(div);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function addTyping() {
    if (!messagesEl) return;
    const div = document.createElement('div');
    div.id = 'trinity-typing';
    div.className = 'flex justify-start';
    div.innerHTML = `<div class="px-3.5 py-2.5 rounded-2xl rounded-bl-md text-sm text-slate-400" style="background:#1a1d20">Digitando<span class="trinity-dots">...</span></div>`;
    messagesEl.appendChild(div);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function removeTyping() {
    document.getElementById('trinity-typing')?.remove();
  }

  async function sendMessage() {
    if (isSending) return;
    const text = input?.value.trim();
    if (!text) return;
    input.value = '';

    addMessage('user', text);
    chatHistory.push({ role: 'user', content: text });

    isSending = true;
    addTyping();

    try {
      const res = await fetch('/api/trinity', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: chatHistory }),
      });

      removeTyping();

      if (!res.ok) {
        addMessage('trinity', 'Ops, tive um probleminha aqui. Tenta de novo?');
        isSending = false;
        return;
      }

      const data = await res.json();
      const reply = data.reply || 'Não entendi, pode reformular?';
      addMessage('trinity', reply);
      chatHistory.push({ role: 'model', content: reply });
    } catch {
      removeTyping();
      addMessage('trinity', 'Ops, algo deu errado. Tenta de novo em alguns segundos!');
    }

    isSending = false;
  }

  sendBtn?.addEventListener('click', sendMessage);
  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  // Show speech bubble after 3 seconds
  const bubble = document.getElementById('trinity-bubble');
  setTimeout(() => {
    if (panel?.classList.contains('hidden')) {
      bubble?.classList.remove('hidden');
      dot?.classList.remove('hidden');
      // Hide bubble after 6 seconds
      setTimeout(() => { bubble?.classList.add('hidden'); }, 6000);
    }
  }, 3000);

  // Close on click outside
  document.addEventListener('click', (e) => {
    if (widget && !widget.contains(e.target as Node) && !panel?.classList.contains('hidden')) {
      closePanel();
    }
  });
</script>

<style>
  @keyframes trinityDots {
    0%, 20% { content: '.'; }
    40% { content: '..'; }
    60%, 100% { content: '...'; }
  }
  .trinity-dots {
    animation: trinityDots 1.2s steps(1) infinite;
  }
  @keyframes trinityBubbleIn {
    0% { opacity: 0; transform: translateY(8px) scale(0.9); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }
</style>
