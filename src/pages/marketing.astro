---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dashboard Marketing — BuildCode" noindex={true}>
  <!-- Full page wrapper -->
  <div id="marketing-app" class="flex min-h-screen bg-[#0D0D0D] text-slate-100" style="display:none;">

    <!-- ═══════════════════════════════════════════ -->
    <!--  SIDEBAR                                    -->
    <!-- ═══════════════════════════════════════════ -->
    <aside id="sidebar" class="fixed left-0 top-0 h-full z-40 flex flex-col py-6 bg-[#121415]/80 backdrop-blur-xl border-r border-[#2A3135] transition-all duration-300 overflow-hidden" style="width:60px;" onmouseenter="this.style.width='240px'" onmouseleave="this.style.width='60px'">
      <!-- Logo -->
      <div class="flex items-center gap-3 px-4 mb-8 whitespace-nowrap">
        <img src="/faviconBC.png" alt="BC" class="w-7 h-7 flex-shrink-0" />
        <span class="font-bold text-white text-lg sidebar-label">Marketing</span>
      </div>

      <!-- Nav items -->
      <nav class="flex flex-col gap-1 flex-1 px-2">
        <button data-module="generator" class="sidebar-btn active flex items-center gap-3 px-3 py-2.5 rounded-xl text-left whitespace-nowrap transition-all duration-200">
          <span class="material-symbols-outlined text-[22px] flex-shrink-0">auto_awesome</span>
          <span class="sidebar-label text-sm font-medium">Gerador de Conteúdo</span>
        </button>
        <button data-module="calendar" class="sidebar-btn flex items-center gap-3 px-3 py-2.5 rounded-xl text-left whitespace-nowrap transition-all duration-200">
          <span class="material-symbols-outlined text-[22px] flex-shrink-0">calendar_month</span>
          <span class="sidebar-label text-sm font-medium">Calendário Editorial</span>
        </button>
        <button data-module="visual" class="sidebar-btn flex items-center gap-3 px-3 py-2.5 rounded-xl text-left whitespace-nowrap transition-all duration-200">
          <span class="material-symbols-outlined text-[22px] flex-shrink-0">palette</span>
          <span class="sidebar-label text-sm font-medium">Criador Visual</span>
        </button>
        <button data-module="ideas" class="sidebar-btn flex items-center gap-3 px-3 py-2.5 rounded-xl text-left whitespace-nowrap transition-all duration-200">
          <span class="material-symbols-outlined text-[22px] flex-shrink-0">lightbulb</span>
          <span class="sidebar-label text-sm font-medium">Banco de Ideias</span>
        </button>
        <button data-module="analytics" class="sidebar-btn flex items-center gap-3 px-3 py-2.5 rounded-xl text-left whitespace-nowrap transition-all duration-200">
          <span class="material-symbols-outlined text-[22px] flex-shrink-0">analytics</span>
          <span class="sidebar-label text-sm font-medium">Analytics</span>
        </button>
        <button data-module="launch" class="sidebar-btn flex items-center gap-3 px-3 py-2.5 rounded-xl text-left whitespace-nowrap transition-all duration-200">
          <span class="material-symbols-outlined text-[22px] flex-shrink-0">rocket_launch</span>
          <span class="sidebar-label text-sm font-medium">Estratégia de Lançamento</span>
        </button>
        <button data-module="copy" class="sidebar-btn flex items-center gap-3 px-3 py-2.5 rounded-xl text-left whitespace-nowrap transition-all duration-200">
          <span class="material-symbols-outlined text-[22px] flex-shrink-0">edit_note</span>
          <span class="sidebar-label text-sm font-medium">Copy Workshop</span>
        </button>
      </nav>

      <!-- Back link -->
      <div class="px-2 mt-4">
        <a href="/perfil" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-slate-400 hover:text-white whitespace-nowrap transition-all duration-200">
          <span class="material-symbols-outlined text-[22px] flex-shrink-0">arrow_back</span>
          <span class="sidebar-label text-sm font-medium">Voltar</span>
        </a>
      </div>
    </aside>

    <!-- ═══════════════════════════════════════════ -->
    <!--  MAIN CONTENT                               -->
    <!-- ═══════════════════════════════════════════ -->
    <main class="flex-1 ml-[60px] p-6 lg:p-8">
      <!-- Header -->
      <header class="flex items-center justify-between mb-8">
        <div>
          <h1 class="font-bold text-2xl text-white">Dashboard Marketing</h1>
          <p class="text-slate-400 text-sm mt-1">Gerencie conteúdo, calendário e estratégias</p>
        </div>
        <div id="header-user" class="flex items-center gap-3">
          <span id="header-name" class="text-sm text-slate-300"></span>
          <div id="header-avatar" class="w-9 h-9 rounded-full bg-[#2E748B]/30 flex items-center justify-center text-sm font-bold text-[#2E748B]"></div>
        </div>
      </header>

      <!-- ════════════════════════════════════ -->
      <!--  MODULE 1: GERADOR DE CONTEÚDO      -->
      <!-- ════════════════════════════════════ -->
      <section id="module-generator" class="module-panel">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <!-- Form -->
          <div class="bg-[#121415]/50 border border-[#2A3135] rounded-2xl p-6">
            <h2 class="font-bold text-xl text-white mb-6 flex items-center gap-2">
              <span class="material-symbols-outlined text-[#F2AB6D]">auto_awesome</span>
              Gerador de Conteúdo
            </h2>
            <div class="space-y-4">
              <div>
                <label class="block text-sm text-slate-300 mb-1.5">Plataforma</label>
                <select id="gen-platform" class="w-full bg-[#0D0D0D] border border-[#2A3135] rounded-xl px-4 py-2.5 text-white focus:border-[#2E748B] focus:outline-none transition-colors">
                  <option value="tiktok">TikTok</option>
                  <option value="linkedin">LinkedIn</option>
                  <option value="instagram">Instagram</option>
                  <option value="twitter">Twitter / X</option>
                </select>
              </div>
              <div>
                <label class="block text-sm text-slate-300 mb-1.5">Tipo de Conteúdo</label>
                <select id="gen-type" class="w-full bg-[#0D0D0D] border border-[#2A3135] rounded-xl px-4 py-2.5 text-white focus:border-[#2E748B] focus:outline-none transition-colors">
                  <option value="post">Post</option>
                  <option value="script">Script</option>
                  <option value="carousel">Carousel</option>
                  <option value="hook">Hook</option>
                  <option value="banner">Banner Copy</option>
                  <option value="story">Story</option>
                </select>
              </div>
              <div>
                <label class="block text-sm text-slate-300 mb-1.5">Tom</label>
                <select id="gen-tone" class="w-full bg-[#0D0D0D] border border-[#2A3135] rounded-xl px-4 py-2.5 text-white focus:border-[#2E748B] focus:outline-none transition-colors">
                  <option value="profissional">Profissional</option>
                  <option value="casual">Casual</option>
                  <option value="inspiracional">Inspiracional</option>
                  <option value="técnico">Técnico</option>
                  <option value="provocativo">Provocativo</option>
                </select>
              </div>
              <div>
                <label class="block text-sm text-slate-300 mb-1.5">Tema / Tópico</label>
                <textarea id="gen-topic" rows="3" placeholder="Ex: Como a IA está transformando a arquitetura de software..." class="w-full bg-[#0D0D0D] border border-[#2A3135] rounded-xl px-4 py-2.5 text-white placeholder-slate-500 focus:border-[#2E748B] focus:outline-none transition-colors resize-none"></textarea>
              </div>
              <button id="gen-btn" class="w-full bg-[#F2AB6D] hover:bg-[#e09a5c] text-[#0D0D0D] font-bold py-3 rounded-xl transition-all duration-200 flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-[20px]">auto_awesome</span>
                Gerar com IA
              </button>
            </div>
          </div>

          <!-- Result -->
          <div class="bg-[#121415]/50 border border-[#2A3135] rounded-2xl p-6 flex flex-col">
            <h2 class="font-bold text-xl text-white mb-4">Resultado</h2>
            <div id="gen-loading" class="hidden flex-1 flex items-center justify-center">
              <div class="animate-spin w-8 h-8 border-2 border-[#2E748B] border-t-transparent rounded-full"></div>
            </div>
            <textarea id="gen-result" rows="14" placeholder="O conteúdo gerado aparecerá aqui..." class="flex-1 w-full bg-[#0D0D0D] border border-[#2A3135] rounded-xl px-4 py-3 text-white placeholder-slate-500 focus:border-[#2E748B] focus:outline-none transition-colors resize-none text-sm leading-relaxed"></textarea>
            <div class="flex gap-3 mt-4">
              <button id="gen-copy" class="flex-1 bg-[#2A3135] hover:bg-[#3A4145] text-white py-2.5 rounded-xl transition-all duration-200 flex items-center justify-center gap-2 text-sm">
                <span class="material-symbols-outlined text-[18px]">content_copy</span>
                Copiar
              </button>
              <button id="gen-save" class="flex-1 bg-[#2E748B]/20 hover:bg-[#2E748B]/30 text-[#2E748B] py-2.5 rounded-xl transition-all duration-200 flex items-center justify-center gap-2 text-sm border border-[#2E748B]/30">
                <span class="material-symbols-outlined text-[18px]">save</span>
                Salvar como Rascunho
              </button>
            </div>
          </div>
        </div>
      </section>

      <!-- ════════════════════════════════════ -->
      <!--  MODULE 2: CALENDÁRIO EDITORIAL     -->
      <!-- ════════════════════════════════════ -->
      <section id="module-calendar" class="module-panel hidden">
        <div class="bg-[#121415]/50 border border-[#2A3135] rounded-2xl p-6">
          <div class="flex items-center justify-between mb-6">
            <h2 class="font-bold text-xl text-white flex items-center gap-2">
              <span class="material-symbols-outlined text-[#F2AB6D]">calendar_month</span>
              Calendário Editorial
            </h2>
            <div class="flex items-center gap-4">
              <button id="cal-prev" class="text-slate-400 hover:text-white transition-colors"><span class="material-symbols-outlined">chevron_left</span></button>
              <span id="cal-month-label" class="text-white font-semibold min-w-[180px] text-center"></span>
              <button id="cal-next" class="text-slate-400 hover:text-white transition-colors"><span class="material-symbols-outlined">chevron_right</span></button>
            </div>
          </div>
          <!-- Weekday headers -->
          <div class="grid grid-cols-7 gap-1 mb-1">
            <div class="text-center text-xs text-slate-500 font-medium py-2">Dom</div>
            <div class="text-center text-xs text-slate-500 font-medium py-2">Seg</div>
            <div class="text-center text-xs text-slate-500 font-medium py-2">Ter</div>
            <div class="text-center text-xs text-slate-500 font-medium py-2">Qua</div>
            <div class="text-center text-xs text-slate-500 font-medium py-2">Qui</div>
            <div class="text-center text-xs text-slate-500 font-medium py-2">Sex</div>
            <div class="text-center text-xs text-slate-500 font-medium py-2">Sáb</div>
          </div>
          <!-- Calendar grid -->
          <div id="cal-grid" class="grid grid-cols-7 gap-1"></div>
        </div>
        <!-- Day detail panel -->
        <div id="cal-detail" class="hidden mt-4 bg-[#121415]/50 border border-[#2A3135] rounded-2xl p-6">
          <h3 id="cal-detail-title" class="font-bold text-lg text-white mb-4"></h3>
          <div id="cal-detail-posts" class="space-y-3"></div>
        </div>
      </section>

      <!-- ════════════════════════════════════ -->
      <!--  MODULE 3: CRIADOR VISUAL           -->
      <!-- ════════════════════════════════════ -->
      <section id="module-visual" class="module-panel hidden">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <!-- Controls -->
          <div class="bg-[#121415]/50 border border-[#2A3135] rounded-2xl p-6">
            <h2 class="font-bold text-xl text-white mb-6 flex items-center gap-2">
              <span class="material-symbols-outlined text-[#F2AB6D]">palette</span>
              Criador de Banners
            </h2>
            <div class="space-y-4">
              <div>
                <label class="block text-sm text-slate-300 mb-1.5">Template</label>
                <select id="vis-template" class="w-full bg-[#0D0D0D] border border-[#2A3135] rounded-xl px-4 py-2.5 text-white focus:border-[#2E748B] focus:outline-none transition-colors">
                  <option value="announcement">Announcement</option>
                  <option value="tip">Tip of the Day</option>
                  <option value="feature">Feature Highlight</option>
                </select>
              </div>
              <div>
                <label class="block text-sm text-slate-300 mb-1.5">Título</label>
                <input id="vis-title" type="text" value="BuildCode" placeholder="Título do banner" class="w-full bg-[#0D0D0D] border border-[#2A3135] rounded-xl px-4 py-2.5 text-white focus:border-[#2E748B] focus:outline-none transition-colors" />
              </div>
              <div>
                <label class="block text-sm text-slate-300 mb-1.5">Subtítulo</label>
                <input id="vis-subtitle" type="text" value="Arquitetura de Software com IA" placeholder="Subtítulo do banner" class="w-full bg-[#0D0D0D] border border-[#2A3135] rounded-xl px-4 py-2.5 text-white focus:border-[#2E748B] focus:outline-none transition-colors" />
              </div>
              <div>
                <label class="block text-sm text-slate-300 mb-1.5">Cor de Fundo</label>
                <div class="flex gap-2 items-center">
                  <input id="vis-bg" type="color" value="#2E748B" class="w-12 h-10 rounded-lg border border-[#2A3135] cursor-pointer bg-transparent" />
                  <span id="vis-bg-label" class="text-sm text-slate-400">#2E748B</span>
                </div>
              </div>
              <div>
                <label class="block text-sm text-slate-300 mb-1.5">Cor do Texto</label>
                <div class="flex gap-2">
                  <button id="vis-text-white" class="flex-1 py-2 rounded-xl bg-white text-black text-sm font-medium border-2 border-[#2E748B]">Branco</button>
                  <button id="vis-text-black" class="flex-1 py-2 rounded-xl bg-[#2A3135] text-white text-sm font-medium border-2 border-transparent">Preto</button>
                </div>
              </div>
              <button id="vis-download" class="w-full bg-[#F2AB6D] hover:bg-[#e09a5c] text-[#0D0D0D] font-bold py-3 rounded-xl transition-all duration-200 flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-[20px]">download</span>
                Download PNG
              </button>
            </div>
          </div>
          <!-- Canvas -->
          <div class="lg:col-span-2 bg-[#121415]/50 border border-[#2A3135] rounded-2xl p-6 flex items-center justify-center">
            <canvas id="vis-canvas" width="800" height="400" class="rounded-xl max-w-full h-auto border border-[#2A3135]"></canvas>
          </div>
        </div>
      </section>

      <!-- ════════════════════════════════════ -->
      <!--  MODULE 4: BANCO DE IDEIAS          -->
      <!-- ════════════════════════════════════ -->
      <section id="module-ideas" class="module-panel hidden">
        <h2 class="font-bold text-xl text-white mb-6 flex items-center gap-2">
          <span class="material-symbols-outlined text-[#F2AB6D]">lightbulb</span>
          Banco de Ideias
        </h2>
        <!-- Category filter -->
        <div class="flex flex-wrap gap-2 mb-6" id="ideas-categories"></div>
        <!-- Kanban columns -->
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
          <div class="bg-[#121415]/50 border border-[#2A3135] rounded-2xl p-4">
            <h3 class="font-semibold text-white mb-3 flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-slate-400"></span> Backlog
              <span id="ideas-count-backlog" class="text-xs text-slate-500 ml-auto">0</span>
            </h3>
            <div id="ideas-col-backlog" class="space-y-2 min-h-[100px]"></div>
          </div>
          <div class="bg-[#121415]/50 border border-[#2A3135] rounded-2xl p-4">
            <h3 class="font-semibold text-white mb-3 flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-[#F2AB6D]"></span> Em Andamento
              <span id="ideas-count-progress" class="text-xs text-slate-500 ml-auto">0</span>
            </h3>
            <div id="ideas-col-progress" class="space-y-2 min-h-[100px]"></div>
          </div>
          <div class="bg-[#121415]/50 border border-[#2A3135] rounded-2xl p-4">
            <h3 class="font-semibold text-white mb-3 flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-emerald-400"></span> Feito
              <span id="ideas-count-done" class="text-xs text-slate-500 ml-auto">0</span>
            </h3>
            <div id="ideas-col-done" class="space-y-2 min-h-[100px]"></div>
          </div>
          <div class="bg-[#121415]/50 border border-[#2A3135] rounded-2xl p-4">
            <h3 class="font-semibold text-white mb-3 flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-red-400"></span> Descartado
              <span id="ideas-count-discarded" class="text-xs text-slate-500 ml-auto">0</span>
            </h3>
            <div id="ideas-col-discarded" class="space-y-2 min-h-[100px]"></div>
          </div>
        </div>
      </section>

      <!-- ════════════════════════════════════ -->
      <!--  MODULE 5: ANALYTICS                -->
      <!-- ════════════════════════════════════ -->
      <section id="module-analytics" class="module-panel hidden">
        <h2 class="font-bold text-xl text-white mb-6 flex items-center gap-2">
          <span class="material-symbols-outlined text-[#F2AB6D]">analytics</span>
          Analytics de Conteúdo
        </h2>
        <!-- Stats cards -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
          <div class="bg-[#121415]/50 border border-[#2A3135] rounded-2xl p-5">
            <p class="text-slate-400 text-sm">Total Posts</p>
            <p id="stat-total" class="text-3xl font-bold text-white mt-1">0</p>
          </div>
          <div class="bg-[#121415]/50 border border-[#2A3135] rounded-2xl p-5">
            <p class="text-slate-400 text-sm">Publicados</p>
            <p id="stat-published" class="text-3xl font-bold text-emerald-400 mt-1">0</p>
          </div>
          <div class="bg-[#121415]/50 border border-[#2A3135] rounded-2xl p-5">
            <p class="text-slate-400 text-sm">Agendados</p>
            <p id="stat-scheduled" class="text-3xl font-bold text-[#F2AB6D] mt-1">0</p>
          </div>
          <div class="bg-[#121415]/50 border border-[#2A3135] rounded-2xl p-5">
            <p class="text-slate-400 text-sm">Rascunhos</p>
            <p id="stat-drafts" class="text-3xl font-bold text-slate-400 mt-1">0</p>
          </div>
        </div>
        <!-- Chart -->
        <div class="bg-[#121415]/50 border border-[#2A3135] rounded-2xl p-6 mb-6">
          <h3 class="font-semibold text-white mb-4">Posts por Plataforma (últimos 30 dias)</h3>
          <canvas id="analytics-chart" width="700" height="250" class="max-w-full"></canvas>
        </div>
        <!-- Posts table -->
        <div class="bg-[#121415]/50 border border-[#2A3135] rounded-2xl p-6 overflow-x-auto">
          <h3 class="font-semibold text-white mb-4">Posts Recentes</h3>
          <table class="w-full text-sm">
            <thead>
              <tr class="text-slate-400 border-b border-[#2A3135]">
                <th class="text-left py-3 px-2">Título</th>
                <th class="text-left py-3 px-2">Plataforma</th>
                <th class="text-left py-3 px-2">Status</th>
                <th class="text-left py-3 px-2">Data</th>
                <th class="text-left py-3 px-2">Views</th>
                <th class="text-left py-3 px-2">Likes</th>
                <th class="text-left py-3 px-2">Comments</th>
              </tr>
            </thead>
            <tbody id="analytics-table" class="text-slate-300"></tbody>
          </table>
        </div>
      </section>

      <!-- ════════════════════════════════════ -->
      <!--  MODULE 6: ESTRATÉGIA DE LANÇAMENTO -->
      <!-- ════════════════════════════════════ -->
      <section id="module-launch" class="module-panel hidden">
        <h2 class="font-bold text-xl text-white mb-6 flex items-center gap-2">
          <span class="material-symbols-outlined text-[#F2AB6D]">rocket_launch</span>
          Estratégia de Lançamento
        </h2>
        <div class="space-y-6" id="launch-phases"></div>
      </section>

      <!-- ════════════════════════════════════ -->
      <!--  MODULE 7: COPY WORKSHOP            -->
      <!-- ════════════════════════════════════ -->
      <section id="module-copy" class="module-panel hidden">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <!-- Main area -->
          <div class="lg:col-span-2 space-y-4">
            <div class="bg-[#121415]/50 border border-[#2A3135] rounded-2xl p-6">
              <h2 class="font-bold text-xl text-white mb-4 flex items-center gap-2">
                <span class="material-symbols-outlined text-[#F2AB6D]">edit_note</span>
                Copy Workshop
              </h2>
              <textarea id="copy-input" rows="8" placeholder="Cole aqui seu texto de marketing para análise..." class="w-full bg-[#0D0D0D] border border-[#2A3135] rounded-xl px-4 py-3 text-white placeholder-slate-500 focus:border-[#2E748B] focus:outline-none transition-colors resize-none"></textarea>
              <button id="copy-analyze-btn" class="mt-4 w-full bg-[#F2AB6D] hover:bg-[#e09a5c] text-[#0D0D0D] font-bold py-3 rounded-xl transition-all duration-200 flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-[20px]">psychology</span>
                Analisar com IA
              </button>
            </div>
            <!-- Results -->
            <div id="copy-result-panel" class="hidden bg-[#121415]/50 border border-[#2A3135] rounded-2xl p-6">
              <h3 class="font-semibold text-white mb-3">Análise e Sugestões</h3>
              <div id="copy-loading" class="hidden flex items-center justify-center py-8">
                <div class="animate-spin w-8 h-8 border-2 border-[#2E748B] border-t-transparent rounded-full"></div>
              </div>
              <div id="copy-result" class="text-slate-300 text-sm leading-relaxed whitespace-pre-wrap"></div>
            </div>
          </div>
          <!-- Tips sidebar -->
          <div class="bg-[#121415]/50 border border-[#2A3135] rounded-2xl p-6 h-fit">
            <h3 class="font-semibold text-white mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-[#2E748B]">tips_and_updates</span>
              Dicas Rápidas
            </h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-2 text-sm text-slate-300"><span class="text-[#F2AB6D] font-bold mt-0.5">1.</span> Clareza &gt; Criatividade</li>
              <li class="flex items-start gap-2 text-sm text-slate-300"><span class="text-[#F2AB6D] font-bold mt-0.5">2.</span> Benefícios &gt; Features</li>
              <li class="flex items-start gap-2 text-sm text-slate-300"><span class="text-[#F2AB6D] font-bold mt-0.5">3.</span> Especificidade &gt; Generalidade</li>
              <li class="flex items-start gap-2 text-sm text-slate-300"><span class="text-[#F2AB6D] font-bold mt-0.5">4.</span> Linguagem do cliente &gt; Jargão técnico</li>
              <li class="flex items-start gap-2 text-sm text-slate-300"><span class="text-[#F2AB6D] font-bold mt-0.5">5.</span> Uma ideia por seção</li>
              <li class="flex items-start gap-2 text-sm text-slate-300"><span class="text-[#F2AB6D] font-bold mt-0.5">6.</span> Voz ativa, tom confiante</li>
            </ul>
            <div class="mt-6 p-4 bg-[#2E748B]/10 rounded-xl border border-[#2E748B]/20">
              <p class="text-xs text-slate-400 leading-relaxed">
                <strong class="text-[#2E748B]">Pro tip:</strong> Sempre teste duas versões do mesmo copy. O que parece melhor na teoria nem sempre converte mais na prática.
              </p>
            </div>
          </div>
        </div>
      </section>

    </main>
  </div>

  <!-- Loading state -->
  <div id="marketing-loading" class="flex items-center justify-center min-h-screen bg-[#0D0D0D]">
    <div class="animate-spin w-10 h-10 border-2 border-[#2E748B] border-t-transparent rounded-full"></div>
  </div>

  <script>
    import { supabase, getProfile } from '../lib/supabase';

    // ═══════════════════════════════════════════
    //  AUTH CHECK
    // ═══════════════════════════════════════════
    let session = null;
    let profile = null;
    let allPosts = [];

    async function init() {
      const { data: { session: s } } = await supabase.auth.getSession();
      if (!s) { window.location.href = '/login'; return; }
      session = s;

      const p = await getProfile(s.user.id);
      if (!p || (p.role !== 'master' && !p.can_access_marketing)) {
        window.location.href = '/perfil';
        return;
      }
      profile = p;

      // Show UI
      document.getElementById('marketing-loading').style.display = 'none';
      document.getElementById('marketing-app').style.display = 'flex';

      // Header user info
      document.getElementById('header-name').textContent = p.full_name || s.user.email;
      const avatarEl = document.getElementById('header-avatar');
      if (p.avatar_url) {
        avatarEl.innerHTML = `<img src="${p.avatar_url}" class="w-9 h-9 rounded-full object-cover" alt="avatar" />`;
      } else {
        avatarEl.textContent = (p.full_name || s.user.email || '?')[0].toUpperCase();
      }

      // Load posts for calendar and analytics
      await loadPosts();

      // Init modules
      initCalendar();
      initVisualCreator();
      initIdeas();
      initAnalytics();
      initLaunchChecklist();
    }

    function authHeaders() {
      return { 'Authorization': `Bearer ${session.access_token}`, 'Content-Type': 'application/json' };
    }

    async function loadPosts() {
      try {
        const res = await fetch('/api/marketing', { headers: authHeaders() });
        if (res.ok) allPosts = await res.json();
      } catch (e) { console.error('Failed to load posts', e); }
    }

    // ═══════════════════════════════════════════
    //  MODULE SWITCHING
    // ═══════════════════════════════════════════
    const sidebarBtns = document.querySelectorAll('.sidebar-btn');
    const modulePanels = document.querySelectorAll('.module-panel');

    sidebarBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const mod = btn.getAttribute('data-module');
        sidebarBtns.forEach(b => b.classList.remove('active', 'bg-[#2E748B]/10', 'text-[#2E748B]', 'border-l-2', 'border-[#2E748B]'));
        btn.classList.add('active', 'bg-[#2E748B]/10', 'text-[#2E748B]', 'border-l-2', 'border-[#2E748B]');
        modulePanels.forEach(p => p.classList.add('hidden'));
        document.getElementById(`module-${mod}`).classList.remove('hidden');

        // Refresh data-dependent modules
        if (mod === 'calendar') renderCalendar();
        if (mod === 'analytics') { loadPosts().then(() => initAnalytics()); }
      });
    });

    // Set initial active state
    document.querySelector('[data-module="generator"]').classList.add('bg-[#2E748B]/10', 'text-[#2E748B]', 'border-l-2', 'border-[#2E748B]');

    // ═══════════════════════════════════════════
    //  MODULE 1: GERADOR DE CONTEÚDO
    // ═══════════════════════════════════════════
    document.getElementById('gen-btn').addEventListener('click', async () => {
      const platform = (document.getElementById('gen-platform') as HTMLSelectElement).value;
      const contentType = (document.getElementById('gen-type') as HTMLSelectElement).value;
      const tone = (document.getElementById('gen-tone') as HTMLSelectElement).value;
      const topic = (document.getElementById('gen-topic') as HTMLTextAreaElement).value.trim();
      if (!topic) { alert('Preencha o tema/tópico.'); return; }

      const resultEl = document.getElementById('gen-result') as HTMLTextAreaElement;
      const loadingEl = document.getElementById('gen-loading');
      const btn = document.getElementById('gen-btn') as HTMLButtonElement;

      btn.disabled = true;
      btn.textContent = 'Gerando...';
      loadingEl.classList.remove('hidden');
      resultEl.value = '';

      try {
        const res = await fetch('/api/marketing', {
          method: 'POST',
          headers: authHeaders(),
          body: JSON.stringify({ action: 'generate', platform, contentType, tone, topic }),
        });
        const data = await res.json();
        if (res.ok) {
          resultEl.value = data.content || '';
        } else {
          resultEl.value = `Erro: ${data.error || 'Falha ao gerar conteúdo'}`;
        }
      } catch (e) {
        resultEl.value = 'Erro de conexão. Tente novamente.';
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<span class="material-symbols-outlined text-[20px]">auto_awesome</span> Gerar com IA';
        loadingEl.classList.add('hidden');
      }
    });

    document.getElementById('gen-copy').addEventListener('click', () => {
      const text = (document.getElementById('gen-result') as HTMLTextAreaElement).value;
      if (!text) return;
      navigator.clipboard.writeText(text);
      const btn = document.getElementById('gen-copy');
      btn.innerHTML = '<span class="material-symbols-outlined text-[18px]">check</span> Copiado!';
      setTimeout(() => { btn.innerHTML = '<span class="material-symbols-outlined text-[18px]">content_copy</span> Copiar'; }, 2000);
    });

    document.getElementById('gen-save').addEventListener('click', async () => {
      const content = (document.getElementById('gen-result') as HTMLTextAreaElement).value.trim();
      if (!content) { alert('Gere conteúdo antes de salvar.'); return; }
      const platform = (document.getElementById('gen-platform') as HTMLSelectElement).value;
      const contentType = (document.getElementById('gen-type') as HTMLSelectElement).value;
      const topic = (document.getElementById('gen-topic') as HTMLTextAreaElement).value.trim();

      try {
        const res = await fetch('/api/marketing', {
          method: 'POST',
          headers: authHeaders(),
          body: JSON.stringify({
            platform,
            content_type: contentType,
            title: topic.substring(0, 80) || 'Rascunho sem título',
            content,
            status: 'draft',
          }),
        });
        const data = await res.json();
        if (res.ok) {
          allPosts.unshift(data);
          const btn = document.getElementById('gen-save');
          btn.innerHTML = '<span class="material-symbols-outlined text-[18px]">check</span> Salvo!';
          setTimeout(() => { btn.innerHTML = '<span class="material-symbols-outlined text-[18px]">save</span> Salvar como Rascunho'; }, 2000);
        } else {
          alert(data.error || 'Erro ao salvar');
        }
      } catch (e) { alert('Erro de conexão'); }
    });

    // ═══════════════════════════════════════════
    //  MODULE 2: CALENDÁRIO EDITORIAL
    // ═══════════════════════════════════════════
    let calYear, calMonth;

    function initCalendar() {
      const now = new Date();
      calYear = now.getFullYear();
      calMonth = now.getMonth();
      renderCalendar();
    }

    document.getElementById('cal-prev').addEventListener('click', () => {
      calMonth--;
      if (calMonth < 0) { calMonth = 11; calYear--; }
      renderCalendar();
    });
    document.getElementById('cal-next').addEventListener('click', () => {
      calMonth++;
      if (calMonth > 11) { calMonth = 0; calYear++; }
      renderCalendar();
    });

    const monthNames = ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'];

    const platformColors = {
      tiktok: 'bg-pink-400',
      linkedin: 'bg-blue-400',
      instagram: 'bg-purple-400',
      twitter: 'bg-sky-400',
    };

    const statusBadges = {
      draft: { label: 'Rascunho', cls: 'bg-slate-500/20 text-slate-400' },
      scheduled: { label: 'Agendado', cls: 'bg-yellow-500/20 text-yellow-400' },
      published: { label: 'Publicado', cls: 'bg-emerald-500/20 text-emerald-400' },
    };

    function renderCalendar() {
      document.getElementById('cal-month-label').textContent = `${monthNames[calMonth]} ${calYear}`;
      const grid = document.getElementById('cal-grid');
      grid.innerHTML = '';

      const firstDay = new Date(calYear, calMonth, 1).getDay();
      const daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();
      const today = new Date();

      // Empty cells before first day
      for (let i = 0; i < firstDay; i++) {
        const cell = document.createElement('div');
        cell.className = 'min-h-[80px] rounded-xl';
        grid.appendChild(cell);
      }

      for (let d = 1; d <= daysInMonth; d++) {
        const dateStr = `${calYear}-${String(calMonth + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
        const dayPosts = allPosts.filter(p => {
          const pDate = p.scheduled_date || p.created_at;
          return pDate && pDate.startsWith(dateStr);
        });

        const isToday = today.getFullYear() === calYear && today.getMonth() === calMonth && today.getDate() === d;
        const cell = document.createElement('div');
        cell.className = `min-h-[80px] rounded-xl border ${isToday ? 'border-[#2E748B] bg-[#2E748B]/10' : 'border-[#2A3135]/50 bg-[#0D0D0D]/30'} p-2 cursor-pointer hover:border-[#2E748B]/50 transition-all duration-200`;
        cell.innerHTML = `
          <span class="text-xs ${isToday ? 'text-[#2E748B] font-bold' : 'text-slate-400'}">${d}</span>
          <div class="flex flex-wrap gap-1 mt-1">
            ${dayPosts.map(p => `<span class="w-2 h-2 rounded-full ${platformColors[p.platform] || 'bg-slate-400'}" title="${p.title}"></span>`).join('')}
          </div>
          ${dayPosts.length > 0 ? `<span class="text-[10px] text-slate-500 mt-1 block">${dayPosts.length} post${dayPosts.length > 1 ? 's' : ''}</span>` : ''}
        `;

        cell.addEventListener('click', () => showDayDetail(dateStr, d, dayPosts));
        grid.appendChild(cell);
      }
    }

    function showDayDetail(dateStr, day, posts) {
      const panel = document.getElementById('cal-detail');
      const title = document.getElementById('cal-detail-title');
      const container = document.getElementById('cal-detail-posts');

      title.textContent = `${day} de ${monthNames[calMonth]} de ${calYear}`;
      panel.classList.remove('hidden');

      if (posts.length === 0) {
        container.innerHTML = '<p class="text-slate-500 text-sm">Nenhum post para este dia.</p>';
        return;
      }

      container.innerHTML = posts.map(p => {
        const badge = statusBadges[p.status] || statusBadges.draft;
        return `
          <div class="bg-[#0D0D0D]/50 border border-[#2A3135] rounded-xl p-4 flex items-center justify-between">
            <div>
              <p class="text-white font-medium text-sm">${p.title}</p>
              <div class="flex items-center gap-2 mt-1">
                <span class="w-2 h-2 rounded-full ${platformColors[p.platform] || 'bg-slate-400'}"></span>
                <span class="text-xs text-slate-400 capitalize">${p.platform}</span>
                <span class="text-xs px-2 py-0.5 rounded-full ${badge.cls}">${badge.label}</span>
              </div>
            </div>
          </div>
        `;
      }).join('');
    }

    // ═══════════════════════════════════════════
    //  MODULE 3: CRIADOR VISUAL
    // ═══════════════════════════════════════════
    let visTextColor = '#ffffff';

    function initVisualCreator() {
      renderBanner();
    }

    function renderBanner() {
      const canvas = document.getElementById('vis-canvas') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d');
      const template = (document.getElementById('vis-template') as HTMLSelectElement).value;
      const title = (document.getElementById('vis-title') as HTMLInputElement).value || 'BuildCode';
      const subtitle = (document.getElementById('vis-subtitle') as HTMLInputElement).value || '';
      const bgColor = (document.getElementById('vis-bg') as HTMLInputElement).value;

      // Background
      ctx.fillStyle = bgColor;
      ctx.fillRect(0, 0, 800, 400);

      // Template decorations
      if (template === 'announcement') {
        // Diagonal accent
        ctx.fillStyle = visTextColor === '#ffffff' ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.08)';
        ctx.beginPath();
        ctx.moveTo(500, 0);
        ctx.lineTo(800, 0);
        ctx.lineTo(800, 300);
        ctx.closePath();
        ctx.fill();
        // Small label
        ctx.fillStyle = '#F2AB6D';
        ctx.font = 'bold 14px Inter, sans-serif';
        ctx.fillText('NOVO', 60, 120);
      } else if (template === 'tip') {
        // Circle decoration
        ctx.fillStyle = visTextColor === '#ffffff' ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';
        ctx.beginPath();
        ctx.arc(700, 80, 120, 0, Math.PI * 2);
        ctx.fill();
        ctx.beginPath();
        ctx.arc(100, 350, 80, 0, Math.PI * 2);
        ctx.fill();
        // Label
        ctx.fillStyle = '#F2AB6D';
        ctx.font = 'bold 14px Inter, sans-serif';
        ctx.fillText('DICA DO DIA', 60, 120);
      } else if (template === 'feature') {
        // Gradient bar at bottom
        const grad = ctx.createLinearGradient(0, 360, 800, 360);
        grad.addColorStop(0, '#F2AB6D');
        grad.addColorStop(1, 'transparent');
        ctx.fillStyle = grad;
        ctx.fillRect(0, 370, 800, 30);
        // Label
        ctx.fillStyle = '#F2AB6D';
        ctx.font = 'bold 14px Inter, sans-serif';
        ctx.fillText('FEATURE', 60, 120);
      }

      // Title
      ctx.fillStyle = visTextColor;
      ctx.font = 'bold 42px Inter, sans-serif';
      ctx.fillText(title, 60, 200);

      // Subtitle
      if (subtitle) {
        ctx.fillStyle = visTextColor === '#ffffff' ? 'rgba(255,255,255,0.7)' : 'rgba(0,0,0,0.7)';
        ctx.font = '22px Inter, sans-serif';
        ctx.fillText(subtitle, 60, 245);
      }

      // Branding
      ctx.fillStyle = visTextColor === '#ffffff' ? 'rgba(255,255,255,0.4)' : 'rgba(0,0,0,0.4)';
      ctx.font = '14px Inter, sans-serif';
      ctx.fillText('buildcode.com.br', 60, 360);
    }

    // Bind all visual creator inputs
    ['vis-template', 'vis-title', 'vis-subtitle', 'vis-bg'].forEach(id => {
      document.getElementById(id).addEventListener('input', () => {
        if (id === 'vis-bg') {
          document.getElementById('vis-bg-label').textContent = (document.getElementById('vis-bg') as HTMLInputElement).value;
        }
        renderBanner();
      });
    });

    document.getElementById('vis-text-white').addEventListener('click', () => {
      visTextColor = '#ffffff';
      document.getElementById('vis-text-white').classList.add('border-[#2E748B]');
      document.getElementById('vis-text-white').classList.remove('border-transparent');
      document.getElementById('vis-text-black').classList.add('border-transparent');
      document.getElementById('vis-text-black').classList.remove('border-[#2E748B]');
      renderBanner();
    });
    document.getElementById('vis-text-black').addEventListener('click', () => {
      visTextColor = '#000000';
      document.getElementById('vis-text-black').classList.add('border-[#2E748B]');
      document.getElementById('vis-text-black').classList.remove('border-transparent');
      document.getElementById('vis-text-white').classList.add('border-transparent');
      document.getElementById('vis-text-white').classList.remove('border-[#2E748B]');
      renderBanner();
    });

    document.getElementById('vis-download').addEventListener('click', () => {
      const canvas = document.getElementById('vis-canvas') as HTMLCanvasElement;
      const link = document.createElement('a');
      link.download = 'buildcode-banner.png';
      link.href = canvas.toDataURL('image/png');
      link.click();
    });

    // ═══════════════════════════════════════════
    //  MODULE 4: BANCO DE IDEIAS
    // ═══════════════════════════════════════════
    const MARKETING_IDEAS = {
      'Content & SEO': [
        'Blog posts com keywords de cauda longa sobre arquitetura de software',
        'Série de tutoriais em vídeo sobre design patterns com IA',
        'Criar glossário interativo de termos de arquitetura',
        'Guest posts em blogs de tecnologia brasileiros',
        'SEO técnico: schema markup para SaaS e ratings',
      ],
      'Free Tools': [
        'Calculadora de custo de infraestrutura cloud',
        'Gerador de diagramas de arquitetura simplificado',
        'Quiz "Qual stack ideal para seu projeto?"',
        'Template gratuito de PRD para download',
      ],
      'Paid Ads': [
        'Google Ads para keywords de arquitetura de software',
        'LinkedIn Ads targeting CTOs e tech leads',
        'Retargeting para visitantes que não converteram',
        'YouTube pre-roll em canais de programação',
      ],
      'Social & Community': [
