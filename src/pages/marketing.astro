        'Sequência de onboarding em 7 emails',
        'Email de reengajamento para usuários inativos',
        'Drip campaign para leads do blog',
      ],
      'Partnerships': [
        'Parceria com bootcamps de programação',
        'Co-marketing com ferramentas complementares (Figma, Notion)',
        'Programa de afiliados para influencers tech',
        'Integração com plataformas de ensino (Alura, Rocketseat)',
      ],
      'Events': [
        'Workshop online gratuito de arquitetura com IA',
        'Participar de eventos tech (TDC, DevFest)',
        'Hackathon patrocinado pelo BuildCode',
        'Webinars com CTOs sobre decisões de stack',
      ],
      'Launches': [
        'Product Hunt launch com assets e comunidade preparados',
        'Beta exclusivo para primeiros 100 cadastrados',
        'Countdown landing page com lista de espera',
        'Press release para mídia tech brasileira',
      ],
      'Product-Led': [
        'Free tier generoso para viralizar',
        'Onboarding interativo com projeto exemplo',
        'Templates prontos de arquitetura popular (Next.js + Supabase)',
        'Export/share de PRDs com branding BuildCode',
      ],
      'Referral': [
        'Programa "Indique e Ganhe" (créditos por referral)',
        'Badge/certificado compartilhável após completar wizard',
        'Desconto para times (3+ usuários)',
      ],
      'Pricing': [
        'Plano anual com 2 meses grátis',
        'Pricing transparente vs competidores (página comparativa)',
        'Trial de 14 dias sem cartão',
        'Plano especial para startups early-stage',
      ],
      'Growth Hacks': [
        'Embed de widget de arquitetura em blogs parceiros',
        'API pública limitada para integrações',
        'Gamificação: XP por projetos criados',
        'Notificação de trends (ex: "Vue.js usage +30% this month")',
      ],
      'Brand': [
        'Manifesto da marca: "Construa com confiança"',
        'Identidade visual consistente em todas as plataformas',
        'Case studies de clientes reais',
        'Página "Sobre" com storytelling da fundação',
      ],
    };

    const IDEA_COLUMNS = ['backlog', 'progress', 'done', 'discarded'];

    function getIdeasState() {
      try {
        return JSON.parse(localStorage.getItem('bc-marketing-ideas') || 'null');
      } catch { return null; }
    }

    function saveIdeasState(state) {
      localStorage.setItem('bc-marketing-ideas', JSON.stringify(state));
    }

    function buildDefaultIdeasState() {
      const state = {};
      let id = 1;
      Object.entries(MARKETING_IDEAS).forEach(([cat, ideas]) => {
        ideas.forEach(text => {
          state[id] = { id, text, category: cat, column: 'backlog' };
          id++;
        });
      });
      return state;
    }

    let ideasState = getIdeasState() || buildDefaultIdeasState();
    let ideasFilterCat = 'all';

    function initIdeas() {
      // Render category filters
      const cats = Object.keys(MARKETING_IDEAS);
      const container = document.getElementById('ideas-categories');
      container.innerHTML = `<button class="ideas-cat-btn active px-3 py-1.5 rounded-full text-xs font-medium transition-all bg-[#2E748B] text-white" data-cat="all">Todas</button>` +
        cats.map(c => `<button class="ideas-cat-btn px-3 py-1.5 rounded-full text-xs font-medium transition-all bg-[#2A3135] text-slate-300 hover:bg-[#3A4145]" data-cat="${c}">${c}</button>`).join('');

      container.querySelectorAll('.ideas-cat-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          ideasFilterCat = btn.getAttribute('data-cat');
          container.querySelectorAll('.ideas-cat-btn').forEach(b => {
            b.classList.remove('bg-[#2E748B]', 'text-white');
            b.classList.add('bg-[#2A3135]', 'text-slate-300');
          });
          btn.classList.add('bg-[#2E748B]', 'text-white');
          btn.classList.remove('bg-[#2A3135]', 'text-slate-300');
          renderIdeas();
        });
      });

      renderIdeas();
    }

    function renderIdeas() {
      const ideas = Object.values(ideasState).filter((i: any) => ideasFilterCat === 'all' || i.category === ideasFilterCat);

      IDEA_COLUMNS.forEach(col => {
        const colKey = col === 'progress' ? 'progress' : col;
        const colEl = document.getElementById(`ideas-col-${col}`);
        const countEl = document.getElementById(`ideas-count-${col}`);
        const colIdeas = ideas.filter((i: any) => i.column === col);
        countEl.textContent = String(colIdeas.length);

        colEl.innerHTML = colIdeas.map((idea: any) => `
          <div class="bg-[#0D0D0D]/60 border border-[#2A3135] rounded-xl p-3 group" data-idea-id="${idea.id}">
            <p class="text-xs text-slate-300 leading-relaxed">${idea.text}</p>
            <div class="flex items-center justify-between mt-2">
              <span class="text-[10px] text-slate-500 bg-[#2A3135] px-2 py-0.5 rounded-full">${idea.category}</span>
              <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                ${IDEA_COLUMNS.filter(c => c !== col).map(c => {
                  const icons = { backlog: 'inventory_2', progress: 'play_arrow', done: 'check', discarded: 'close' };
                  const labels = { backlog: 'Backlog', progress: 'Andamento', done: 'Feito', discarded: 'Descartar' };
                  return `<button class="idea-move-btn text-slate-500 hover:text-white transition-colors" data-idea-id="${idea.id}" data-target="${c}" title="Mover para ${labels[c]}"><span class="material-symbols-outlined text-[16px]">${icons[c]}</span></button>`;
                }).join('')}
              </div>
            </div>
          </div>
        `).join('');

        // Bind move buttons
        colEl.querySelectorAll('.idea-move-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const ideaId = btn.getAttribute('data-idea-id');
            const target = btn.getAttribute('data-target');
            ideasState[ideaId].column = target;
            saveIdeasState(ideasState);
            renderIdeas();
          });
        });
      });
    }

    // ═══════════════════════════════════════════
    //  MODULE 5: ANALYTICS
    // ═══════════════════════════════════════════
    function initAnalytics() {
      // Stats
      const total = allPosts.length;
      const published = allPosts.filter(p => p.status === 'published').length;
      const scheduled = allPosts.filter(p => p.status === 'scheduled').length;
      const drafts = allPosts.filter(p => p.status === 'draft').length;

      document.getElementById('stat-total').textContent = String(total);
      document.getElementById('stat-published').textContent = String(published);
      document.getElementById('stat-scheduled').textContent = String(scheduled);
      document.getElementById('stat-drafts').textContent = String(drafts);

      // Bar chart — posts per platform
      renderPlatformChart();

      // Table
      renderPostsTable();
    }

    function renderPlatformChart() {
      const canvas = document.getElementById('analytics-chart') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d');
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      const thirtyDaysAgo = new Date();
      thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);

      const recentPosts = allPosts.filter(p => new Date(p.created_at) >= thirtyDaysAgo);
      const platforms = ['tiktok', 'linkedin', 'instagram', 'twitter'];
      const colors = { tiktok: '#f472b6', linkedin: '#60a5fa', instagram: '#a78bfa', twitter: '#38bdf8' };
      const counts = platforms.map(pl => recentPosts.filter(p => p.platform === pl).length);
      const maxCount = Math.max(...counts, 1);

      const barWidth = 80;
      const gap = 60;
      const chartHeight = 180;
      const startX = 80;
      const startY = 220;

      // Y axis
      ctx.strokeStyle = '#2A3135';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(startX - 10, startY - chartHeight);
      ctx.lineTo(startX - 10, startY);
      ctx.lineTo(startX + (barWidth + gap) * platforms.length, startY);
      ctx.stroke();

      // Grid lines
      for (let i = 0; i <= 4; i++) {
        const y = startY - (chartHeight / 4) * i;
        ctx.strokeStyle = '#2A3135';
        ctx.beginPath();
        ctx.moveTo(startX - 10, y);
        ctx.lineTo(startX + (barWidth + gap) * platforms.length, y);
        ctx.stroke();

        ctx.fillStyle = '#64748b';
        ctx.font = '12px Inter, sans-serif';
        ctx.textAlign = 'right';
        ctx.fillText(String(Math.round((maxCount / 4) * i)), startX - 18, y + 4);
      }

      platforms.forEach((pl, i) => {
        const x = startX + i * (barWidth + gap);
        const barH = (counts[i] / maxCount) * chartHeight;

        // Bar
        ctx.fillStyle = colors[pl];
        ctx.beginPath();
        ctx.roundRect(x, startY - barH, barWidth, barH, [6, 6, 0, 0]);
        ctx.fill();

        // Value on top
        ctx.fillStyle = '#e2e8f0';
        ctx.font = 'bold 14px Inter, sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText(String(counts[i]), x + barWidth / 2, startY - barH - 8);

        // Label
        ctx.fillStyle = '#94a3b8';
        ctx.font = '13px Inter, sans-serif';
        ctx.fillText(pl.charAt(0).toUpperCase() + pl.slice(1), x + barWidth / 2, startY + 20);
      });
    }

    function renderPostsTable() {
      const tbody = document.getElementById('analytics-table');
      const recent = allPosts.slice(0, 20);

      if (recent.length === 0) {
        tbody.innerHTML = '<tr><td colspan="7" class="py-6 text-center text-slate-500">Nenhum post encontrado</td></tr>';
        return;
      }

      tbody.innerHTML = recent.map(p => {
        const badge = statusBadges[p.status] || statusBadges.draft;
        const date = p.scheduled_date || p.created_at;
        const formattedDate = date ? new Date(date).toLocaleDateString('pt-BR') : '-';
        const metrics = p.metrics || {};
        return `
          <tr class="border-b border-[#2A3135]/50 hover:bg-[#2A3135]/20 transition-colors">
            <td class="py-3 px-2 text-white text-sm max-w-[200px] truncate">${p.title}</td>
            <td class="py-3 px-2 capitalize">${p.platform}</td>
            <td class="py-3 px-2"><span class="text-xs px-2 py-0.5 rounded-full ${badge.cls}">${badge.label}</span></td>
            <td class="py-3 px-2">${formattedDate}</td>
            <td class="py-3 px-2"><input type="number" class="metric-input w-16 bg-transparent border border-[#2A3135] rounded px-2 py-1 text-xs text-white focus:border-[#2E748B] focus:outline-none" data-post-id="${p.id}" data-metric="views" value="${metrics.views || 0}" min="0" /></td>
            <td class="py-3 px-2"><input type="number" class="metric-input w-16 bg-transparent border border-[#2A3135] rounded px-2 py-1 text-xs text-white focus:border-[#2E748B] focus:outline-none" data-post-id="${p.id}" data-metric="likes" value="${metrics.likes || 0}" min="0" /></td>
            <td class="py-3 px-2"><input type="number" class="metric-input w-16 bg-transparent border border-[#2A3135] rounded px-2 py-1 text-xs text-white focus:border-[#2E748B] focus:outline-none" data-post-id="${p.id}" data-metric="comments" value="${metrics.comments || 0}" min="0" /></td>
          </tr>
        `;
      }).join('');

      // Inline metric editing
      let debounceTimers = {};
      tbody.querySelectorAll('.metric-input').forEach(input => {
        input.addEventListener('change', async (e) => {
          const el = e.target as HTMLInputElement;
          const postId = el.getAttribute('data-post-id');
          const metricKey = el.getAttribute('data-metric');
          const val = parseInt(el.value) || 0;

          // Find post and update metrics
          const post = allPosts.find(p => p.id === postId);
          if (!post) return;
          const metrics = { ...(post.metrics || {}), [metricKey]: val };

          clearTimeout(debounceTimers[postId]);
          debounceTimers[postId] = setTimeout(async () => {
            try {
              await fetch('/api/marketing', {
                method: 'PATCH',
                headers: authHeaders(),
                body: JSON.stringify({ id: postId, metrics }),
              });
              post.metrics = metrics;
            } catch (e) { console.error('Failed to update metric', e); }
          }, 500);
        });
      });
    }

    // ═══════════════════════════════════════════
    //  MODULE 6: ESTRATÉGIA DE LANÇAMENTO
    // ═══════════════════════════════════════════
    const LAUNCH_PHASES = [
      {
        name: 'Pre-Launch',
        icon: 'flag',
        items: [
          'Definir mensagem principal',
          'Preparar landing page',
          'Criar lista de espera',
          'Agendar email de lançamento',
          'Preparar posts sociais',
          'Configurar analytics',
          'Teste beta com early adopters',
          'Criar press kit',
        ],
      },
      {
        name: 'Launch Day',
        icon: 'rocket_launch',
        items: [
          'Publicar landing page',
          'Enviar email principal',
          'Posts em todas as redes',
          'Submeter no ProductHunt',
          'Engajar nos comentários',
          'Monitorar métricas',
        ],
      },
      {
        name: 'Pós-Launch',
        icon: 'trending_up',
        items: [
          'Coletar feedback',
          'Analisar métricas D1-D7',
          'Ajustar mensagem',
          'Retarget visitantes',
          'Publicar case study',
          'Planejar próximo lançamento',
        ],
      },
    ];

    function getLaunchState() {
      try {
        return JSON.parse(localStorage.getItem('bc-launch-checklist') || '{}');
      } catch { return {}; }
    }

    function saveLaunchState(state) {
      localStorage.setItem('bc-launch-checklist', JSON.stringify(state));
    }

    function initLaunchChecklist() {
      const container = document.getElementById('launch-phases');
      const state = getLaunchState();

      container.innerHTML = LAUNCH_PHASES.map((phase, pi) => {
        const phaseKey = `phase-${pi}`;
        const checkedCount = phase.items.filter((_, ii) => state[`${phaseKey}-${ii}`]).length;
        const pct = Math.round((checkedCount / phase.items.length) * 100);

        return `
          <div class="bg-[#121415]/50 border border-[#2A3135] rounded-2xl p-6">
            <div class="flex items-center justify-between mb-4">
              <h3 class="font-semibold text-white flex items-center gap-2">
                <span class="material-symbols-outlined text-[#F2AB6D]">${phase.icon}</span>
                ${phase.name}
              </h3>
              <span class="text-sm text-slate-400">${checkedCount}/${phase.items.length}</span>
            </div>
            <!-- Progress bar -->
            <div class="w-full h-2 bg-[#2A3135] rounded-full mb-4 overflow-hidden">
              <div class="h-full rounded-full transition-all duration-500 ${pct === 100 ? 'bg-emerald-400' : 'bg-[#2E748B]'}" style="width:${pct}%"></div>
            </div>
            <div class="space-y-2">
              ${phase.items.map((item, ii) => {
                const key = `${phaseKey}-${ii}`;
                const checked = state[key] || false;
                return `
                  <label class="flex items-center gap-3 p-2.5 rounded-xl hover:bg-[#2A3135]/30 cursor-pointer transition-colors group">
                    <input type="checkbox" class="launch-check w-5 h-5 rounded-md bg-[#0D0D0D] border-2 border-[#2A3135] text-[#2E748B] focus:ring-[#2E748B] focus:ring-offset-0 cursor-pointer accent-[#2E748B]" data-key="${key}" ${checked ? 'checked' : ''} />
                    <span class="text-sm ${checked ? 'text-slate-500 line-through' : 'text-slate-300'}">${item}</span>
                  </label>
                `;
              }).join('')}
            </div>
          </div>
        `;
      }).join('');

      // Bind checkboxes
      container.querySelectorAll('.launch-check').forEach(cb => {
        cb.addEventListener('change', (e) => {
          const el = e.target as HTMLInputElement;
          const key = el.getAttribute('data-key');
          const st = getLaunchState();
          st[key] = el.checked;
          saveLaunchState(st);
          initLaunchChecklist(); // Re-render for progress bar
        });
      });
    }

    // ═══════════════════════════════════════════
    //  MODULE 7: COPY WORKSHOP
    // ═══════════════════════════════════════════
    document.getElementById('copy-analyze-btn').addEventListener('click', async () => {
      const text = (document.getElementById('copy-input') as HTMLTextAreaElement).value.trim();
      if (!text) { alert('Cole um texto de marketing para analisar.'); return; }

      const resultPanel = document.getElementById('copy-result-panel');
      const loadingEl = document.getElementById('copy-loading');
      const resultEl = document.getElementById('copy-result');
      const btn = document.getElementById('copy-analyze-btn') as HTMLButtonElement;

      resultPanel.classList.remove('hidden');
      loadingEl.classList.remove('hidden');
      resultEl.textContent = '';
      btn.disabled = true;
      btn.textContent = 'Analisando...';

      try {
        const res = await fetch('/api/marketing', {
          method: 'POST',
          headers: authHeaders(),
          body: JSON.stringify({
            action: 'generate',
            platform: 'linkedin',
            contentType: 'post',
            tone: 'profissional',
            topic: `Analise o seguinte texto de marketing e forneça feedback detalhado:

TEXTO PARA ANÁLISE:
"""
${text}
"""

Por favor, analise nos seguintes aspectos:
1. CLAREZA: A mensagem é clara e direta?
2. PERSUASÃO: Usa gatilhos emocionais e lógicos eficazes?
3. CTA: O call-to-action é forte e específico?
4. TOM: O tom é adequado para o público-alvo?
5. ESTRUTURA: A organização facilita a leitura?
6. MELHORIAS: Sugira 3 versões alternativas do texto principal.
7. PONTUAÇÃO: Dê uma nota de 1 a 10 para o copy.`,
          }),
        });
        const data = await res.json();
        if (res.ok) {
          resultEl.textContent = data.content || 'Nenhuma análise retornada.';
        } else {
          resultEl.textContent = `Erro: ${data.error || 'Falha na análise'}`;
        }
      } catch (e) {
        resultEl.textContent = 'Erro de conexão. Tente novamente.';
      } finally {
        loadingEl.classList.add('hidden');
        btn.disabled = false;
        btn.innerHTML = '<span class="material-symbols-outlined text-[20px]">psychology</span> Analisar com IA';
      }
    });

    // ═══════════════════════════════════════════
    //  INIT
    // ═══════════════════════════════════════════
    init();
  </script>
</Layout>
