---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="BuildCode - Nunca mais construa software no escuro">
  <div class="relative flex h-auto min-h-screen w-full flex-col overflow-x-hidden">
    <Header />

    <main class="flex-1 flex flex-col items-center w-full">

      <!-- ═══════════════════════════════════════════════════════
           SEÇÃO 1 — HERO
           A primeira impressão que define tudo.
      ═══════════════════════════════════════════════════════ -->
      <section class="relative w-full flex flex-col items-center justify-center min-h-screen px-6 py-24 overflow-hidden">
        <!-- Video Background -->
        <div class="absolute inset-0 z-0 pointer-events-none">
          <video autoplay loop muted playsinline class="absolute inset-0 w-full h-full object-cover">
            <source src="/code01.mp4" type="video/mp4" />
          </video>
          <div class="absolute inset-0 bg-background-dark/85 backdrop-blur-[3px]"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-background-dark via-background-dark/40 to-transparent"></div>
        </div>

        <!-- Ambient glow -->
        <div class="absolute inset-0 pointer-events-none z-[1]">
          <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[900px] h-[600px] bg-primary/15 rounded-full blur-[150px]"></div>
          <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-primary-dark/20 rounded-full blur-[120px]"></div>
        </div>

        <div class="relative z-10 flex flex-col items-center text-center max-w-[1000px] gap-6 opacity-0 animate-[fade-in-up_1s_ease-out_forwards]">
          <!-- Badge -->
          <div class="inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/5 px-5 py-2 mb-2">
            <span class="flex size-2 rounded-full bg-primary animate-pulse"></span>
            <span class="text-xs font-bold tracking-[0.2em] text-primary uppercase" data-i18n="hero.badge">IA-Powered Architecture</span>
          </div>

          <!-- Headline -->
          <h1 class="font-display text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-black leading-[0.95] tracking-tighter text-white">
            Nunca mais construa<br/>
            software <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-secondary to-primary-dark">no escuro.</span>
          </h1>

          <!-- Sub-headline -->
          <p class="text-lg md:text-xl text-slate-400 font-medium leading-relaxed max-w-[680px] mt-2">
            O BuildCode analisa seus requisitos, seleciona a stack ideal e gera documentação profissional completa. Tudo guiado por inteligência artificial em menos de 3 minutos.
          </p>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row items-center gap-4 mt-8">
            <a href="/app" class="group flex w-full sm:w-auto cursor-pointer items-center justify-center rounded-full bg-gradient-to-r from-primary to-primary-dark text-white hover:shadow-[0_0_40px_rgba(46,116,139,0.5)] transition-all px-10 py-4 text-base font-bold tracking-wide focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-background-dark">
              Criar Meu Projeto Agora
              <span class="material-symbols-outlined ml-2 group-hover:translate-x-1 transition-transform">arrow_forward</span>
            </a>
            <a href="#problema" class="flex w-full sm:w-auto cursor-pointer items-center justify-center rounded-full glass-panel text-white hover:bg-white/5 transition-colors px-8 py-4 text-base font-semibold tracking-wide focus:outline-none focus:ring-2 focus:ring-white/30">
              Entender o Problema
              <span class="material-symbols-outlined ml-2 text-primary text-xl">expand_more</span>
            </a>
          </div>

          <!-- Social proof micro -->
          <div class="flex items-center gap-6 mt-12 text-sm text-slate-500">
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-primary text-lg">shield</span>
              <span>LGPD Compliant</span>
            </div>
            <div class="w-px h-4 bg-border-color"></div>
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-primary text-lg">smart_toy</span>
              <span>4 Agentes de IA</span>
            </div>
            <div class="w-px h-4 bg-border-color hidden sm:block"></div>
            <div class="hidden sm:flex items-center gap-2">
              <span class="material-symbols-outlined text-primary text-lg">description</span>
              <span>PRD + Prompt Base</span>
            </div>
          </div>
        </div>

        <!-- Scroll indicator -->
        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 opacity-50 animate-bounce">
          <span class="material-symbols-outlined text-primary text-2xl">keyboard_arrow_down</span>
        </div>
      </section>


      <!-- ═══════════════════════════════════════════════════════
           SEÇÃO 2 — O PROBLEMA
           Falhas de segurança, má gestão, falta de organização.
      ═══════════════════════════════════════════════════════ -->
      <section class="w-full px-6 py-28 md:px-12 lg:px-24 bg-surface-dark/50 border-y border-border-color relative overflow-hidden" id="problema">
        <!-- Background accent -->
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-red-500/5 rounded-full blur-[120px] pointer-events-none"></div>

        <div class="mx-auto max-w-[1200px] flex flex-col gap-16">
          <!-- Section header -->
          <div class="flex flex-col items-center text-center gap-5 max-w-[800px] mx-auto">
            <div class="inline-flex items-center gap-2 rounded-full border border-red-500/20 bg-red-500/5 px-4 py-1.5">
              <span class="material-symbols-outlined text-red-400 text-sm">warning</span>
              <span class="text-xs font-bold tracking-[0.15em] text-red-400 uppercase">Alerta Crítico</span>
            </div>
            <h2 class="font-display text-3xl md:text-5xl font-black tracking-tight text-white leading-tight">
              Seu software é um alvo.<br/>
              <span class="text-red-400">Você só não sabe ainda.</span>
            </h2>
            <p class="text-lg text-slate-400 font-medium leading-relaxed">
              A cada 39 segundos, um ataque cibernético acontece no mundo. E a maioria das vítimas tinha "certeza" de que estava protegida. O problema não é a falta de ferramentas. É a falta de planejamento desde o dia zero.
            </p>
          </div>

          <!-- Problem cards -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="glass-panel p-8 rounded-2xl flex flex-col gap-6 hover:-translate-y-1 transition-transform duration-300 border-t-2 border-t-red-500/30">
              <div class="size-14 rounded-xl bg-red-500/10 border border-red-500/20 flex items-center justify-center text-red-400">
                <span class="material-symbols-outlined text-3xl">lock_open</span>
              </div>
              <div class="flex flex-col gap-3">
                <h3 class="font-display text-xl font-bold text-white">Falhas de Segurança Silenciosas</h3>
                <p class="text-slate-400 leading-relaxed">SQL Injection, XSS, CSRF. Vulnerabilidades que dormem no seu código até alguém explorá-las. Sem uma arquitetura segura desde o início, cada feature nova é uma porta aberta para invasores.</p>
              </div>
              <div class="mt-auto pt-4 border-t border-border-color">
                <span class="text-red-400 text-sm font-semibold">78% das brechas vêm de código mal arquitetado</span>
              </div>
            </div>

            <div class="glass-panel p-8 rounded-2xl flex flex-col gap-6 hover:-translate-y-1 transition-transform duration-300 border-t-2 border-t-yellow-500/30">
              <div class="size-14 rounded-xl bg-yellow-500/10 border border-yellow-500/20 flex items-center justify-center text-yellow-400">
                <span class="material-symbols-outlined text-3xl">folder_off</span>
              </div>
              <div class="flex flex-col gap-3">
                <h3 class="font-display text-xl font-bold text-white">Projetos Sem Gestão Real</h3>
                <p class="text-slate-400 leading-relaxed">Sem documentação, sem roadmap técnico, sem PRD. O time avança no escuro, cada dev puxa pra um lado, e o projeto se torna um labirinto que ninguém entende. Nem quem criou.</p>
              </div>
              <div class="mt-auto pt-4 border-t border-border-color">
                <span class="text-yellow-400 text-sm font-semibold">67% dos projetos falham por gestão deficiente</span>
              </div>
            </div>

            <div class="glass-panel p-8 rounded-2xl flex flex-col gap-6 hover:-translate-y-1 transition-transform duration-300 border-t-2 border-t-orange-500/30">
              <div class="size-14 rounded-xl bg-orange-500/10 border border-orange-500/20 flex items-center justify-center text-orange-400">
                <span class="material-symbols-outlined text-3xl">whatshot</span>
              </div>
              <div class="flex flex-col gap-3">
                <h3 class="font-display text-xl font-bold text-white">Dívida Técnica Explosiva</h3>
                <p class="text-slate-400 leading-relaxed">Escolher a stack errada é plantar uma bomba-relógio. Quando o produto precisa escalar, o custo de refatoração não é técnico. É existencial. Startups morrem por isso todos os dias.</p>
              </div>
              <div class="mt-auto pt-4 border-t border-border-color">
                <span class="text-orange-400 text-sm font-semibold">Refatorar custa 10x mais que planejar</span>
              </div>
            </div>
          </div>
        </div>
      </section>


      <!-- ═══════════════════════════════════════════════════════
           SEÇÃO 3 — A REALIDADE ATUAL DO MERCADO
           Vibe coding, falsa segurança, amadorismo disfarçado.
      ═══════════════════════════════════════════════════════ -->
      <section class="w-full px-6 py-28 md:px-12 lg:px-24 relative overflow-hidden" id="realidade">
        <div class="absolute bottom-0 left-0 w-[600px] h-[400px] bg-purple-500/5 rounded-full blur-[100px] pointer-events-none"></div>

        <div class="mx-auto max-w-[1200px] flex flex-col lg:flex-row gap-16 items-center">
          <!-- Left: Text content -->
          <div class="flex-1 flex flex-col gap-8">
            <div class="inline-flex w-fit items-center gap-2 rounded-full border border-purple-500/20 bg-purple-500/5 px-4 py-1.5">
              <span class="text-xs font-bold tracking-[0.15em] text-purple-400 uppercase">Realidade do Mercado</span>
            </div>
            <h2 class="font-display text-3xl md:text-5xl font-black tracking-tight text-white leading-tight">
              Saber usar IA pra gerar código<br/>
              <span class="text-purple-400">não te faz engenheiro.</span>
            </h2>
            <p class="text-lg text-slate-400 leading-relaxed">
              O mercado está inundado de "devs" que copiam e colam código de ChatGPT sem entender o que está por trás. Chamam isso de "vibe coding" e consideram isso programação. Enquanto isso, os sistemas que eles criam são bombas-relógio de segurança esperando pra explodir.
            </p>

            <div class="flex flex-col gap-5 mt-2">
              <div class="flex items-start gap-4 p-4 rounded-xl bg-white/[0.02] border border-white/[0.04]">
                <span class="material-symbols-outlined text-red-400 text-2xl mt-0.5 shrink-0">dangerous</span>
                <div>
                  <h4 class="text-white font-bold">Código sem contexto de segurança</h4>
                  <p class="text-slate-400 text-sm mt-1">Uma API sem rate limiting, um form sem sanitização, um JWT sem expiração. Erros que uma IA gera em 2 segundos e que um hacker explora em menos.</p>
                </div>
              </div>
              <div class="flex items-start gap-4 p-4 rounded-xl bg-white/[0.02] border border-white/[0.04]">
                <span class="material-symbols-outlined text-red-400 text-2xl mt-0.5 shrink-0">dangerous</span>
                <div>
                  <h4 class="text-white font-bold">Arquiteturas que não sobrevivem à escala</h4>
                  <p class="text-slate-400 text-sm mt-1">Monolitos acoplados, banco de dados sem indexação, zero caching. Funciona com 10 usuários. Com 10.000, colapsa.</p>
                </div>
              </div>
              <div class="flex items-start gap-4 p-4 rounded-xl bg-white/[0.02] border border-white/[0.04]">
                <span class="material-symbols-outlined text-red-400 text-2xl mt-0.5 shrink-0">dangerous</span>
                <div>
                  <h4 class="text-white font-bold">Falsa confiança, prejuízo real</h4>
                  <p class="text-slate-400 text-sm mt-1">"Tá funcionando" não significa "tá seguro". A diferença entre um software amador e um profissional está no que acontece quando as coisas dão errado.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Right: Visual element -->
          <div class="flex-1 w-full max-w-lg">
            <div class="relative rounded-2xl glass-panel glow-border p-6 font-mono text-sm">
              <!-- Terminal header -->
              <div class="flex items-center gap-2 mb-6 pb-4 border-b border-border-color">
                <div class="size-3 rounded-full bg-red-500/60"></div>
                <div class="size-3 rounded-full bg-yellow-500/60"></div>
                <div class="size-3 rounded-full bg-green-500/60"></div>
                <span class="ml-3 text-slate-500 text-xs">security-scan.sh</span>
              </div>
              <!-- Simulated scan output -->
              <div class="space-y-2 text-slate-400">
                <p><span class="text-primary">$</span> scanning target application...</p>
                <p class="text-slate-500">━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ 100%</p>
                <p class="mt-3"><span class="text-red-400 font-bold">CRITICAL</span> SQL Injection in /api/users</p>
                <p><span class="text-red-400 font-bold">CRITICAL</span> XSS via unsanitized input</p>
                <p><span class="text-yellow-400 font-bold">HIGH</span> &nbsp;&nbsp;&nbsp;&nbsp;No rate limiting on auth</p>
                <p><span class="text-yellow-400 font-bold">HIGH</span> &nbsp;&nbsp;&nbsp;&nbsp;JWT without expiration</p>
                <p><span class="text-orange-400 font-bold">MEDIUM</span> &nbsp;CORS wildcard enabled</p>
                <p><span class="text-orange-400 font-bold">MEDIUM</span> &nbsp;Missing CSP headers</p>
                <p class="mt-4 text-slate-500">────────────────────────────────</p>
                <p class="text-red-400 font-bold">6 vulnerabilities found.</p>
                <p class="text-red-400">Application status: <span class="animate-pulse">COMPROMISED</span></p>
              </div>
            </div>
          </div>
        </div>
      </section>


      <!-- ═══════════════════════════════════════════════════════
           SEÇÃO 4 — POR QUE USAR O BUILDCODE
           Facilidade, segurança, IA 24/7, organização.
      ═══════════════════════════════════════════════════════ -->
      <section class="w-full px-6 py-28 md:px-12 lg:px-24 bg-surface-dark/50 border-y border-border-color relative" id="porque">
        <div class="absolute top-1/2 right-0 w-[500px] h-[500px] bg-primary/8 rounded-full blur-[120px] -translate-y-1/2 pointer-events-none"></div>

        <div class="mx-auto max-w-[1200px] flex flex-col gap-16">
          <div class="flex flex-col items-center text-center gap-5 max-w-[800px] mx-auto">
            <div class="inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/5 px-4 py-1.5">
              <span class="material-symbols-outlined text-primary text-sm">auto_awesome</span>
              <span class="text-xs font-bold tracking-[0.15em] text-primary uppercase">Por Que BuildCode</span>
            </div>
            <h2 class="font-display text-3xl md:text-5xl font-black tracking-tight text-white leading-tight">
              Construa software como um<br/>
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">arquiteto sênior.</span>
            </h2>
            <p class="text-lg text-slate-400 font-medium leading-relaxed">
              Mesmo que você esteja começando. O BuildCode coloca décadas de experiência em engenharia nas suas mãos, em forma de inteligência artificial que pensa antes de agir.
            </p>
          </div>

          <!-- Feature grid -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="glass-panel p-8 rounded-2xl flex flex-col gap-5 group hover:border-primary/30 transition-all duration-300">
              <div class="flex items-center gap-4">
                <div class="size-12 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center text-primary group-hover:bg-primary/20 transition-colors">
                  <span class="material-symbols-outlined text-2xl">rocket_launch</span>
                </div>
                <h3 class="font-display text-xl font-bold text-white">Simplicidade Radical</h3>
              </div>
              <p class="text-slate-400 leading-relaxed">Responda um questionário inteligente de 20 etapas. A IA faz o resto: seleciona a stack, gera o PRD, cria o Prompt Base e entrega tudo documentado. Zero complexidade pra você.</p>
            </div>

            <div class="glass-panel p-8 rounded-2xl flex flex-col gap-5 group hover:border-primary/30 transition-all duration-300">
              <div class="flex items-center gap-4">
                <div class="size-12 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center text-primary group-hover:bg-primary/20 transition-colors">
                  <span class="material-symbols-outlined text-2xl">shield_lock</span>
                </div>
                <h3 class="font-display text-xl font-bold text-white">Segurança Desde o Dia Zero</h3>
              </div>
              <p class="text-slate-400 leading-relaxed">Cada recomendação do BuildCode já considera OWASP Top 10, sanitização de inputs, rate limiting, autenticação robusta e boas práticas de infraestrutura. Segurança não é extra. É o padrão.</p>
            </div>

            <div class="glass-panel p-8 rounded-2xl flex flex-col gap-5 group hover:border-primary/30 transition-all duration-300">
              <div class="flex items-center gap-4">
                <div class="size-12 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center text-primary group-hover:bg-primary/20 transition-colors">
                  <span class="material-symbols-outlined text-2xl">smart_toy</span>
                </div>
                <h3 class="font-display text-xl font-bold text-white">IA Disponível 24/7</h3>
              </div>
              <p class="text-slate-400 leading-relaxed">Dúvidas sobre sua stack? Quer entender por que o sistema recomendou PostgreSQL em vez de MongoDB? Pergunte ao chat integrado. A IA responde com contexto do seu projeto, não com respostas genéricas.</p>
            </div>

            <div class="glass-panel p-8 rounded-2xl flex flex-col gap-5 group hover:border-primary/30 transition-all duration-300">
              <div class="flex items-center gap-4">
                <div class="size-12 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center text-primary group-hover:bg-primary/20 transition-colors">
                  <span class="material-symbols-outlined text-2xl">account_tree</span>
                </div>
                <h3 class="font-display text-xl font-bold text-white">Organização de Verdade</h3>
              </div>
              <p class="text-slate-400 leading-relaxed">PRD profissional, Prompt Base otimizado, insights de complexidade, gráficos de stack e projetos salvos no seu perfil. Tudo que um gestor de projetos precisa, automatizado e em português.</p>
            </div>
          </div>

          <!-- CTA inline -->
          <div class="flex justify-center">
            <a href="/app" class="group flex items-center gap-3 rounded-full bg-white/[0.03] border border-primary/20 hover:border-primary/50 hover:bg-primary/5 transition-all px-8 py-4 text-primary font-bold">
              Experimentar Gratuitamente
              <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">east</span>
            </a>
          </div>
        </div>
      </section>


      <!-- ═══════════════════════════════════════════════════════
           SEÇÃO 5 — FUNCIONAMENTOS E DIFERENCIAIS
           IAs integradas, gráficos, questionário inteligente.
      ═══════════════════════════════════════════════════════ -->
      <section class="w-full px-6 py-28 md:px-12 lg:px-24 relative overflow-hidden" id="diferenciais">
        <div class="mx-auto max-w-[1200px] flex flex-col gap-20">
          <div class="flex flex-col items-center text-center gap-5 max-w-[800px] mx-auto">
            <div class="inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/5 px-4 py-1.5">
              <span class="material-symbols-outlined text-primary text-sm">diamond</span>
              <span class="text-xs font-bold tracking-[0.15em] text-primary uppercase">Diferenciais</span>
            </div>
            <h2 class="font-display text-3xl md:text-5xl font-black tracking-tight text-white leading-tight">
              O que torna o BuildCode<br/>
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-primary-dark">insubstituível.</span>
            </h2>
          </div>

          <!-- Feature showcase -->
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Feature 1 -->
            <div class="relative rounded-2xl glass-panel p-8 flex flex-col gap-6 overflow-hidden group">
              <div class="absolute top-0 right-0 w-32 h-32 bg-primary/10 rounded-full blur-[60px] opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
              <div class="size-14 rounded-xl bg-gradient-to-br from-primary/20 to-primary-dark/20 border border-primary/20 flex items-center justify-center">
                <span class="material-symbols-outlined text-primary text-3xl">psychology</span>
              </div>
              <h3 class="font-display text-xl font-bold text-white">4 Agentes de IA Especializados</h3>
              <p class="text-slate-400 leading-relaxed">Cada agente tem personalidade, visão técnica e abordagem única. Escolha quem vai guiar seu projeto: do pragmático ao visionário, do especialista em segurança à rainha do fullstack.</p>
              <div class="flex flex-wrap gap-2 mt-auto pt-4">
                <span class="text-xs px-3 py-1 rounded-full bg-red-500/10 text-red-400 border border-red-500/20 font-semibold">The Boss</span>
                <span class="text-xs px-3 py-1 rounded-full bg-purple-500/10 text-purple-400 border border-purple-500/20 font-semibold">Azrael</span>
                <span class="text-xs px-3 py-1 rounded-full bg-green-500/10 text-green-400 border border-green-500/20 font-semibold">Rizler</span>
                <span class="text-xs px-3 py-1 rounded-full bg-pink-500/10 text-pink-400 border border-pink-500/20 font-semibold">Anastasia</span>
              </div>
            </div>

            <!-- Feature 2 -->
            <div class="relative rounded-2xl glass-panel p-8 flex flex-col gap-6 overflow-hidden group">
              <div class="absolute top-0 right-0 w-32 h-32 bg-primary/10 rounded-full blur-[60px] opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
              <div class="size-14 rounded-xl bg-gradient-to-br from-primary/20 to-primary-dark/20 border border-primary/20 flex items-center justify-center">
                <span class="material-symbols-outlined text-primary text-3xl">bar_chart</span>
              </div>
              <h3 class="font-display text-xl font-bold text-white">Gráficos de Stack Interativos</h3>
              <p class="text-slate-400 leading-relaxed">Ao final do questionário, visualize sua arquitetura em gráficos detalhados: distribuição de tecnologias, complexidade por camada, custo estimado e score de segurança. Dados, não achismos.</p>
              <div class="flex flex-wrap gap-2 mt-auto pt-4">
                <span class="text-xs px-3 py-1 rounded-full bg-white/5 text-slate-400 border border-white/10">Radar Chart</span>
                <span class="text-xs px-3 py-1 rounded-full bg-white/5 text-slate-400 border border-white/10">Cost Analysis</span>
                <span class="text-xs px-3 py-1 rounded-full bg-white/5 text-slate-400 border border-white/10">Security Score</span>
              </div>
            </div>

            <!-- Feature 3 -->
            <div class="relative rounded-2xl glass-panel p-8 flex flex-col gap-6 overflow-hidden group">
              <div class="absolute top-0 right-0 w-32 h-32 bg-primary/10 rounded-full blur-[60px] opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
