<script is:inline>
  // Switch hero video based on theme
  function updateHeroVideo() {
    var video = document.getElementById('hero-video');
    if (!video) return;
    var isLight = document.documentElement.classList.contains('light');
    var src = isLight ? video.dataset.light : video.dataset.dark;
    var currentSrc = video.querySelector('source');
    if (currentSrc && src && !currentSrc.src.endsWith(src)) {
      currentSrc.src = src;
      video.load();
    }
  }
  // Run on load and watch for theme changes
  updateHeroVideo();
  var _heroObs = new MutationObserver(updateHeroVideo);
  _heroObs.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
</script>
