  const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
  renderer.setSize(window.innerWidth, window.innerHeight);
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

  // Create particles
  const count = 1500;
  const geometry = new THREE.BufferGeometry();
  const positions = new Float32Array(count * 3);
  const colors = new Float32Array(count * 3);
  const sizes = new Float32Array(count);

  const primary = new THREE.Color(0x2E748B);
  const secondary = new THREE.Color(0x5A9DB5);
  const accent = new THREE.Color(0xF2AB6D);

  for (let i = 0; i < count; i++) {
    positions[i * 3] = (Math.random() - 0.5) * 120;
    positions[i * 3 + 1] = (Math.random() - 0.5) * 120;
    positions[i * 3 + 2] = (Math.random() - 0.5) * 120;

    const r = Math.random();
    const c = r < 0.7 ? primary : r < 0.9 ? secondary : accent;
    colors[i * 3] = c.r;
    colors[i * 3 + 1] = c.g;
    colors[i * 3 + 2] = c.b;

    sizes[i] = Math.random() * 1.2 + 0.3;
  }

  geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
  geometry.setAttribute('color', new THREE.BufferAttribute(colors, 3));
  geometry.setAttribute('size', new THREE.BufferAttribute(sizes, 1));

  const material = new THREE.PointsMaterial({
    size: 0.8,
    vertexColors: true,
    transparent: true,
    opacity: 0.2,
    sizeAttenuation: true,
    blending: THREE.AdditiveBlending,
    depthWrite: false,
  });

  const particles = new THREE.Points(geometry, material);
  scene.add(particles);

  camera.position.z = 50;

  // Dive animation state
  let isDiving = false;
  let diveProgress = 0;
  const diveSpeed = 0.02;
  const originalZ = 50;
  const diveTargetZ = 5;

  // Expose dive function globally
  window.__bcDive = function() {
    isDiving = true;
    diveProgress = 0;
  };

  // Animation loop
  const clock = new THREE.Clock();
  function animate() {
    requestAnimationFrame(animate);
    const elapsed = clock.getElapsedTime();

    // Gentle rotation
    particles.rotation.y = elapsed * 0.03;
    particles.rotation.x = Math.sin(elapsed * 0.02) * 0.1;

    // Subtle particle floating
    const pos = geometry.attributes.position.array;
    for (let i = 0; i < count; i++) {
      pos[i * 3 + 1] += Math.sin(elapsed + i * 0.1) * 0.003;
    }
    geometry.attributes.position.needsUpdate = true;

    // Camera dive animation (Q5 → Q6 transition)
    if (isDiving) {
      diveProgress += diveSpeed;
      const ease = 1 - Math.pow(1 - Math.min(diveProgress, 1), 3); // easeOutCubic
      camera.position.z = originalZ - (originalZ - diveTargetZ) * ease;
      material.opacity = 0.2 + ease * 0.4;

      if (diveProgress >= 1) {
        // Return slowly after dive
        setTimeout(() => {
          isDiving = false;
          const returnAnim = () => {
            if (camera.position.z < originalZ) {
              camera.position.z += 0.3;
              material.opacity = Math.max(0.2, material.opacity - 0.005);
              requestAnimationFrame(returnAnim);
            }
          };
          returnAnim();
        }, 1500);
      }
    }

    renderer.render(scene, camera);
  }
  animate();

  // Resize handler
  window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
  });
}
</script>
