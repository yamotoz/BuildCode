           <section class="p-4 rounded-xl bg-primary/5 border border-primary/10 relative overflow-hidden">
             <div class="absolute left-0 top-0 w-1 h-full bg-primary/50"></div>
             <h4 class="text-[10px] text-primary uppercase font-bold tracking-[0.2em] mb-2 pl-2">Cena Ideal</h4>
             <p id="modal-tech-usecases" class="text-sm text-slate-200 font-medium pl-2 leading-relaxed"></p>
