<style>
  .step { display: flex; }
  .step.hidden { display: none; }

  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .step:not(.hidden) {
    animation: fade-in-up 0.5s cubic-bezier(0.16,1,0.3,1) forwards;
  }

  /* Tooltip term styling */
  [data-tip] {
    cursor: help;
    border-bottom: 1px dashed rgba(46,116,139,0.5);
    color: #5A9DB5;
    transition: color 0.2s;
  }
  [data-tip]:hover {
    color: #F2AB6D;
  }
</style>

<script define:vars={{ tooltipData: tooltips, skillsData: skillsMap, totalSteps, techDB }}>
document.addEventListener('DOMContentLoaded', () => {
  let currentStep = 1;
  let userSeniority = 'junior';
  let userTipo = 'hobby';
  let visibleSteps = []; // dynamically computed

  const steps = document.querySelectorAll('.step');
  const progressBar = document.getElementById('progress-bar');
  const stepCounter = document.getElementById('step-counter');
  const stepPhaseName = document.getElementById('step-phase-name');
  const form = document.getElementById('wizard-form');
  const prdOutput = document.getElementById('prd-output');
  const promptOutput = document.getElementById('prompt-output');

  // Refs dos insights
  const insightCost = document.getElementById('insight-cost');
  const insightComplexity = document.getElementById('insight-complexity');
  const insightTtm = document.getElementById('insight-ttm');
  const insightLevel = document.getElementById('insight-level');
  const insightTip = document.getElementById('insight-tip');

  // Tooltip
  const tooltipEl = document.getElementById('bc-tooltip');
  const tooltipText = document.getElementById('bc-tooltip-text');

  const phaseNames = ['Contexto', 'Stack Técnica', 'Qualidade', 'Final'];

  // ═══════════════════════════════════════════
  //  VISIBILIDADE & NAVEGAÇÃO DOS PASSOS
  // ═══════════════════════════════════════════
  function computeVisibleSteps() {
    visibleSteps = [];
    // Passos de pergunta do wizard (1-20)
    document.querySelectorAll('.step[data-step]').forEach(el => {
      const stepNum = parseInt(el.getAttribute('data-step'));
      const vf = el.getAttribute('data-visible-for');
      if (!vf || vf === 'all') {
        visibleSteps.push(stepNum);
        return;
      }
      // Passos 21+ (LLM, loading, resultado) são sempre visíveis
      if (stepNum > 20) {
        visibleSteps.push(stepNum);
        return;
      }
      try {
        const types = JSON.parse(vf);
        if (Array.isArray(types) && types.includes(userTipo)) {
          visibleSteps.push(stepNum);
        }
      } catch(e) {
        visibleSteps.push(stepNum);
      }
    });
    visibleSteps.sort((a, b) => a - b);

    // Atualiza badges de passos opcionais
    document.querySelectorAll('.step[data-step]').forEach(el => {
      const stepNum = parseInt(el.getAttribute('data-step'));
      const optFor = el.getAttribute('data-optional-for');
      const badge = document.getElementById(`optional-badge-${stepNum}`);
      if (!badge) return;
      let isOptional = false;
      if (optFor) {
        try {
          const types = JSON.parse(optFor);
          isOptional = Array.isArray(types) && types.includes(userTipo);
        } catch(e) {}
      }
      badge.classList.toggle('hidden', !isOptional);
      badge.classList.toggle('inline-flex', isOptional);
    });
  }

  function getNextVisibleStep(from) {
    for (let i = 0; i < visibleSteps.length; i++) {
      if (visibleSteps[i] > from) return visibleSteps[i];
    }
    return null;
  }

  function getPrevVisibleStep(from) {
    for (let i = visibleSteps.length - 1; i >= 0; i--) {
      if (visibleSteps[i] < from) return visibleSteps[i];
    }
    return null;
  }

  function isLastWizardStep(step) {
    // Último passo do wizard antes da seleção de idioma do prompt (passo 24)
    const wizardSteps = visibleSteps.filter(s => s <= 23);
    return wizardSteps.length > 0 && wizardSteps[wizardSteps.length - 1] === step;
  }

  function getPhase(step) {
    if (step <= 5 || step === 21 || step === 22) return 1;
    if (step <= 12) return 2;
    if (step <= 18) return 3;
    return 4;
  }

  function updateProgress(step) {
    const wizardSteps = visibleSteps.filter(s => s <= 25);
    const idx = wizardSteps.indexOf(step);
    const pct = idx >= 0 ? Math.min((idx / Math.max(wizardSteps.length - 1, 1)) * 100, 100) : 100;
    progressBar.style.width = `${pct}%`;
    const phase = getPhase(step);
    stepPhaseName.textContent = phaseNames[phase - 1] || 'Resultado';

    // Atualiza labels das fases
    for (let i = 1; i <= 4; i++) {
      const phLbl = document.getElementById(`phase-lbl-${i}`);
      if (!phLbl) continue;
      const els = phLbl.querySelectorAll('span');
      els.forEach(el => {
        if (i <= phase) {
          el.classList.remove('text-slate-600');
          el.classList.add('text-primary');
        } else {
          el.classList.remove('text-primary');
          el.classList.add('text-slate-600');
        }
      });
    }
  }

  function showStep(step) {
    steps.forEach(el => el.classList.add('hidden'));
    const active = document.querySelector(`.step[data-step="${step}"]`);
    if (active) active.classList.remove('hidden');
    updateProgress(step);
    updateRecommendedBadges();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // ═══════════════════════════════════════════
  //  BADGES DE RECOMENDAÇÃO
  // ═══════════════════════════════════════════
  function updateRecommendedBadges() {
    document.querySelectorAll('.rec-badge').forEach(badge => {
      const recFor = badge.getAttribute('data-rec-for');
      if (!recFor) return;
      try {
        const levels = JSON.parse(recFor);
        const show = Array.isArray(levels) && levels.includes(userSeniority);
        badge.classList.toggle('hidden', !show);
        badge.classList.toggle('inline-flex', show);
      } catch(e) {}
    });

    // Badges de não recomendado (baseado no tipo de projeto)
    document.querySelectorAll('.not-rec-badge').forEach(badge => {
      const notRecFor = badge.getAttribute('data-not-rec-for');
      if (!notRecFor) return;
      try {
        const types = JSON.parse(notRecFor);
        const show = Array.isArray(types) && types.includes(userTipo);
        badge.classList.toggle('hidden', !show);
        badge.classList.toggle('inline-flex', show);
      } catch(e) {}
    });
  }

  // Filtragem de opções baseada em senioridade
  function filterOptionsBySeniority() {
    const levelMap = { 'junior': 1, 'pleno': 2, 'senior': 3 };
    const level = levelMap[userSeniority] || 1;

    document.querySelectorAll('.option-label[data-min-level]').forEach(label => {
      const minLevel = parseInt(label.getAttribute('data-min-level') || '1');
      if (minLevel > level) {
        label.style.display = 'none';
        const input = label.querySelector('input');
        if (input) input.checked = false;
      } else {
        label.style.display = '';
      }
    });

    computeVisibleSteps();
    updateRecommendedBadges();
  }

  // Escuta mudança de senioridade
  document.querySelectorAll('input[name="senioridade"]').forEach(radio => {
    radio.addEventListener('change', (e) => {
      userSeniority = e.target.value;
      filterOptionsBySeniority();
      updateInsights();
    });
  });
  document.querySelectorAll('input[name="tipo"]').forEach(radio => {
    radio.addEventListener('change', (e) => {
      userTipo = e.target.value;
      computeVisibleSteps();
      filterOptionsBySeniority();
      updateInsights();
    });
  });

  // Botões Próximo / Anterior
  document.querySelectorAll('.next-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      // Valida passo atual
      if (currentStep === 1) {
        const ctx = document.getElementById('contexto');
        if (!ctx.value.trim()) {
          ctx.classList.add('border-red-500', 'ring-1', 'ring-red-500/50');
          ctx.focus();
          return;
        }
        ctx.classList.remove('border-red-500', 'ring-1', 'ring-red-500/50');

        // Bloqueia usuários não autenticados de avançar além do passo 1
        // Só bloqueia se auth state já foi resolvido e confirma que é guest
        const auth = window.__bcAuth;
        if (auth && auth.ready === true && auth.session === null) {
          if (typeof window.__bcShowAuthGate === 'function') {
            window.__bcShowAuthGate();
          }
          return;
        }
      }

      const prevPhase = getPhase(currentStep);
      let nextStep;

      if (isLastWizardStep(currentStep)) {
        // Pula para seleção de idioma do prompt (passo 24)
        nextStep = 24;
      } else if (currentStep === 24) {
        // Da seleção de idioma → seleção de LLM (passo 25)
        nextStep = 25;
      } else {
        nextStep = getNextVisibleStep(currentStep);
      }

      if (nextStep) {
        currentStep = nextStep;
        const newPhase = getPhase(currentStep);
        showStep(currentStep);
        updateInsights();

        // Mergulho da câmera Three.js na transição fase 1 → fase 2
        if (prevPhase === 1 && newPhase === 2 && typeof window.__bcDive === 'function') {
          window.__bcDive();
        }
      }
    });
  });

  document.querySelectorAll('.prev-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      let prevStep;
      if (currentStep === 25) {
        // Seleção de LLM → volta para idioma do prompt
        prevStep = 24;
      } else if (currentStep === 24) {
        // Idioma do prompt → volta para último passo do wizard
        const wizardSteps = visibleSteps.filter(s => s <= 23);
        prevStep = wizardSteps.length > 0 ? wizardSteps[wizardSteps.length - 1] : 20;
      } else {
        prevStep = getPrevVisibleStep(currentStep);
      }
      if (prevStep) {
        currentStep = prevStep;
        showStep(currentStep);
        updateInsights();
      }
    });
  });

  // Idioma do prompt: mostra/esconde input customizado
  document.querySelectorAll('input[name="prompt-language"]').forEach(radio => {
    radio.addEventListener('change', (e) => {
      const customInput = document.getElementById('custom-lang-input');
      if (customInput) {
        customInput.classList.toggle('hidden', e.target.value !== 'custom');
      }
    });
  });

  // ═══════════════════════════════════════════
  //  MOTOR DE INSIGHTS AO VIVO
  // ═══════════════════════════════════════════
  function updateInsights() {
    const escala = form.querySelector('input[name="escala"]:checked')?.value;
    const tipo = form.querySelector('input[name="tipo"]:checked')?.value;

    // Custo estimado
    const costMap = { '50': '$0 – $20/mês', '1000': '$20 – $100/mês', '10000': '$100 – $500/mês', '50000': '$500 – $5k+/mês' };
    insightCost.textContent = costMap[escala] || '—';

    // Estrelas de complexidade
    const compMap = { '50': 1, '1000': 2, '10000': 3, '50000': 5 };
    const levelComp = { 'hobby': 0, 'saas': 1, 'enterprise': 2 };
    let stars = (compMap[escala] || 0) + (levelComp[tipo] || 0);
    stars = Math.min(stars, 5);
    const starsHTML = Array.from({ length: 5 }, (_, i) =>
      `<span class="material-symbols-outlined text-sm ${i < stars ? 'text-cta' : 'text-slate-700'}" style="font-variation-settings: 'FILL' ${i < stars ? 1 : 0}">star</span>`
    ).join('');
    insightComplexity.innerHTML = starsHTML;

    // TTM
    const ttmMap = { '50': '2–4 semanas', '1000': '1–3 meses', '10000': '3–6 meses', '50000': '6–12 meses' };
    insightTtm.textContent = ttmMap[escala] || '—';

    // Nível
    const levelLbl = { 'junior': '🟢 Júnior', 'pleno': '🟡 Pleno', 'senior': '🔴 Sênior' };
    insightLevel.textContent = levelLbl[userSeniority] || '—';

    // Dicas por passo
    const tips = {
      1: 'Descreva seu projeto com o máximo de detalhes para uma arquitetura precisa.',
      2: 'Sua senioridade adapta as recomendações automaticamente.',
      3: 'A escala define toda a infraestrutura necessária.',
      4: 'Projetos SaaS exigem mais rigor em segurança e escalabilidade.',
      5: 'O Prompt Base será otimizado para a ferramenta escolhida.',
      6: 'Frontend escolhido influencia a experiência do usuário e a performance.',
      7: 'O backend é o motor do sistema. Managed (BaaS) é ideal para MVPs.',
      8: 'MCPs conectam sua IA diretamente às ferramentas do projeto.',
      9: 'SQL é confiável e maduro. NoSQL é flexível. Vetorial é para IA.',
      10: 'Skills técnicas são injetadas no prompt como referências de boas práticas.',
      11: 'Vercel e Railway são ideais para começar rápido. AWS para escala enterprise.',
      12: 'Híbrido (SQL + Cache) é a escolha dos sistemas de alta performance.',
      13: 'RBAC é essencial para sistemas com múltiplos tipos de usuário.',
      14: 'Rate Limiting e Sanitização são o mínimo para qualquer app em produção.',
      15: 'WebSockets são essenciais para chat, dashboards live e notificações.',
      16: 'Funcional é tendência. OOP é tradição. Misto é pragmatismo.',
      17: 'Graceful Degradation melhora a UX. Strict Mode melhora a segurança.',
      18: 'i18n desde o dia 1 evita refatoração dolorosa no futuro.',
      19: 'Stripe + Webhooks é a combinação mais usada para SaaS.',
      20: 'Testes E2E garantem que o sistema funciona como o usuário espera.',
    };
    insightTip.textContent = tips[currentStep] || 'Próxima etapa...';
  }

  // ═══════════════════════════════════════════
  //  SISTEMA DE TOOLTIPS
  // ═══════════════════════════════════════════
  document.addEventListener('mouseover', (e) => {
    const target = e.target.closest('[data-tip]');
    if (!target) return;
    const term = target.getAttribute('data-tip');
    const text = tooltipData[term];
    if (!text) return;
    tooltipText.textContent = text;
    tooltipEl.style.opacity = '1';
    const rect = target.getBoundingClientRect();
    tooltipEl.style.top = `${rect.top - tooltipEl.offsetHeight - 10}px`;
    tooltipEl.style.left = `${rect.left + rect.width / 2}px`;
  });
  document.addEventListener('mouseout', (e) => {
    if (e.target.closest('[data-tip]')) {
      tooltipEl.style.opacity = '0';
    }
  });

  // ═══════════════════════════════════════════
  //  GERAÇÃO DO PRD + PROMPT BASE
  // ═══════════════════════════════════════════
  const generateBtn = document.getElementById('generate-btn');
  let preGenAsked = false;
  if (generateBtn) {
    generateBtn.addEventListener('click', () => {
      // Primeiro clique: abre chat e pergunta se quer adicionar contexto
      if (!preGenAsked) {
        preGenAsked = true;
        // Abre painel de chat
        openChat();

        const contextFormatted = getWizardContextFormatted();
        const preGenMsg = `Antes de gerar seu PRD e Prompt Base, quero saber se voce tem algo a mais pra adicionar no projeto.\n\nSuas selecoes ate agora:\n\n${contextFormatted || 'Nenhuma selecao detectada.'}\n\nTem algum detalhe extra, requisito especifico ou preferencia? Quando estiver pronto, e so me dizer que quer prosseguir!`;
        appendChatMsg('assistant', preGenMsg, { skipAudio: true });
        return;
      }

      // Segundo clique (ou mais): vai direto para geração
      closeChat();
      showStep(26);
      triggerGeneration();
    });
  }

  function triggerGeneration() {
    const msgs = [
      'Analisando contexto do projeto...',
      'Mapeando topologia de banco de dados...',
      'Validando padroes de escalabilidade...',
      'Selecionando stack ideal...',
      'Gerando Roadmap de Seguranca...',
      'Montando Prompt Base otimizado...',
      'Finalizando documentacao...',
    ];
    let i = 0;
    const loadingMsg = document.getElementById('loading-msg');

    // Gera PRD local (template) como fallback imediato
    generateOutputs();

    // Dispara chamada LLM em paralelo com a animação
    const selectedModel = getFormValue('llm-model');
    let llmPromise = null;

    console.log('[Generate] selectedModel:', selectedModel, '| auth:', !!window.__bcAuth?.session);

    if (selectedModel && window.__bcAuth?.session) {
      const wizardContext = buildWizardContext();
      console.log('[Generate] Chamando /api/generate com modelo:', selectedModel);
      llmPromise = fetch('/api/generate', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${window.__bcAuth.session.access_token}`,
        },
        body: JSON.stringify({
          model: selectedModel,
          systemPrompt: `Voce e o BuildCode AI Engine, um arquiteto de software de elite. Gere um PRD (Product Requirements Document) tecnico completo em portugues (PT-BR) baseado nas selecoes do wizard abaixo. Use formatacao markdown. Inclua: sumario executivo, decisao de stack com justificativa tecnica, arquitetura do sistema, seguranca, escalabilidade, estimativa financeira, integracoes, estrategia de testes, SEO. Seja detalhado e profissional. Nao invente dados — use apenas as informacoes fornecidas.`,
          userPrompt: wizardContext,
        }),
      }).then(r => {
        console.log('[Generate] API response status:', r.status);
        return r.json();
      }).then(data => {
        if (data.error) {
          console.error('[Generate] API error:', data.error);
        } else {
          console.log('[Generate] Sucesso! Tier:', data.tier, '| Provider:', data.provider);
        }
        return data;
      }).catch(err => {
        console.error('[Generate] Fetch failed:', err);
        return null;
      });
    } else {
      console.warn('[Generate] Pulando API — modelo vazio ou sem sessão');
    }

    const interval = setInterval(() => {
      if (i < msgs.length) { loadingMsg.textContent = msgs[i]; i++; }
      else {
        clearInterval(interval);
        const finalize = (llmResult) => {
          // Se a LLM retornou conteúdo, substitui o PRD template
          if (llmResult?.result) {
            prdOutput.value = llmResult.result;
            console.log('[Generate] PRD gerado por IA ✓');
          } else {
            console.warn('[Generate] Usando template local (API falhou ou modelo não selecionado)');
            if (llmResult?.error) {
              console.error('[Generate] Motivo:', llmResult.error);
            }
          }
          enforcePromptLimit();
          buildInsights();
          showStep(27);
          progressBar.style.width = '100%';
          showDownloadBtns(true);
          updateCharCount();

          // Badge visual mostrando fonte do PRD
          const badge = document.getElementById('prd-source-badge');
          if (badge) {
            if (llmResult?.result) {
              badge.textContent = '✦ Gerado por IA (' + (llmResult.tier || selectedModel || '?') + ')';
              badge.className = 'text-[10px] font-bold px-2.5 py-1 rounded-full bg-emerald-500/15 text-emerald-400 border border-emerald-500/20';
            } else {
              badge.textContent = '⚠ Template local (IA indisponível)';
              badge.className = 'text-[10px] font-bold px-2.5 py-1 rounded-full bg-amber-500/15 text-amber-400 border border-amber-500/20';
            }
            badge.classList.remove('hidden');
          }
        };

        if (llmPromise) {
          // Aguarda resposta da LLM (com timeout de 30s)
          const timeout = new Promise(resolve => setTimeout(() => resolve(null), 30000));
          Promise.race([llmPromise, timeout]).then(result => {
            setTimeout(() => finalize(result), 300);
          });
        } else {
          setTimeout(() => finalize(null), 500);
        }
      }
    }, 600);
  }

