---
import Layout from '../layouts/Layout.astro';
import { questions, phases, testesOptions, llmModels, difficultyConfig, promptLanguageOptions } from '../data/wizard-config';
import { tooltips } from '../data/tooltips';
import { skillsMap } from '../data/skills-map';
import { technologies } from '../data/technologies';
export const prerender = false;

const totalSteps = 20;

// Mapa de logos para opções estáticas do wizard (SVGs locais)
const si = (slug: string) => `/icons/${slug}.svg`;
const optionLogoMap: Record<string, string> = {
  // Ferramentas
  cursor: si('cursor'), 'claude-code': si('anthropic'), vscode: si('visualstudiocode'), windsurf: si('codeium'),
  // Frontend
  'html-css': si('html5'), astro: si('astro'), react: si('react'), vue: si('vuedotjs'),
  nextjs: si('nextdotjs'), nuxt: si('nuxtdotjs'), svelte: si('svelte'), angular: si('angular'),
  solid: si('solid'), remix: si('remix'),
  // Backend
  supabase: si('supabase'), firebase: si('firebase'), express: si('express'), nestjs: si('nestjs'),
  fastify: si('fastify'), fastapi: si('fastapi'), django: si('django'), go: si('go'),
  rust: si('rust'), spring: si('springboot'), laravel: si('laravel'),
  // Database
  'sql-managed': si('postgresql'), 'sql-raw': si('postgresql'), nosql: si('mongodb'), vetorial: si('pinecone'),
  // Infra
  vercel: si('vercel'), railway: si('railway'), netlify: si('netlify'), cloudflare: si('cloudflare'),
  digitalocean: si('digitalocean'), aws: si('amazonaws'), 'docker-vps': si('docker'),
};

// Serializa banco de tecnologias para busca client-side (apenas campos necessários)
const techDB = technologies.map(t => ({
  name: t.name,
  category: t.category,
  tagline: t.tagline,
  logo: t.logo,
  website: t.website,
  description: t.description,
  pros: t.pros,
  cons: t.cons,
  useCases: t.useCases,
  language: t.language,
  typeIcon: t.typeIcon
}));
---

<Layout title="BuildCode | Arquiteto de Software" description="Wizard de arquitetura de software com IA. Responda 20 perguntas e receba um PRD e Prompt Base otimizados." noindex={true}>
  <!-- Particle Canvas Background -->
  <canvas id="particle-canvas" style="position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:50;pointer-events:none;"></canvas>

  <div class="relative flex flex-col min-h-screen overflow-hidden">

    <!-- Background decorative -->
    <div class="absolute inset-0 z-[1] pointer-events-none"
      style="background-image: radial-gradient(circle at 2px 2px, rgba(46,116,139,0.04) 1px, transparent 0); background-size: 40px 40px;">
    </div>
    <div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] rounded-full blur-[120px] pointer-events-none bg-primary/10 z-[1]"></div>
    <div class="absolute -bottom-[10%] -right-[10%] w-[40%] h-[40%] rounded-full blur-[120px] pointer-events-none bg-primary-dark/10 z-[1]"></div>

    <!-- TOOLTIP FLOATING ELEMENT -->
    <div id="bc-tooltip" class="fixed z-[9999] px-4 py-3 rounded-xl bg-[#0D1117]/95 backdrop-blur-xl border border-primary/30 text-slate-200 text-xs leading-relaxed max-w-xs shadow-[0_8px_32px_rgba(0,0,0,0.6),0_0_20px_rgba(46,116,139,0.15)] pointer-events-none opacity-0 transition-opacity duration-200" style="transform: translateX(-50%)">
      <div class="flex items-start gap-2">
        <span class="material-symbols-outlined text-primary text-sm mt-0.5 shrink-0">info</span>
        <span id="bc-tooltip-text"></span>
      </div>
    </div>

    <!-- TOP NAV -->
    <header class="relative z-20 flex items-center justify-between px-4 sm:px-8 py-3 sm:py-4 border-b border-border-color glass-panel">
      <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
        <img id="app-logo" src="/logo_backofff.png" data-dark="/logo_backofff.png" data-light="/Logowhitemodeloff.png" alt="BuildCode" class="h-8 w-auto object-contain" width="136" height="32" />
        <span class="font-display text-lg font-bold text-white tracking-tight hidden sm:block">BuildCode</span>
      </a>

      <!-- Progress Stepper (4 phases) -->
      <div class="hidden md:flex flex-col items-center flex-1 max-w-2xl px-12">
        <div class="flex justify-between w-full mb-2">
          {phases.map((p, i) => (
            <div class="flex items-center gap-1.5" id={`phase-lbl-${p.id}`}>
              <span class={`material-symbols-outlined text-sm ${i === 0 ? 'text-primary' : 'text-slate-600'} transition-colors`}>{p.icon}</span>
              <span class={`text-[10px] uppercase tracking-widest font-bold ${i === 0 ? 'text-primary' : 'text-slate-600'} transition-colors`}>{p.label}</span>
            </div>
          ))}
        </div>
        <div class="w-full h-[2px] bg-surface-dark rounded-full relative overflow-hidden">
          <div id="progress-bar" class="absolute top-0 left-0 h-full bg-gradient-to-r from-primary to-secondary shadow-[0_0_15px_rgba(46,116,139,0.5)] rounded-full transition-all duration-700 ease-out" style="width: 0%"></div>
        </div>
        <!-- hidden elements kept for JS references -->
        <span id="step-counter" class="sr-only">01 / 20</span>
        <span id="step-phase-name" class="sr-only">Contexto</span>
      </div>

      <!-- Right: User -->
      <div class="flex items-center gap-3">
        <!-- Login link (visible when NOT authenticated) -->
        <a id="app-login-btn" href="/login" class="hidden items-center gap-1.5 px-4 py-2 rounded-full border border-primary/30 text-primary hover:bg-primary/10 transition-colors text-sm font-semibold cursor-pointer">
          <span class="material-symbols-outlined text-sm">login</span>
          Login
        </a>
        <!-- User pill (visible when authenticated) -->
        <div class="relative">
          <button id="app-user-btn" type="button" class="hidden items-center gap-2.5 cursor-pointer rounded-full border border-primary/20 pl-3 pr-1.5 py-1.5 hover:bg-primary/5 hover:border-primary/40 transition-all">
            <span id="app-user-name" class="text-sm font-medium text-white max-w-[120px] truncate"></span>
            <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center overflow-hidden border border-primary/30">
              <img id="app-avatar-img" src="" alt="Avatar do usuário" class="w-full h-full object-cover hidden" />
              <span id="app-avatar-initials" class="text-[10px] font-bold text-primary"></span>
            </div>
          </button>
          <!-- Profile dropdown -->
          <div id="app-profile-dropdown" class="hidden absolute right-0 top-full mt-2 w-72 rounded-2xl glass-panel border border-primary/20 shadow-[0_8px_32px_rgba(0,0,0,0.5)] z-50 overflow-hidden">
            <div class="p-4 border-b border-border-color flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center overflow-hidden border border-primary/30 shrink-0">
                <img id="app-dd-avatar-img" src="" alt="Avatar do usuário" class="w-full h-full object-cover hidden" />
                <span id="app-dd-avatar-initials" class="text-xs font-bold text-primary"></span>
              </div>
              <div class="flex-1 min-w-0">
                <p id="app-dd-name" class="text-sm font-bold text-white truncate"></p>
                <p id="app-dd-email" class="text-[11px] text-slate-500 truncate"></p>
              </div>
              <span id="app-dd-role-badge" class="hidden px-2 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wider border"></span>
            </div>
            <div class="p-2 flex flex-col gap-0.5">
              <a href="/perfil" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-slate-300 hover:text-white hover:bg-primary/10 transition-colors">
                <span class="material-symbols-outlined text-base text-primary">person</span>
                Meu Perfil
              </a>
              <a href="/perfil" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-slate-300 hover:text-white hover:bg-primary/10 transition-colors">
                <span class="material-symbols-outlined text-base text-primary">settings</span>
                Configurações
              </a>
              <a href="/perfil#plano" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-slate-300 hover:text-white hover:bg-primary/10 transition-colors">
                <span class="material-symbols-outlined text-base" style="color: #F2AB6D;">credit_card</span>
                Planos
              </a>
              <button id="app-logout-btn" type="button" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-red-400 hover:text-red-300 hover:bg-red-500/10 transition-colors w-full text-left">
                <span class="material-symbols-outlined text-base">logout</span>
                Sair
              </button>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- MAIN CONTENT -->
    <main id="main-content" class="relative z-10 flex flex-1 gap-4 lg:gap-6 p-3 sm:p-4 lg:p-6 max-w-[1440px] mx-auto w-full">
      <h1 class="sr-only">Wizard de Arquitetura de Software</h1>

      <!-- LEFT SIDEBAR: Live Insights -->
      <aside class="w-72 hidden xl:flex flex-col gap-6 shrink-0">
        <div class="glass-panel rounded-2xl p-6 flex flex-col gap-6">
          <div>
            <h3 class="text-xs font-bold uppercase tracking-widest text-primary mb-4" data-i18n="app.insights">Architecture Insights</h3>
            <div class="flex flex-col gap-4">
              <div class="flex items-center justify-between">
                <span class="text-sm text-slate-400" data-i18n="app.custo">Estimativa de Custo</span>
                <span id="insight-cost" class="text-sm font-semibold text-green-400">—</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm text-slate-400" data-i18n="app.complexidade">Complexidade</span>
                <div id="insight-complexity" class="flex gap-0.5">
                  <span class="material-symbols-outlined text-sm text-slate-700">star</span>
                  <span class="material-symbols-outlined text-sm text-slate-700">star</span>
                  <span class="material-symbols-outlined text-sm text-slate-700">star</span>
                  <span class="material-symbols-outlined text-sm text-slate-700">star</span>
                  <span class="material-symbols-outlined text-sm text-slate-700">star</span>
                </div>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm text-slate-400" data-i18n="app.ttm">Time-to-Market</span>
                <span id="insight-ttm" class="text-sm font-semibold text-white">—</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm text-slate-400" data-i18n="app.senioridade">Senioridade</span>
                <span id="insight-level" class="text-sm font-semibold text-primary">—</span>
              </div>
            </div>
          </div>
          <div class="pt-6 border-t border-border-color">
            <h3 class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-4"><span data-i18n="app.sugestao">💡 Sugestão Live</span></h3>
            <div class="p-3 bg-surface-dark/70 rounded-lg border border-border-color">
              <p id="insight-tip" class="text-[11px] leading-relaxed text-slate-300" data-i18n="app.sugestao.default">Preencha o formulário para receber sugestões em tempo real.</p>
            </div>
          </div>
        </div>

        <div class="glass-panel rounded-2xl p-4 flex items-center gap-3 mt-auto">
          <div class="size-2 rounded-full bg-green-500 animate-pulse"></div>
          <span class="text-xs font-medium text-slate-400" data-i18n="app.engine">AI Engine: Online & Analisando</span>
        </div>
      </aside>

      <!-- CENTER: Wizard -->
      <section class="flex-1 flex flex-col items-center justify-center gap-4 sm:gap-6 lg:gap-8 py-4 sm:py-6 lg:py-8">
        <form id="wizard-form" class="w-full max-w-5xl">

          <!-- Render all 20 questions dynamically -->
          {questions.map((q) => (
            <div class={`step flex ${q.step === 1 ? '' : 'hidden'} flex-col items-center gap-8`} data-step={q.step} data-phase={q.phase} data-visible-for={q.visibleFor === 'all' ? 'all' : JSON.stringify(q.visibleFor)} data-optional-for={q.optionalFor ? JSON.stringify(q.optionalFor) : ''}>
              <div class="text-center max-w-2xl space-y-3">
                <h2 class="font-display text-2xl sm:text-3xl lg:text-5xl font-black text-white tracking-tight">
                  {q.titlePre}{' '}<span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">{q.titleHighlight}</span>{' '}{q.titlePost}
                </h2>
                <p class="text-slate-400 text-sm sm:text-base lg:text-lg font-medium">{q.subtitle}</p>
                <span id={`optional-badge-${q.step}`} class="hidden items-center gap-1 px-3 py-1 rounded-full bg-cta/10 text-cta text-[10px] font-bold uppercase tracking-widest border border-cta/20">
                  <span class="material-symbols-outlined text-xs">info</span> Etapa opcional — pode pular
                </span>
              </div>

              {/* Textarea type */}
              {q.type === 'textarea' && (
                <textarea
                  id={q.name}
                  name={q.name}
                  rows="5"
                  required
                  aria-label={q.placeholder || q.title}
                  class="w-full glass-panel rounded-2xl p-6 text-white text-sm focus:outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/50 transition-all resize-none leading-relaxed font-body"
                  placeholder={q.placeholder}
                ></textarea>
              )}

              {/* Radio / Checkbox options */}
              {(q.type === 'radio' || q.type === 'checkbox') && q.options && (
                <div class="w-full space-y-6">
                  {/* Search bar for searchable questions */}
                  {q.searchable && (
                    <div class="w-full" data-search-block={q.name} data-db-category={q.dbCategory}>
                      <div class="relative flex items-center gap-3">
                        <span class="material-symbols-outlined absolute left-4 text-slate-500 text-lg pointer-events-none">search</span>
                        <input
                          type="text"
                          aria-label={`Buscar ${q.name === 'frontend' ? 'framework frontend' : q.name === 'backend' ? 'tecnologia backend' : q.name === 'database' ? 'banco de dados' : 'plataforma de infra'}`}
                          class="tech-search-input w-full pl-11 pr-4 py-3 rounded-xl glass-panel text-sm text-white placeholder:text-slate-600 focus:outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/50 transition-all"
                          placeholder={`Buscar ${q.name === 'frontend' ? 'framework frontend' : q.name === 'backend' ? 'tecnologia backend' : q.name === 'database' ? 'banco de dados' : 'plataforma de infra'} no banco...`}
                          data-for={q.name}
                          data-category={q.dbCategory}
                          autocomplete="off"
                        />
                        <button
                          type="button"
                          class="custom-tech-btn shrink-0 flex items-center gap-2 px-4 py-3 rounded-xl border border-cta/30 bg-cta/10 text-cta text-xs font-bold hover:bg-cta hover:text-background-dark transition-all"
                          data-for={q.name}
                          title="Informe uma tecnologia que não está na biblioteca"
                        >
                          <span class="material-symbols-outlined text-sm">edit</span>
                          <span data-i18n="app.personalizar">Personalizar</span>
                        </button>
                        <span class="text-[10px] text-slate-600 font-mono shrink-0 pr-1" data-i18n="app.esc">ESC limpa</span>
                      </div>
                      <!-- Custom tech input (hidden by default) -->
                      <div class="custom-tech-input hidden mt-3 flex items-center gap-3" data-custom-for={q.name}>
                        <input
                          type="text"
                          class="custom-tech-value flex-1 px-4 py-3 rounded-xl glass-panel text-sm text-white placeholder:text-slate-600 focus:outline-none focus:border-cta/50 focus:ring-1 focus:ring-cta/50 transition-all border-cta/20"
                          placeholder="Digite o nome da tecnologia que deseja usar..."
                          data-i18n-placeholder="app.personalizar.placeholder"
                          autocomplete="off"
                        />
                        <button
                          type="button"
                          class="custom-tech-confirm shrink-0 flex items-center gap-2 px-4 py-3 rounded-xl bg-cta text-background-dark text-xs font-bold hover:bg-cta/80 transition-all"
                          data-for={q.name}
                        >
                          <span class="material-symbols-outlined text-sm">check</span>
                          <span data-i18n="app.personalizar.confirmar">Confirmar</span>
                        </button>
                      </div>
                      <div
                        class="tech-search-results hidden mt-3 grid grid-cols-1 md:grid-cols-3 gap-3"
                        data-results-for={q.name}
                      ></div>
                      <p class="tech-search-empty hidden mt-3 text-center text-sm text-slate-600 py-4">Nenhuma tecnologia encontrada. Tente outro termo.</p>
                      <div class="w-full h-px bg-border-color my-4"></div>
                    </div>
                  )}

                  {/* Custom IDE input for "Outro" */}
                  {q.name === 'ferramenta' && (
                    <div id="custom-ide-block" class="hidden w-full mb-4">
                      <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-cta text-lg">edit</span>
                        <input
                          type="text"
                          id="custom-ide-input"
                          aria-label="IDE personalizada"
                          class="flex-1 px-4 py-3 rounded-xl glass-panel text-sm text-white placeholder:text-slate-600 focus:outline-none focus:border-cta/50 focus:ring-1 focus:ring-cta/50 transition-all border-cta/20"
                          placeholder="Informe o nome da sua IDE (ex: WebStorm, Neovim, Zed...)"
                          autocomplete="off"
                        />
                      </div>
                    </div>
                  )}

                  {/* Custom MCP input + search */}
                  {q.name === 'mcps' && (
                    <div class="w-full space-y-3 mb-4">
                      <div class="relative flex items-center gap-3">
                        <span class="material-symbols-outlined absolute left-4 text-slate-500 text-lg pointer-events-none">search</span>
                        <input
                          type="text"
                          id="mcp-search-input"
                          aria-label="Buscar MCP"
                          class="w-full pl-11 pr-4 py-3 rounded-xl glass-panel text-sm text-white placeholder:text-slate-600 focus:outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/50 transition-all"
                          placeholder="Buscar MCPs na biblioteca..."
                          autocomplete="off"
                        />
                        <button
                          type="button"
                          id="mcp-custom-toggle"
                          class="shrink-0 flex items-center gap-2 px-4 py-3 rounded-xl border border-cta/30 bg-cta/10 text-cta text-xs font-bold hover:bg-cta hover:text-background-dark transition-all"
                        >
                          <span class="material-symbols-outlined text-sm">add</span>
                          Personalizar
                        </button>
                      </div>
                      <div id="mcp-custom-block" class="hidden flex items-center gap-3">
                        <input
                          type="text"
                          id="mcp-custom-input"
                          aria-label="MCP personalizado"
                          class="flex-1 px-4 py-3 rounded-xl glass-panel text-sm text-white placeholder:text-slate-600 focus:outline-none focus:border-cta/50 focus:ring-1 focus:ring-cta/50 transition-all border-cta/20"
                          placeholder="Nome do MCP personalizado (ex: slack-mcp, notion-mcp...)"
                          autocomplete="off"
                        />
                        <button
                          type="button"
                          id="mcp-custom-add"
                          class="shrink-0 flex items-center gap-2 px-4 py-3 rounded-xl bg-cta text-background-dark text-xs font-bold hover:bg-cta/80 transition-all"
                        >
                          <span class="material-symbols-outlined text-sm">check</span>
                          Adicionar
                        </button>
                      </div>
                      <div id="mcp-search-results" class="hidden grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3"></div>
                      <div class="w-full h-px bg-border-color"></div>
                    </div>
                  )}

                  <div class={`grid grid-cols-1 gap-3 sm:gap-4 w-full ${q.cols === 2 ? 'sm:grid-cols-2' : q.cols === 4 ? 'sm:grid-cols-2 lg:grid-cols-4' : 'sm:grid-cols-2 lg:grid-cols-3'}`}>
                    {q.options.map(opt => {
                      const diff = opt.difficulty ? difficultyConfig[opt.difficulty] : null;
                      return (
                      <label class="cursor-pointer group option-label relative" data-min-level={opt.minLevel || 1} data-recommended={opt.recommendedFor ? JSON.stringify(opt.recommendedFor) : ''}>
                        <input type={q.type} name={q.name} value={opt.value} class="peer sr-only" />
                        <div class="glass-panel rounded-2xl p-5 flex flex-col gap-3 text-left transition-all duration-300 peer-checked:border-primary peer-checked:bg-primary/10 peer-checked:shadow-[0_0_30px_rgba(46,116,139,0.2)] peer-checked:scale-[1.02] hover:scale-[1.02] hover:shadow-[0_0_20px_rgba(46,116,139,0.15)] hover:border-primary/40 h-full">
                          <div class="flex items-start justify-between gap-2">
                            <div class="size-10 rounded-xl bg-primary/10 group-[.peer:checked+&]:bg-primary transition-colors shrink-0 overflow-hidden relative flex items-center justify-center">
                              {optionLogoMap[opt.value] ? (
                                <img src={optionLogoMap[opt.value]} alt={opt.label} class="w-6 h-6 object-contain" width="24" height="24" />
                              ) : (
                                <span class="material-symbols-outlined text-primary group-[.peer:checked+&]:text-background-dark text-xl">{opt.icon}</span>
                              )}
                            </div>
                            <div class="flex items-center gap-1.5">
                              {diff && (
                                <span class={`px-2 py-0.5 rounded-md text-[9px] font-bold uppercase tracking-wider border ${diff.color} ${diff.border} ${diff.bg}`}>{diff.label}</span>
                              )}
                              {opt.website && (
                                <button
                                  type="button"
                                  class="info-btn shrink-0 size-7 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-slate-500 hover:text-primary hover:border-primary/40 hover:bg-primary/10 transition-all z-10"
                                  data-tech-name={opt.label}
                                  data-tech-url={opt.website}
                                  title={`Saber mais sobre ${opt.label}`}
                                  onclick="event.preventDefault(); event.stopPropagation(); window._openInfoModal && window._openInfoModal(this.getAttribute('data-tech-name'), this.getAttribute('data-tech-url'));"
                                >
                                  <span class="material-symbols-outlined text-[16px] pointer-events-none">info</span>
                                </button>
                              )}
                            </div>
                          </div>
                          <div class="flex-1">
                            <h4 class="font-bold text-white text-sm">{opt.label}</h4>
                            <p class="text-xs text-slate-500 mt-1 leading-relaxed">{opt.desc}</p>
                          </div>
                          {opt.recommendedFor && opt.recommendedFor.length > 0 && (
                            <span class="rec-badge hidden items-center gap-1 px-2 py-0.5 rounded-full bg-primary/10 text-primary text-[9px] font-bold uppercase tracking-wider border border-primary/20 w-fit" data-rec-for={JSON.stringify(opt.recommendedFor)}>
                              <span class="material-symbols-outlined text-[10px]">thumb_up</span> Recomendado
                            </span>
                          )}
                          {opt.notRecommendedFor && opt.notRecommendedFor.length > 0 && (
                            <span class="not-rec-badge hidden items-center gap-1 px-2 py-0.5 rounded-full bg-red-500/10 text-red-400 text-[9px] font-bold uppercase tracking-wider border border-red-500/20 w-fit" data-not-rec-for={JSON.stringify(opt.notRecommendedFor)}>
                              <span class="material-symbols-outlined text-[10px]">warning</span> Nao recomendado p/ Portfolio
                            </span>
                          )}
                        </div>
                      </label>
                    );})}
                  </div>
                </div>

              )}

              {/* Special: Testes sub-section under Q20 */}
              {q.step === 20 && (
                <div class="w-full mt-4">
                  <h3 class="font-display text-lg font-bold text-white mb-4 flex items-center gap-2">
