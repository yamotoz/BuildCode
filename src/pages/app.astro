      const input = customBlock.querySelector('.custom-tech-value');
      const value = input.value.trim();
      if (!value) return;

      // Deselect any existing radio for this question
      document.querySelectorAll(`input[name="${questionName}"]`).forEach(r => r.checked = false);

      // Create a hidden radio with the custom value and check it
      const existingCustom = document.getElementById(`custom-radio-${questionName}`);
      if (existingCustom) existingCustom.remove();

      const hiddenRadio = document.createElement('input');
      hiddenRadio.type = 'radio';
      hiddenRadio.name = questionName;
