  function openInfoModal(techName, techUrl) {
     // match by url first (more accurate), then by name
     let tech = availableTechs.find(t => t.website && techUrl && t.website === techUrl);
     if (!tech) {
        tech = availableTechs.find(t => t.name.toLowerCase().includes(techName.toLowerCase()) || techName.toLowerCase().includes(t.name.toLowerCase()));
