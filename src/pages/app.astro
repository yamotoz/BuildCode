    if (!resultsContainer) return;

    input.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase().trim();
      
      if (query.length < 2) {
        resultsContainer.innerHTML = '';
        resultsContainer.classList.add('hidden');
        emptyMsg.classList.add('hidden');
        return;
      }

      // Filter by category and query, take max 9 results
      const results = availableTechs.filter(t => {
        // match category exactly
        if (t.category !== category && !(category === 'data' && t.category === 'database')) return false;
        
        // check keyword match
        return t.name.toLowerCase().includes(query) || (t.tagline && t.tagline.toLowerCase().includes(query));
      }).slice(0, 9); // limits to 9 solutions as requested

      if (results.length === 0) {
        resultsContainer.innerHTML = '';
        resultsContainer.classList.add('hidden');
        emptyMsg.classList.remove('hidden');
        return;
      }

      emptyMsg.classList.add('hidden');
      
      // Assume missing minLevel is Senior-equivalent in the DB to trigger warnings
      const currentLevelNum = getSeniorityNum(userSeniority);

      resultsContainer.innerHTML = results.map(tech => {
        // Simple heuristic: if it's not in the 9 pre-filtered options, it's probably heavier/advanced.
        // We warn them it's advanced.
        const isAdvanced = currentLevelNum < 2; // warn juniors basically

        return `
          <label class="cursor-pointer group option-label relative">
            <input type="radio" name="${questionName}" value="${tech.name}" class="peer sr-only" />
            <div class="glass-panel rounded-2xl p-4 flex flex-col gap-2 text-left transition-all duration-300 peer-checked:border-primary peer-checked:bg-primary/10 peer-checked:shadow-[0_0_20px_rgba(46,116,139,0.2)] hover:border-primary/40 h-full">
              <div class="flex items-start justify-between gap-2">
                <div class="size-8 rounded-lg bg-surface flex items-center justify-center shrink-0">
                  <img src="${tech.logo || 'https://svgl.app/library/supabase.svg'}" alt="${tech.name}" class="w-5 h-5 object-contain" onerror="this.src='https://svgl.app/library/supabase.svg'" />
                </div>
                ${isAdvanced ? '<span class="px-2 py-0.5 rounded-md bg-yellow-500/10 text-yellow-400 text-[10px] font-bold border border-yellow-500/20" title="Tecnologia consideravelmente complexa para um MVP ou nível Júnior.">⚠️ Avançado</span>' : ''}
              </div>
              <div class="flex items-start justify-between gap-2 mt-1">
                <div class="flex-1">
                  <h4 class="font-bold text-white text-sm truncate">${tech.name}</h4>
                  <p class="text-[11px] text-slate-500 mt-0.5 line-clamp-2 leading-snug">${tech.tagline}</p>
                </div>
                <button
                  type="button"
                  class="info-btn shrink-0 size-7 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-slate-500 hover:text-primary hover:border-primary/40 hover:bg-primary/10 transition-all z-10 mt-1"
