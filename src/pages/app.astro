     void modal.offsetWidth;
     modal.classList.add('flex', 'opacity-100');
     modalPanel.classList.remove('scale-95');
     modalPanel.classList.add('scale-100');
  }
  
  function closeModal() {
     modal.classList.remove('opacity-100');
     modalPanel.classList.remove('scale-100');
     modalPanel.classList.add('scale-95');
     setTimeout(() => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
     }, 300);
  }
  
  closeModalBtn.addEventListener('click', closeModal);
  modalOverlay.addEventListener('click', closeModal);
  
  document.addEventListener('keydown', (e) => {
     if (e.key === 'Escape' && modal.classList.contains('flex')) {
        closeModal();
     }
  });
  
  // Delegate clicks on dynamic elements (since search results recreate dom)
  document.addEventListener('click', (e) => {
     const infoBtn = e.target.closest('.info-btn');
     if (infoBtn) {
        openInfoModal(infoBtn.getAttribute('data-tech-name'), infoBtn.getAttribute('data-tech-url'));
     }
  });

  // Init
  showStep(1);
  updateInsights();
});

// Pass DB from server to client
window.techDB = techDB;
