<style>
  .step { display: flex; }
  .step.hidden { display: none; }

  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .step:not(.hidden) {
    animation: fade-in-up 0.5s cubic-bezier(0.16,1,0.3,1) forwards;
  }

  /* Tooltip term styling */
  [data-tip] {
    cursor: help;
    border-bottom: 1px dashed rgba(46,116,139,0.5);
    color: #5A9DB5;
    transition: color 0.2s;
  }
  [data-tip]:hover {
    color: #F2AB6D;
  }
</style>

<script define:vars={{ tooltipData: tooltips, skillsData: skillsMap, totalSteps, techDB }}>
document.addEventListener('DOMContentLoaded', () => {
  let currentStep = 1;
  let userSeniority = 'junior'; // default
  let userTipo = 'hobby';

  const steps = document.querySelectorAll('.step');
  const progressBar = document.getElementById('progress-bar');
  const stepCounter = document.getElementById('step-counter');
  const stepPhaseName = document.getElementById('step-phase-name');
  const form = document.getElementById('wizard-form');
  const prdOutput = document.getElementById('prd-output');
  const promptOutput = document.getElementById('prompt-output');

  // Insight refs
  const insightCost = document.getElementById('insight-cost');
  const insightComplexity = document.getElementById('insight-complexity');
  const insightTtm = document.getElementById('insight-ttm');
  const insightLevel = document.getElementById('insight-level');
  const insightTip = document.getElementById('insight-tip');

  // Tooltip
  const tooltipEl = document.getElementById('bc-tooltip');
  const tooltipText = document.getElementById('bc-tooltip-text');

  const phaseNames = ['Contexto', 'Stack Técnica', 'Qualidade', 'Final'];

  // ═══════════════════════════════════════════
  //  STEP NAVIGATION
  // ═══════════════════════════════════════════
  function getPhase(step) {
    if (step <= 5) return 1;
    if (step <= 12) return 2;
    if (step <= 18) return 3;
    return 4;
  }

  function updateProgress(step) {
    const pct = Math.min(((step - 1) / totalSteps) * 100, 100);
    progressBar.style.width = `${pct}%`;
    const s = Math.min(step, totalSteps);
    stepCounter.textContent = `${String(s).padStart(2, '0')} / ${totalSteps}`;
    const phase = getPhase(step);
    stepPhaseName.textContent = phaseNames[phase - 1] || 'Resultado';

    // Update phase labels
    for (let i = 1; i <= 4; i++) {
      const phLbl = document.getElementById(`phase-lbl-${i}`);
      if (!phLbl) continue;
      const els = phLbl.querySelectorAll('span');
      els.forEach(el => {
        if (i <= phase) {
          el.classList.remove('text-slate-600');
          el.classList.add('text-primary');
        } else {
          el.classList.remove('text-primary');
          el.classList.add('text-slate-600');
        }
      });
    }
  }

  function showStep(step) {
    steps.forEach(el => el.classList.add('hidden'));
    const active = document.querySelector(`.step[data-step="${step}"]`);
    if (active) active.classList.remove('hidden');
    updateProgress(step);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // Seniority-based option filtering
  function filterOptionsBySeniority() {
    const levelMap = { 'junior': 1, 'pleno': 2, 'senior': 3 };
    const level = levelMap[userSeniority] || 1;

    document.querySelectorAll('.option-label[data-min-level]').forEach(label => {
      const minLevel = parseInt(label.getAttribute('data-min-level') || '1');
      if (minLevel > level) {
        label.style.display = 'none';
        // Uncheck hidden inputs
        const input = label.querySelector('input');
        if (input) input.checked = false;
      } else {
        label.style.display = '';
      }
    });

    // Show/hide optional badges for hobby
    document.querySelectorAll('[id^="optional-badge-"]').forEach(badge => {
      badge.classList.toggle('hidden', userTipo !== 'hobby');
      badge.classList.toggle('inline-flex', userTipo === 'hobby');
    });
  }

  // Listen for seniority change
  document.querySelectorAll('input[name="senioridade"]').forEach(radio => {
    radio.addEventListener('change', (e) => {
      userSeniority = e.target.value;
      filterOptionsBySeniority();
      updateInsights();
    });
  });
  document.querySelectorAll('input[name="tipo"]').forEach(radio => {
    radio.addEventListener('change', (e) => {
      userTipo = e.target.value;
      filterOptionsBySeniority();
      updateInsights();
    });
  });

  // Next / Prev buttons
  document.querySelectorAll('.next-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      // Validate current step
      if (currentStep === 1) {
        const ctx = document.getElementById('contexto');
        if (!ctx.value.trim()) {
          ctx.classList.add('border-red-500', 'ring-1', 'ring-red-500/50');
          ctx.focus();
          return;
        }
        ctx.classList.remove('border-red-500', 'ring-1', 'ring-red-500/50');
      }
      if (currentStep < totalSteps) {
        const prevPhase = getPhase(currentStep);
        currentStep++;
        const newPhase = getPhase(currentStep);
        showStep(currentStep);
        updateInsights();

        // Three.js camera dive on phase 1 → phase 2 (Q5 → Q6)
        if (prevPhase === 1 && newPhase === 2 && typeof window.__bcDive === 'function') {
          window.__bcDive();
        }
      }
    });
  });

  document.querySelectorAll('.prev-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      if (currentStep > 1) { currentStep--; showStep(currentStep); updateInsights(); }
    });
  });

  // ═══════════════════════════════════════════
  //  LIVE INSIGHTS ENGINE
  // ═══════════════════════════════════════════
  function updateInsights() {
    const escala = form.querySelector('input[name="escala"]:checked')?.value;
    const tipo = form.querySelector('input[name="tipo"]:checked')?.value;

    // Cost
    const costMap = { '50': '$0 – $20/mês', '1000': '$20 – $100/mês', '10000': '$100 – $500/mês', '50000': '$500 – $5k+/mês' };
    insightCost.textContent = costMap[escala] || '—';

    // Complexity stars
    const compMap = { '50': 1, '1000': 2, '10000': 3, '50000': 5 };
    const levelComp = { 'hobby': 0, 'saas': 1, 'enterprise': 2 };
    let stars = (compMap[escala] || 0) + (levelComp[tipo] || 0);
    stars = Math.min(stars, 5);
    const starsHTML = Array.from({ length: 5 }, (_, i) =>
      `<span class="material-symbols-outlined text-sm ${i < stars ? 'text-cta' : 'text-slate-700'}" style="font-variation-settings: 'FILL' ${i < stars ? 1 : 0}">star</span>`
    ).join('');
    insightComplexity.innerHTML = starsHTML;

    // TTM
    const ttmMap = { '50': '2–4 semanas', '1000': '1–3 meses', '10000': '3–6 meses', '50000': '6–12 meses' };
    insightTtm.textContent = ttmMap[escala] || '—';

    // Level
    const levelLbl = { 'junior': '🟢 Júnior', 'pleno': '🟡 Pleno', 'senior': '🔴 Sênior' };
    insightLevel.textContent = levelLbl[userSeniority] || '—';

    // Tips
    const tips = {
      1: 'Descreva seu projeto com o máximo de detalhes para uma arquitetura precisa.',
      2: 'Sua senioridade adapta as recomendações automaticamente.',
      3: 'A escala define toda a infraestrutura necessária.',
      4: 'Projetos SaaS exigem mais rigor em segurança e escalabilidade.',
      5: 'O Prompt Base será otimizado para a ferramenta escolhida.',
      6: 'Frontend escolhido influencia a experiência do usuário e a performance.',
      7: 'O backend é o motor do sistema. Managed (BaaS) é ideal para MVPs.',
      8: 'MCPs conectam sua IA diretamente às ferramentas do projeto.',
      9: 'SQL é confiável e maduro. NoSQL é flexível. Vetorial é para IA.',
      10: 'Skills técnicas são injetadas no prompt como referências de boas práticas.',
      11: 'Vercel e Railway são ideais para começar rápido. AWS para escala enterprise.',
      12: 'Híbrido (SQL + Cache) é a escolha dos sistemas de alta performance.',
      13: 'RBAC é essencial para sistemas com múltiplos tipos de usuário.',
      14: 'Rate Limiting e Sanitização são o mínimo para qualquer app em produção.',
      15: 'WebSockets são essenciais para chat, dashboards live e notificações.',
      16: 'Funcional é tendência. OOP é tradição. Misto é pragmatismo.',
      17: 'Graceful Degradation melhora a UX. Strict Mode melhora a segurança.',
      18: 'i18n desde o dia 1 evita refatoração dolorosa no futuro.',
      19: 'Stripe + Webhooks é a combinação mais usada para SaaS.',
      20: 'Testes E2E garantem que o sistema funciona como o usuário espera.',
    };
    insightTip.textContent = tips[currentStep] || 'Próxima etapa...';
  }

  // ═══════════════════════════════════════════
  //  TOOLTIP SYSTEM
  // ═══════════════════════════════════════════
  document.addEventListener('mouseover', (e) => {
    const target = e.target.closest('[data-tip]');
    if (!target) return;
    const term = target.getAttribute('data-tip');
    const text = tooltipData[term];
    if (!text) return;
    tooltipText.textContent = text;
    tooltipEl.style.opacity = '1';
    const rect = target.getBoundingClientRect();
    tooltipEl.style.top = `${rect.top - tooltipEl.offsetHeight - 10}px`;
    tooltipEl.style.left = `${rect.left + rect.width / 2}px`;
  });
  document.addEventListener('mouseout', (e) => {
    if (e.target.closest('[data-tip]')) {
      tooltipEl.style.opacity = '0';
    }
  });

  // ═══════════════════════════════════════════
  //  GENERATE PRD + PROMPT BASE
  // ═══════════════════════════════════════════
  const generateBtn = document.getElementById('generate-btn');
  if (generateBtn) {
    generateBtn.addEventListener('click', () => {
      showStep(21); // Loading

      const msgs = [
        'Analisando contexto do projeto...',
        'Mapeando topologia de banco de dados...',
        'Validando padrões de escalabilidade...',
        'Selecionando stack ideal...',
        'Calculando estimativa financeira...',
        'Gerando Roadmap de Segurança...',
        'Montando Prompt Base otimizado...',
        'Finalizando documentação...',
      ];
      let i = 0;
      const loadingMsg = document.getElementById('loading-msg');
      const interval = setInterval(() => {
        if (i < msgs.length) { loadingMsg.textContent = msgs[i]; i++; }
        else {
          clearInterval(interval);
          setTimeout(() => {
            generateOutputs();
            showStep(22);
            progressBar.style.width = '100%';
          }, 500);
        }
      }, 600);
    });
  }

  function getFormValue(name) {
    const el = form.querySelector(`input[name="${name}"]:checked`);
    return el ? el.value : '';
  }
  function getFormValues(name) {
    return Array.from(form.querySelectorAll(`input[name="${name}"]:checked`)).map(el => el.value);
  }
  function getTextValue(name) {
    const el = form.querySelector(`[name="${name}"]`);
    return el ? el.value : '';
  }

  function generateOutputs() {
    const data = {
      contexto: getTextValue('contexto'),
      senioridade: getFormValue('senioridade'),
      escala: getFormValue('escala'),
      tipo: getFormValue('tipo'),
      ferramenta: getFormValue('ferramenta'),
      frontend: getFormValue('frontend'),
      backend: getFormValue('backend'),
      mcps: getFormValues('mcps'),
      database: getFormValue('database'),
      skills: getFormValues('skills'),
      infra: getFormValue('infra'),
      persistencia: getFormValue('persistencia'),
      auth: getFormValue('auth'),
      seguranca: getFormValues('seguranca'),
      realtime: getFormValue('realtime'),
      codestyle: getFormValue('codestyle'),
      erros: getFormValue('erros'),
      i18n: getFormValue('i18n'),
      integracoes: getFormValues('integracoes'),
      seo: getFormValue('seo'),
      testes: getFormValues('testes'),
    };

    // Label maps for display
    const lbl = {
      senioridade: { junior: 'Júnior', pleno: 'Pleno', senior: 'Sênior' },
      escala: { '50': 'Até 50 MAC', '1000': 'Até 1.000 MAC', '10000': 'Até 10.000 MAC', '50000': '50.000+ MAC' },
      tipo: { hobby: 'Pessoal/Hobby', saas: 'SaaS', enterprise: 'Enterprise' },
      ferramenta: { cursor: 'Cursor', 'claude-code': 'Claude Code', antigravity: 'Anti-Gravity', vscode: 'VS Code', windsurf: 'Windsurf', outro: 'Outro' },
      frontend: { 'html-css': 'HTML+CSS', astro: 'Astro', react: 'React', vue: 'Vue.js', nextjs: 'Next.js', nuxt: 'Nuxt.js', svelte: 'Svelte/SvelteKit', angular: 'Angular', solid: 'SolidJS', remix: 'Remix' },
      backend: { supabase: 'Supabase', firebase: 'Firebase', express: 'Node.js+Express', nestjs: 'NestJS', fastify: 'Fastify', fastapi: 'FastAPI', django: 'Django', go: 'Go', rust: 'Rust', spring: 'Spring Boot', laravel: 'Laravel' },
      database: { 'sql-managed': 'SQL Managed', 'sql-raw': 'SQL Dedicado', nosql: 'NoSQL', vetorial: 'Vetorial (AI)' },
      infra: { vercel: 'Vercel', railway: 'Railway', supabase: 'Supabase Host', netlify: 'Netlify', cloudflare: 'Cloudflare', digitalocean: 'DigitalOcean', aws: 'AWS', 'docker-vps': 'Docker+VPS' },
      persistencia: { relacional: 'Relacional', documentos: 'Documentos', hibrido: 'Híbrido' },
      auth: { nenhum: 'Sem Auth', basico: 'Email+Senha', oauth: 'OAuth Social', rbac: 'RBAC', enterprise: 'Enterprise SSO' },
      realtime: { nao: 'Não', websocket: 'WebSocket', sse: 'SSE', polling: 'Polling' },
      codestyle: { functional: 'Funcional', oop: 'OOP', misto: 'Misto' },
      erros: { graceful: 'Graceful Degradation', strict: 'Strict', hibrido: 'Híbrido' },
      i18n: { nao: 'Não', poucos: '2-3 idiomas', global: 'Global' },
      seo: { 'seo-full': 'SEO Completo', 'seo-none': 'App Privado', 'seo-partial': 'Parcial' },
    };

    const L = (cat, val) => lbl[cat]?.[val] || val || 'Não definido';
    const date = new Date().toLocaleDateString('pt-BR');
    const isSenior = data.senioridade === 'senior';

    // Cost estimation
    const costBase = { '50': 0, '1000': 30, '10000': 150, '50000': 800 };
    const costInfra = { vercel: 0, railway: 5, supabase: 0, netlify: 0, cloudflare: 5, digitalocean: 12, aws: 50, 'docker-vps': 15 };
    const costAuth = { nenhum: 0, basico: 0, oauth: 0, rbac: 10, enterprise: 50 };
    const estimatedCost = (costBase[data.escala] || 0) + (costInfra[data.infra] || 0) + (costAuth[data.auth] || 0);
    const costRange = `$${estimatedCost} – $${Math.round(estimatedCost * 2.5)}/mês`;

    // Collect skills URLs
    const selectedSkillsURLs = [];
    const techNames = [L('frontend', data.frontend), L('backend', data.backend)];
    techNames.forEach(tn => {
      if (skillsData[tn]) {
        skillsData[tn].forEach(s => selectedSkillsURLs.push(`- ${s.name}: ${s.url}`));
      }
    });

    // ═══ PRD OUTPUT ═══
    prdOutput.value = `# 📋 PRD TÉCNICO — BUILDCODE AI
Gerado em: ${date} | Senioridade: ${L('senioridade', data.senioridade)}
Escala: ${L('escala', data.escala)} | Tipo: ${L('tipo', data.tipo)}

---

## 1. SUMÁRIO EXECUTIVO

**Projeto:** ${data.contexto.substring(0, 200)}${data.contexto.length > 200 ? '...' : ''}

**Classificação:** ${L('tipo', data.tipo)} — ${L('escala', data.escala)}
**Nível do Dev:** ${L('senioridade', data.senioridade)}
**Plataforma de Dev:** ${L('ferramenta', data.ferramenta)}

---

## 2. JUSTIFICATIVA DE STACK

| Camada         | Tecnologia Escolhida          | Justificativa |
|----------------|------------------------------|---------------|
| **Frontend**   | ${L('frontend', data.frontend)} | ${isSenior ? 'Performance e escalabilidade prioritárias.' : 'Facilidade de uso e comunidade ativa.'} |
| **Backend**    | ${L('backend', data.backend)}   | ${isSenior ? 'Controle total sobre lógica e performance.' : 'Produtividade máxima com managed services.'} |
| **Banco**      | ${L('database', data.database)} | ${data.database === 'sql-managed' ? 'Zero overhead de infra.' : 'Controle e flexibilidade de dados.'} |
| **Infra**      | ${L('infra', data.infra)}       | ${data.infra === 'vercel' || data.infra === 'railway' ? 'Deploy rápido e escalável.' : 'Controle total da infraestrutura.'} |
| **Auth**       | ${L('auth', data.auth)}         | ${data.auth === 'rbac' ? 'Controle de acesso granular por papéis.' : 'Simplicidade para o contexto do projeto.'} |
| **Persistência** | ${L('persistencia', data.persistencia)} | Best fit para o modelo de dados do projeto. |

---

## 3. DESENHO DA ARQUITETURA

**Padrão Arquitetural:** ${isSenior ? 'Clean Architecture + SOLID + Domain-Driven Design' : 'MVC Simplificado + Monolito'}
**Comunicação:** ${data.realtime !== 'nao' ? 'REST API + ' + L('realtime', data.realtime) : 'REST API (HTTP)'}
**Autenticação:** ${L('auth', data.auth)} ${data.seguranca.includes('mfa') ? '+ MFA' : ''}
**Estilo de Código:** ${L('codestyle', data.codestyle)}
**Tratamento de Erros:** ${L('erros', data.erros)}
**i18n:** ${L('i18n', data.i18n)}

### Fluxo de Dados:
\`\`\`
[Cliente] → [${L('frontend', data.frontend)}] → [${L('backend', data.backend)}] → [${L('database', data.database)}]
${data.realtime !== 'nao' ? `         ↕ [${L('realtime', data.realtime)}] (Real-time)` : ''}
${data.persistencia === 'hibrido' ? '         → [Redis Cache Layer]' : ''}
\`\`\`

---

## 4. ROADMAP DE SEGURANÇA

${data.seguranca.length > 0 ? data.seguranca.map(s => {
  const segLabels = { https: 'HTTPS/TLS Forçado', sanitizacao: 'Sanitização de Dados', 'rate-limit': 'Rate Limiting', mfa: 'MFA', csrf: 'CSRF Protection', helmet: 'Security Headers' };
  return `- ✅ **${segLabels[s] || s}**`;
}).join('\n') : '- ⚠️ Nenhuma camada de segurança selecionada. Recomendamos ao mínimo HTTPS + Sanitização.'}

${isSenior ? `
### Recomendações Adicionais (Sênior):
- Implementar OWASP Top 10 compliance
- Secrets management (Vault ou variáveis de ambiente criptografadas)
- Logs de auditoria para ações críticas
- Pen-testing antes do go-live` : ''}

---

