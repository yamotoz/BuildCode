      const trimmed = line.trim();
      if (!trimmed) { if (inTable) { html += '</table>'; inTable = false; } html += '<br/>'; continue; }
      if (trimmed.startsWith('# ')) { html += '<h1>' + trimmed.slice(2) + '</h1>'; }
      else if (trimmed.startsWith('## ')) { html += '<h2>' + trimmed.slice(3) + '</h2>'; }
      else if (trimmed.startsWith('### ')) { html += '<h3>' + trimmed.slice(4) + '</h3>'; }
      else if (trimmed.startsWith('---')) { html += '<hr/>'; }
      else if (trimmed.startsWith('| ') && trimmed.endsWith('|')) {
        const cells = trimmed.split('|').filter(c => c.trim()).map(c => c.trim());
        if (cells.every(c => /^[-:]+$/.test(c))) continue;
        if (!inTable) { html += '<table>'; inTable = true; }
        const tag = !inTable || html.split('<tr>').length <= 2 ? 'th' : 'td';
        html += '<tr>' + cells.map(c => '<' + tag + '>' + c.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>') + '</' + tag + '>').join('') + '</tr>';
      }
      else if (trimmed.startsWith('- ')) { html += '<p class="list-item">' + trimmed.slice(2).replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>') + '</p>'; }
      else if (trimmed.startsWith('> ')) { html += '<blockquote>' + trimmed.slice(2) + '</blockquote>'; }
      else { html += '<p>' + trimmed.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>') + '</p>'; }
    }
    if (inTable) html += '</table>';

    return '<!DOCTYPE html><html><head><meta charset="utf-8"><title>' + title + ' - BuildCode</title><style>' +
      'body{font-family:"Segoe UI",Helvetica,Arial,sans-serif;max-width:800px;margin:40px auto;padding:0 30px;color:#1a1a2e;line-height:1.7;font-size:14px}' +
      'h1{font-size:28px;color:#0d1b2a;border-bottom:3px solid #2E748B;padding-bottom:12px;margin-top:40px;letter-spacing:-0.5px}' +
      'h2{font-size:20px;color:#1b3a4b;border-bottom:2px solid #e2e8f0;padding-bottom:8px;margin-top:32px}' +
      'h3{font-size:16px;color:#2E748B;margin-top:20px}' +
      'p{margin:6px 0}' +
      '.list-item{padding-left:20px;position:relative}.list-item:before{content:"\\2022";position:absolute;left:6px;color:#2E748B;font-weight:bold}' +
      'table{width:100%;border-collapse:collapse;margin:16px 0;font-size:13px}' +
      'th,td{border:1px solid #d1d5db;padding:10px 14px;text-align:left}' +
      'th{background:#f0f4f8;font-weight:600;color:#1b3a4b}' +
      'tr:nth-child(even) td{background:#f8fafc}' +
      'hr{border:none;border-top:1px solid #e2e8f0;margin:28px 0}' +
      'blockquote{border-left:4px solid #2E748B;padding:10px 16px;margin:12px 0;background:#f0f9ff;color:#334155;font-style:italic;border-radius:0 6px 6px 0}' +
      'strong{color:#0d1b2a}' +
      '.header-bar{background:linear-gradient(135deg,#0d1b2a,#1b3a4b);color:white;padding:30px 40px;margin:-40px -30px 30px;border-radius:0 0 12px 12px}' +
      '.header-bar h1{color:white;border:none;margin:0;font-size:24px;letter-spacing:0.5px}.header-bar p{color:#a8c5d6;margin:4px 0 0;font-size:13px}' +
      '.footer{text-align:center;margin-top:60px;padding:20px;border-top:2px solid #e2e8f0;color:#94a3b8;font-size:11px}' +
      '@media print{body{margin:20px;padding:0 20px}.header-bar{margin:-20px -20px 20px;padding:20px 30px}}' +
      '</style></head><body>' +
      '<div class="header-bar"><h1>BuildCode AI Engine</h1><p>' + title + ' — Gerado em ' + date + '</p></div>' +
      html +
      '<div class="footer">Documento gerado automaticamente pelo BuildCode AI Engine v2.1<br/>buildcode.app — ' + date + '</div>' +
      '</body></html>';
  }

  // PDF auto-download via hidden iframe + print-to-PDF fallback
  downloadPdfBtn?.addEventListener('click', async () => {
    const { text, isPrompt } = getActiveContent();
    const title = isPrompt ? 'Prompt Base' : 'PRD Tecnico';
    const filename = isPrompt ? 'BuildCode_PromptBase.pdf' : 'BuildCode_PRD.pdf';
    const htmlContent = buildStyledHtml(text, title);

    // Tenta html2pdf.js (carregado sob demanda via CDN)
    try {
      if (!window.html2pdf) {
        await new Promise((resolve, reject) => {
          const s = document.createElement('script');
          s.src = 'https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.2/html2pdf.bundle.min.js';
          s.onload = resolve;
          s.onerror = reject;
          document.head.appendChild(s);
        });
      }
      const container = document.createElement('div');
      container.innerHTML = htmlContent;
      // Extrai apenas o conteúdo do body para html2pdf
      const bodyMatch = htmlContent.match(/<body[^>]*>([\s\S]*)<\/body>/i);
      const styleMatch = htmlContent.match(/<style[^>]*>([\s\S]*?)<\/style>/i);
      const wrapper = document.createElement('div');
      if (styleMatch) {
        const styleEl = document.createElement('style');
        styleEl.textContent = styleMatch[1];
        wrapper.appendChild(styleEl);
      }
      const bodyDiv = document.createElement('div');
      bodyDiv.innerHTML = bodyMatch ? bodyMatch[1] : text;
      wrapper.appendChild(bodyDiv);

      await window.html2pdf().set({
        margin: [10, 10, 10, 10],
        filename: filename,
        image: { type: 'jpeg', quality: 0.98 },
        html2canvas: { scale: 2, useCORS: true },
        jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' },
        pagebreak: { mode: ['avoid-all', 'css', 'legacy'] }
      }).from(wrapper).save();
    } catch (err) {
      console.warn('[PDF] html2pdf failed, falling back to print:', err);
      const w = window.open('', '_blank');
      if (!w) return;
      w.document.write(htmlContent);
      w.document.close();
      setTimeout(() => { w.print(); }, 500);
    }
  });

