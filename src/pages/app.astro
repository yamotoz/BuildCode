     document.getElementById('modal-tech-pros').innerHTML = (tech.pros || []).map(p =>
        `<li class="flex gap-2 text-[12px] text-slate-400 items-start"><span class="material-symbols-outlined text-[#5A9DB5]/80 text-[14px] shrink-0 mt-0.5">done</span> <span class="leading-relaxed">${p}</span></li>`
     ).join('');

     document.getElementById('modal-tech-cons').innerHTML = (tech.cons || []).map(c =>
        `<li class="flex gap-2 text-[12px] text-slate-400 items-start"><span class="material-symbols-outlined text-cta/70 text-[14px] shrink-0 mt-0.5">close</span> <span class="leading-relaxed">${c}</span></li>`
     ).join('');
     
     document.getElementById('modal-tech-usecases').textContent = tech.useCases;

     const websiteLink = document.getElementById('modal-tech-website');
     if (tech.website && tech.website !== '#') {
       websiteLink.href = tech.website;
       websiteLink.classList.remove('hidden');
       websiteLink.classList.add('flex');
