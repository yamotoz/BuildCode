  // ═══════════════════════════════════════════
  //  PROMPT BASE CHARACTER LIMIT ENFORCEMENT
  // ═══════════════════════════════════════════
  function enforcePromptLimit() {
    const limit = getPromptLimit();
    const text = promptOutput.value;
    if (text.length > limit) {
      promptOutput.value = text.substring(0, limit);
      const plan = getUserPlan();
      const planLabels = { explorador: 'Explorador (10.000)', consultor: 'Consultor (25.000)', arquiteto: 'Arquiteto (80.000)' };
      const nextPlan = plan === 'explorador' ? 'Consultor' : plan === 'consultor' ? 'Arquiteto' : null;
      const upgradeMsg = nextPlan ? ` Faça upgrade para o plano ${nextPlan} para mais caracteres.` : '';
      console.warn(`[BuildCode] Prompt Base truncado para ${limit} caracteres (Plano ${planLabels[plan]}).${upgradeMsg}`);
    }
    updateCharCount();
  }

