           <a id="modal-tech-website" href="#" target="_blank" rel="noopener noreferrer" class="hidden flex items-center justify-center gap-2 w-full px-5 py-3 rounded-xl bg-primary/10 border border-primary/20 text-primary text-sm font-bold hover:bg-primary hover:text-background-dark transition-all duration-200 group/link">
