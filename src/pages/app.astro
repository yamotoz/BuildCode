  const saveProjectBtn = document.getElementById('save-project-btn');
  const saveProjectFeedback = document.getElementById('save-project-feedback');
  const saveProjectImage = document.getElementById('save-project-image');
  const saveProjectPreview = document.getElementById('save-project-preview');



  saveProjectBtn?.addEventListener('click', async () => {
    const auth = window.__bcAuth;
    if (!auth?.session) {
      showFeedback('Faca login para salvar projetos.', false);
      return;
    }

    const title = document.getElementById('save-project-title')?.value?.trim();
    if (!title) {
      showFeedback('Informe um titulo para o projeto.', false);
      return;
    }

    saveProjectBtn.setAttribute('disabled', 'true');
    saveProjectBtn.innerHTML = '<span class="material-symbols-outlined text-sm animate-spin">progress_activity</span> Salvando...';

    try {
      const sbUrl = window.__bcSupabaseUrl;
      const sbKey = window.__bcSupabaseKey;
      const token = auth.session.access_token;
      const userId = auth.session.user.id;

      // Verificar limite de projetos por plano
      const currentPlan = getUserPlan();
      const PROJECT_LIMITS = { explorador: 3, consultor: 15, arquiteto: 999999 };
      const maxProjects = PROJECT_LIMITS[currentPlan] || 3;

      const countRes = await fetch(sbUrl + '/rest/v1/projects?select=id&user_id=eq.' + userId, {
        headers: { 'apikey': sbKey, 'Authorization': 'Bearer ' + token },
      });
      const existingProjects = await countRes.json();
      if (Array.isArray(existingProjects) && existingProjects.length >= maxProjects) {
        const planNames = { explorador: 'Explorador', consultor: 'Consultor', arquiteto: 'Arquiteto' };
        showFeedback(`Limite de ${maxProjects} projetos atingido (Plano ${planNames[currentPlan] || currentPlan}). Apague um projeto no perfil para salvar outro, ou faça upgrade.`, false);
        saveProjectBtn.removeAttribute('disabled');
        saveProjectBtn.innerHTML = '<span class="material-symbols-outlined text-sm">save</span> Salvar no meu painel';
        return;
      }

      const desc = document.getElementById('save-project-desc')?.value?.trim() || '';

      // Validar char limit do Prompt Base antes de salvar
      var promptLimit = getPromptLimit();
      if (promptOutput.value.length > promptLimit) {
        showFeedback('Prompt Base excede o limite de ' + promptLimit.toLocaleString() + ' caracteres do seu plano. Reduza o conteúdo ou faça upgrade.', false);
        saveProjectBtn.removeAttribute('disabled');
        saveProjectBtn.innerHTML = '<span class="material-symbols-outlined text-sm">save</span> Salvar no meu painel';
        return;
      }

      const headers = { 'apikey': sbKey, 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json', 'Prefer': 'return=minimal' };

      // Upload image if provided (max 5MB, images only)
      let imageUrl = '';
      const file = saveProjectImage?.files?.[0];
      if (file && file.type.startsWith('image/') && file.size <= 5 * 1024 * 1024) {
        const ext = (file.name.split('.').pop() || 'png').toLowerCase().replace(/[^a-z0-9]/g, '');
        const path = userId + '/' + Date.now() + '.' + ext;
        const uploadRes = await fetch(sbUrl + '/storage/v1/object/project-images/' + path, {
          method: 'POST',
          headers: { 'apikey': sbKey, 'Authorization': 'Bearer ' + token, 'Content-Type': file.type },
          body: file,
        });
        if (uploadRes.ok) {
          imageUrl = sbUrl + '/storage/v1/object/public/project-images/' + path;
        }
      }

      // Upload PRD e Prompt Base para Storage (banco fica leve)
      const timestamp = Date.now();
      const prdPath = userId + '/' + timestamp + '_prd.md';
      const promptPath = userId + '/' + timestamp + '_prompt.md';
      const storageHeaders = { 'apikey': sbKey, 'Authorization': 'Bearer ' + token, 'Content-Type': 'text/markdown' };

      const [prdUpload, promptUpload] = await Promise.all([
        fetch(sbUrl + '/storage/v1/object/prd-files/' + prdPath, {
          method: 'POST', headers: storageHeaders, body: prdOutput.value,
        }),
        fetch(sbUrl + '/storage/v1/object/prd-files/' + promptPath, {
          method: 'POST', headers: storageHeaders, body: promptOutput.value,
        }),
      ]);

      const prdStoragePath = prdUpload.ok ? prdPath : null;
      const promptStoragePath = promptUpload.ok ? promptPath : null;

      // Insert project via server-side API (valida plano, limites e char limit)
      const insertRes = await fetch('/api/save-project', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
        body: JSON.stringify({
          name: title,
          business_context: desc,
          scale: getFormValue('escala'),
          nature: getFormValue('tipo'),
          generated_prd: prdStoragePath ? '' : prdOutput.value,
          generated_prompt: promptStoragePath ? '' : promptOutput.value,
          prd_storage_path: prdStoragePath,
          prompt_storage_path: promptStoragePath,
          agent_used: localStorage.getItem('bc-agent') || 'theboss',
          llm_model: getFormValue('llm-model'),
          image_url: imageUrl,
        }),
      });

      if (!insertRes.ok) {
        const errBody = await insertRes.json().catch(() => ({}));
        console.error('[SaveProject] API error:', errBody);
        throw new Error(errBody.error || 'Erro ao salvar');
      }

      showFeedback('Projeto salvo com sucesso!', true);
      document.getElementById('save-project-title').value = '';
      document.getElementById('save-project-desc').value = '';
    } catch (err) {
      console.error('[SaveProject]', err);
      showFeedback('Erro ao salvar projeto. Tente novamente.', false);
    }

    saveProjectBtn.removeAttribute('disabled');
    saveProjectBtn.innerHTML = '<span class="material-symbols-outlined text-sm">save</span> Salvar no meu painel';
