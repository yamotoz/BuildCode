    anastasia: '/agentes/vids_agents/anastasia.mp4',
  };
  var wantVideo = localStorage.getItem('bc-agent-video') === 'true';
  var toggleVideo = document.getElementById('chat-toggle-video');
  var headerVideo = document.getElementById('chat-header-video');
  if (wantVideo && agentVideos[selectedAgent]) {
    var vidSrc = agentVideos[selectedAgent];
    if (toggleVideo) {
      toggleVideo.src = vidSrc;
      toggleVideo.classList.remove('hidden');
      if (chatToggleAvatar) chatToggleAvatar.classList.add('hidden');
      toggleVideo.style.objectPosition = 'center 20%';
    }
    if (headerVideo) {
      headerVideo.src = vidSrc;
      headerVideo.classList.remove('hidden');
      if (chatAgentAvatar) chatAgentAvatar.classList.add('hidden');
    }
  }

  // Initial greeting message
  if (chatMessages) {
    const greetDiv = document.createElement('div');
    greetDiv.className = 'flex gap-2';
    greetDiv.innerHTML = `
      <img src="${agent.icon}" alt="${agent.name}" class="size-6 rounded-full object-cover border border-white/20 shrink-0" />
      <div class="bg-surface-dark/80 rounded-xl rounded-tl-sm px-3 py-2 text-slate-300 text-xs leading-relaxed max-w-[85%]">${agent.greeting.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</div>`;
    chatMessages.appendChild(greetDiv);
  }

  // Build context string from wizard selections
  function getWizardContext() {
    const selections = [];
    const fields = [
      { name: 'senioridade', label: 'Senioridade' },
      { name: 'escala', label: 'Escala' },
      { name: 'tipo', label: 'Tipo de Projeto' },
      { name: 'ferramenta', label: 'IDE' },
      { name: 'frontend', label: 'Frontend' },
      { name: 'backend', label: 'Backend' },
      { name: 'database', label: 'Banco de Dados' },
      { name: 'infra', label: 'Infra' },
      { name: 'auth', label: 'Auth' },
    ];
    fields.forEach(f => {
      const val = getFormValue(f.name);
      if (val) selections.push(`${f.label}: ${val}`);
    });
    const ctx = getTextValue('contexto');
    if (ctx) selections.unshift(`Projeto: ${ctx.substring(0, 150)}`);
    return selections.length > 0 ? selections.join(' | ') : '';
  }

  // Formatted context for pre-generation message (human-readable, no pipes)
  function getWizardContextFormatted() {
    const ctx = getTextValue('contexto');
    const fields = [
      { name: 'senioridade', label: 'Senioridade' },
      { name: 'escala', label: 'Escala' },
      { name: 'tipo', label: 'Tipo' },
      { name: 'ferramenta', label: 'IDE' },
      { name: 'frontend', label: 'Frontend' },
      { name: 'backend', label: 'Backend' },
      { name: 'database', label: 'Banco de Dados' },
      { name: 'infra', label: 'Infra' },
      { name: 'auth', label: 'Auth' },
    ];
    let lines = [];
    if (ctx) lines.push('Projeto: ' + ctx.substring(0, 200));
    lines.push('');
    fields.forEach(f => {
      const val = getFormValue(f.name);
      if (val) lines.push('  ' + f.label + ': ' + val);
    });
    return lines.join('\n');
  }

  // Strip markdown formatting for clean chat display
  function cleanMarkdown(text) {
    return text
      .replace(/\*\*(.*?)\*\*/g, '$1')
      .replace(/\*(.*?)\*/g, '$1')
      .replace(/#{1,6}\s/g, '')
      .replace(/`([^`]+)`/g, '$1')
      .replace(/```[\s\S]*?```/g, (match) => match.replace(/```\w*\n?/g, '').trim());
  }

  function openChat() {
    chatPanel.classList.remove('hidden');
    chatPanel.classList.add('flex');
    chatInput?.focus();
  }
  function closeChat() {
    chatPanel.classList.add('hidden');
    chatPanel.classList.remove('flex');
  }

  chatToggle?.addEventListener('click', () => {
    // Block guests from opening chat
    const auth = window.__bcAuth;
    if (auth && auth.ready && !auth.session) {
      if (typeof window.__bcShowAuthGate === 'function') {
        window.__bcShowAuthGate();
      }
      return;
    }
    const isOpen = !chatPanel.classList.contains('hidden');
    if (isOpen) closeChat();
    else openChat();
  });

  chatClose?.addEventListener('click', closeChat);

  function appendChatMsg(role, text, opts) {
    const wrapper = document.createElement('div');
    wrapper.className = 'flex gap-2' + (role === 'user' ? ' justify-end' : '');

    // Escape HTML to prevent XSS
    const safe = text.replace(/</g, '&lt;').replace(/>/g, '&gt;');

    if (role === 'user') {
      wrapper.innerHTML = `<div class="bg-primary/20 rounded-xl rounded-tr-sm px-3 py-2 text-white text-xs leading-relaxed max-w-[85%]">${safe}</div>`;
    } else {
      wrapper.innerHTML = `
        <img src="${agent.icon}" alt="${agent.name}" class="size-6 rounded-full object-cover border border-white/20 shrink-0" />
        <div class="bg-surface-dark/80 rounded-xl rounded-tl-sm px-3 py-2 text-slate-300 text-xs leading-relaxed max-w-[85%]">${safe}</div>`;
    }
    chatMessages.appendChild(wrapper);
    chatMessages.scrollTop = chatMessages.scrollHeight;

    // TTS audio for long assistant responses (> 780 chars)
    if (role === 'assistant' && text.length > 780 && !(opts && opts.skipAudio)) {
      generateTTSAudio(text, wrapper);
    }
  }

  async function generateTTSAudio(text, parentWrapper) {
    // Create audio placeholder
    const audioWrapper = document.createElement('div');
    audioWrapper.className = 'flex gap-2 ml-8';
    audioWrapper.innerHTML = `
      <div class="bg-surface-dark/60 rounded-xl px-3 py-2 flex items-center gap-2 text-slate-500 text-[10px]">
        <span class="material-symbols-outlined text-xs animate-pulse">graphic_eq</span>
        Gerando audio...
      </div>`;
    chatMessages.appendChild(audioWrapper);
    chatMessages.scrollTop = chatMessages.scrollHeight;

    try {
      const ttsHeaders = { 'Content-Type': 'application/json' };
      var ttsAuth = window.__bcAuth;
      if (ttsAuth && ttsAuth.session && ttsAuth.session.access_token) {
        ttsHeaders['Authorization'] = 'Bearer ' + ttsAuth.session.access_token;
      }
      const res = await fetch('/api/tts', {
        method: 'POST',
        headers: ttsHeaders,
        body: JSON.stringify({ text: text.substring(0, 300), agentId: selectedAgent }),
      });

      if (!res.ok) {
        audioWrapper.remove();
        return;
      }

      const audioBlob = await res.blob();
      const audioUrl = URL.createObjectURL(audioBlob);

      audioWrapper.innerHTML = `
        <div class="bg-surface-dark/60 rounded-xl px-3 py-2 flex items-center gap-2">
          <button type="button" class="tts-play-btn flex items-center gap-2 text-primary hover:text-primary-light transition-colors text-[10px] font-bold">
            <span class="material-symbols-outlined text-sm">play_circle</span>
            Ouvir resumo
          </button>
          <audio src="${audioUrl}" class="hidden"></audio>
        </div>`;

      const playBtn = audioWrapper.querySelector('.tts-play-btn');
      const audioEl = audioWrapper.querySelector('audio');
      let isPlaying = false;

      playBtn.addEventListener('click', () => {
        if (isPlaying) {
          audioEl.pause();
          audioEl.currentTime = 0;
          playBtn.querySelector('.material-symbols-outlined').textContent = 'play_circle';
          isPlaying = false;
        } else {
          audioEl.play();
          playBtn.querySelector('.material-symbols-outlined').textContent = 'stop_circle';
          isPlaying = true;
        }
      });

      audioEl.addEventListener('ended', () => {
        playBtn.querySelector('.material-symbols-outlined').textContent = 'play_circle';
        isPlaying = false;
      });

      chatMessages.scrollTop = chatMessages.scrollHeight;
    } catch {
      audioWrapper.remove();
    }
  }

  async function sendChatMessage(overrideMsg) {
    // Block guests from sending messages
    const auth = window.__bcAuth;
    if (auth && auth.ready && !auth.session) {
      if (typeof window.__bcShowAuthGate === 'function') window.__bcShowAuthGate();
      return;
    }

    const msg = overrideMsg || chatInput.value.trim();
    if (!msg) return;

    if (!overrideMsg) chatInput.value = '';
    appendChatMsg('user', msg);

    // Always inject wizard context in every message
    const contextStr = getWizardContext();
    const fullMsg = contextStr ? `[Contexto do wizard: ${contextStr}] ${msg}` : msg;
    chatHistory.push({ role: 'user', content: fullMsg });

    // Show typing indicator
    const typing = document.createElement('div');
    typing.className = 'flex gap-2 chat-typing';
    typing.innerHTML = `<img src="${agent.icon}" alt="${agent.name}" class="size-6 rounded-full object-cover border border-white/20 shrink-0 animate-pulse" /><div class="bg-surface-dark/80 rounded-xl rounded-tl-sm px-3 py-2 text-slate-500 text-xs">Digitando...</div>`;
    chatMessages.appendChild(typing);
    chatMessages.scrollTop = chatMessages.scrollHeight;

    try {
      const chatHeaders = { 'Content-Type': 'application/json' };
      const chatAuth = window.__bcAuth;
      if (chatAuth?.session?.access_token) {
        chatHeaders['Authorization'] = 'Bearer ' + chatAuth.session.access_token;
      }
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: chatHeaders,
        body: JSON.stringify({ messages: chatHistory, agentId: selectedAgent }),
      });
      const data = await res.json();
      typing.remove();

      const rawReply = data.reply || data.error || 'Erro ao obter resposta.';
      const reply = cleanMarkdown(rawReply);
      chatHistory.push({ role: 'assistant', content: rawReply });
      appendChatMsg('assistant', reply);
      // Log de chat feito pelo /api/chat (server-side)

      // Detect if assistant wants to proceed with generation
      const proceedPhrases = ['iniciar a geracao', 'iniciar a geração', 'gerar seu PRD', 'gerar o PRD', 'Vou fechar o chat', 'vou fechar o chat'];
      const shouldProceed = preGenAsked && proceedPhrases.some(p => rawReply.toLowerCase().includes(p.toLowerCase()));
      if (shouldProceed) {
        setTimeout(() => {
          closeChat();
          showStep(26);
          triggerGeneration();
        }, 2000);
      }
    } catch (err) {
      typing.remove();
      appendChatMsg('assistant', 'Erro de conexao. Tente novamente.');
    }
  }

  chatSend?.addEventListener('click', () => sendChatMessage());
  chatInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendChatMessage();
    }
  });

  // Init
  computeVisibleSteps();
  showStep(1);
  updateInsights();
});

// Pass DB from server to client
window.techDB = techDB;
</script>

<!-- App Auth: User pill + Profile dropdown -->
<script>
import { supabase, getProfile, signOut, getUserSubscription } from '../lib/supabase';
import type { Session } from '@supabase/supabase-js';

// Global auth state accessible by wizard script
(window as any).__bcAuth = { session: null, profile: null, subscription: null, ready: false };
(window as any).__bcSupabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
(window as any).__bcSupabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

async function applyAuthUI(session: Session | null) {
  const loginBtn = document.getElementById('app-login-btn');
  const userBtn = document.getElementById('app-user-btn');
  const userName = document.getElementById('app-user-name');
  const avatarImg = document.getElementById('app-avatar-img') as HTMLImageElement | null;
  const avatarInitials = document.getElementById('app-avatar-initials');
  const ddName = document.getElementById('app-dd-name');
  const ddEmail = document.getElementById('app-dd-email');
  const ddAvatarImg = document.getElementById('app-dd-avatar-img') as HTMLImageElement | null;
  const ddAvatarInitials = document.getElementById('app-dd-avatar-initials');
  const ddRoleBadge = document.getElementById('app-dd-role-badge');

  if (!loginBtn || !userBtn) {
    console.warn('[BuildCode] Auth elements not found');
    return;
  }

  if (session) {
    // Authenticated — show user pill, hide login
    loginBtn.style.display = 'none';
    userBtn.style.display = 'flex';

    let profile = null;
    let subscription = null;
    try { profile = await getProfile(session.user.id); } catch (_) {}
    try { subscription = await getUserSubscription(session.user.id); } catch (_) {}

    // Redirect to login if terms not accepted
    if (profile && !profile.terms_accepted_at) {
      window.location.href = '/login';
      return;
    }

    // Store auth state globally
    (window as any).__bcAuth = { session, profile, subscription, ready: true };

    // Apply LLM tier restrictions for Explorador plan
    const currentPlan = subscription?.plan || 'explorador';
    if (currentPlan === 'explorador') {
      document.querySelectorAll('input[name="llm-model"]').forEach(input => {
        const label = input.closest('label') as HTMLElement;
        if (!label) return;
        const tierBadge = label.querySelector('[class*="tracking-wider"]') as HTMLElement;
        const tierText = tierBadge?.textContent?.trim().toLowerCase() || '';
        const modelValue = (input as HTMLInputElement).value;
        const isBudget = modelValue.includes(':free');

        if (!isBudget) {
          (input as HTMLInputElement).disabled = true;
          label.style.cursor = 'not-allowed';
          label.style.opacity = '0.4';
          const panel = label.querySelector('.glass-panel') as HTMLElement;
          if (panel) {
            const lock = document.createElement('div');
            lock.className = 'absolute inset-0 bg-black/50 backdrop-blur-[2px] flex flex-col items-center justify-center z-20 rounded-2xl';
            lock.innerHTML = '<span class="material-symbols-outlined text-3xl text-slate-400 mb-1">lock</span><span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">Consultor+</span>';
            panel.style.position = 'relative';
            panel.appendChild(lock);
          }
        }
      });
    }

    // Force agent to theboss for Explorador plan
    if (currentPlan === 'explorador') {
      const savedAgent = localStorage.getItem('bc-agent');
      if (savedAgent && savedAgent !== 'theboss') {
        localStorage.setItem('bc-agent', 'theboss');
      }
    }

    // Unlock chat widget for authenticated users
    const chatLock = document.getElementById('chat-lock-overlay');
    if (chatLock) chatLock.remove();
    // Restore chat panel state (may have been hidden by a previous guest-state event)
    const chatPanelEl = document.getElementById('chat-panel');
    if (chatPanelEl && chatPanelEl.classList.contains('hidden')) {
      // Ensure flex-col is preserved for next open
      if (!chatPanelEl.classList.contains('flex-col')) chatPanelEl.classList.add('flex-col');
    }

    const displayName = profile?.full_name || session.user.email?.split('@')[0] || 'Usuário';
    const initials = displayName.split(' ').map((w: string) => w[0]).join('').toUpperCase().slice(0, 2);

    if (userName) userName.textContent = displayName;

    if (profile?.avatar_url && avatarImg) {
      avatarImg.src = profile.avatar_url;
      avatarImg.classList.remove('hidden');
      if (avatarInitials) avatarInitials.classList.add('hidden');
    } else if (avatarInitials) {
      avatarInitials.textContent = initials;
      avatarInitials.classList.remove('hidden');
      if (avatarImg) avatarImg.classList.add('hidden');
    }

    if (ddName) ddName.textContent = displayName;
    if (ddEmail) ddEmail.textContent = session.user.email || '';

    if (profile?.avatar_url && ddAvatarImg) {
      ddAvatarImg.src = profile.avatar_url;
      ddAvatarImg.classList.remove('hidden');
      if (ddAvatarInitials) ddAvatarInitials.classList.add('hidden');
    } else if (ddAvatarInitials) {
      ddAvatarInitials.textContent = initials;
      ddAvatarInitials.classList.remove('hidden');
      if (ddAvatarImg) ddAvatarImg.classList.add('hidden');
    }

    if (ddRoleBadge && profile?.role) {
      const roleConfig: Record<string, { label: string; classes: string }> = {
        master: { label: 'Master', classes: 'bg-purple-500/15 text-purple-400 border-purple-500/20' },
        admin: { label: 'Admin', classes: 'bg-amber-500/15 text-amber-400 border-amber-500/20' },
        user: { label: 'Usuário', classes: 'bg-slate-500/15 text-slate-400 border-slate-500/20' },
      };
      const rc = roleConfig[profile.role] || roleConfig.user;
      ddRoleBadge.textContent = rc.label;
      ddRoleBadge.className = `px-2 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wider border ${rc.classes}`;
    }

    if (profile?.theme === 'light') {
      document.documentElement.classList.remove('dark');
      document.documentElement.classList.add('light');
      localStorage.setItem('bc-theme', 'light');
    }
  } else {
    // Not authenticated — show login, hide user pill
    loginBtn.style.display = 'flex';
    userBtn.style.display = 'none';

    // Store guest auth state
    (window as any).__bcAuth = { session: null, profile: null, subscription: null, ready: true };

    // Lock chat widget for guests
    const chatWidget = document.getElementById('chat-widget');
    if (chatWidget && !document.getElementById('chat-lock-overlay')) {
      // Hide the real chat panel
      const chatPanel = document.getElementById('chat-panel');
      if (chatPanel) { chatPanel.classList.add('hidden'); chatPanel.classList.remove('flex'); }

      // Add lock overlay on toggle button
      const toggle = document.getElementById('chat-toggle');
      if (toggle) {
        toggle.style.position = 'relative';
        const lockOverlay = document.createElement('div');
        lockOverlay.id = 'chat-lock-overlay';
        lockOverlay.className = 'absolute inset-0 rounded-full bg-black/70 backdrop-blur-sm flex items-center justify-center z-10 cursor-pointer';
        lockOverlay.innerHTML = '<span class="material-symbols-outlined text-slate-400 text-xl">lock</span>';
        // Intercept clicks on the overlay itself (not the toggle button)
        lockOverlay.addEventListener('click', (e) => {
          e.stopPropagation();
          showAuthGate();
        });
        toggle.appendChild(lockOverlay);
      }
    }
  }
}

// Auth gate modal
function showAuthGate() {
  const existing = document.getElementById('auth-gate-modal');
  if (existing) { existing.classList.remove('hidden'); return; }

  const modal = document.createElement('div');
  modal.id = 'auth-gate-modal';
  modal.className = 'fixed inset-0 z-[99999] flex items-center justify-center px-4';
  modal.innerHTML = `
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" id="auth-gate-backdrop"></div>
    <div class="relative bg-surface-dark rounded-2xl border border-primary/20 p-8 max-w-sm w-full text-center shadow-[0_8px_40px_rgba(0,0,0,0.6)]">
      <div class="w-16 h-16 rounded-full bg-primary/10 border border-primary/20 flex items-center justify-center mx-auto mb-5">
        <span class="material-symbols-outlined text-3xl text-primary">lock</span>
      </div>
      <h3 class="text-xl font-bold text-white mb-2">Crie sua conta gratuita</h3>
      <p class="text-slate-400 text-sm mb-6 leading-relaxed">Para acessar o questionario, os agentes de IA e gerar seu PRD, voce precisa estar logado.</p>
      <div class="flex flex-col gap-3">
        <a href="/login" class="w-full py-3 rounded-xl bg-primary text-white font-semibold text-sm hover:bg-primary-dark transition-colors flex items-center justify-center gap-2">
          <span class="material-symbols-outlined text-lg">login</span>
          Entrar ou Criar Conta
        </a>
        <button type="button" id="auth-gate-close" class="w-full py-3 rounded-xl border border-border-color text-slate-400 font-medium text-sm hover:text-white hover:border-slate-500 transition-colors cursor-pointer">
          Voltar
        </button>
      </div>
    </div>`;
  document.body.appendChild(modal);

  document.getElementById('auth-gate-backdrop')?.addEventListener('click', () => modal.classList.add('hidden'));
  document.getElementById('auth-gate-close')?.addEventListener('click', () => modal.classList.add('hidden'));
}

// Expose globally so wizard script can use it
(window as any).__bcShowAuthGate = showAuthGate;

// Use onAuthStateChange as the PRIMARY auth mechanism.
// It fires INITIAL_SESSION on subscribe (after client reads localStorage),
// which is more reliable than calling getSession() immediately.
supabase.auth.onAuthStateChange((_event, session) => {
  applyAuthUI(session);
});

// Dropdown toggle
const userBtn = document.getElementById('app-user-btn');
const dropdown = document.getElementById('app-profile-dropdown');

userBtn?.addEventListener('click', (e) => {
  e.stopPropagation();
  dropdown?.classList.toggle('hidden');
});

document.addEventListener('click', (e) => {
  if (dropdown && !dropdown.classList.contains('hidden')) {
    const target = e.target as HTMLElement;
    if (!dropdown.contains(target) && target !== userBtn) {
      dropdown.classList.add('hidden');
    }
  }
});

// Logout
document.getElementById('app-logout-btn')?.addEventListener('click', async () => {
  await signOut();
  window.location.href = '/';
});
</script>

<script>
  // ═══ Canvas 2D Particle System (sem dependências externas) ═══
  (function() {
    const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    function resize() {
      canvas.width = window.innerWidth * dpr;
      canvas.height = window.innerHeight * dpr;
      ctx.scale(dpr, dpr);
    }
    resize();
    window.addEventListener('resize', resize);

    const COLORS = [
      'rgba(46,116,139,',  // primary — 70%
      'rgba(90,157,181,',  // secondary — 20%
      'rgba(242,171,109,', // accent — 10%
    ];

    const COUNT = 120;
    const particles: { x: number; y: number; vx: number; vy: number; size: number; color: string; opacity: number; phase: number }[] = [];
    const W = () => window.innerWidth;
    const H = () => window.innerHeight;

    for (let i = 0; i < COUNT; i++) {
      const r = Math.random();
      const colorBase = r < 0.7 ? COLORS[0] : r < 0.9 ? COLORS[1] : COLORS[2];
      particles.push({
        x: Math.random() * W(),
        y: Math.random() * H(),
        vx: (Math.random() - 0.5) * 0.3,
        vy: (Math.random() - 0.5) * 0.3,
        size: Math.random() * 2.5 + 1,
        color: colorBase,
        opacity: Math.random() * 0.5 + 0.2,
        phase: Math.random() * Math.PI * 2,
      });
    }

    // Connection lines between nearby particles
    const LINE_DIST = 150;
    const LINE_DIST_SQ = LINE_DIST * LINE_DIST;

    let animId: number;
    let time = 0;

    function draw() {
      animId = requestAnimationFrame(draw);
      time += 0.005;
      const w = W();
      const h = H();
      ctx.clearRect(0, 0, w, h);

      // Update and draw particles
      for (let i = 0; i < COUNT; i++) {
        const p = particles[i];
        p.x += p.vx;
        p.y += p.vy + Math.sin(time + p.phase) * 0.15;

        // Wrap around edges
        if (p.x < -10) p.x = w + 10;
        if (p.x > w + 10) p.x = -10;
        if (p.y < -10) p.y = h + 10;
        if (p.y > h + 10) p.y = -10;

        // Pulsing opacity
        const alpha = p.opacity + Math.sin(time * 2 + p.phase) * 0.1;

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = p.color + alpha.toFixed(2) + ')';
        ctx.fill();
      }

      // Draw connection lines
      ctx.lineWidth = 0.5;
      for (let i = 0; i < COUNT; i++) {
        for (let j = i + 1; j < COUNT; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const distSq = dx * dx + dy * dy;
          if (distSq < LINE_DIST_SQ) {
            const alpha = (1 - distSq / LINE_DIST_SQ) * 0.15;
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.strokeStyle = 'rgba(46,116,139,' + alpha.toFixed(3) + ')';
            ctx.stroke();
          }
        }
      }
    }
    draw();

    // Expose dive animation
    (window as any).__bcDive = function() {
      // Speed burst + scatter effect
      for (let i = 0; i < COUNT; i++) {
        particles[i].vx += (Math.random() - 0.5) * 3;
        particles[i].vy += (Math.random() - 0.5) * 3;
      }
      // Gradually slow down
      setTimeout(() => {
        for (let i = 0; i < COUNT; i++) {
          particles[i].vx = (Math.random() - 0.5) * 0.3;
          particles[i].vy = (Math.random() - 0.5) * 0.3;
        }
      }, 1500);
    };
  })();
</script>

<script>
  // Logo swap for light/dark theme
  function updatePageLogo() {
    document.querySelectorAll('img[data-dark][data-light]').forEach(el => {
      const isLight = document.documentElement.classList.contains('light');
      el.setAttribute('src', isLight ? (el.getAttribute('data-light') || '') : (el.getAttribute('data-dark') || ''));
    });
  }
  updatePageLogo();
  new MutationObserver(updatePageLogo).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
</script>
