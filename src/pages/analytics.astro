---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AnalyticsDashboard from '../components/analytics/AnalyticsDashboard';

export const prerender = false;
---

<Layout
  title="Analytics - Comparacao de Tecnologias | BuildCode"
  description="Compare tecnologias lado a lado com dados do GitHub em tempo real. Stars, forks, issues, commits e linguagens. Graficos interativos e insights por IA."
  canonicalPath="/analytics"
>
  <Header />
  <main class="min-h-screen">
    <AnalyticsDashboard client:load />
  </main>
  <Footer />
</Layout>
