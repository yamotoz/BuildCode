  async function loadProjects() {
    try {
      const projects = await getUserProjects(currentUserId);
      const listEl = document.getElementById('projects-list');
      const countBadge = document.getElementById('projects-count-badge');
      if (!listEl) return;

      if (countBadge) {
        countBadge.textContent = String(projects.length);
        if (projects.length > 0) countBadge.classList.remove('hidden');
      }

      if (projects.length === 0) {
        listEl.innerHTML = `
          <div class="flex flex-col items-center justify-center py-8 text-center">
            <span class="material-symbols-outlined text-3xl text-slate-700 mb-2">folder_off</span>
            <p class="text-sm text-slate-500">Nenhum projeto salvo ainda</p>
            <p class="text-[10px] text-slate-600 mt-1">Crie um projeto no Arquiteto de Software e salve aqui</p>
          </div>`;
        return;
      }

      const scaleLabels: Record<string, string> = { '50': 'Pessoal', '1000': 'Startup', '10000': 'Scale-up', '50000': 'Enterprise' };
      const natureLabels: Record<string, string> = { hobby: 'Hobby', saas: 'SaaS', enterprise: 'Enterprise' };

      listEl.innerHTML = projects.map((p: Project) => {
        const date = new Date(p.created_at).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
        const hasImage = p.image_url && p.image_url.length > 0;
        const prdPreview = (p.generated_prd || '').substring(0, 120).replace(/[#*\n]/g, ' ').trim();
        return `
          <div class="group rounded-xl p-4 transition-all hover:border-primary/20" style="background: rgba(255,255,255,0.02); border: 1px solid #2A3135;" data-project-id="${esc(p.id)}">
            <div class="flex gap-3">
              ${hasImage ? `<img src="${esc(p.image_url)}" alt="${esc(p.name)}" class="size-14 rounded-lg object-cover shrink-0 border border-white/5" />` : `<div class="size-14 rounded-lg bg-primary/5 border border-primary/10 flex items-center justify-center shrink-0"><span class="material-symbols-outlined text-primary text-xl">code</span></div>`}
              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-2">
                  <h4 class="text-sm font-bold text-white truncate">${esc(p.name)}</h4>
                  <div class="flex items-center gap-1 shrink-0">
                    <button type="button" class="project-view-btn p-1 rounded-md text-slate-600 hover:text-primary hover:bg-primary/10 transition-all" title="Ver PRD" data-prd="${encodeURIComponent(p.generated_prd || '')}" data-prompt="${encodeURIComponent(p.generated_prompt || '')}" data-prd-path="${esc(p.prd_storage_path || '')}" data-prompt-path="${esc(p.prompt_storage_path || '')}" data-name="${esc(p.name)}">
                      <span class="material-symbols-outlined text-[16px]">visibility</span>
                    </button>
                    <button type="button" class="project-delete-btn p-1 rounded-md text-slate-600 hover:text-red-400 hover:bg-red-500/10 transition-all" title="Excluir" data-id="${esc(p.id)}">
                      <span class="material-symbols-outlined text-[16px]">delete</span>
                    </button>
                  </div>
                </div>
                <p class="text-[10px] text-slate-500 mt-0.5">${date} · ${esc(scaleLabels[p.scale] || p.scale || '-')} · ${esc(natureLabels[p.nature] || p.nature || '-')}</p>
                ${p.business_context ? `<p class="text-[11px] text-slate-600 mt-1 line-clamp-1">${esc(p.business_context)}</p>` : ''}
                ${prdPreview ? `<p class="text-[10px] text-slate-700 mt-1 line-clamp-1 font-mono">${esc(prdPreview)}...</p>` : ''}
              </div>
            </div>
          </div>`;
      }).join('');

      // Visualizar projeto (modal/expandir) — carrega do Storage se disponível
      listEl.querySelectorAll('.project-view-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const prdPath = btn.getAttribute('data-prd-path') || '';
          const promptPath = btn.getAttribute('data-prompt-path') || '';
          const name = btn.getAttribute('data-name') || 'Projeto';

          let prd = decodeURIComponent(btn.getAttribute('data-prd') || '');
          let prompt = decodeURIComponent(btn.getAttribute('data-prompt') || '');

          // Busca do Storage se os paths existirem e o texto inline estiver vazio
          if (prdPath && !prd) {
            try {
              const { data: { session: s } } = await supabase.auth.getSession();
              if (s) {
                const sbUrl = import.meta.env.PUBLIC_SUPABASE_URL;
                const headers = { 'apikey': import.meta.env.PUBLIC_SUPABASE_ANON_KEY, 'Authorization': 'Bearer ' + s.access_token };
                const [prdRes, promptRes] = await Promise.all([
                  prdPath ? fetch(sbUrl + '/storage/v1/object/prd-files/' + prdPath, { headers }) : null,
                  promptPath ? fetch(sbUrl + '/storage/v1/object/prd-files/' + promptPath, { headers }) : null,
                ]);
                if (prdRes?.ok) prd = await prdRes.text();
                if (promptRes?.ok) prompt = await promptRes.text();
              }
            } catch (e) { console.error('[Storage] Erro ao carregar PRD:', e); }
          }

          const htmlContent = buildProjectViewHtml(name, prd, prompt);
          const w = window.open('', '_blank');
          if (w) { w.document.write(htmlContent); w.document.close(); }
        });
      });

      // Excluir projeto
      listEl.querySelectorAll('.project-delete-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = btn.getAttribute('data-id');
          if (!id || !await bcConfirm('Excluir Projeto', 'Deseja excluir este projeto? Esta ação não pode ser desfeita.')) return;
          await deleteProject(id);
          const card = btn.closest('[data-project-id]');
          if (card) card.remove();
          // Atualiza contador
          const remaining = listEl.querySelectorAll('[data-project-id]').length;
          if (countBadge) countBadge.textContent = String(remaining);
          if (remaining === 0) {
            if (countBadge) countBadge.classList.add('hidden');
            listEl.innerHTML = `
              <div class="flex flex-col items-center justify-center py-8 text-center">
                <span class="material-symbols-outlined text-3xl text-slate-700 mb-2">folder_off</span>
                <p class="text-sm text-slate-500">Nenhum projeto salvo ainda</p>
                <p class="text-[10px] text-slate-600 mt-1">Crie um projeto no Arquiteto de Software e salve aqui</p>
              </div>`;
          }
        });
      });
    } catch (err) {
      console.error('[Projects]', err);
    }
  }

  function buildProjectViewHtml(name: string, prd: string, prompt: string) {
    const date = new Date().toLocaleDateString('pt-BR');
    const safeName = esc(name);
    return `<!DOCTYPE html><html><head><meta charset="utf-8"><title>${safeName} - BuildCode</title>
    <style>
      body{font-family:"Segoe UI",Helvetica,sans-serif;max-width:900px;margin:40px auto;padding:0 30px;color:#e2e8f0;background:#0a0a0a;line-height:1.7;font-size:14px}
      .header{background:linear-gradient(135deg,#0d1b2a,#1b3a4b);padding:30px 40px;margin:-40px -30px 30px;border-radius:0 0 12px 12px}
      .header h1{color:#fff;font-size:24px;margin:0;letter-spacing:0.5px}.header p{color:#a8c5d6;margin:4px 0 0;font-size:13px}
      h1{font-size:24px;color:#fff;border-bottom:2px solid #2E748B;padding-bottom:12px;margin-top:40px}
      h2{font-size:18px;color:#94a3b8;border-bottom:1px solid #1e293b;padding-bottom:8px;margin-top:28px}
      h3{font-size:15px;color:#2E748B;margin-top:16px}
      pre{background:#111;border:1px solid #1e293b;border-radius:8px;padding:16px;overflow-x:auto;font-size:13px;color:#a8c5d6}
      .tabs{display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid #1e293b;padding-bottom:0}
      .tab{padding:10px 20px;cursor:pointer;color:#64748b;font-weight:600;font-size:13px;border-bottom:2px solid transparent;transition:all 0.2s}
      .tab.active{color:#2E748B;border-bottom-color:#2E748B}
      .tab:hover{color:#94a3b8}
      .content{display:none;white-space:pre-wrap;font-family:monospace;font-size:13px;line-height:1.8;color:#cbd5e1}
      .content.active{display:block}
      .footer{text-align:center;margin-top:60px;padding:20px;border-top:1px solid #1e293b;color:#475569;font-size:11px}
    </style></head><body>
    <div class="header"><h1>${safeName}</h1><p>BuildCode AI Engine — Gerado em ${date}</p></div>
    <div class="tabs">
      <div class="tab active" onclick="switchTab(0)">PRD</div>
      <div class="tab" onclick="switchTab(1)">Prompt Base</div>
    </div>
    <div class="content active" id="tab-0">${prd.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</div>
    <div class="content" id="tab-1">${prompt.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</div>
    <div class="footer">BuildCode AI Engine v2.1 — buildcode.app</div>
    <script>function switchTab(i){document.querySelectorAll('.content').forEach((e,j)=>{e.classList.toggle('active',j===i)});document.querySelectorAll('.tab').forEach((e,j)=>{e.classList.toggle('active',j===i)})}<\/script>
    </body></html>`;
  }

