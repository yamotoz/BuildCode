---
import Layout from '../layouts/Layout.astro';

export const prerender = false;
---

<Layout title="BuildCode | Meu Perfil">
  <div class="min-h-screen bg-background-dark relative">
    <!-- Background glows -->
    <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[150px] pointer-events-none"></div>
    <div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-cta/5 rounded-full blur-[120px] pointer-events-none"></div>

    <!-- Top bar -->
    <header class="sticky top-0 z-40 glass-panel border-b border-border-color px-6 py-4">
      <div class="max-w-5xl mx-auto flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 text-slate-100 hover:opacity-80 transition-opacity">
          <img src="/logo_backofff.png" alt="BuildCode" class="h-8 w-auto object-contain" />
          <h2 class="font-display text-xl font-bold tracking-tight text-white hidden sm:block">BuildCode</h2>
        </a>
        <div class="flex items-center gap-3">
          <a href="/app" class="text-sm text-slate-400 hover:text-white transition-colors font-medium">Acessar Sistema</a>
          <button id="btn-logout" type="button" class="flex items-center gap-1.5 px-4 py-2 rounded-full border border-red-500/20 text-red-400 hover:bg-red-500/10 transition-all text-sm font-medium cursor-pointer">
            <span class="material-symbols-outlined text-sm">logout</span>
            Sair
          </button>
        </div>
      </div>
    </header>

    <!-- Loading state -->
    <div id="profile-loading" class="flex items-center justify-center py-32">
      <div class="flex flex-col items-center gap-4">
        <span class="material-symbols-outlined text-4xl text-primary animate-spin">progress_activity</span>
        <p class="text-slate-400 text-sm">Carregando perfil...</p>
      </div>
    </div>

    <!-- Not authenticated -->
    <div id="profile-unauth" class="hidden flex-col items-center justify-center py-32 text-center">
      <span class="material-symbols-outlined text-6xl text-slate-600 mb-4">lock</span>
      <h2 class="text-2xl font-bold text-white mb-2">Acesso necessário</h2>
      <p class="text-slate-400 mb-6">Faça login para acessar seu perfil.</p>
      <a href="/login" class="px-6 py-3 rounded-xl bg-primary text-white font-semibold hover:bg-primary-dark transition-colors">Fazer Login</a>
    </div>

    <!-- Profile content -->
    <main id="profile-content" class="hidden max-w-5xl mx-auto px-6 py-12">
      <div class="space-y-8">

        <!-- Profile card -->
        <div class="rounded-2xl p-8 relative overflow-hidden" style="background: #121212; border: 1px solid #2A3135;">
          <div class="absolute -top-20 -right-20 w-60 h-60 bg-primary/5 rounded-full blur-[80px] pointer-events-none"></div>

          <div class="relative z-10 flex flex-col sm:flex-row items-center gap-8">
            <!-- Avatar -->
            <div class="relative group">
              <div id="avatar-container" class="w-28 h-28 rounded-full border-2 border-primary/30 overflow-hidden bg-surface-dark flex items-center justify-center shadow-[0_0_30px_rgba(46,116,139,0.15)]">
                <img id="avatar-img" src="" alt="Avatar" class="w-full h-full object-cover hidden" />
                <span id="avatar-initials" class="text-3xl font-bold text-primary"></span>
              </div>
              <label for="avatar-input" class="absolute inset-0 rounded-full bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center cursor-pointer">
                <span class="material-symbols-outlined text-white text-xl">photo_camera</span>
              </label>
              <input id="avatar-input" type="file" accept="image/*" class="hidden" />
            </div>

            <!-- Name + Email + Badge -->
            <div class="flex-1 text-center sm:text-left">
              <h1 id="profile-name" class="text-2xl font-bold text-white mb-1"></h1>
              <p id="profile-email" class="text-slate-400 text-sm mb-3"></p>
              <div class="flex items-center gap-2 justify-center sm:justify-start flex-wrap">
                <!-- Seniority badge -->
                <div id="profile-badge" class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-primary/10 text-primary border border-primary/20">
                  <span class="material-symbols-outlined text-xs">workspace_premium</span>
                  <span id="badge-text">Junior</span>
                </div>
                <!-- Role badge (hidden by default, shown for master/admin) -->
                <div id="role-badge" class="hidden items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider">
                  <span class="material-symbols-outlined text-xs">shield</span>
                  <span id="role-badge-text"></span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Settings grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

          <!-- Dados pessoais -->
          <div class="rounded-2xl p-6 space-y-5" style="background: #121212; border: 1px solid #2A3135;">
            <div class="flex items-center gap-2 mb-2">
              <span class="material-symbols-outlined text-primary text-lg">person</span>
              <h3 class="text-lg font-bold text-white">Dados Pessoais</h3>
            </div>

            <div class="space-y-4">
              <div>
                <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1.5 block">Nome completo</label>
                <input id="input-name" type="text" class="w-full rounded-xl border border-border-color bg-surface-dark/50 px-4 py-3 text-sm text-white focus:border-primary/60 focus:ring-1 focus:ring-primary/40 outline-none transition-all" placeholder="Seu nome" />
              </div>

              <div>
                <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1.5 block">E-mail</label>
                <input id="input-email" type="email" disabled class="w-full rounded-xl border border-border-color bg-surface-dark/30 px-4 py-3 text-sm text-slate-500 cursor-not-allowed" />
              </div>

              <button id="btn-save-name" type="button" class="w-full py-3 rounded-xl bg-primary/10 text-primary border border-primary/20 font-semibold text-sm hover:bg-primary/20 transition-all cursor-pointer flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-sm">save</span>
                Salvar Nome
              </button>
            </div>
          </div>

          <!-- Preferências -->
          <div class="rounded-2xl p-6 space-y-5" style="background: #121212; border: 1px solid #2A3135;">
            <div class="flex items-center gap-2 mb-2">
              <span class="material-symbols-outlined text-cta text-lg">tune</span>
              <h3 class="text-lg font-bold text-white">Preferências</h3>
            </div>

            <div class="space-y-5">
              <!-- Seniority -->
              <div>
                <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-2 block">Senioridade</label>
                <div class="grid grid-cols-3 gap-2">
                  <button data-seniority="junior" class="seniority-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border text-center">Junior</button>
                  <button data-seniority="pleno" class="seniority-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border text-center">Pleno</button>
                  <button data-seniority="senior" class="seniority-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border text-center">Senior</button>
                </div>
              </div>

              <!-- Theme -->
              <div>
                <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-2 block">Tema</label>
                <div class="grid grid-cols-2 gap-2">
                  <button data-theme="dark" class="theme-btn py-3 rounded-xl text-sm font-bold transition-all cursor-pointer border flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-sm">dark_mode</span> Escuro
                  </button>
                  <button data-theme="light" class="theme-btn py-3 rounded-xl text-sm font-bold transition-all cursor-pointer border flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-sm">light_mode</span> Claro
                  </button>
                </div>
              </div>

              <!-- Language -->
              <div>
                <div class="flex items-center gap-1.5 mb-2">
                  <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500">Idioma</label>
                  <div class="relative group/tip">
                    <span class="material-symbols-outlined text-slate-600 text-xs cursor-help">info</span>
                    <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-56 p-2.5 rounded-lg text-[11px] text-slate-300 leading-relaxed opacity-0 invisible group-hover/tip:opacity-100 group-hover/tip:visible transition-all z-20 pointer-events-none" style="background: #1a1a1a; border: 1px solid #2A3135;">
                      Este idioma será usado na interface do sistema. O idioma do prompt gerado é configurado separadamente no wizard.
                      <div class="absolute top-full left-1/2 -translate-x-1/2 w-2 h-2 rotate-45" style="background: #1a1a1a; border-right: 1px solid #2A3135; border-bottom: 1px solid #2A3135;"></div>
                    </div>
                  </div>
                </div>
                <div class="grid grid-cols-2 gap-2">
                  <button data-lang="pt" class="lang-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border flex items-center justify-center gap-2">
                    <span class="text-base">🇧🇷</span> Português
                  </button>
                  <button data-lang="en" class="lang-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border flex items-center justify-center gap-2">
                    <span class="text-base">🇺🇸</span> English
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ══════════════════════════════════════════════ -->
        <!-- USAGE TAB -->
        <!-- ══════════════════════════════════════════════ -->
        <div class="rounded-2xl p-6 space-y-5 relative overflow-hidden" style="background: #121212; border: 1px solid #2A3135;">
          <div class="absolute -top-20 -left-20 w-60 h-60 bg-primary/5 rounded-full blur-[80px] pointer-events-none"></div>
          <div class="flex items-center gap-2 mb-2 relative z-10">
            <span class="material-symbols-outlined text-primary text-lg">monitoring</span>
            <h3 class="text-lg font-bold text-white">Uso & Consumo</h3>
          </div>

          <!-- Plan card -->
          <div class="relative z-10 rounded-xl p-5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4" style="background: rgba(46,116,139,0.06); border: 1px solid rgba(46,116,139,0.15);">
            <div>
              <p class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1">Plano Atual</p>
              <div class="flex items-center gap-2">
                <span id="usage-plan-name" class="text-xl font-bold text-white">Explorador</span>
                <span id="usage-plan-badge" class="text-[9px] px-2 py-0.5 rounded-full font-bold uppercase tracking-wider bg-emerald-500/15 text-emerald-400 border border-emerald-500/20">Free</span>
              </div>
              <p id="usage-plan-period" class="text-xs text-slate-500 mt-1"></p>
            </div>
            <a href="/precos" class="px-4 py-2 rounded-xl bg-primary/10 text-primary border border-primary/20 text-sm font-semibold hover:bg-primary/20 transition-all">
              Ver Planos
            </a>
          </div>

          <!-- Stats grid -->
          <div class="grid grid-cols-3 gap-3 relative z-10">
            <div class="rounded-xl p-4 text-center" style="background: rgba(255,255,255,0.02); border: 1px solid #2A3135;">
              <span class="material-symbols-outlined text-primary text-xl mb-1">description</span>
              <p id="usage-prd-count" class="text-2xl font-bold text-white">0</p>
              <p class="text-[10px] text-slate-500 uppercase tracking-wider font-bold">Gerações PRD</p>
            </div>
            <div class="rounded-xl p-4 text-center" style="background: rgba(255,255,255,0.02); border: 1px solid #2A3135;">
              <span class="material-symbols-outlined text-cta text-xl mb-1">chat</span>
              <p id="usage-chat-count" class="text-2xl font-bold text-white">0</p>
              <p class="text-[10px] text-slate-500 uppercase tracking-wider font-bold">Chats</p>
            </div>
            <div class="rounded-xl p-4 text-center" style="background: rgba(255,255,255,0.02); border: 1px solid #2A3135;">
              <span class="material-symbols-outlined text-purple-400 text-xl mb-1">volume_up</span>
              <p id="usage-tts-count" class="text-2xl font-bold text-white">0</p>
              <p class="text-[10px] text-slate-500 uppercase tracking-wider font-bold">Áudios TTS</p>
            </div>
          </div>

          <!-- Usage by model -->
          <div class="relative z-10">
            <p class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-3">Uso por Modelo</p>
            <div id="usage-model-bars" class="space-y-2">
              <p class="text-xs text-slate-600 italic">Nenhum uso registrado ainda.</p>
            </div>
          </div>
        </div>

        <!-- ══════════════════════════════════════════════ -->
        <!-- AGENT SELECTION (Champion Select) -->
        <!-- ══════════════════════════════════════════════ -->
        <div class="rounded-2xl p-6 space-y-5 relative overflow-hidden" style="background: #121212; border: 1px solid #2A3135;">
          <div class="absolute -top-20 -right-20 w-60 h-60 bg-primary/5 rounded-full blur-[80px] pointer-events-none"></div>
          <div class="flex items-center gap-2 mb-2 relative z-10">
            <span class="material-symbols-outlined text-primary text-lg">smart_toy</span>
            <h3 class="text-lg font-bold text-white">Escolha seu Mentor</h3>
            <span class="text-[10px] text-slate-500 ml-2">Selecione o agente que guiara seu desenvolvimento</span>
          </div>

          <div id="agent-grid" class="grid grid-cols-2 lg:grid-cols-4 gap-3 relative z-10">
            <!-- Cards dynamically rendered below -->
            <button type="button" data-agent="theboss" class="agent-card group relative rounded-xl overflow-hidden border-2 border-transparent hover:border-[#C0392B]/60 transition-all duration-300 cursor-pointer aspect-[3/4] bg-black">
              <img src="/agentes/Theboss.png" alt="The Boss" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
              <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 p-3 sm:p-4">
                <h4 class="text-white font-bold text-sm sm:text-base tracking-wide">The Boss</h4>
                <p class="text-slate-400 text-[10px] sm:text-xs font-medium mt-0.5">O Arquiteto Pragmatico</p>
                <p class="text-slate-500 text-[9px] sm:text-[10px] mt-2 leading-relaxed opacity-0 group-hover:opacity-100 transition-opacity duration-300 hidden sm:block">"Voce quer um software ou um brinquedo?"</p>
              </div>
              <div class="agent-check absolute top-2 right-2 w-6 h-6 rounded-full bg-[#C0392B] items-center justify-center hidden">
                <span class="material-symbols-outlined text-white text-sm">check</span>
              </div>
            </button>

            <button type="button" data-agent="azrael" class="agent-card group relative rounded-xl overflow-hidden border-2 border-transparent hover:border-[#8E44AD]/60 transition-all duration-300 cursor-pointer aspect-[3/4] bg-black">
              <img src="/agentes/Azrael.png" alt="Azrael" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
              <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 p-3 sm:p-4">
                <h4 class="text-white font-bold text-sm sm:text-base tracking-wide">Azrael</h4>
                <p class="text-slate-400 text-[10px] sm:text-xs font-medium mt-0.5">O Visionario Obsessivo</p>
                <p class="text-slate-500 text-[9px] sm:text-[10px] mt-2 leading-relaxed opacity-0 group-hover:opacity-100 transition-opacity duration-300 hidden sm:block">"Isso e funcional, mas nao e revolucionario."</p>
              </div>
              <div class="agent-check absolute top-2 right-2 w-6 h-6 rounded-full bg-[#8E44AD] items-center justify-center hidden">
                <span class="material-symbols-outlined text-white text-sm">check</span>
              </div>
            </button>

            <button type="button" data-agent="rizler" class="agent-card group relative rounded-xl overflow-hidden border-2 border-transparent hover:border-[#27AE60]/60 transition-all duration-300 cursor-pointer aspect-[3/4] bg-black">
              <img src="/agentes/Rizler.png" alt="Rizler" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
              <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 p-3 sm:p-4">
                <h4 class="text-white font-bold text-sm sm:text-base tracking-wide">Rizler</h4>
                <p class="text-slate-400 text-[10px] sm:text-xs font-medium mt-0.5">O Fantasma do Red Team</p>
                <p class="text-slate-500 text-[9px] sm:text-[10px] mt-2 leading-relaxed opacity-0 group-hover:opacity-100 transition-opacity duration-300 hidden sm:block">"Bonito seu front-end. Uma pena que eu levaria 12s pra derrubar."</p>
              </div>
              <div class="agent-check absolute top-2 right-2 w-6 h-6 rounded-full bg-[#27AE60] items-center justify-center hidden">
                <span class="material-symbols-outlined text-white text-sm">check</span>
              </div>
            </button>

            <button type="button" data-agent="anastasia" class="agent-card group relative rounded-xl overflow-hidden border-2 border-transparent hover:border-[#E91E63]/60 transition-all duration-300 cursor-pointer aspect-[3/4] bg-black">
              <img src="/agentes/Anastasia.png" alt="Anastasia" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
              <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 p-3 sm:p-4">
                <h4 class="text-white font-bold text-sm sm:text-base tracking-wide">Anastasia</h4>
                <p class="text-slate-400 text-[10px] sm:text-xs font-medium mt-0.5">A Rainha do Fullstack</p>
                <p class="text-slate-500 text-[9px] sm:text-[10px] mt-2 leading-relaxed opacity-0 group-hover:opacity-100 transition-opacity duration-300 hidden sm:block">"Calma, baby. Vamos deixar tudo perfeito."</p>
              </div>
              <div class="agent-check absolute top-2 right-2 w-6 h-6 rounded-full bg-[#E91E63] items-center justify-center hidden">
                <span class="material-symbols-outlined text-white text-sm">check</span>
              </div>
            </button>
          </div>
        </div>

        <!-- LoL-style Loading Screen (hidden, shown on selection) -->
        <div id="agent-loading-screen" class="hidden fixed inset-0 z-[9999] bg-[#0D0D0D] flex flex-col items-center justify-center">
          <div class="flex items-end justify-center gap-2 sm:gap-4 w-full max-w-4xl px-4">
            <div data-loading-agent="theboss" class="agent-loading-col flex flex-col items-center gap-3 flex-1 opacity-30 grayscale transition-all duration-700">
              <div class="relative w-full aspect-[3/5] rounded-lg overflow-hidden border-2 border-white/10">
                <img src="/agentes/Theboss.png" alt="The Boss" class="w-full h-full object-cover" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
                <p class="absolute bottom-3 left-0 right-0 text-center text-white text-xs sm:text-sm font-bold">The Boss</p>
              </div>
              <div class="w-full h-1 rounded-full bg-white/10 overflow-hidden">
                <div class="agent-load-bar h-full bg-[#C0392B] rounded-full transition-all duration-[4000ms] ease-out" style="width: 0%"></div>
              </div>
            </div>
            <div data-loading-agent="azrael" class="agent-loading-col flex flex-col items-center gap-3 flex-1 opacity-30 grayscale transition-all duration-700">
              <div class="relative w-full aspect-[3/5] rounded-lg overflow-hidden border-2 border-white/10">
                <img src="/agentes/Azrael.png" alt="Azrael" class="w-full h-full object-cover" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
                <p class="absolute bottom-3 left-0 right-0 text-center text-white text-xs sm:text-sm font-bold">Azrael</p>
              </div>
              <div class="w-full h-1 rounded-full bg-white/10 overflow-hidden">
                <div class="agent-load-bar h-full bg-[#8E44AD] rounded-full transition-all duration-[4000ms] ease-out" style="width: 0%"></div>
              </div>
            </div>
            <div data-loading-agent="rizler" class="agent-loading-col flex flex-col items-center gap-3 flex-1 opacity-30 grayscale transition-all duration-700">
              <div class="relative w-full aspect-[3/5] rounded-lg overflow-hidden border-2 border-white/10">
                <img src="/agentes/Rizler.png" alt="Rizler" class="w-full h-full object-cover" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
                <p class="absolute bottom-3 left-0 right-0 text-center text-white text-xs sm:text-sm font-bold">Rizler</p>
              </div>
              <div class="w-full h-1 rounded-full bg-white/10 overflow-hidden">
                <div class="agent-load-bar h-full bg-[#27AE60] rounded-full transition-all duration-[4000ms] ease-out" style="width: 0%"></div>
              </div>
            </div>
            <div data-loading-agent="anastasia" class="agent-loading-col flex flex-col items-center gap-3 flex-1 opacity-30 grayscale transition-all duration-700">
              <div class="relative w-full aspect-[3/5] rounded-lg overflow-hidden border-2 border-white/10">
                <img src="/agentes/Anastasia.png" alt="Anastasia" class="w-full h-full object-cover" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
                <p class="absolute bottom-3 left-0 right-0 text-center text-white text-xs sm:text-sm font-bold">Anastasia</p>
              </div>
              <div class="w-full h-1 rounded-full bg-white/10 overflow-hidden">
                <div class="agent-load-bar h-full bg-[#E91E63] rounded-full transition-all duration-[4000ms] ease-out" style="width: 0%"></div>
              </div>
            </div>
          </div>
          <!-- Loading tip -->
          <div class="mt-8 sm:mt-12 text-center px-6">
            <p id="loading-tip" class="text-slate-500 text-xs sm:text-sm italic max-w-md"></p>
          </div>
        </div>

        <!-- ══════════════════════════════════════════════ -->
        <!-- LLM MODEL SELECTION -->
        <!-- ══════════════════════════════════════════════ -->
        <div class="rounded-2xl p-6 space-y-5 relative overflow-hidden" style="background: #121212; border: 1px solid #2A3135;">
          <div class="absolute -bottom-20 -left-20 w-60 h-60 bg-cta/5 rounded-full blur-[80px] pointer-events-none"></div>
          <div class="flex items-center gap-2 mb-2 relative z-10">
            <span class="material-symbols-outlined text-cta text-lg">psychology</span>
            <h3 class="text-lg font-bold text-white">Modelo do Mentor</h3>
            <span class="text-[10px] text-slate-500 ml-2">LLM que seu agente usa no chat para conversar com voce</span>
          </div>

          <!-- Search -->
          <div class="relative z-10">
            <div class="relative">
              <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 text-lg">search</span>
              <input id="llm-search" type="text" placeholder="Buscar modelo..." class="w-full rounded-xl border border-border-color bg-surface-dark/50 pl-10 pr-4 py-3 text-sm text-white focus:border-cta/60 focus:ring-1 focus:ring-cta/40 outline-none transition-all" />
            </div>
          </div>

          <!-- Tier labels -->
