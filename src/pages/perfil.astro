  // Upload de avatar (max 2MB, images only)
  document.getElementById('avatar-input')!.addEventListener('change', async (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;

    // Validate file type
    if (!file.type.startsWith('image/')) {
      alert('Apenas imagens são permitidas.');
      (e.target as HTMLInputElement).value = '';
      return;
    }

    // Validate file size (2MB max)
    const MAX_AVATAR_SIZE = 2 * 1024 * 1024; // 2MB
    if (file.size > MAX_AVATAR_SIZE) {
      alert('A imagem deve ter no máximo 2MB. Sua imagem tem ' + (file.size / 1024 / 1024).toFixed(1) + 'MB.');
      (e.target as HTMLInputElement).value = '';
      return;
    }

    const avatarImg = document.getElementById('avatar-img') as HTMLImageElement;
    const avatarInitials = document.getElementById('avatar-initials')!;

    const reader = new FileReader();
    reader.onload = () => {
      avatarImg.src = reader.result as string;
      avatarImg.classList.remove('hidden');
      avatarInitials.classList.add('hidden');
    };
    reader.readAsDataURL(file);

    const url = await uploadAvatar(currentUserId, file);
    if (url) {
      await updateProfile(currentUserId, { avatar_url: url + '?t=' + Date.now() });
      showFeedback();
    }
  });

  // ══════════════════════════════
  //  PASSWORD CHANGE
  // ══════════════════════════════

  document.getElementById('btn-save-password')!.addEventListener('click', async () => {
    const currentPass = (document.getElementById('input-current-password') as HTMLInputElement).value;
    const newPass = (document.getElementById('input-new-password') as HTMLInputElement).value;
    const confirmPass = (document.getElementById('input-confirm-password') as HTMLInputElement).value;
    const msgEl = document.getElementById('password-msg')!;

    if (!currentPass || !newPass || !confirmPass) {
      msgEl.className = 'rounded-xl px-4 py-3 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
      msgEl.textContent = 'Preencha todos os campos.';
      msgEl.classList.remove('hidden');
      return;
    }

    if (newPass.length < 6) {
      msgEl.className = 'rounded-xl px-4 py-3 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
      msgEl.textContent = 'A nova senha deve ter no mínimo 6 caracteres.';
      msgEl.classList.remove('hidden');
      return;
    }

    if (newPass !== confirmPass) {
      msgEl.className = 'rounded-xl px-4 py-3 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
      msgEl.textContent = 'As senhas não coincidem.';
      msgEl.classList.remove('hidden');
      return;
    }

    // Verifica senha atual reautenticando
    const { data: { user } } = await supabase.auth.getUser();
    if (!user?.email) {
      msgEl.className = 'rounded-xl px-4 py-3 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
      msgEl.textContent = 'Sessão inválida. Faça login novamente.';
      msgEl.classList.remove('hidden');
      return;
    }

    msgEl.className = 'rounded-xl px-4 py-3 text-sm font-medium bg-primary/10 text-primary border border-primary/20';
    msgEl.textContent = 'Verificando...';
    msgEl.classList.remove('hidden');

    const { error: signInError } = await supabase.auth.signInWithPassword({ email: user.email, password: currentPass });
    if (signInError) {
      msgEl.className = 'rounded-xl px-4 py-3 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
      msgEl.textContent = 'Senha atual incorreta.';
      return;
    }

    const { error } = await updatePassword(newPass);
    if (error) {
      msgEl.className = 'rounded-xl px-4 py-3 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
      msgEl.textContent = 'Erro ao atualizar senha: ' + error.message;
    } else {
      msgEl.className = 'rounded-xl px-4 py-3 text-sm font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/20';
      msgEl.textContent = 'Senha atualizada com sucesso!';
      (document.getElementById('input-current-password') as HTMLInputElement).value = '';
      (document.getElementById('input-new-password') as HTMLInputElement).value = '';
      (document.getElementById('input-confirm-password') as HTMLInputElement).value = '';
      setTimeout(() => { msgEl.className = 'hidden'; }, 3000);
    }
  });

  // ══════════════════════════════
  //  DELETE ACCOUNT
  // ══════════════════════════════

  const modalDeleteAccount = document.getElementById('modal-delete-account')!;
  const deleteStep1 = document.getElementById('delete-step-1')!;
  const deleteStep2 = document.getElementById('delete-step-2')!;

  function openDeleteModal() {
    deleteStep1.classList.remove('hidden');
    deleteStep2.classList.add('hidden');
    modalDeleteAccount.classList.remove('hidden');
    modalDeleteAccount.classList.add('flex');
  }

  function closeDeleteModal() {
    modalDeleteAccount.classList.add('hidden');
    modalDeleteAccount.classList.remove('flex');
  }

  document.getElementById('btn-delete-account')!.addEventListener('click', openDeleteModal);
  document.getElementById('btn-delete-cancel')!.addEventListener('click', closeDeleteModal);
  document.getElementById('btn-delete-cancel-2')!.addEventListener('click', closeDeleteModal);

  document.getElementById('btn-delete-step1-confirm')!.addEventListener('click', () => {
    deleteStep1.classList.add('hidden');
    deleteStep2.classList.remove('hidden');
  });

  document.getElementById('btn-delete-step2-confirm')!.addEventListener('click', async () => {
    const msgEl = document.getElementById('delete-account-msg')!;
    const btn = document.getElementById('btn-delete-step2-confirm') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Excluindo...';

    const { error } = await deleteOwnAccount();
    if (error) {
      msgEl.className = 'rounded-xl px-4 py-3 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
      msgEl.textContent = error.message;
      msgEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Excluir permanentemente';
    } else {
      await signOut();
      window.location.href = '/';
