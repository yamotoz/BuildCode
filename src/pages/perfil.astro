  async function openUserAnalytics(userId: string) {
    muaModal.classList.remove('hidden');
    muaModal.classList.add('flex');
    muaLoading.classList.remove('hidden');
    muaContent.classList.add('hidden');

    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return;

    const res = await fetch(`/api/admin-user-stats?userId=${userId}`, {
      headers: { 'Authorization': `Bearer ${session.access_token}` },
    });
    if (!res.ok) { muaLoading.classList.add('hidden'); return; }

    const { profile, logs, credits, subscription } = await res.json();

    // Avatar
    const avatarEl = document.getElementById('mua-avatar')!;
    if (profile?.avatar_url) {
      avatarEl.innerHTML = `<img src="${esc(profile.avatar_url)}" class="w-full h-full object-cover" />`;
    } else {
      avatarEl.textContent = getInitials(profile?.full_name || '??');
    }

    // Info
    (document.getElementById('mua-name') as HTMLElement).textContent = profile?.full_name || 'Sem nome';
    (document.getElementById('mua-email') as HTMLElement).textContent = profile?.email || userId;

    const planName = subscription?.plan || 'explorador';
    (document.getElementById('mua-plan') as HTMLElement).textContent = planName.charAt(0).toUpperCase() + planName.slice(1);

    const statusEl = document.getElementById('mua-status')!;
    const status = subscription?.status || 'inactive';
    statusEl.textContent = status === 'active' ? 'Ativo' : 'Inativo';
    statusEl.className = `text-sm font-bold ${status === 'active' ? 'text-emerald-400' : 'text-red-400'}`;

    const roleMap: Record<string, string> = { master: 'Master', admin: 'Administrador', user: 'Usuário' };
    (document.getElementById('mua-role') as HTMLElement).textContent = roleMap[profile?.role] || profile?.role || '-';

    const since = profile?.created_at ? new Date(profile.created_at).toLocaleDateString('pt-BR', { month: 'short', year: 'numeric' }) : '-';
    (document.getElementById('mua-since') as HTMLElement).textContent = since;

    // Uso do mês atual
    const now = new Date();
    const monthStart = new Date(now.getFullYear(), now.getMonth(), 1).toISOString();
    const monthLogs = (logs as any[]).filter((l: any) => l.created_at >= monthStart);

    const budgetModels = ['gemma-3-4b', 'llama-3.1-8b', 'mistral-small-3.1-24b'];
    const midModels = ['gemini-2.0-flash', 'gpt-4o-mini', 'claude-3.5-haiku'];

    const ecoUsed = monthLogs.filter((l: any) =>
      l.action === 'generation_budget' || budgetModels.some(m => l.llm_model?.includes(m))
    ).length;
    const midUsed = monthLogs.filter((l: any) =>
      l.action === 'generation_mid' || midModels.some(m => l.llm_model?.includes(m))
    ).length;
    const eliteUsed = monthLogs.filter((l: any) =>
      l.action === 'generation_pro' || (!budgetModels.some(m => l.llm_model?.includes(m)) && !midModels.some(m => l.llm_model?.includes(m)) && l.action?.startsWith('generation'))
    ).length;

    (document.getElementById('mua-eco') as HTMLElement).textContent = String(ecoUsed);
    (document.getElementById('mua-mid') as HTMLElement).textContent = String(midUsed);
    (document.getElementById('mua-elite') as HTMLElement).textContent = String(eliteUsed);

    // Indie credits
    if (credits && (credits.indie_credits_economy > 0 || credits.indie_credits_mid > 0 || credits.indie_credits_elite > 0)) {
      document.getElementById('mua-credits-section')!.classList.remove('hidden');
      (document.getElementById('mua-ic-eco') as HTMLElement).textContent = String(credits.indie_credits_economy || 0);
      (document.getElementById('mua-ic-mid') as HTMLElement).textContent = String(credits.indie_credits_mid || 0);
      (document.getElementById('mua-ic-elite') as HTMLElement).textContent = String(credits.indie_credits_elite || 0);
    } else {
      document.getElementById('mua-credits-section')!.classList.add('hidden');
    }

    // Gráfico: últimos 6 meses
    const months: { label: string; eco: number; mid: number; elite: number; chat: number }[] = [];
    for (let i = 5; i >= 0; i--) {
      const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
      const start = d.toISOString();
      const end = new Date(d.getFullYear(), d.getMonth() + 1, 1).toISOString();
      const ml = (logs as any[]).filter((l: any) => l.created_at >= start && l.created_at < end);
      months.push({
        label: d.toLocaleDateString('pt-BR', { month: 'short' }),
        eco: ml.filter((l: any) => l.action === 'generation_budget' || budgetModels.some(m => l.llm_model?.includes(m))).length,
        mid: ml.filter((l: any) => l.action === 'generation_mid' || midModels.some(m => l.llm_model?.includes(m))).length,
        elite: ml.filter((l: any) => l.action === 'generation_pro').length,
        chat: ml.filter((l: any) => l.action === 'chat_message').length,
      });
    }

    drawMuaChart(months);

    // Últimas atividades
    const activityList = document.getElementById('mua-activity-list')!;
    const recent = (logs as any[]).slice(0, 20);
    if (recent.length === 0) {
      activityList.innerHTML = `<p class="text-xs text-slate-600 py-2">Nenhuma atividade registrada.</p>`;
    } else {
      activityList.innerHTML = recent.map((l: any) => {
        const date = new Date(l.created_at).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });
        const actionMap: Record<string, { label: string; color: string }> = {
          generation_budget: { label: 'Geração Economy', color: 'text-emerald-400' },
          generation_mid: { label: 'Geração Mid', color: 'text-blue-400' },
          generation_pro: { label: 'Geração Elite', color: 'text-purple-400' },
          chat_message: { label: 'Chat', color: 'text-slate-400' },
        };
        const info = actionMap[l.action] || { label: esc(l.action), color: 'text-slate-500' };
        return `<div class="flex items-center justify-between py-1.5 px-3 rounded-lg" style="background: #0d1214; border: 1px solid #1e2a2e;">
          <span class="text-xs ${info.color} font-medium">${info.label}${l.llm_model ? ` <span class="text-slate-600 font-normal">· ${esc(l.llm_model)}</span>` : ''}</span>
          <span class="text-[10px] text-slate-600 shrink-0 ml-3">${date}</span>
        </div>`;
      }).join('');
    }

    muaLoading.classList.add('hidden');
    muaContent.classList.remove('hidden');
  }

  function drawMuaChart(months: { label: string; eco: number; mid: number; elite: number; chat: number }[]) {
    const canvas = document.getElementById('mua-chart') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d')!;
    const dpr = window.devicePixelRatio || 1;
    const w = canvas.parentElement!.clientWidth - 32;
    const h = 140;
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    canvas.style.width = w + 'px';
    canvas.style.height = h + 'px';
    ctx.scale(dpr, dpr);

    const maxVal = Math.max(...months.map(m => m.eco + m.mid + m.elite + m.chat), 1);
    const padL = 28, padR = 8, padT = 10, padB = 28;
    const chartW = w - padL - padR;
    const chartH = h - padT - padB;
    const barGroupW = chartW / months.length;
    const barW = Math.min(barGroupW * 0.55, 36);
    const barGap = 1;
    const subW = (barW - barGap * 3) / 4;

    ctx.clearRect(0, 0, w, h);

    // Grid lines
    for (let i = 0; i <= 4; i++) {
      const y = padT + (chartH / 4) * i;
      ctx.beginPath();
      ctx.strokeStyle = 'rgba(255,255,255,0.04)';
      ctx.lineWidth = 1;
      ctx.moveTo(padL, y);
      ctx.lineTo(w - padR, y);
      ctx.stroke();
    }

    const colors = ['rgba(52,211,153,0.75)', 'rgba(96,165,250,0.75)', 'rgba(167,139,250,0.75)', 'rgba(148,163,184,0.5)'];

    months.forEach((m, i) => {
      const cx = padL + i * barGroupW + barGroupW / 2 - barW / 2;
      const vals = [m.eco, m.mid, m.elite, m.chat];
      vals.forEach((v, j) => {
        const bh = (v / maxVal) * chartH;
        const x = cx + j * (subW + barGap);
        const y = padT + chartH - bh;
        ctx.fillStyle = colors[j];
        ctx.beginPath();
        ctx.roundRect(x, y, subW, bh, [2, 2, 0, 0]);
        ctx.fill();
      });

      // Month label
      ctx.fillStyle = 'rgba(148,163,184,0.6)';
      ctx.font = '10px Inter, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText(m.label, padL + i * barGroupW + barGroupW / 2, h - 8);
    });

    // Y axis labels
    ctx.fillStyle = 'rgba(100,116,139,0.7)';
    ctx.font = '9px Inter, sans-serif';
    ctx.textAlign = 'right';
    [0, Math.round(maxVal / 2), maxVal].forEach((v, i) => {
      const y = padT + chartH - (v / maxVal) * chartH;
      ctx.fillText(String(v), padL - 4, y + 3);
    });
  }

