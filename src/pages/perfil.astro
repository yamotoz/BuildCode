  function renderAgentSelection(selectedId: string) {
    document.querySelectorAll('.agent-card').forEach(card => {
      const id = (card as HTMLElement).dataset.agent;
      const check = card.querySelector('.agent-check');
      if (id === selectedId) {
        card.classList.add('ring-2');
        (card as HTMLElement).style.borderColor = agentColors[id] || '#2E748B';
        (card as HTMLElement).style.boxShadow = `0 0 20px ${agentColors[id]}40`;
        if (check) { check.classList.remove('hidden'); check.classList.add('flex'); }
      } else {
        card.classList.remove('ring-2');
        (card as HTMLElement).style.borderColor = 'transparent';
        (card as HTMLElement).style.boxShadow = 'none';
        if (check) { check.classList.add('hidden'); check.classList.remove('flex'); }
      }
    });
  }

  function showAgentLoadingScreen(selectedId: string) {
    const screen = document.getElementById('agent-loading-screen')!;
    screen.classList.remove('hidden');
    document.body.style.overflow = 'hidden';

    // Highlight selected agent
    document.querySelectorAll('.agent-loading-col').forEach(col => {
      const id = (col as HTMLElement).dataset.loadingAgent;
      if (id === selectedId) {
        col.classList.remove('opacity-30', 'grayscale');
        col.classList.add('opacity-100');
        const border = col.querySelector('.relative') as HTMLElement;
        if (border) border.style.borderColor = agentColors[id] || '#2E748B';
      } else {
        col.classList.add('opacity-30', 'grayscale');
        col.classList.remove('opacity-100');
      }
    });

    // Show random tip
    const tips = agentTips[selectedId] || agentTips.theboss;
    const tipEl = document.getElementById('loading-tip')!;
    tipEl.textContent = '"' + tips[Math.floor(Math.random() * tips.length)] + '"';

    // Animate progress bars
    setTimeout(() => {
      document.querySelectorAll('.agent-load-bar').forEach(bar => {
        (bar as HTMLElement).style.width = '100%';
      });
    }, 100);

    // Close after 4 seconds
    setTimeout(() => {
      screen.classList.add('hidden');
      document.body.style.overflow = '';
    }, 4200);
  }

