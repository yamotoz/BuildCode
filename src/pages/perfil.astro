---
import Layout from '../layouts/Layout.astro';

export const prerender = false;
---

<Layout title="BuildCode | Meu Perfil">
  <div class="min-h-screen bg-background-dark relative">
    <!-- Background glows -->
    <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[150px] pointer-events-none"></div>
    <div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-cta/5 rounded-full blur-[120px] pointer-events-none"></div>

    <!-- Top bar -->
    <header class="sticky top-0 z-40 glass-panel border-b border-border-color px-6 py-4">
      <div class="max-w-5xl mx-auto flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 text-slate-100 hover:opacity-80 transition-opacity">
          <img src="/logo_backofff.png" alt="BuildCode" class="h-8 w-auto object-contain" />
          <h2 class="font-display text-xl font-bold tracking-tight text-white hidden sm:block">BuildCode</h2>
        </a>
        <div class="flex items-center gap-3">
          <a href="/app" class="text-sm text-slate-400 hover:text-white transition-colors font-medium">Acessar Sistema</a>
          <button id="btn-logout" type="button" class="flex items-center gap-1.5 px-4 py-2 rounded-full border border-red-500/20 text-red-400 hover:bg-red-500/10 transition-all text-sm font-medium cursor-pointer">
            <span class="material-symbols-outlined text-sm">logout</span>
            Sair
          </button>
        </div>
      </div>
    </header>

    <!-- Loading state -->
    <div id="profile-loading" class="flex items-center justify-center py-32">
      <div class="flex flex-col items-center gap-4">
        <span class="material-symbols-outlined text-4xl text-primary animate-spin">progress_activity</span>
        <p class="text-slate-400 text-sm">Carregando perfil...</p>
      </div>
    </div>

    <!-- Not authenticated -->
    <div id="profile-unauth" class="hidden flex-col items-center justify-center py-32 text-center">
      <span class="material-symbols-outlined text-6xl text-slate-600 mb-4">lock</span>
      <h2 class="text-2xl font-bold text-white mb-2">Acesso necessário</h2>
      <p class="text-slate-400 mb-6">Faça login para acessar seu perfil.</p>
      <a href="/login" class="px-6 py-3 rounded-xl bg-primary text-white font-semibold hover:bg-primary-dark transition-colors">Fazer Login</a>
    </div>

    <!-- Profile content -->
    <main id="profile-content" class="hidden max-w-5xl mx-auto px-6 py-12">
      <div class="space-y-8">

        <!-- Profile card -->
        <div class="rounded-2xl p-8 relative overflow-hidden" style="background: #121212; border: 1px solid #2A3135;">
          <div class="absolute -top-20 -right-20 w-60 h-60 bg-primary/5 rounded-full blur-[80px] pointer-events-none"></div>

          <div class="relative z-10 flex flex-col sm:flex-row items-center gap-8">
            <!-- Avatar -->
            <div class="relative group">
              <div id="avatar-container" class="w-28 h-28 rounded-full border-2 border-primary/30 overflow-hidden bg-surface-dark flex items-center justify-center shadow-[0_0_30px_rgba(46,116,139,0.15)]">
                <img id="avatar-img" src="" alt="Avatar" class="w-full h-full object-cover hidden" />
                <span id="avatar-initials" class="text-3xl font-bold text-primary"></span>
              </div>
              <label for="avatar-input" class="absolute inset-0 rounded-full bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center cursor-pointer">
                <span class="material-symbols-outlined text-white text-xl">photo_camera</span>
              </label>
              <input id="avatar-input" type="file" accept="image/*" class="hidden" />
            </div>

            <!-- Name + Email + Badge -->
            <div class="flex-1 text-center sm:text-left">
              <h1 id="profile-name" class="text-2xl font-bold text-white mb-1"></h1>
              <p id="profile-email" class="text-slate-400 text-sm mb-3"></p>
              <div class="flex items-center gap-2 justify-center sm:justify-start flex-wrap">
                <!-- Seniority badge -->
                <div id="profile-badge" class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-primary/10 text-primary border border-primary/20">
                  <span class="material-symbols-outlined text-xs">workspace_premium</span>
                  <span id="badge-text">Junior</span>
                </div>
                <!-- Role badge (hidden by default, shown for master/admin) -->
                <div id="role-badge" class="hidden items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider">
                  <span class="material-symbols-outlined text-xs">shield</span>
                  <span id="role-badge-text"></span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Settings grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

          <!-- Dados pessoais -->
          <div class="rounded-2xl p-6 space-y-5" style="background: #121212; border: 1px solid #2A3135;">
            <div class="flex items-center gap-2 mb-2">
              <span class="material-symbols-outlined text-primary text-lg">person</span>
              <h3 class="text-lg font-bold text-white">Dados Pessoais</h3>
            </div>

            <div class="space-y-4">
              <div>
                <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1.5 block">Nome completo</label>
                <input id="input-name" type="text" class="w-full rounded-xl border border-border-color bg-surface-dark/50 px-4 py-3 text-sm text-white focus:border-primary/60 focus:ring-1 focus:ring-primary/40 outline-none transition-all" placeholder="Seu nome" />
              </div>

              <div>
                <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1.5 block">E-mail</label>
                <input id="input-email" type="email" disabled class="w-full rounded-xl border border-border-color bg-surface-dark/30 px-4 py-3 text-sm text-slate-500 cursor-not-allowed" />
              </div>

              <button id="btn-save-name" type="button" class="w-full py-3 rounded-xl bg-primary/10 text-primary border border-primary/20 font-semibold text-sm hover:bg-primary/20 transition-all cursor-pointer flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-sm">save</span>
                Salvar Nome
              </button>
            </div>
          </div>

          <!-- Preferências -->
          <div class="rounded-2xl p-6 space-y-5" style="background: #121212; border: 1px solid #2A3135;">
            <div class="flex items-center gap-2 mb-2">
              <span class="material-symbols-outlined text-cta text-lg">tune</span>
              <h3 class="text-lg font-bold text-white">Preferências</h3>
            </div>

            <div class="space-y-5">
              <!-- Seniority -->
              <div>
                <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-2 block">Senioridade</label>
                <div class="grid grid-cols-3 gap-2">
                  <button data-seniority="junior" class="seniority-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border text-center">Junior</button>
                  <button data-seniority="pleno" class="seniority-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border text-center">Pleno</button>
                  <button data-seniority="senior" class="seniority-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border text-center">Senior</button>
                </div>
              </div>

              <!-- Theme -->
              <div>
                <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-2 block">Tema</label>
                <div class="grid grid-cols-2 gap-2">
                  <button data-theme="dark" class="theme-btn py-3 rounded-xl text-sm font-bold transition-all cursor-pointer border flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-sm">dark_mode</span> Escuro
                  </button>
                  <button data-theme="light" class="theme-btn py-3 rounded-xl text-sm font-bold transition-all cursor-pointer border flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-sm">light_mode</span> Claro
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Alterar Senha -->
        <div class="rounded-2xl p-6 space-y-5" style="background: #121212; border: 1px solid #2A3135;">
          <div class="flex items-center gap-2 mb-2">
            <span class="material-symbols-outlined text-cta text-lg">lock</span>
            <h3 class="text-lg font-bold text-white">Alterar Senha</h3>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1.5 block">Nova senha</label>
              <input id="input-new-password" type="password" class="w-full rounded-xl border border-border-color bg-surface-dark/50 px-4 py-3 text-sm text-white focus:border-primary/60 focus:ring-1 focus:ring-primary/40 outline-none transition-all" placeholder="Mínimo 6 caracteres" minlength="6" />
            </div>
            <div>
              <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1.5 block">Confirmar nova senha</label>
              <input id="input-confirm-password" type="password" class="w-full rounded-xl border border-border-color bg-surface-dark/50 px-4 py-3 text-sm text-white focus:border-primary/60 focus:ring-1 focus:ring-primary/40 outline-none transition-all" placeholder="Repita a senha" minlength="6" />
            </div>
          </div>
          <div id="password-msg" class="hidden rounded-xl px-4 py-3 text-sm font-medium"></div>
          <button id="btn-save-password" type="button" class="w-full py-3 rounded-xl bg-cta/10 text-cta border border-cta/20 font-semibold text-sm hover:bg-cta/20 transition-all cursor-pointer flex items-center justify-center gap-2">
            <span class="material-symbols-outlined text-sm">key</span>
            Atualizar Senha
          </button>
        </div>

        <!-- ══════════════════════════════════════════════ -->
        <!-- PAINEL DE GESTÃO DE USUÁRIOS (Master only) -->
        <!-- ══════════════════════════════════════════════ -->
        <div id="admin-panel" class="hidden space-y-6">
          <div class="rounded-2xl p-6 space-y-5" style="background: #121212; border: 1px solid #2A3135;">
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-purple-400 text-lg">admin_panel_settings</span>
                <h3 class="text-lg font-bold text-white">Gestão de Usuários</h3>
              </div>
              <button id="btn-add-user" type="button" class="flex items-center gap-1.5 px-4 py-2 rounded-xl bg-purple-500/10 text-purple-400 border border-purple-500/20 hover:bg-purple-500/20 transition-all text-sm font-semibold cursor-pointer">
                <span class="material-symbols-outlined text-sm">person_add</span>
                Adicionar Usuário
              </button>
            </div>

            <!-- Add user form (hidden by default) -->
            <div id="add-user-form" class="hidden rounded-xl p-5 space-y-4" style="background: rgba(168,85,247,0.05); border: 1px solid rgba(168,85,247,0.15);">
              <h4 class="text-sm font-bold text-purple-300">Novo Usuário</h4>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                <div>
                  <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1 block">Nome</label>
                  <input id="new-user-name" type="text" class="w-full rounded-lg border border-border-color bg-surface-dark/50 px-3 py-2.5 text-sm text-white focus:border-purple-500/60 outline-none transition-all" placeholder="Nome completo" />
                </div>
                <div>
                  <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1 block">E-mail</label>
                  <input id="new-user-email" type="email" class="w-full rounded-lg border border-border-color bg-surface-dark/50 px-3 py-2.5 text-sm text-white focus:border-purple-500/60 outline-none transition-all" placeholder="email@exemplo.com" />
                </div>
                <div>
                  <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1 block">Cargo</label>
                  <select id="new-user-role" class="w-full rounded-lg border border-border-color bg-surface-dark/50 px-3 py-2.5 text-sm text-white focus:border-purple-500/60 outline-none transition-all">
                    <option value="user">Usuário</option>
                    <option value="admin">Administrador</option>
                  </select>
                </div>
              </div>
              <div id="add-user-msg" class="hidden rounded-lg px-3 py-2 text-sm font-medium"></div>
              <div class="flex gap-2">
                <button id="btn-confirm-add" type="button" class="flex items-center gap-1.5 px-4 py-2 rounded-lg bg-purple-500/15 text-purple-400 border border-purple-500/25 hover:bg-purple-500/25 transition-all text-sm font-semibold cursor-pointer">
                  <span class="material-symbols-outlined text-sm">check</span>
                  Criar Usuário
                </button>
                <button id="btn-cancel-add" type="button" class="px-4 py-2 rounded-lg text-slate-400 hover:text-white transition-colors text-sm cursor-pointer">
                  Cancelar
                </button>
              </div>
            </div>

            <!-- Users table -->
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="text-left text-[10px] uppercase tracking-widest font-bold text-slate-500 border-b border-border-color">
                    <th class="pb-3 pr-4">Usuário</th>
                    <th class="pb-3 pr-4">E-mail</th>
                    <th class="pb-3 pr-4">Cargo</th>
                    <th class="pb-3 pr-4">Senioridade</th>
                    <th class="pb-3 text-right">Ações</th>
                  </tr>
                </thead>
                <tbody id="users-table-body" class="divide-y divide-border-color">
                  <tr>
                    <td colspan="5" class="py-8 text-center text-slate-500">
                      <span class="material-symbols-outlined text-2xl animate-spin">progress_activity</span>
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Saved feedback -->
        <div id="save-feedback" class="hidden fixed bottom-6 right-6 z-50 px-5 py-3 rounded-xl bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-sm font-medium shadow-lg flex items-center gap-2">
          <span class="material-symbols-outlined text-sm">check_circle</span>
          Salvo com sucesso!
        </div>

      </div>
    </main>
  </div>
</Layout>

<script>
  import { supabase, getProfile, updateProfile, uploadAvatar, signOut, updatePassword, listAllProfiles, setUserRole, deleteUserProfile, inviteUser } from '../lib/supabase';
  import type { Profile } from '../lib/supabase';

  const loadingEl = document.getElementById('profile-loading')!;
  const unauthEl = document.getElementById('profile-unauth')!;
  const contentEl = document.getElementById('profile-content')!;

  let currentProfile: Profile | null = null;
  let currentUserId: string = '';
  let currentUserEmail: string = '';

  function showFeedback() {
    const fb = document.getElementById('save-feedback')!;
    fb.classList.remove('hidden');
    setTimeout(() => fb.classList.add('hidden'), 2000);
  }

  function applyThemeToPage(theme: string) {
    if (theme === 'light') {
      document.documentElement.classList.remove('dark');
      document.documentElement.classList.add('light');
      localStorage.setItem('bc-theme', 'light');
    } else {
      document.documentElement.classList.remove('light');
      document.documentElement.classList.add('dark');
      localStorage.setItem('bc-theme', 'dark');
    }
  }

  function getInitials(name: string): string {
    return name.split(' ').map(w => w[0]).join('').toUpperCase().slice(0, 2);
  }

  function renderProfile(profile: Profile, email: string) {
    // Name + Email
    document.getElementById('profile-name')!.textContent = profile.full_name || 'Usuário';
    document.getElementById('profile-email')!.textContent = email;
    (document.getElementById('input-name') as HTMLInputElement).value = profile.full_name || '';
    (document.getElementById('input-email') as HTMLInputElement).value = email;

    // Avatar
    const avatarImg = document.getElementById('avatar-img') as HTMLImageElement;
    const avatarInitials = document.getElementById('avatar-initials')!;
    if (profile.avatar_url) {
      avatarImg.src = profile.avatar_url;
      avatarImg.classList.remove('hidden');
      avatarInitials.classList.add('hidden');
    } else {
      avatarImg.classList.add('hidden');
      avatarInitials.classList.remove('hidden');
      avatarInitials.textContent = getInitials(profile.full_name || email);
    }

    // Seniority Badge
    const badgeText = document.getElementById('badge-text')!;
    badgeText.textContent = profile.seniority.charAt(0).toUpperCase() + profile.seniority.slice(1);

    // Role Badge
    const roleBadge = document.getElementById('role-badge')!;
    const roleBadgeText = document.getElementById('role-badge-text')!;
    if (profile.role === 'master') {
      roleBadge.classList.remove('hidden');
      roleBadge.classList.add('inline-flex');
      roleBadge.className = roleBadge.className.replace(/bg-\S+/g, '').replace(/text-\S+/g, '').replace(/border-\S+/g, '');
      roleBadge.className = 'inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-purple-500/15 text-purple-400 border border-purple-500/20';
      roleBadgeText.textContent = 'Master';
    } else if (profile.role === 'admin') {
      roleBadge.classList.remove('hidden');
      roleBadge.classList.add('inline-flex');
      roleBadge.className = 'inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-amber-500/15 text-amber-400 border border-amber-500/20';
      roleBadgeText.textContent = 'Admin';
    } else {
      roleBadge.classList.add('hidden');
      roleBadge.classList.remove('inline-flex');
    }

    // Seniority buttons
    document.querySelectorAll('.seniority-btn').forEach(btn => {
      const val = (btn as HTMLElement).dataset.seniority;
      if (val === profile.seniority) {
        btn.className = 'seniority-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border bg-primary/15 text-primary border-primary/30';
      } else {
        btn.className = 'seniority-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border text-slate-500 border-border-color hover:text-white hover:bg-surface-light';
      }
    });

    // Theme buttons
    document.querySelectorAll('.theme-btn').forEach(btn => {
      const val = (btn as HTMLElement).dataset.theme;
      if (val === profile.theme) {
        btn.className = 'theme-btn py-3 rounded-xl text-sm font-bold transition-all cursor-pointer border flex items-center justify-center gap-2 bg-primary/15 text-primary border-primary/30';
      } else {
        btn.className = 'theme-btn py-3 rounded-xl text-sm font-bold transition-all cursor-pointer border flex items-center justify-center gap-2 text-slate-500 border-border-color hover:text-white hover:bg-surface-light';
      }
    });

    applyThemeToPage(profile.theme);

    // Show admin panel for master
    const adminPanel = document.getElementById('admin-panel')!;
    if (profile.role === 'master') {
      adminPanel.classList.remove('hidden');
      loadUsers();
    }
  }

  // ══════════════════════════════
  //  USER MANAGEMENT
  // ══════════════════════════════

  async function loadUsers() {
    const tbody = document.getElementById('users-table-body')!;
    const profiles = await listAllProfiles();

    // We need emails — fetch from auth if possible, otherwise show ID
    tbody.innerHTML = '';

    if (profiles.length === 0) {
      tbody.innerHTML = '<tr><td colspan="5" class="py-8 text-center text-slate-500">Nenhum usuário encontrado</td></tr>';
      return;
    }

    profiles.forEach(p => {
      const isSelf = p.id === currentUserId;
      const roleLabel = p.role === 'master' ? 'Master' : p.role === 'admin' ? 'Administrador' : 'Usuário';
      const roleColor = p.role === 'master' ? 'text-purple-400 bg-purple-500/10 border-purple-500/20'
        : p.role === 'admin' ? 'text-amber-400 bg-amber-500/10 border-amber-500/20'
        : 'text-slate-400 bg-white/5 border-border-color';

      const row = document.createElement('tr');
      row.className = 'group';
      row.innerHTML = `
        <td class="py-3.5 pr-4">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-xs font-bold text-primary border border-primary/20 overflow-hidden">
              ${p.avatar_url
                ? `<img src="${p.avatar_url}" class="w-full h-full object-cover" />`
                : `<span>${getInitials(p.full_name || '??')}</span>`
              }
            </div>
            <span class="text-white font-medium">${p.full_name || 'Sem nome'}${isSelf ? ' <span class="text-slate-500 text-xs">(você)</span>' : ''}</span>
          </div>
        </td>
        <td class="py-3.5 pr-4 text-slate-400">${p.id.slice(0, 8)}...</td>
        <td class="py-3.5 pr-4">
          <span class="inline-flex px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider border ${roleColor}">${roleLabel}</span>
        </td>
        <td class="py-3.5 pr-4 text-slate-400 capitalize">${p.seniority}</td>
        <td class="py-3.5 text-right">
          ${isSelf || p.role === 'master' ? '' : `
            <div class="flex items-center gap-1 justify-end opacity-0 group-hover:opacity-100 transition-opacity">
              <select data-user-id="${p.id}" class="role-select rounded-lg border border-border-color bg-surface-dark/50 px-2 py-1 text-xs text-white outline-none cursor-pointer">
                <option value="user" ${p.role === 'user' ? 'selected' : ''}>Usuário</option>
                <option value="admin" ${p.role === 'admin' ? 'selected' : ''}>Admin</option>
              </select>
              <button data-delete-user="${p.id}" class="p-1.5 rounded-lg text-red-400/60 hover:text-red-400 hover:bg-red-500/10 transition-all cursor-pointer" title="Remover usuário">
                <span class="material-symbols-outlined text-sm">delete</span>
              </button>
            </div>
          `}
        </td>
      `;
      tbody.appendChild(row);
    });

    // Role change handlers
    tbody.querySelectorAll('.role-select').forEach(select => {
      select.addEventListener('change', async (e) => {
        const el = e.target as HTMLSelectElement;
        const userId = el.dataset.userId!;
        const newRole = el.value;
        const { error } = await setUserRole(userId, newRole);
        if (error) {
          alert('Erro ao alterar cargo: ' + error.message);
          loadUsers();
        } else {
          showFeedback();
          loadUsers();
        }
      });
    });

    // Delete handlers
    tbody.querySelectorAll('[data-delete-user]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const userId = (btn as HTMLElement).dataset.deleteUser!;
        if (!confirm('Tem certeza que deseja remover este usuário?')) return;
        const { error } = await deleteUserProfile(userId);
        if (error) {
          alert('Erro ao remover: ' + error.message);
        } else {
          showFeedback();
          loadUsers();
        }
      });
    });
  }

  // Init
  async function init() {
    const { data: { session } } = await supabase.auth.getSession();

    if (!session) {
      loadingEl.classList.add('hidden');
      unauthEl.classList.remove('hidden');
      unauthEl.classList.add('flex');
      return;
    }

    currentUserId = session.user.id;
    currentUserEmail = session.user.email || '';
    const profile = await getProfile(currentUserId);

    if (!profile) {
      loadingEl.classList.add('hidden');
      unauthEl.classList.remove('hidden');
      unauthEl.classList.add('flex');
      return;
    }

    currentProfile = profile;
    renderProfile(profile, currentUserEmail);
    loadingEl.classList.add('hidden');
    contentEl.classList.remove('hidden');
  }

  init();

  // Logout
  document.getElementById('btn-logout')!.addEventListener('click', async () => {
    await signOut();
    localStorage.removeItem('bc-theme');
    window.location.href = '/';
  });

  // Save name
  document.getElementById('btn-save-name')!.addEventListener('click', async () => {
    const name = (document.getElementById('input-name') as HTMLInputElement).value.trim();
    if (!name) return;
    await updateProfile(currentUserId, { full_name: name });
    document.getElementById('profile-name')!.textContent = name;
    document.getElementById('avatar-initials')!.textContent = getInitials(name);
    showFeedback();
  });

  // Seniority
  document.querySelectorAll('.seniority-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const val = (btn as HTMLElement).dataset.seniority as Profile['seniority'];
      await updateProfile(currentUserId, { seniority: val });
      if (currentProfile) {
        currentProfile.seniority = val;
        renderProfile(currentProfile, currentUserEmail);
      }
      showFeedback();
    });
  });

  // Theme
  document.querySelectorAll('.theme-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const val = (btn as HTMLElement).dataset.theme as Profile['theme'];
      await updateProfile(currentUserId, { theme: val });
      if (currentProfile) {
        currentProfile.theme = val;
        renderProfile(currentProfile, currentUserEmail);
      }
      showFeedback();
    });
  });

  // Avatar upload
  document.getElementById('avatar-input')!.addEventListener('change', async (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;

    const avatarImg = document.getElementById('avatar-img') as HTMLImageElement;
    const avatarInitials = document.getElementById('avatar-initials')!;

    const reader = new FileReader();
    reader.onload = () => {
      avatarImg.src = reader.result as string;
      avatarImg.classList.remove('hidden');
      avatarInitials.classList.add('hidden');
    };
    reader.readAsDataURL(file);

    const url = await uploadAvatar(currentUserId, file);
    if (url) {
      await updateProfile(currentUserId, { avatar_url: url + '?t=' + Date.now() });
      showFeedback();
    }
  });

  // ══════════════════════════════
  //  PASSWORD CHANGE
  // ══════════════════════════════

  document.getElementById('btn-save-password')!.addEventListener('click', async () => {
    const newPass = (document.getElementById('input-new-password') as HTMLInputElement).value;
    const confirmPass = (document.getElementById('input-confirm-password') as HTMLInputElement).value;
    const msgEl = document.getElementById('password-msg')!;

    if (!newPass || !confirmPass) {
      msgEl.className = 'rounded-xl px-4 py-3 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
      msgEl.textContent = 'Preencha ambos os campos.';
      return;
    }

    if (newPass.length < 6) {
      msgEl.className = 'rounded-xl px-4 py-3 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
      msgEl.textContent = 'A senha deve ter no mínimo 6 caracteres.';
      return;
    }

    if (newPass !== confirmPass) {
      msgEl.className = 'rounded-xl px-4 py-3 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
      msgEl.textContent = 'As senhas não coincidem.';
      return;
    }

    const { error } = await updatePassword(newPass);
    if (error) {
      msgEl.className = 'rounded-xl px-4 py-3 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
      msgEl.textContent = 'Erro ao atualizar senha: ' + error.message;
    } else {
      msgEl.className = 'rounded-xl px-4 py-3 text-sm font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/20';
      msgEl.textContent = 'Senha atualizada com sucesso!';
      (document.getElementById('input-new-password') as HTMLInputElement).value = '';
      (document.getElementById('input-confirm-password') as HTMLInputElement).value = '';
      setTimeout(() => { msgEl.className = 'hidden'; }, 3000);
    }
  });

  // ══════════════════════════════
  //  ADD USER (Master only)
  // ══════════════════════════════

  document.getElementById('btn-add-user')!.addEventListener('click', () => {
    document.getElementById('add-user-form')!.classList.toggle('hidden');
  });

  document.getElementById('btn-cancel-add')!.addEventListener('click', () => {
    document.getElementById('add-user-form')!.classList.add('hidden');
  });

  document.getElementById('btn-confirm-add')!.addEventListener('click', async () => {
    const name = (document.getElementById('new-user-name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('new-user-email') as HTMLInputElement).value.trim();
    const role = (document.getElementById('new-user-role') as HTMLSelectElement).value as 'user' | 'admin';
    const msgEl = document.getElementById('add-user-msg')!;

    if (!name || !email) {
      msgEl.className = 'rounded-lg px-3 py-2 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
      msgEl.textContent = 'Preencha nome e e-mail.';
      return;
    }

    msgEl.className = 'rounded-lg px-3 py-2 text-sm font-medium bg-primary/10 text-primary border border-primary/20';
    msgEl.textContent = 'Criando usuário...';

    const { error } = await inviteUser(email, name, role);
    if (error) {
      msgEl.className = 'rounded-lg px-3 py-2 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
      msgEl.textContent = 'Erro: ' + error.message;
    } else {
      msgEl.className = 'rounded-lg px-3 py-2 text-sm font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/20';
      msgEl.textContent = 'Usuário criado! Um e-mail de redefinição de senha foi enviado.';
      (document.getElementById('new-user-name') as HTMLInputElement).value = '';
      (document.getElementById('new-user-email') as HTMLInputElement).value = '';
      loadUsers();
      setTimeout(() => {
        document.getElementById('add-user-form')!.classList.add('hidden');
        msgEl.className = 'hidden';
      }, 3000);
    }
  });
</script>
