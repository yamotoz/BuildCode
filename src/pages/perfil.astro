<script is:inline>
  function switchProfileTab(tab) {
    var perfil = document.getElementById('tab-perfil');
    var plano = document.getElementById('tab-plano');
    var perfilSections = document.querySelectorAll('.perfil-section');
    if (!perfil || !plano) return;
    if (tab === 'plano') {
      perfil.classList.add('hidden');
      plano.classList.remove('hidden');
      perfilSections.forEach(function(s) { s.classList.add('hidden'); });
      // Hide profile card, logout, admin panel, upgrade toast, confirm modal, agent loading
      var profileCard = document.querySelector('#profile-content > .space-y-8 > .rounded-2xl:first-child');
      if (profileCard) profileCard.classList.add('hidden');
      var logoutWrap = document.querySelector('#profile-content .flex.justify-center.pt-4.pb-8');
      if (logoutWrap) logoutWrap.classList.add('hidden');
      var adminPanel = document.getElementById('admin-panel');
      if (adminPanel) adminPanel.classList.add('hidden');
    } else {
      plano.classList.add('hidden');
      perfil.classList.remove('hidden');
      perfilSections.forEach(function(s) { s.classList.remove('hidden'); });
      var profileCard = document.querySelector('#profile-content > .space-y-8 > .rounded-2xl:first-child');
      if (profileCard) profileCard.classList.remove('hidden');
      var logoutWrap = document.querySelector('#profile-content .flex.justify-center.pt-4.pb-8');
      if (logoutWrap) logoutWrap.classList.remove('hidden');
      // Re-show admin panel if user is master (it was hidden during plano view)
      var adminPanel = document.getElementById('admin-panel');
      if (adminPanel && adminPanel.dataset.isMaster === 'true') adminPanel.classList.remove('hidden');
    }
  }
  // Auto-switch to plano tab if hash is #plano
  if (window.location.hash === '#plano') {
    switchProfileTab('plano');
  }
  // Listen for hash changes (e.g. clicking Plano from dropdown while on /perfil)
  window.addEventListener('hashchange', function() {
    if (window.location.hash === '#plano') {
      switchProfileTab('plano');
    } else {
      switchProfileTab('perfil');
    }
  });
</script>

<script>
  import { supabase, getProfile, updateProfile, uploadAvatar, signOut, updatePassword, listAllProfiles, setUserRole, deleteUserProfile, inviteUser, getUserSubscription, getUserProjects, deleteProject, deleteOwnAccount } from '../lib/supabase';
  import type { Profile, Subscription, Project } from '../lib/supabase';

  const loadingEl = document.getElementById('profile-loading')!;
  const unauthEl = document.getElementById('profile-unauth')!;
  const contentEl = document.getElementById('profile-content')!;

  let currentProfile: Profile | null = null;
  let currentUserId: string = '';

  // === HTML Escape (previne XSS) ===
  function esc(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // === Upgrade Toast ===
  let toastTimer: ReturnType<typeof setTimeout> | null = null;

  // ── Confirm modal (replaces browser confirm()) ──
  function bcConfirm(title: string, msg: string): Promise<boolean> {
    return new Promise(resolve => {
      const modal = document.getElementById('bc-confirm-modal')!;
      const titleEl = document.getElementById('bc-confirm-title')!;
      const msgEl = document.getElementById('bc-confirm-msg')!;
      const yesBtn = document.getElementById('bc-confirm-yes')!;
      const noBtn = document.getElementById('bc-confirm-no')!;
      const backdrop = document.getElementById('bc-confirm-backdrop')!;

      titleEl.textContent = title;
      msgEl.textContent = msg;
      modal.classList.remove('hidden');

      function close(result: boolean) {
        modal.classList.add('hidden');
        yesBtn.removeEventListener('click', onYes);
        noBtn.removeEventListener('click', onNo);
        backdrop.removeEventListener('click', onNo);
        resolve(result);
      }
      function onYes() { close(true); }
      function onNo() { close(false); }

      yesBtn.addEventListener('click', onYes);
      noBtn.addEventListener('click', onNo);
      backdrop.addEventListener('click', onNo);
    });
  }

  function showUpgradeToast(title: string, msg: string) {
    const toast = document.getElementById('upgrade-toast');
    const titleEl = document.getElementById('upgrade-toast-title');
    const msgEl = document.getElementById('upgrade-toast-msg');
    if (!toast || !titleEl || !msgEl) return;
    titleEl.textContent = title;
    msgEl.textContent = msg;
    toast.classList.remove('hidden');
    toast.style.animation = 'none';
    toast.offsetHeight; // force reflow
    toast.style.animation = 'slideDown 0.3s ease-out';
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(() => hideUpgradeToast(), 5000);
  }

  function hideUpgradeToast() {
    const toast = document.getElementById('upgrade-toast');
    if (!toast) return;
    toast.classList.add('hidden');
    if (toastTimer) { clearTimeout(toastTimer); toastTimer = null; }
  }

  document.getElementById('upgrade-toast-close')?.addEventListener('click', hideUpgradeToast);
  document.getElementById('upgrade-toast-dismiss')?.addEventListener('click', hideUpgradeToast);
  let currentUserEmail: string = '';

  function showFeedback() {
    const fb = document.getElementById('save-feedback')!;
    fb.classList.remove('hidden');
    setTimeout(() => fb.classList.add('hidden'), 2000);
  }

  function applyThemeToPage(theme: string) {
    if (theme === 'light') {
      document.documentElement.classList.remove('dark');
      document.documentElement.classList.add('light');
      localStorage.setItem('bc-theme', 'light');
    } else {
      document.documentElement.classList.remove('light');
      document.documentElement.classList.add('dark');
      localStorage.setItem('bc-theme', 'dark');
    }
  }

  function getInitials(name: string): string {
    return name.split(' ').map(w => w[0]).join('').toUpperCase().slice(0, 2);
  }

  function renderProfile(profile: Profile, email: string) {
    // Nome + Email
    document.getElementById('profile-name')!.textContent = profile.full_name || 'Usuário';
    document.getElementById('profile-email')!.textContent = email;
    (document.getElementById('input-name') as HTMLInputElement).value = profile.full_name || '';
    (document.getElementById('input-email') as HTMLInputElement).value = email;

    // Avatar
    const avatarImg = document.getElementById('avatar-img') as HTMLImageElement;
    const avatarInitials = document.getElementById('avatar-initials')!;
    if (profile.avatar_url) {
      avatarImg.src = profile.avatar_url;
      avatarImg.classList.remove('hidden');
      avatarInitials.classList.add('hidden');
    } else {
      avatarImg.classList.add('hidden');
      avatarInitials.classList.remove('hidden');
      avatarInitials.textContent = getInitials(profile.full_name || email);
    }

    // Badge de Senioridade
    const badgeText = document.getElementById('badge-text')!;
    badgeText.textContent = profile.seniority.charAt(0).toUpperCase() + profile.seniority.slice(1);

    // Badge de Cargo
    const roleBadge = document.getElementById('role-badge')!;
    const roleBadgeText = document.getElementById('role-badge-text')!;
    if (profile.role === 'master') {
      roleBadge.classList.remove('hidden');
      roleBadge.classList.add('inline-flex');
      roleBadge.className = roleBadge.className.replace(/bg-\S+/g, '').replace(/text-\S+/g, '').replace(/border-\S+/g, '');
      roleBadge.className = 'inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-purple-500/15 text-purple-400 border border-purple-500/20';
      roleBadgeText.textContent = 'Master';
    } else if (profile.role === 'admin') {
      roleBadge.classList.remove('hidden');
      roleBadge.classList.add('inline-flex');
      roleBadge.className = 'inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-amber-500/15 text-amber-400 border border-amber-500/20';
      roleBadgeText.textContent = 'Admin';
    } else {
      roleBadge.classList.add('hidden');
      roleBadge.classList.remove('inline-flex');
    }

    // Botões de senioridade
    document.querySelectorAll('.seniority-btn').forEach(btn => {
      const val = (btn as HTMLElement).dataset.seniority;
      if (val === profile.seniority) {
        btn.className = 'seniority-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border bg-primary/15 text-primary border-primary/30';
      } else {
        btn.className = 'seniority-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border text-slate-500 border-border-color hover:text-white hover:bg-surface-light';
      }
    });

    // Botões de tema
    document.querySelectorAll('.theme-btn').forEach(btn => {
      const val = (btn as HTMLElement).dataset.theme;
      if (val === profile.theme) {
        btn.className = 'theme-btn py-3 rounded-xl text-sm font-bold transition-all cursor-pointer border flex items-center justify-center gap-2 bg-primary/15 text-primary border-primary/30';
      } else {
        btn.className = 'theme-btn py-3 rounded-xl text-sm font-bold transition-all cursor-pointer border flex items-center justify-center gap-2 text-slate-500 border-border-color hover:text-white hover:bg-surface-light';
      }
    });

    applyThemeToPage(profile.theme);

    // Botões de idioma
    const savedLang = (profile as any).preferred_language || localStorage.getItem('bc-lang') || 'pt';
    document.querySelectorAll('.lang-btn').forEach(btn => {
      const val = (btn as HTMLElement).dataset.lang;
      if (val === savedLang) {
        btn.className = 'lang-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border flex items-center justify-center gap-2 bg-primary/15 text-primary border-primary/30';
      } else {
        btn.className = 'lang-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border flex items-center justify-center gap-2 text-slate-500 border-border-color hover:text-white hover:bg-surface-light';
      }
    });

    // Exibe painel admin para master
    const adminPanel = document.getElementById('admin-panel')!;
    if (profile.role === 'master') {
      adminPanel.classList.remove('hidden');
      adminPanel.dataset.isMaster = 'true';
      loadUsers();
      // Mostra plan switcher para master
      const switcher = document.getElementById('master-plan-switcher');
      if (switcher) switcher.classList.remove('hidden');
    }
  }

  // ══════════════════════════════
  //  GESTÃO DE USUÁRIOS
  // ══════════════════════════════

  let usersLoading = false;
  let allProfiles: Profile[] = [];
  let userFilter: 'admins' | 'all' = 'admins'; // padrão: exibe apenas admins
  let userSearchQuery = '';

  async function loadUsers() {
    if (usersLoading) return;
    usersLoading = true;

    try {
      const tbody = document.getElementById('users-table-body')!;
      const emptyMsg = document.getElementById('users-empty-msg');
      allProfiles = await listAllProfiles();
      renderUsersTable();
      attachUserTableEvents();
    } catch (err) {
      console.error('Erro ao carregar usuários:', err);
    } finally {
      usersLoading = false;
    }
  }

  function getFilteredProfiles(): Profile[] {
    let filtered = allProfiles;

    // Filtro por cargo
    if (userFilter === 'admins') {
      filtered = filtered.filter(p => p.role === 'admin' || p.role === 'master');
    }

    // Filtro de busca
    if (userSearchQuery.length > 0) {
      const q = userSearchQuery.toLowerCase();
      filtered = filtered.filter(p =>
        (p.full_name || '').toLowerCase().includes(q) ||
        (p.id || '').toLowerCase().includes(q)
      );
    }

    return filtered;
  }

  function renderUsersTable() {
    const tbody = document.getElementById('users-table-body')!;
    const emptyMsg = document.getElementById('users-empty-msg');
    const profiles = getFilteredProfiles();

    tbody.innerHTML = '';

    if (profiles.length === 0) {
      tbody.innerHTML = '';
      if (emptyMsg) {
        emptyMsg.textContent = userSearchQuery ? `Nenhum usuario encontrado para "${userSearchQuery}"` : (userFilter === 'admins' ? 'Nenhum administrador encontrado.' : 'Nenhum usuario encontrado.');
        emptyMsg.classList.remove('hidden');
      }
      return;
    }

    if (emptyMsg) emptyMsg.classList.add('hidden');

    profiles.forEach(p => {
      const isSelf = p.id === currentUserId;
      const roleLabel = p.role === 'master' ? 'Master' : p.role === 'admin' ? 'Administrador' : 'Usuário';
      const roleColor = p.role === 'master' ? 'text-purple-400 bg-purple-500/10 border-purple-500/20'
        : p.role === 'admin' ? 'text-amber-400 bg-amber-500/10 border-amber-500/20'
        : 'text-slate-400 bg-white/5 border-border-color';
      const isVip = p.plan === 'vip';
      const vipBadge = isVip ? `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wider border bg-blue-900/40 text-blue-300 border-blue-700/50 ml-1.5">⬡ VIP</span>` : '';

      // Destaca resultado de busca
      const displayName = p.full_name || 'Sem nome';
      let nameHtml = esc(displayName);
      if (userSearchQuery.length > 0) {
        const escaped = esc(displayName);
        const escapedQuery = esc(userSearchQuery);
        const idx = escaped.toLowerCase().indexOf(escapedQuery.toLowerCase());
        if (idx !== -1) {
          nameHtml = escaped.substring(0, idx) + '<mark class="bg-purple-500/30 text-white rounded px-0.5">' + escaped.substring(idx, idx + escapedQuery.length) + '</mark>' + escaped.substring(idx + escapedQuery.length);
        }
      }

      const row = document.createElement('tr');
      row.className = 'group';
      row.innerHTML = `
        <td class="py-3.5 pr-4">
          <div class="flex items-center gap-3">
            <div data-open-analytics="${p.id}" class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-xs font-bold text-primary border border-primary/20 overflow-hidden cursor-pointer hover:ring-2 hover:ring-primary/40 transition-all" title="Ver analytics de ${esc(p.full_name || '')}">
              ${p.avatar_url
                ? `<img src="${esc(p.avatar_url)}" class="w-full h-full object-cover pointer-events-none" />`
                : `<span class="pointer-events-none">${esc(getInitials(p.full_name || '??'))}</span>`
              }
            </div>
            <span class="text-white font-medium">${nameHtml}${isSelf ? ' <span class="text-slate-500 text-xs">(você)</span>' : ''}${vipBadge}</span>
          </div>
        </td>
        <td class="py-3.5 pr-4 text-slate-400">${p.id.slice(0, 8)}...</td>
        <td class="py-3.5 pr-4">
          <span class="inline-flex px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider border ${roleColor}">${roleLabel}</span>
        </td>
        <td class="py-3.5 pr-4 text-slate-400 capitalize">${p.seniority}</td>
        <td class="py-3.5 text-right">
          ${isSelf || p.role === 'master' ? '' : `
            <div class="flex items-center gap-1 justify-end opacity-0 group-hover:opacity-100 transition-opacity">
              <select data-user-id="${p.id}" aria-label="Cargo de ${displayName}" class="role-select rounded-lg border border-border-color bg-surface-dark/50 px-2 py-1 text-xs text-white outline-none cursor-pointer">
                <option value="user" ${p.role === 'user' ? 'selected' : ''}>Usuário</option>
                <option value="admin" ${p.role === 'admin' ? 'selected' : ''}>Admin</option>
              </select>
              <button data-delete-user="${p.id}" data-delete-name="${displayName}" class="p-1.5 rounded-lg text-red-400/60 hover:text-red-400 hover:bg-red-500/10 transition-all cursor-pointer" title="Remover ${displayName}">
                <span class="material-symbols-outlined text-sm">delete</span>
              </button>
            </div>
          `}
        </td>
      `;
      tbody.appendChild(row);
    });
  }

  function attachUserTableEvents() {
    const tbody = document.getElementById('users-table-body')!;
    // Remove listeners antigos substituindo o nó
    const newTbody = tbody.cloneNode(true) as HTMLElement;
    tbody.parentNode!.replaceChild(newTbody, tbody);

    newTbody.addEventListener('change', async (e) => {
      const el = e.target as HTMLSelectElement;
      if (!el.classList.contains('role-select')) return;
      const userId = el.dataset.userId!;
      const newRole = el.value;
      el.disabled = true;
      const { error } = await setUserRole(userId, newRole);
      if (error) {
        showUpgradeToast('Erro', 'Erro ao alterar cargo: ' + error.message);
      } else {
        showFeedback();
      }
      await loadUsers();
    });

    newTbody.addEventListener('click', async (e) => {
      const btn = (e.target as HTMLElement).closest('[data-delete-user]') as HTMLElement;
      if (!btn) return;
      const userId = btn.dataset.deleteUser!;
      const userName = btn.dataset.deleteName || 'este usuario';
      if (!await bcConfirm('Remover Usuário', `Tem certeza que deseja remover "${userName}"? Esta ação é irreversível.`)) return;
      const { error } = await deleteUserProfile(userId);
      if (error) {
        showUpgradeToast('Erro', 'Erro ao remover: ' + error.message);
      } else {
        showFeedback();
      }
      await loadUsers();
    });
  }

  // Input de busca
  const userSearchInput = document.getElementById('user-search-input') as HTMLInputElement;
  userSearchInput?.addEventListener('input', () => {
    userSearchQuery = userSearchInput.value.trim();
    renderUsersTable();
    attachUserTableEvents();
  });

  // Botões de filtro
  const filterAdminsBtn = document.getElementById('filter-admins-btn');
  const filterAllBtn = document.getElementById('filter-all-btn');

  function updateFilterButtons() {
    const activeClass = 'bg-purple-500/10 text-purple-400 border-purple-500/20';
    const inactiveClass = 'text-slate-500 border-white/[0.06] hover:text-white hover:border-white/[0.12]';
    if (userFilter === 'admins') {
      filterAdminsBtn!.className = `user-filter-btn active flex items-center gap-1.5 px-3.5 py-2 rounded-xl text-xs font-semibold border transition-all cursor-pointer ${activeClass}`;
      filterAllBtn!.className = `user-filter-btn flex items-center gap-1.5 px-3.5 py-2 rounded-xl text-xs font-semibold border transition-all cursor-pointer ${inactiveClass}`;
    } else {
      filterAllBtn!.className = `user-filter-btn active flex items-center gap-1.5 px-3.5 py-2 rounded-xl text-xs font-semibold border transition-all cursor-pointer ${activeClass}`;
      filterAdminsBtn!.className = `user-filter-btn flex items-center gap-1.5 px-3.5 py-2 rounded-xl text-xs font-semibold border transition-all cursor-pointer ${inactiveClass}`;
    }
  }

  filterAdminsBtn?.addEventListener('click', () => {
    userFilter = 'admins';
    updateFilterButtons();
    renderUsersTable();
    attachUserTableEvents();
  });

  filterAllBtn?.addEventListener('click', () => {
    userFilter = 'all';
    updateFilterButtons();
    renderUsersTable();
    attachUserTableEvents();
  });

  // Inicialização
  async function init() {
    const { data: { session } } = await supabase.auth.getSession();

    if (!session) {
      loadingEl.classList.add('hidden');
      unauthEl.classList.remove('hidden');
      unauthEl.classList.add('flex');
      return;
    }

    currentUserId = session.user.id;
    currentUserEmail = session.user.email || '';
    const profile = await getProfile(currentUserId);

    if (!profile) {
      loadingEl.classList.add('hidden');
      unauthEl.classList.remove('hidden');
      unauthEl.classList.add('flex');
      return;
    }

    // Redireciona para login se termos não aceitos (força modal de termos)
    if (!profile.terms_accepted_at) {
      window.location.href = '/login';
      return;
    }

    currentProfile = profile;
    renderProfile(profile, currentUserEmail);
    await loadUsageData();
    initAgentSelection();
    initLlmSelection();
    loadProjects();
    loadingEl.classList.add('hidden');
    contentEl.classList.remove('hidden');
  }

  async function loadUsageData() {
    try {
      // Carrega assinatura
      const sub = await getUserSubscription(currentUserId);
      const planNames: Record<string, string> = { explorador: 'Explorador', consultor: 'Consultor', arquiteto: 'Arquiteto', vip: '⬡ VIP' };
      const planColors: Record<string, { bg: string; text: string; border: string; label: string }> = {
        explorador: { bg: 'bg-emerald-500/15',  text: 'text-emerald-400', border: 'border-emerald-500/20', label: 'Free'  },
        consultor:  { bg: 'bg-primary/15',       text: 'text-primary',     border: 'border-primary/20',     label: 'Pro'   },
        arquiteto:  { bg: 'bg-cta/15',           text: 'text-cta',         border: 'border-cta/20',         label: 'Elite' },
        vip:        { bg: 'bg-blue-900/40',      text: 'text-blue-300',    border: 'border-blue-700/50',    label: 'VIP'   },
      };
      const plan = sub?.plan || 'explorador';
      // Store plan globally for agent/llm restrictions
      (window as any).__bcPlan = plan;
      const pc = planColors[plan] || planColors.explorador;

      // Update plan badge in profile card
      const planBadge = document.getElementById('plan-badge');
      const planBadgeText = document.getElementById('plan-badge-text');
      if (planBadge && planBadgeText) {
        planBadgeText.textContent = planNames[plan] || 'Explorador';
        planBadge.className = `inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider ${pc.bg} ${pc.text} border ${pc.border}`;
      }

      const nameEl = document.getElementById('usage-plan-name');
      const badgeEl = document.getElementById('usage-plan-badge');
      const periodEl = document.getElementById('usage-plan-period');
      if (nameEl) nameEl.textContent = planNames[plan] || 'Explorador';
      if (badgeEl) {
        badgeEl.textContent = pc.label;
        badgeEl.className = `text-[9px] px-2 py-0.5 rounded-full font-bold uppercase tracking-wider ${pc.bg} ${pc.text} border ${pc.border}`;
      }
      if (periodEl && sub?.current_period_end) {
        const end = new Date(sub.current_period_end);
        periodEl.textContent = `Válido até ${end.toLocaleDateString('pt-BR')}`;
      }

      // Créditos padrão por plano (quando user_credits não existe ainda)
      const PLAN_DEFAULTS: Record<string, { eco: number; mid: number; elite: number }> = {
        explorador: { eco: 50,     mid: 0,      elite: 0      },
        consultor:  { eco: 999999, mid: 999999, elite: 20     },
        arquiteto:  { eco: 999999, mid: 999999, elite: 50     },
        vip:        { eco: 999999, mid: 999999, elite: 999999 },
      };

      // Carrega créditos e logs via API server-side (bypassa RLS)
      const { data: { session: currentSession } } = await supabase.auth.getSession();
      let credits: any = null;
      let allLogs: any[] = [];
      try {
        const statsRes = await fetch('/api/usage-stats', {
          headers: { 'Authorization': `Bearer ${currentSession?.access_token}` },
        });
        if (statsRes.ok) {
          const statsData = await statsRes.json();
          credits = statsData.credits;
          allLogs = statsData.logs || [];
          console.log('[Perfil] Logs carregados:', allLogs.length, '| Créditos indie:', credits);
        } else {
          console.error('[Perfil] usage-stats falhou:', statsRes.status);
        }
      } catch (e) { console.error('[Perfil] Erro ao carregar stats:', e); }

      const planLabelEl = document.getElementById('credits-plan-label');
      if (planLabelEl) planLabelEl.textContent = `(${planNames[plan] || 'mensal'})`;

      const monthStart = new Date();
      monthStart.setDate(1);
      monthStart.setHours(0, 0, 0, 0);
      const logs = allLogs.filter((l: any) => new Date(l.created_at) >= monthStart);

      const prdCount = logs.filter(l => l.action === 'prd_generation' || l.action?.startsWith('generation_')).length;
      const chatCount = logs.filter(l => l.action === 'chat_message').length;
      const ttsCount = logs.filter(l => l.action === 'tts_audio').length;

      const prdEl = document.getElementById('usage-prd-count');
      const chatEl = document.getElementById('usage-chat-count');
      const ttsEl = document.getElementById('usage-tts-count');
      if (prdEl) prdEl.textContent = String(prdCount);
      if (chatEl) chatEl.textContent = String(chatCount);
      if (ttsEl) ttsEl.textContent = String(ttsCount);

      // Atualiza créditos restantes (limite - uso do mês)
      // Limites SEMPRE vêm do plano — o banco pode ter valores desatualizados
      const defaults = PLAN_DEFAULTS[plan] || PLAN_DEFAULTS.explorador;
      const ecoLimit = defaults.eco;
      const midLimit = defaults.mid;
      const eliteLimit = defaults.elite;

      // Indie credits (from Recarga Rebelde)
      const indieEco = credits?.indie_credits_economy || 0;
      const indieMid = credits?.indie_credits_mid || 0;
      const indieElite = credits?.indie_credits_elite || 0;

      // Contar uso por tier no mês
      // Dupla verificação: por model ID OU por action tier (failsafe)
      const budgetModels = ['google/gemma-3-4b-it:free', 'meta-llama/llama-3.1-8b-instruct:free', 'mistralai/mistral-small-3.1-24b-instruct:free'];
      const midModels = ['google/gemini-2.0-flash-001', 'openai/gpt-4o-mini', 'anthropic/claude-3.5-haiku'];
      const proModels = ['anthropic/claude-sonnet-4', 'openai/gpt-4o', 'google/gemini-2.5-pro-preview'];

      const ecoUsed = logs.filter(l =>
        budgetModels.includes(l.llm_model) || l.action === 'chat_message' || l.action === 'generation_budget'
      ).length;
      const midUsed = logs.filter(l =>
        midModels.includes(l.llm_model) || l.action === 'generation_mid'
      ).length;
      const eliteUsed = logs.filter(l =>
        proModels.includes(l.llm_model) || l.action === 'generation_pro'
      ).length;

      // Lógica de crédito:
      // - Explorador: desconta do indie (Recarga Rebelde) PRIMEIRO, depois do plano
      // - Consultor/Arquiteto: desconta SOMENTE do plano. Indie credits ficam intocados.
      const calcCredits = (planLimit: number, indie: number, used: number, useIndie: boolean) => {
        if (planLimit >= 999999) return { indieLeft: indie, planLeft: 999999, total: 999999 };
        if (useIndie) {
          // Explorador: indie primeiro, depois plano
          const indieUsed = Math.min(indie, used);
          const indieLeft = indie - indieUsed;
          const remainingUsed = used - indieUsed;
          const planLeft = Math.max(planLimit - remainingUsed, 0);
          return { indieLeft, planLeft, total: indieLeft + planLeft };
        }
        // Consultor/Arquiteto: só plano, indie intocado
        const planLeft = Math.max(planLimit - used, 0);
        return { indieLeft: indie, planLeft, total: indie + planLeft };
      };

      const isExplorador = plan === 'explorador';

      console.log('[Perfil] Uso do mês:', { ecoUsed, midUsed, eliteUsed });
      console.log('[Perfil] Limites do plano:', { ecoLimit, midLimit, eliteLimit });
      console.log('[Perfil] Indie:', { indieEco, indieMid, indieElite });
      console.log('[Perfil] Actions nos logs:', logs.map(l => l.action + ':' + l.llm_model).slice(0, 20));

      const ecoCreds = calcCredits(ecoLimit, indieEco, ecoUsed, isExplorador);
      const midCreds = calcCredits(midLimit, indieMid, midUsed, isExplorador);
      const eliteCreds = calcCredits(eliteLimit, indieElite, eliteUsed, isExplorador);

      // Store globally for LLM lock system
      (window as any).__bcCredits = {
        eco: ecoCreds.total,
        mid: midCreds.total,
        elite: eliteCreds.total,
      };

      // Mostra créditos do plano
      const showPlanVal = (id: string, val: number, unlimited: boolean) => {
        const el = document.getElementById(id);
        if (!el) return;
        el.textContent = unlimited ? '∞' : String(val);
      };
      showPlanVal('credits-plan-eco', ecoCreds.planLeft, ecoLimit >= 999999);
      showPlanVal('credits-plan-mid', midCreds.planLeft, midLimit >= 999999);
      showPlanVal('credits-plan-elite', eliteCreds.planLeft, eliteLimit >= 999999);

      // Mostra créditos indie restantes
      const showIndieVal = (id: string, val: number) => {
        const el = document.getElementById(id);
        if (!el) return;
        el.textContent = String(val);
      };
      showIndieVal('credits-indie-eco', ecoCreds.indieLeft);
      showIndieVal('credits-indie-mid', midCreds.indieLeft);
      showIndieVal('credits-indie-elite', eliteCreds.indieLeft);

      // Uso por modelo
      const modelMap: Record<string, number> = {};
      logs.forEach(l => {
        if (l.llm_model) {
          modelMap[l.llm_model] = (modelMap[l.llm_model] || 0) + 1;
        }
      });

      const barsEl = document.getElementById('usage-model-bars');
      if (barsEl) {
        const entries = Object.entries(modelMap).sort((a, b) => b[1] - a[1]);
        if (entries.length === 0) {
          barsEl.innerHTML = '<p class="text-xs text-slate-600 italic">Nenhum uso registrado ainda.</p>';
        } else {
          const max = entries[0][1];
          barsEl.innerHTML = entries.map(([model, count]) => {
            const pct = Math.round((count / max) * 100);
            const shortName = model.split('/').pop()?.replace(':free', '') || model;
            return `<div class="flex items-center gap-3">
              <span class="text-xs text-slate-400 w-28 truncate shrink-0">${shortName}</span>
              <div class="flex-1 h-2 rounded-full bg-white/5 overflow-hidden">
                <div class="h-full rounded-full bg-primary transition-all" style="width: ${pct}%"></div>
              </div>
              <span class="text-xs text-slate-500 w-8 text-right">${count}</span>
            </div>`;
          }).join('');
        }
      }
      // ── Interactive chart: usage over time ──
      const lineChartEl = document.getElementById('usage-line-chart');
      if (lineChartEl) {
        // Group all logs by day and by tier
        const dayMap: Record<string, { eco: number; mid: number; elite: number }> = {};
        allLogs.forEach(l => {
          const day = new Date(l.created_at).toISOString().slice(0, 10);
          if (!dayMap[day]) dayMap[day] = { eco: 0, mid: 0, elite: 0 };
          if (budgetModels.includes(l.llm_model) || l.action === 'chat_message' || l.action === 'generation_budget') dayMap[day].eco++;
          else if (midModels.includes(l.llm_model) || l.action === 'generation_mid') dayMap[day].mid++;
          else if (proModels.includes(l.llm_model) || l.action === 'generation_pro') dayMap[day].elite++;
        });

        let chartPeriod = 'dias';
        let chartType = 'line';

        function getDaysForPeriod(period: string): string[] {
          const result: string[] = [];
          const today = new Date();
          if (period === 'dias') {
            // Last 14 days, grouped by day
            for (let i = 13; i >= 0; i--) {
              const d = new Date(today);
              d.setDate(d.getDate() - i);
              result.push(d.toISOString().slice(0, 10));
            }
          } else if (period === 'semanas') {
            // Last 8 weeks, grouped by week (use Monday as start)
            for (let w = 7; w >= 0; w--) {
              const d = new Date(today);
              d.setDate(d.getDate() - (w * 7));
              // Snap to Monday
              const day = d.getDay();
              const diff = day === 0 ? -6 : 1 - day;
              d.setDate(d.getDate() + diff);
              const key = d.toISOString().slice(0, 10);
              if (!result.includes(key)) result.push(key);
            }
          } else {
            // Last 6 months, grouped by month (use 1st of month)
            for (let m = 5; m >= 0; m--) {
              const d = new Date(today.getFullYear(), today.getMonth() - m, 1);
              result.push(d.toISOString().slice(0, 10));
            }
          }
          return result;
        }

        function aggregateForPeriod(period: string, keys: string[]): Record<string, { eco: number; mid: number; elite: number }> {
          const agg: Record<string, { eco: number; mid: number; elite: number }> = {};
          keys.forEach(k => agg[k] = { eco: 0, mid: 0, elite: 0 });

          Object.entries(dayMap).forEach(([day, val]) => {
            let bucket: string | null = null;
            if (period === 'dias') {
              bucket = keys.includes(day) ? day : null;
            } else if (period === 'semanas') {
              // Find which week bucket this day belongs to
              const dayDate = new Date(day + 'T00:00:00');
              for (let i = keys.length - 1; i >= 0; i--) {
                const weekStart = new Date(keys[i] + 'T00:00:00');
                const weekEnd = new Date(weekStart);
                weekEnd.setDate(weekEnd.getDate() + 7);
                if (dayDate >= weekStart && dayDate < weekEnd) {
                  bucket = keys[i];
                  break;
                }
              }
            } else {
              // Month: match year-month
              const ym = day.slice(0, 7);
              const match = keys.find(k => k.slice(0, 7) === ym);
              if (match) bucket = match;
            }
            if (bucket && agg[bucket]) {
              agg[bucket].eco += val.eco;
              agg[bucket].mid += val.mid;
              agg[bucket].elite += val.elite;
            }
          });
          return agg;
        }

        function renderChart() {
          if (!lineChartEl) return;
          const chartKeys = getDaysForPeriod(chartPeriod);
          const data = aggregateForPeriod(chartPeriod, chartKeys);

          const totalEco = chartKeys.reduce((s, k) => s + data[k].eco, 0);
          const totalMid = chartKeys.reduce((s, k) => s + data[k].mid, 0);
          const totalElite = chartKeys.reduce((s, k) => s + data[k].elite, 0);
          const totalAll = totalEco + totalMid + totalElite;

          const legend = `<div class="flex items-center gap-4 mb-3">
            <span class="flex items-center gap-1.5 text-[10px] font-bold"><span class="w-3 h-[3px] rounded-full bg-emerald-400 inline-block"></span><span class="text-slate-400">Econômica (${totalEco})</span></span>
            <span class="flex items-center gap-1.5 text-[10px] font-bold"><span class="w-3 h-[3px] rounded-full bg-amber-400 inline-block"></span><span class="text-slate-400">Média (${totalMid})</span></span>
            <span class="flex items-center gap-1.5 text-[10px] font-bold"><span class="w-3 h-[3px] rounded-full bg-purple-400 inline-block"></span><span class="text-slate-400">Elite (${totalElite})</span></span>
          </div>`;

          if (totalAll === 0) {
            lineChartEl.innerHTML = '<p class="text-xs text-slate-600 italic text-center py-8">Nenhum uso registrado neste período.</p>';
            return;
          }

          // Common chart setup
          const W = 500, H = 180, PAD = 30, PADR = 10, PADT = 10, PADB = 25;
          const plotW = W - PAD - PADR;
          const plotH = H - PADT - PADB;
          const maxVal = Math.max(1, ...chartKeys.map(k => Math.max(data[k].eco, data[k].mid, data[k].elite)));

          const toX = (i: number) => chartKeys.length === 1 ? PAD + plotW / 2 : PAD + (i / (chartKeys.length - 1)) * plotW;
          const toY = (v: number) => PADT + plotH - (v / maxVal) * plotH;

          const ySteps = [0, Math.round(maxVal / 2), maxVal];
          const yLabels = ySteps.map(v => `<text x="${PAD - 6}" y="${toY(v) + 3}" fill="#64748b" font-size="9" text-anchor="end">${v}</text>`).join('');
          const yLines = ySteps.map(v => `<line x1="${PAD}" y1="${toY(v)}" x2="${W - PADR}" y2="${toY(v)}" stroke="#1e293b" stroke-width="1"/>`).join('');

          // X-axis labels based on period type
          const step = Math.max(1, Math.floor(chartKeys.length / 6));
          const monthNames = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
          const xLabels = chartKeys.map((k, i) => {
            if (i % step !== 0 && i !== chartKeys.length - 1) return '';
            const parts = k.split('-');
            let label = `${parts[2]}/${parts[1]}`;
            if (chartPeriod === 'semanas') label = `S${parts[2]}/${parts[1]}`;
            if (chartPeriod === 'meses') label = monthNames[parseInt(parts[1]) - 1] || parts[1];
            return `<text x="${toX(i)}" y="${H - 4}" fill="#64748b" font-size="9" text-anchor="middle">${label}</text>`;
          }).join('');

          // Smooth bezier path helper
          function smoothPath(key: 'eco' | 'mid' | 'elite'): string {
            const pts = chartKeys.map((k, i) => ({ x: toX(i), y: toY(data[k][key]) }));
            if (pts.length < 2) return `M${pts[0].x},${pts[0].y}`;
            let path = `M${pts[0].x.toFixed(1)},${pts[0].y.toFixed(1)}`;
            for (let i = 0; i < pts.length - 1; i++) {
              const p0 = pts[Math.max(0, i - 1)];
              const p1 = pts[i];
              const p2 = pts[i + 1];
              const p3 = pts[Math.min(pts.length - 1, i + 2)];
              const cp1x = p1.x + (p2.x - p0.x) / 6;
              const cp1y = p1.y + (p2.y - p0.y) / 6;
              const cp2x = p2.x - (p3.x - p1.x) / 6;
              const cp2y = p2.y - (p3.y - p1.y) / 6;
              path += ` C${cp1x.toFixed(1)},${cp1y.toFixed(1)} ${cp2x.toFixed(1)},${cp2y.toFixed(1)} ${p2.x.toFixed(1)},${p2.y.toFixed(1)}`;
            }
            return path;
          }
          const areaPath = (key: 'eco' | 'mid' | 'elite') => {
            const line = smoothPath(key);
            const lastX = toX(chartKeys.length - 1);
            const firstX = toX(0);
            const baseY = toY(0);
            return `${line} L${lastX.toFixed(1)},${baseY.toFixed(1)} L${firstX.toFixed(1)},${baseY.toFixed(1)} Z`;
          };
          const totalLen = plotW + plotH;

          let chartContent = '';

          if (chartType === 'bar') {
            const barW = Math.max(2, Math.min(8, plotW / chartKeys.length / 4));
            chartContent = chartKeys.map((k, i) => {
              const x = toX(i);
              const baseY = toY(0);
              const eH = (data[k].eco / maxVal) * plotH;
              const mH = (data[k].mid / maxVal) * plotH;
              const elH = (data[k].elite / maxVal) * plotH;
              return `
                <rect x="${(x - barW * 1.5 - 1).toFixed(1)}" y="${(baseY - eH).toFixed(1)}" width="${barW}" height="${eH.toFixed(1)}" rx="1" fill="#34d399" opacity="0.85" class="chart-anim-bar" style="animation: chartGrowUp 0.5s ease-out ${i * 0.02}s both; transform-origin: bottom;">
                  <title>Eco: ${data[k].eco}</title></rect>
                <rect x="${(x - barW / 2).toFixed(1)}" y="${(baseY - mH).toFixed(1)}" width="${barW}" height="${mH.toFixed(1)}" rx="1" fill="#fbbf24" opacity="0.85" class="chart-anim-bar" style="animation: chartGrowUp 0.5s ease-out ${i * 0.02 + 0.1}s both; transform-origin: bottom;">
                  <title>Mid: ${data[k].mid}</title></rect>
                <rect x="${(x + barW / 2 + 1).toFixed(1)}" y="${(baseY - elH).toFixed(1)}" width="${barW}" height="${elH.toFixed(1)}" rx="1" fill="#a855f7" opacity="0.85" class="chart-anim-bar" style="animation: chartGrowUp 0.5s ease-out ${i * 0.02 + 0.2}s both; transform-origin: bottom;">
                  <title>Elite: ${data[k].elite}</title></rect>`;
            }).join('');
          } else if (chartType === 'area') {
            // Area chart: filled areas with stronger opacity, no stroke lines on top
            chartContent = `
              <defs>
                <linearGradient id="gEcoA" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#34d399" stop-opacity="0.4"/><stop offset="100%" stop-color="#34d399" stop-opacity="0.02"/></linearGradient>
                <linearGradient id="gMidA" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#fbbf24" stop-opacity="0.35"/><stop offset="100%" stop-color="#fbbf24" stop-opacity="0.02"/></linearGradient>
                <linearGradient id="gEliteA" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#a855f7" stop-opacity="0.35"/><stop offset="100%" stop-color="#a855f7" stop-opacity="0.02"/></linearGradient>
              </defs>
              <path d="${areaPath('eco')}" fill="url(#gEcoA)" class="chart-anim-area" style="animation: chartFadeIn 0.6s ease-out 0.1s both;"/>
              <path d="${areaPath('mid')}" fill="url(#gMidA)" class="chart-anim-area" style="animation: chartFadeIn 0.6s ease-out 0.25s both;"/>
              <path d="${areaPath('elite')}" fill="url(#gEliteA)" class="chart-anim-area" style="animation: chartFadeIn 0.6s ease-out 0.4s both;"/>
              <path d="${smoothPath('eco')}" fill="none" stroke="#34d399" stroke-width="1.5" stroke-linecap="round" stroke-opacity="0.6"/>
              <path d="${smoothPath('mid')}" fill="none" stroke="#fbbf24" stroke-width="1.5" stroke-linecap="round" stroke-opacity="0.6"/>
              <path d="${smoothPath('elite')}" fill="none" stroke="#a855f7" stroke-width="1.5" stroke-linecap="round" stroke-opacity="0.6"/>`;
          } else {
            // Line chart with smooth bezier curves
            chartContent = `
              <defs>
                <linearGradient id="gEco" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#34d399" stop-opacity="0.15"/><stop offset="100%" stop-color="#34d399" stop-opacity="0"/></linearGradient>
                <linearGradient id="gMid" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#fbbf24" stop-opacity="0.15"/><stop offset="100%" stop-color="#fbbf24" stop-opacity="0"/></linearGradient>
                <linearGradient id="gElite" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#a855f7" stop-opacity="0.15"/><stop offset="100%" stop-color="#a855f7" stop-opacity="0"/></linearGradient>
              </defs>
              <path d="${areaPath('eco')}" fill="url(#gEco)" class="chart-anim-area"/>
              <path d="${areaPath('mid')}" fill="url(#gMid)" class="chart-anim-area"/>
              <path d="${areaPath('elite')}" fill="url(#gElite)" class="chart-anim-area"/>
              <path d="${smoothPath('eco')}" fill="none" stroke="#34d399" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="chart-anim-line" style="stroke-dasharray: ${totalLen}; stroke-dashoffset: ${totalLen}; animation: chartDraw 1.2s ease-out 0.1s forwards;"/>
              <path d="${smoothPath('mid')}" fill="none" stroke="#fbbf24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="chart-anim-line" style="stroke-dasharray: ${totalLen}; stroke-dashoffset: ${totalLen}; animation: chartDraw 1.2s ease-out 0.3s forwards;"/>
              <path d="${smoothPath('elite')}" fill="none" stroke="#a855f7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="chart-anim-line" style="stroke-dasharray: ${totalLen}; stroke-dashoffset: ${totalLen}; animation: chartDraw 1.2s ease-out 0.5s forwards;"/>
              ${chartKeys.map((k, i) => {
                const hasData = data[k].eco > 0 || data[k].mid > 0 || data[k].elite > 0;
                if (!hasData) return '';
                return `
                  <circle cx="${toX(i)}" cy="${toY(data[k].eco)}" r="3.5" fill="#0D0D0D" stroke="#34d399" stroke-width="2" opacity="${data[k].eco > 0 ? 1 : 0}" style="animation: chartFadeIn 0.3s ease-out ${0.8 + i * 0.03}s both;"><title>Eco: ${data[k].eco}</title></circle>
                  <circle cx="${toX(i)}" cy="${toY(data[k].mid)}" r="3.5" fill="#0D0D0D" stroke="#fbbf24" stroke-width="2" opacity="${data[k].mid > 0 ? 1 : 0}" style="animation: chartFadeIn 0.3s ease-out ${0.8 + i * 0.03}s both;"><title>Mid: ${data[k].mid}</title></circle>
                  <circle cx="${toX(i)}" cy="${toY(data[k].elite)}" r="3.5" fill="#0D0D0D" stroke="#a855f7" stroke-width="2" opacity="${data[k].elite > 0 ? 1 : 0}" style="animation: chartFadeIn 0.3s ease-out ${0.8 + i * 0.03}s both;"><title>Elite: ${data[k].elite}</title></circle>`;
              }).join('')}`;
          }

          lineChartEl.innerHTML = `${legend}
            <svg viewBox="0 0 ${W} ${H}" class="w-full" style="max-height: 220px;">
              ${yLines}
              ${yLabels}
              ${xLabels}
              ${chartContent}
            </svg>`;
        }

        renderChart();

        // Chart controls
        document.querySelectorAll('.chart-period-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            chartPeriod = (btn as HTMLElement).dataset.chartPeriod || 'dias';
            document.querySelectorAll('.chart-period-btn').forEach(b => {
              (b as HTMLElement).className = 'chart-period-btn text-[9px] px-2.5 py-1 font-bold uppercase tracking-wider cursor-pointer transition-all ' +
                ((b as HTMLElement).dataset.chartPeriod === chartPeriod ? 'bg-primary/15 text-primary' : 'text-slate-500 hover:text-white');
            });
            renderChart();
          });
        });
        document.querySelectorAll('.chart-type-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            chartType = (btn as HTMLElement).dataset.chartType || 'line';
            document.querySelectorAll('.chart-type-btn').forEach(b => {
              (b as HTMLElement).className = 'chart-type-btn text-[9px] px-2 py-1 cursor-pointer transition-all ' +
                ((b as HTMLElement).dataset.chartType === chartType ? 'bg-primary/15 text-primary' : 'text-slate-500 hover:text-white');
            });
            renderChart();
          });
        });
      }

    } catch {
      // Tabelas podem ainda não existir — falha silenciosamente
    }
  }

