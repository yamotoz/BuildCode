    profiles.forEach(p => {
      const isSelf = p.id === currentUserId;
      const roleLabel = p.role === 'master' ? 'Master' : p.role === 'admin' ? 'Administrador' : 'Usuário';
      const roleColor = p.role === 'master' ? 'text-purple-400 bg-purple-500/10 border-purple-500/20'
        : p.role === 'admin' ? 'text-amber-400 bg-amber-500/10 border-amber-500/20'
        : 'text-slate-400 bg-white/5 border-border-color';

      const row = document.createElement('tr');
      row.className = 'group';
      row.innerHTML = `
        <td class="py-3.5 pr-4">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-xs font-bold text-primary border border-primary/20 overflow-hidden">
              ${p.avatar_url
                ? `<img src="${p.avatar_url}" class="w-full h-full object-cover" />`
                : `<span>${getInitials(p.full_name || '??')}</span>`
              }
            </div>
            <span class="text-white font-medium">${p.full_name || 'Sem nome'}${isSelf ? ' <span class="text-slate-500 text-xs">(você)</span>' : ''}</span>
          </div>
        </td>
        <td class="py-3.5 pr-4 text-slate-400">${p.id.slice(0, 8)}...</td>
        <td class="py-3.5 pr-4">
          <span class="inline-flex px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider border ${roleColor}">${roleLabel}</span>
        </td>
        <td class="py-3.5 pr-4 text-slate-400 capitalize">${p.seniority}</td>
        <td class="py-3.5 text-right">
          ${isSelf || p.role === 'master' ? '' : `
            <div class="flex items-center gap-1 justify-end opacity-0 group-hover:opacity-100 transition-opacity">
              <select data-user-id="${p.id}" class="role-select rounded-lg border border-border-color bg-surface-dark/50 px-2 py-1 text-xs text-white outline-none cursor-pointer">
                <option value="user" ${p.role === 'user' ? 'selected' : ''}>Usuário</option>
                <option value="admin" ${p.role === 'admin' ? 'selected' : ''}>Admin</option>
              </select>
              <button data-delete-user="${p.id}" class="p-1.5 rounded-lg text-red-400/60 hover:text-red-400 hover:bg-red-500/10 transition-all cursor-pointer" title="Remover usuário">
                <span class="material-symbols-outlined text-sm">delete</span>
              </button>
            </div>
          `}
        </td>
      `;
      tbody.appendChild(row);
    });

    // Role change handlers
    tbody.querySelectorAll('.role-select').forEach(select => {
      select.addEventListener('change', async (e) => {
        const el = e.target as HTMLSelectElement;
        const userId = el.dataset.userId!;
        const newRole = el.value;
        const { error } = await setUserRole(userId, newRole);
        if (error) {
          alert('Erro ao alterar cargo: ' + error.message);
          loadUsers();
        } else {
          showFeedback();
          loadUsers();
        }
      });
    });

    // Delete handlers
    tbody.querySelectorAll('[data-delete-user]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const userId = (btn as HTMLElement).dataset.deleteUser!;
        if (!confirm('Tem certeza que deseja remover este usuário?')) return;
        const { error } = await deleteUserProfile(userId);
        if (error) {
          alert('Erro ao remover: ' + error.message);
        } else {
          showFeedback();
          loadUsers();
        }
      });
    });
  }

  // Init
  async function init() {
    const { data: { session } } = await supabase.auth.getSession();

    if (!session) {
      loadingEl.classList.add('hidden');
      unauthEl.classList.remove('hidden');
      unauthEl.classList.add('flex');
      return;
    }

    currentUserId = session.user.id;
    currentUserEmail = session.user.email || '';
    const profile = await getProfile(currentUserId);

    if (!profile) {
      loadingEl.classList.add('hidden');
      unauthEl.classList.remove('hidden');
      unauthEl.classList.add('flex');
      return;
    }

    currentProfile = profile;
    renderProfile(profile, currentUserEmail);
    initAgentSelection();
    initLlmSelection();
    loadUsageData();
    loadingEl.classList.add('hidden');
    contentEl.classList.remove('hidden');
  }

  async function loadUsageData() {
    try {
      // Load subscription
      const sub = await getUserSubscription(currentUserId);
      const planNames: Record<string, string> = { explorador: 'Explorador', consultor: 'Consultor', arquiteto: 'Arquiteto' };
      const planColors: Record<string, { bg: string; text: string; border: string; label: string }> = {
        explorador: { bg: 'bg-emerald-500/15', text: 'text-emerald-400', border: 'border-emerald-500/20', label: 'Free' },
        consultor: { bg: 'bg-primary/15', text: 'text-primary', border: 'border-primary/20', label: 'Pro' },
        arquiteto: { bg: 'bg-cta/15', text: 'text-cta', border: 'border-cta/20', label: 'Elite' },
      };
      const plan = sub?.plan || 'explorador';
      const pc = planColors[plan] || planColors.explorador;
      const nameEl = document.getElementById('usage-plan-name');
      const badgeEl = document.getElementById('usage-plan-badge');
      const periodEl = document.getElementById('usage-plan-period');
      if (nameEl) nameEl.textContent = planNames[plan] || 'Explorador';
      if (badgeEl) {
        badgeEl.textContent = pc.label;
        badgeEl.className = `text-[9px] px-2 py-0.5 rounded-full font-bold uppercase tracking-wider ${pc.bg} ${pc.text} border ${pc.border}`;
      }
      if (periodEl && sub?.current_period_end) {
        const end = new Date(sub.current_period_end);
        periodEl.textContent = `Válido até ${end.toLocaleDateString('pt-BR')}`;
      }

      // Load usage stats
      const logs = await getUserUsageStats(currentUserId);
      const prdCount = logs.filter(l => l.action === 'prd_generation').length;
      const chatCount = logs.filter(l => l.action === 'chat_message').length;
      const ttsCount = logs.filter(l => l.action === 'tts_audio').length;

      const prdEl = document.getElementById('usage-prd-count');
      const chatEl = document.getElementById('usage-chat-count');
      const ttsEl = document.getElementById('usage-tts-count');
      if (prdEl) prdEl.textContent = String(prdCount);
      if (chatEl) chatEl.textContent = String(chatCount);
      if (ttsEl) ttsEl.textContent = String(ttsCount);

      // Usage by model
      const modelMap: Record<string, number> = {};
      logs.forEach(l => {
        if (l.llm_model) {
          modelMap[l.llm_model] = (modelMap[l.llm_model] || 0) + 1;
        }
      });

      const barsEl = document.getElementById('usage-model-bars');
      if (barsEl) {
        const entries = Object.entries(modelMap).sort((a, b) => b[1] - a[1]);
        if (entries.length === 0) {
          barsEl.innerHTML = '<p class="text-xs text-slate-600 italic">Nenhum uso registrado ainda.</p>';
        } else {
          const max = entries[0][1];
          barsEl.innerHTML = entries.map(([model, count]) => {
            const pct = Math.round((count / max) * 100);
            const shortName = model.split('/').pop()?.replace(':free', '') || model;
            return `<div class="flex items-center gap-3">
              <span class="text-xs text-slate-400 w-28 truncate shrink-0">${shortName}</span>
              <div class="flex-1 h-2 rounded-full bg-white/5 overflow-hidden">
                <div class="h-full rounded-full bg-primary transition-all" style="width: ${pct}%"></div>
              </div>
              <span class="text-xs text-slate-500 w-8 text-right">${count}</span>
            </div>`;
          }).join('');
        }
      }
    } catch {
      // Tables may not exist yet — fail silently
    }
  }

