              <a href="/admin" class="px-5 py-2.5 rounded-xl bg-purple-500/15 text-purple-400 border border-purple-500/25 font-semibold text-sm hover:bg-purple-500/25 transition-all flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">open_in_new</span>
                <span data-i18n="perfil.admin.btn">Abrir Dashboard</span>
              </a>
            </div>
          </div>

          <div class="rounded-2xl p-6 space-y-5" style="background: #121212; border: 1px solid #2A3135;">
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-purple-400 text-lg">admin_panel_settings</span>
                <h3 class="text-lg font-bold text-white" data-i18n="perfil.gestao">Gestão de Usuários</h3>
              </div>
              <button id="btn-add-user" type="button" class="flex items-center gap-1.5 px-4 py-2 rounded-xl bg-purple-500/10 text-purple-400 border border-purple-500/20 hover:bg-purple-500/20 transition-all text-sm font-semibold cursor-pointer">
                <span class="material-symbols-outlined text-sm">person_add</span>
                Adicionar Usuário
              </button>
            </div>

            <!-- Add user form (hidden by default) -->
            <div id="add-user-form" class="hidden rounded-xl p-5 space-y-4" style="background: rgba(168,85,247,0.05); border: 1px solid rgba(168,85,247,0.15);">
              <h4 class="text-sm font-bold text-purple-300">Novo Usuário</h4>
              <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-3">
                <div>
                  <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1 block">Nome</label>
                  <input id="new-user-name" type="text" class="w-full rounded-lg border border-border-color bg-surface-dark/50 px-3 py-2.5 text-sm text-white focus:border-purple-500/60 outline-none transition-all" placeholder="Nome completo" />
                </div>
                <div>
                  <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1 block">E-mail</label>
                  <input id="new-user-email" type="email" class="w-full rounded-lg border border-border-color bg-surface-dark/50 px-3 py-2.5 text-sm text-white focus:border-purple-500/60 outline-none transition-all" placeholder="email@exemplo.com" />
                </div>
                <div>
                  <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1 block">Cargo</label>
                  <select id="new-user-role" class="w-full rounded-lg border border-border-color bg-surface-dark/50 px-3 py-2.5 text-sm text-white focus:border-purple-500/60 outline-none transition-all">
                    <option value="user">Usuário</option>
                    <option value="admin">Administrador</option>
                  </select>
                </div>
                <div>
                  <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1 block">Plano</label>
                  <select id="new-user-plan" class="w-full rounded-lg border border-border-color bg-surface-dark/50 px-3 py-2.5 text-sm text-white focus:border-purple-500/60 outline-none transition-all">
                    <option value="explorador">Explorador (Grátis)</option>
                    <option value="consultor">Consultor (R$35/mês)</option>
                    <option value="arquiteto">Arquiteto (R$50/mês)</option>
                  </select>
                </div>
              </div>
              <div class="flex items-center gap-3 pt-1">
                <label class="relative inline-flex items-center cursor-pointer">
                  <input id="new-user-dashboard" type="checkbox" class="sr-only peer" />
                  <div class="w-9 h-5 rounded-full transition-colors bg-surface-dark/80 border border-border-color peer-checked:bg-purple-500/30 peer-checked:border-purple-500/40 after:content-[''] after:absolute after:top-[3px] after:start-[3px] after:bg-slate-400 after:rounded-full after:h-3.5 after:w-3.5 after:transition-all peer-checked:after:translate-x-full peer-checked:after:bg-purple-400"></div>
                </label>
                <span class="text-xs text-slate-400">Acesso ao Dashboard de Gestao</span>
              </div>
              <div id="add-user-msg" class="hidden rounded-lg px-3 py-2 text-sm font-medium"></div>
              <div class="flex gap-2">
                <button id="btn-confirm-add" type="button" class="flex items-center gap-1.5 px-4 py-2 rounded-lg bg-purple-500/15 text-purple-400 border border-purple-500/25 hover:bg-purple-500/25 transition-all text-sm font-semibold cursor-pointer">
                  <span class="material-symbols-outlined text-sm">check</span>
                  Criar Usuário
                </button>
                <button id="btn-cancel-add" type="button" class="px-4 py-2 rounded-lg text-slate-400 hover:text-white transition-colors text-sm cursor-pointer">
                  Cancelar
                </button>
              </div>
            </div>

            <!-- Search + Filter -->
            <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
              <div class="relative flex-1">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-600 text-base">search</span>
                <input id="user-search-input" type="text" placeholder="Buscar por nome..." class="w-full pl-9 pr-4 py-2.5 rounded-xl bg-white/[0.03] border border-white/[0.06] text-white text-sm placeholder:text-slate-600 focus:border-purple-500/40 focus:outline-none focus:ring-1 focus:ring-purple-500/20 transition-all" />
              </div>
              <div class="flex items-center gap-2">
                <button id="filter-admins-btn" type="button" class="user-filter-btn active flex items-center gap-1.5 px-3.5 py-2 rounded-xl text-xs font-semibold border transition-all cursor-pointer bg-purple-500/10 text-purple-400 border-purple-500/20">
                  <span class="material-symbols-outlined text-[14px]">shield_person</span> Admins
                </button>
                <button id="filter-all-btn" type="button" class="user-filter-btn flex items-center gap-1.5 px-3.5 py-2 rounded-xl text-xs font-semibold border transition-all cursor-pointer text-slate-500 border-white/[0.06] hover:text-white hover:border-white/[0.12]">
                  <span class="material-symbols-outlined text-[14px]">group</span> Todos
                </button>
              </div>
            </div>

            <!-- Users table -->
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="text-left text-[10px] uppercase tracking-widest font-bold text-slate-500 border-b border-border-color">
                    <th class="pb-3 pr-4" data-i18n="perfil.gestao.nome">Nome</th>
                    <th class="pb-3 pr-4">E-mail</th>
                    <th class="pb-3 pr-4" data-i18n="perfil.gestao.cargo">Cargo</th>
                    <th class="pb-3 pr-4" data-i18n="perfil.gestao.senior">Senioridade</th>
                    <th class="pb-3 text-right" data-i18n="perfil.gestao.acoes">Ações</th>
                  </tr>
                </thead>
                <tbody id="users-table-body" class="divide-y divide-border-color">
                  <tr>
                    <td colspan="5" class="py-8 text-center text-slate-500">
                      <span class="material-symbols-outlined text-2xl animate-spin">progress_activity</span>
                    </td>
                  </tr>
                </tbody>
              </table>
              <p id="users-empty-msg" class="hidden text-center text-slate-600 text-xs py-6">Nenhum usuario encontrado.</p>
            </div>
          </div>
        </div>

        <!-- Saved feedback -->
        <div id="save-feedback" class="hidden fixed bottom-6 right-6 z-50 px-5 py-3 rounded-xl bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-sm font-medium shadow-lg flex items-center gap-2">
          <span class="material-symbols-outlined text-sm">check_circle</span>
          Salvo com sucesso!
        </div>

      </div>
    </main>
  </div>
</Layout>

<style is:global>
  @keyframes slideDown {
    from { opacity: 0; transform: translate(-50%, -20px); }
    to { opacity: 1; transform: translate(-50%, 0); }
  }
</style>

<script>
  import { supabase, getProfile, updateProfile, uploadAvatar, signOut, updatePassword, listAllProfiles, setUserRole, deleteUserProfile, inviteUser, getUserSubscription, getUserUsageStats, getUserProjects, deleteProject } from '../lib/supabase';
  import type { Profile, Subscription, Project } from '../lib/supabase';

  const loadingEl = document.getElementById('profile-loading')!;
  const unauthEl = document.getElementById('profile-unauth')!;
  const contentEl = document.getElementById('profile-content')!;

  let currentProfile: Profile | null = null;
  let currentUserId: string = '';

  // === HTML Escape (previne XSS) ===
  function esc(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // === Upgrade Toast ===
  let toastTimer: ReturnType<typeof setTimeout> | null = null;

  function showUpgradeToast(title: string, msg: string) {
    const toast = document.getElementById('upgrade-toast');
    const titleEl = document.getElementById('upgrade-toast-title');
    const msgEl = document.getElementById('upgrade-toast-msg');
    if (!toast || !titleEl || !msgEl) return;
    titleEl.textContent = title;
    msgEl.textContent = msg;
    toast.classList.remove('hidden');
    toast.style.animation = 'none';
    toast.offsetHeight; // force reflow
    toast.style.animation = 'slideDown 0.3s ease-out';
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(() => hideUpgradeToast(), 5000);
  }

  function hideUpgradeToast() {
    const toast = document.getElementById('upgrade-toast');
    if (!toast) return;
    toast.classList.add('hidden');
    if (toastTimer) { clearTimeout(toastTimer); toastTimer = null; }
  }

  document.getElementById('upgrade-toast-close')?.addEventListener('click', hideUpgradeToast);
  document.getElementById('upgrade-toast-dismiss')?.addEventListener('click', hideUpgradeToast);
  let currentUserEmail: string = '';

  function showFeedback() {
    const fb = document.getElementById('save-feedback')!;
    fb.classList.remove('hidden');
    setTimeout(() => fb.classList.add('hidden'), 2000);
  }

  function applyThemeToPage(theme: string) {
    if (theme === 'light') {
      document.documentElement.classList.remove('dark');
      document.documentElement.classList.add('light');
      localStorage.setItem('bc-theme', 'light');
    } else {
      document.documentElement.classList.remove('light');
      document.documentElement.classList.add('dark');
      localStorage.setItem('bc-theme', 'dark');
    }
  }

  function getInitials(name: string): string {
    return name.split(' ').map(w => w[0]).join('').toUpperCase().slice(0, 2);
  }

  function renderProfile(profile: Profile, email: string) {
    // Nome + Email
    document.getElementById('profile-name')!.textContent = profile.full_name || 'Usuário';
    document.getElementById('profile-email')!.textContent = email;
    (document.getElementById('input-name') as HTMLInputElement).value = profile.full_name || '';
    (document.getElementById('input-email') as HTMLInputElement).value = email;

    // Avatar
    const avatarImg = document.getElementById('avatar-img') as HTMLImageElement;
    const avatarInitials = document.getElementById('avatar-initials')!;
    if (profile.avatar_url) {
      avatarImg.src = profile.avatar_url;
      avatarImg.classList.remove('hidden');
      avatarInitials.classList.add('hidden');
    } else {
      avatarImg.classList.add('hidden');
      avatarInitials.classList.remove('hidden');
      avatarInitials.textContent = getInitials(profile.full_name || email);
    }

    // Badge de Senioridade
    const badgeText = document.getElementById('badge-text')!;
    badgeText.textContent = profile.seniority.charAt(0).toUpperCase() + profile.seniority.slice(1);

    // Badge de Cargo
    const roleBadge = document.getElementById('role-badge')!;
    const roleBadgeText = document.getElementById('role-badge-text')!;
    if (profile.role === 'master') {
      roleBadge.classList.remove('hidden');
      roleBadge.classList.add('inline-flex');
      roleBadge.className = roleBadge.className.replace(/bg-\S+/g, '').replace(/text-\S+/g, '').replace(/border-\S+/g, '');
      roleBadge.className = 'inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-purple-500/15 text-purple-400 border border-purple-500/20';
      roleBadgeText.textContent = 'Master';
    } else if (profile.role === 'admin') {
      roleBadge.classList.remove('hidden');
      roleBadge.classList.add('inline-flex');
      roleBadge.className = 'inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-amber-500/15 text-amber-400 border border-amber-500/20';
      roleBadgeText.textContent = 'Admin';
    } else {
      roleBadge.classList.add('hidden');
      roleBadge.classList.remove('inline-flex');
    }

    // Botões de senioridade
    document.querySelectorAll('.seniority-btn').forEach(btn => {
      const val = (btn as HTMLElement).dataset.seniority;
      if (val === profile.seniority) {
        btn.className = 'seniority-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border bg-primary/15 text-primary border-primary/30';
      } else {
        btn.className = 'seniority-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border text-slate-500 border-border-color hover:text-white hover:bg-surface-light';
      }
    });

    // Botões de tema
    document.querySelectorAll('.theme-btn').forEach(btn => {
      const val = (btn as HTMLElement).dataset.theme;
      if (val === profile.theme) {
        btn.className = 'theme-btn py-3 rounded-xl text-sm font-bold transition-all cursor-pointer border flex items-center justify-center gap-2 bg-primary/15 text-primary border-primary/30';
      } else {
        btn.className = 'theme-btn py-3 rounded-xl text-sm font-bold transition-all cursor-pointer border flex items-center justify-center gap-2 text-slate-500 border-border-color hover:text-white hover:bg-surface-light';
      }
    });

    applyThemeToPage(profile.theme);

    // Botões de idioma
    const savedLang = (profile as any).preferred_language || localStorage.getItem('bc-lang') || 'pt';
    document.querySelectorAll('.lang-btn').forEach(btn => {
      const val = (btn as HTMLElement).dataset.lang;
      if (val === savedLang) {
        btn.className = 'lang-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border flex items-center justify-center gap-2 bg-primary/15 text-primary border-primary/30';
      } else {
        btn.className = 'lang-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border flex items-center justify-center gap-2 text-slate-500 border-border-color hover:text-white hover:bg-surface-light';
      }
    });

    // Exibe painel admin para master
    const adminPanel = document.getElementById('admin-panel')!;
    if (profile.role === 'master') {
      adminPanel.classList.remove('hidden');
      loadUsers();
    }
  }

  // ══════════════════════════════
  //  GESTÃO DE USUÁRIOS
  // ══════════════════════════════

  let usersLoading = false;
  let allProfiles: Profile[] = [];
  let userFilter: 'admins' | 'all' = 'admins'; // padrão: exibe apenas admins
  let userSearchQuery = '';

  async function loadUsers() {
    if (usersLoading) return;
    usersLoading = true;

    try {
      const tbody = document.getElementById('users-table-body')!;
      const emptyMsg = document.getElementById('users-empty-msg');
      allProfiles = await listAllProfiles();
      renderUsersTable();
      attachUserTableEvents();
    } catch (err) {
      console.error('Erro ao carregar usuários:', err);
    } finally {
      usersLoading = false;
    }
  }

  function getFilteredProfiles(): Profile[] {
    let filtered = allProfiles;

    // Filtro por cargo
    if (userFilter === 'admins') {
      filtered = filtered.filter(p => p.role === 'admin' || p.role === 'master');
    }

    // Filtro de busca
    if (userSearchQuery.length > 0) {
      const q = userSearchQuery.toLowerCase();
      filtered = filtered.filter(p =>
        (p.full_name || '').toLowerCase().includes(q) ||
        (p.id || '').toLowerCase().includes(q)
      );
    }

    return filtered;
  }

  function renderUsersTable() {
    const tbody = document.getElementById('users-table-body')!;
    const emptyMsg = document.getElementById('users-empty-msg');
    const profiles = getFilteredProfiles();

    tbody.innerHTML = '';

    if (profiles.length === 0) {
      tbody.innerHTML = '';
      if (emptyMsg) {
        emptyMsg.textContent = userSearchQuery ? `Nenhum usuario encontrado para "${userSearchQuery}"` : (userFilter === 'admins' ? 'Nenhum administrador encontrado.' : 'Nenhum usuario encontrado.');
        emptyMsg.classList.remove('hidden');
      }
      return;
    }

    if (emptyMsg) emptyMsg.classList.add('hidden');

    profiles.forEach(p => {
      const isSelf = p.id === currentUserId;
      const roleLabel = p.role === 'master' ? 'Master' : p.role === 'admin' ? 'Administrador' : 'Usuário';
      const roleColor = p.role === 'master' ? 'text-purple-400 bg-purple-500/10 border-purple-500/20'
        : p.role === 'admin' ? 'text-amber-400 bg-amber-500/10 border-amber-500/20'
        : 'text-slate-400 bg-white/5 border-border-color';

      // Destaca resultado de busca
      const displayName = p.full_name || 'Sem nome';
      let nameHtml = esc(displayName);
      if (userSearchQuery.length > 0) {
        const escaped = esc(displayName);
        const escapedQuery = esc(userSearchQuery);
        const idx = escaped.toLowerCase().indexOf(escapedQuery.toLowerCase());
        if (idx !== -1) {
          nameHtml = escaped.substring(0, idx) + '<mark class="bg-purple-500/30 text-white rounded px-0.5">' + escaped.substring(idx, idx + escapedQuery.length) + '</mark>' + escaped.substring(idx + escapedQuery.length);
        }
      }

      const row = document.createElement('tr');
      row.className = 'group';
      row.innerHTML = `
        <td class="py-3.5 pr-4">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-xs font-bold text-primary border border-primary/20 overflow-hidden">
              ${p.avatar_url
                ? `<img src="${esc(p.avatar_url)}" class="w-full h-full object-cover" />`
                : `<span>${esc(getInitials(p.full_name || '??'))}</span>`
              }
            </div>
            <span class="text-white font-medium">${nameHtml}${isSelf ? ' <span class="text-slate-500 text-xs">(você)</span>' : ''}</span>
          </div>
        </td>
        <td class="py-3.5 pr-4 text-slate-400">${p.id.slice(0, 8)}...</td>
        <td class="py-3.5 pr-4">
          <span class="inline-flex px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider border ${roleColor}">${roleLabel}</span>
        </td>
        <td class="py-3.5 pr-4 text-slate-400 capitalize">${p.seniority}</td>
        <td class="py-3.5 text-right">
          ${isSelf || p.role === 'master' ? '' : `
            <div class="flex items-center gap-1 justify-end opacity-0 group-hover:opacity-100 transition-opacity">
              <select data-user-id="${p.id}" class="role-select rounded-lg border border-border-color bg-surface-dark/50 px-2 py-1 text-xs text-white outline-none cursor-pointer">
                <option value="user" ${p.role === 'user' ? 'selected' : ''}>Usuário</option>
                <option value="admin" ${p.role === 'admin' ? 'selected' : ''}>Admin</option>
              </select>
              <button data-delete-user="${p.id}" data-delete-name="${displayName}" class="p-1.5 rounded-lg text-red-400/60 hover:text-red-400 hover:bg-red-500/10 transition-all cursor-pointer" title="Remover ${displayName}">
                <span class="material-symbols-outlined text-sm">delete</span>
              </button>
            </div>
          `}
        </td>
      `;
      tbody.appendChild(row);
    });
  }

  function attachUserTableEvents() {
    const tbody = document.getElementById('users-table-body')!;
    // Remove listeners antigos substituindo o nó
    const newTbody = tbody.cloneNode(true) as HTMLElement;
    tbody.parentNode!.replaceChild(newTbody, tbody);

    newTbody.addEventListener('change', async (e) => {
      const el = e.target as HTMLSelectElement;
      if (!el.classList.contains('role-select')) return;
      const userId = el.dataset.userId!;
      const newRole = el.value;
      el.disabled = true;
      const { error } = await setUserRole(userId, newRole);
      if (error) {
        alert('Erro ao alterar cargo: ' + error.message);
      } else {
        showFeedback();
      }
      await loadUsers();
    });

    newTbody.addEventListener('click', async (e) => {
      const btn = (e.target as HTMLElement).closest('[data-delete-user]') as HTMLElement;
      if (!btn) return;
      const userId = btn.dataset.deleteUser!;
      const userName = btn.dataset.deleteName || 'este usuario';
      if (!confirm(`Tem certeza que deseja remover "${userName}"? Esta ação é irreversível.`)) return;
      const { error } = await deleteUserProfile(userId);
      if (error) {
        alert('Erro ao remover: ' + error.message);
      } else {
        showFeedback();
      }
      await loadUsers();
    });
  }

  // Input de busca
  const userSearchInput = document.getElementById('user-search-input') as HTMLInputElement;
  userSearchInput?.addEventListener('input', () => {
    userSearchQuery = userSearchInput.value.trim();
    renderUsersTable();
    attachUserTableEvents();
  });

  // Botões de filtro
  const filterAdminsBtn = document.getElementById('filter-admins-btn');
  const filterAllBtn = document.getElementById('filter-all-btn');

  function updateFilterButtons() {
    const activeClass = 'bg-purple-500/10 text-purple-400 border-purple-500/20';
    const inactiveClass = 'text-slate-500 border-white/[0.06] hover:text-white hover:border-white/[0.12]';
    if (userFilter === 'admins') {
      filterAdminsBtn!.className = `user-filter-btn active flex items-center gap-1.5 px-3.5 py-2 rounded-xl text-xs font-semibold border transition-all cursor-pointer ${activeClass}`;
      filterAllBtn!.className = `user-filter-btn flex items-center gap-1.5 px-3.5 py-2 rounded-xl text-xs font-semibold border transition-all cursor-pointer ${inactiveClass}`;
    } else {
      filterAllBtn!.className = `user-filter-btn active flex items-center gap-1.5 px-3.5 py-2 rounded-xl text-xs font-semibold border transition-all cursor-pointer ${activeClass}`;
      filterAdminsBtn!.className = `user-filter-btn flex items-center gap-1.5 px-3.5 py-2 rounded-xl text-xs font-semibold border transition-all cursor-pointer ${inactiveClass}`;
    }
  }

  filterAdminsBtn?.addEventListener('click', () => {
    userFilter = 'admins';
    updateFilterButtons();
    renderUsersTable();
    attachUserTableEvents();
  });

  filterAllBtn?.addEventListener('click', () => {
    userFilter = 'all';
    updateFilterButtons();
    renderUsersTable();
    attachUserTableEvents();
  });

  // Inicialização
  async function init() {
    const { data: { session } } = await supabase.auth.getSession();

    if (!session) {
      loadingEl.classList.add('hidden');
      unauthEl.classList.remove('hidden');
      unauthEl.classList.add('flex');
      return;
    }

    currentUserId = session.user.id;
    currentUserEmail = session.user.email || '';
    const profile = await getProfile(currentUserId);

    if (!profile) {
      loadingEl.classList.add('hidden');
      unauthEl.classList.remove('hidden');
      unauthEl.classList.add('flex');
      return;
    }

    // Redireciona para login se termos não aceitos (força modal de termos)
    if (!profile.terms_accepted_at) {
      window.location.href = '/login';
      return;
    }

    currentProfile = profile;
    renderProfile(profile, currentUserEmail);
    initAgentSelection();
    initLlmSelection();
    loadUsageData();
    loadProjects();
    loadingEl.classList.add('hidden');
    contentEl.classList.remove('hidden');
  }

  async function loadUsageData() {
    try {
      // Carrega assinatura
      const sub = await getUserSubscription(currentUserId);
      const planNames: Record<string, string> = { explorador: 'Explorador', consultor: 'Consultor', arquiteto: 'Arquiteto' };
      const planColors: Record<string, { bg: string; text: string; border: string; label: string }> = {
        explorador: { bg: 'bg-emerald-500/15', text: 'text-emerald-400', border: 'border-emerald-500/20', label: 'Free' },
        consultor: { bg: 'bg-primary/15', text: 'text-primary', border: 'border-primary/20', label: 'Pro' },
        arquiteto: { bg: 'bg-cta/15', text: 'text-cta', border: 'border-cta/20', label: 'Elite' },
      };
      const plan = sub?.plan || 'explorador';
      // Store plan globally for agent/llm restrictions
      (window as any).__bcPlan = plan;
      const pc = planColors[plan] || planColors.explorador;
      const nameEl = document.getElementById('usage-plan-name');
      const badgeEl = document.getElementById('usage-plan-badge');
      const periodEl = document.getElementById('usage-plan-period');
      if (nameEl) nameEl.textContent = planNames[plan] || 'Explorador';
      if (badgeEl) {
        badgeEl.textContent = pc.label;
        badgeEl.className = `text-[9px] px-2 py-0.5 rounded-full font-bold uppercase tracking-wider ${pc.bg} ${pc.text} border ${pc.border}`;
      }
      if (periodEl && sub?.current_period_end) {
        const end = new Date(sub.current_period_end);
        periodEl.textContent = `Válido até ${end.toLocaleDateString('pt-BR')}`;
      }

      // Créditos padrão por plano (quando user_credits não existe ainda)
      const PLAN_DEFAULTS: Record<string, { eco: number; mid: number; elite: number }> = {
        explorador: { eco: 50, mid: 0, elite: 0 },
        consultor:  { eco: 999999, mid: 999999, elite: 20 },
        arquiteto:  { eco: 999999, mid: 999999, elite: 50 },
      };

      // Carrega créditos do usuário
      const { data: credits } = await supabase
        .from('user_credits')
        .select('*')
        .eq('user_id', currentUserId)
        .single();

      const planLabelEl = document.getElementById('credits-plan-label');
      if (planLabelEl) planLabelEl.textContent = `(${planNames[plan] || 'mensal'})`;

      const setPlanCredits = (id: string, val: number) => {
        const el = document.getElementById(id);
        if (el) el.textContent = val >= 999999 ? '∞' : String(val);
      };

      if (credits) {
        const setIndieCredits = (id: string, val: number) => {
          const el = document.getElementById(id);
          if (el) el.textContent = String(val);
        };
        setIndieCredits('credits-indie-eco', credits.indie_credits_economy);
        setIndieCredits('credits-indie-mid', credits.indie_credits_mid);
        setIndieCredits('credits-indie-elite', credits.indie_credits_elite);
      }

      // Carrega estatísticas de uso (filtra pelo mês atual)
      const allLogs = await getUserUsageStats(currentUserId);
      const monthStart = new Date();
      monthStart.setDate(1);
      monthStart.setHours(0, 0, 0, 0);
      const logs = allLogs.filter(l => new Date(l.created_at) >= monthStart);

      const prdCount = logs.filter(l => l.action === 'prd_generation').length;
      const chatCount = logs.filter(l => l.action === 'chat_message').length;
      const ttsCount = logs.filter(l => l.action === 'tts_audio').length;

      const prdEl = document.getElementById('usage-prd-count');
      const chatEl = document.getElementById('usage-chat-count');
      const ttsEl = document.getElementById('usage-tts-count');
      if (prdEl) prdEl.textContent = String(prdCount);
      if (chatEl) chatEl.textContent = String(chatCount);
      if (ttsEl) ttsEl.textContent = String(ttsCount);

      // Atualiza créditos restantes (limite - uso do mês)
      const defaults = PLAN_DEFAULTS[plan] || PLAN_DEFAULTS.explorador;
      const ecoLimit = credits ? credits.plan_credits_economy : defaults.eco;
      const midLimit = credits ? credits.plan_credits_mid : defaults.mid;
      const eliteLimit = credits ? credits.plan_credits_elite : defaults.elite;

      // Contar uso por tier no mês
      const budgetModels = ['google/gemma-3-4b-it:free', 'meta-llama/llama-3.1-8b-instruct:free', 'mistralai/mistral-small-3.1-24b-instruct:free'];
      const midModels = ['google/gemini-2.0-flash-001', 'openai/gpt-4o-mini', 'anthropic/claude-3.5-haiku'];
      const proModels = ['anthropic/claude-sonnet-4', 'openai/gpt-4o', 'google/gemini-2.5-pro-preview'];

      const ecoUsed = logs.filter(l => budgetModels.includes(l.llm_model) || l.action === 'chat_message').length;
      const midUsed = logs.filter(l => midModels.includes(l.llm_model)).length;
      const eliteUsed = logs.filter(l => proModels.includes(l.llm_model)).length;

      const showRemaining = (id: string, limit: number, used: number) => {
        const el = document.getElementById(id);
        if (el) el.textContent = limit >= 999999 ? '∞' : String(Math.max(limit - used, 0));
      };
      showRemaining('credits-plan-eco', ecoLimit, ecoUsed);
      showRemaining('credits-plan-mid', midLimit, midUsed);
      showRemaining('credits-plan-elite', eliteLimit, eliteUsed);

      // Uso por modelo
      const modelMap: Record<string, number> = {};
      logs.forEach(l => {
        if (l.llm_model) {
          modelMap[l.llm_model] = (modelMap[l.llm_model] || 0) + 1;
        }
      });

      const barsEl = document.getElementById('usage-model-bars');
      if (barsEl) {
        const entries = Object.entries(modelMap).sort((a, b) => b[1] - a[1]);
        if (entries.length === 0) {
          barsEl.innerHTML = '<p class="text-xs text-slate-600 italic">Nenhum uso registrado ainda.</p>';
        } else {
          const max = entries[0][1];
          barsEl.innerHTML = entries.map(([model, count]) => {
            const pct = Math.round((count / max) * 100);
            const shortName = model.split('/').pop()?.replace(':free', '') || model;
            return `<div class="flex items-center gap-3">
              <span class="text-xs text-slate-400 w-28 truncate shrink-0">${shortName}</span>
              <div class="flex-1 h-2 rounded-full bg-white/5 overflow-hidden">
                <div class="h-full rounded-full bg-primary transition-all" style="width: ${pct}%"></div>
              </div>
              <span class="text-xs text-slate-500 w-8 text-right">${count}</span>
            </div>`;
          }).join('');
        }
      }
    } catch {
      // Tabelas podem ainda não existir — falha silenciosamente
    }
  }

  async function loadProjects() {
    try {
      const projects = await getUserProjects(currentUserId);
      const listEl = document.getElementById('projects-list');
      const countBadge = document.getElementById('projects-count-badge');
      if (!listEl) return;

      if (countBadge) {
        countBadge.textContent = String(projects.length);
        if (projects.length > 0) countBadge.classList.remove('hidden');
      }

      if (projects.length === 0) {
        listEl.innerHTML = `
          <div class="flex flex-col items-center justify-center py-8 text-center">
            <span class="material-symbols-outlined text-3xl text-slate-700 mb-2">folder_off</span>
            <p class="text-sm text-slate-500">Nenhum projeto salvo ainda</p>
            <p class="text-[10px] text-slate-600 mt-1">Crie um projeto no Arquiteto de Software e salve aqui</p>
          </div>`;
        return;
      }

      const scaleLabels: Record<string, string> = { '50': 'Pessoal', '1000': 'Startup', '10000': 'Scale-up', '50000': 'Enterprise' };
      const natureLabels: Record<string, string> = { hobby: 'Hobby', saas: 'SaaS', enterprise: 'Enterprise' };

      listEl.innerHTML = projects.map((p: Project) => {
        const date = new Date(p.created_at).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
        const hasImage = p.image_url && p.image_url.length > 0;
        const prdPreview = (p.generated_prd || '').substring(0, 120).replace(/[#*\n]/g, ' ').trim();
        return `
          <div class="group rounded-xl p-4 transition-all hover:border-primary/20" style="background: rgba(255,255,255,0.02); border: 1px solid #2A3135;" data-project-id="${esc(p.id)}">
            <div class="flex gap-3">
              ${hasImage ? `<img src="${esc(p.image_url)}" alt="${esc(p.name)}" class="size-14 rounded-lg object-cover shrink-0 border border-white/5" />` : `<div class="size-14 rounded-lg bg-primary/5 border border-primary/10 flex items-center justify-center shrink-0"><span class="material-symbols-outlined text-primary text-xl">code</span></div>`}
              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-2">
                  <h4 class="text-sm font-bold text-white truncate">${esc(p.name)}</h4>
                  <div class="flex items-center gap-1 shrink-0">
                    <button type="button" class="project-view-btn p-1 rounded-md text-slate-600 hover:text-primary hover:bg-primary/10 transition-all" title="Ver PRD" data-prd="${encodeURIComponent(p.generated_prd || '')}" data-prompt="${encodeURIComponent(p.generated_prompt || '')}" data-prd-path="${esc(p.prd_storage_path || '')}" data-prompt-path="${esc(p.prompt_storage_path || '')}" data-name="${esc(p.name)}">
                      <span class="material-symbols-outlined text-[16px]">visibility</span>
                    </button>
                    <button type="button" class="project-delete-btn p-1 rounded-md text-slate-600 hover:text-red-400 hover:bg-red-500/10 transition-all" title="Excluir" data-id="${esc(p.id)}">
                      <span class="material-symbols-outlined text-[16px]">delete</span>
                    </button>
                  </div>
                </div>
                <p class="text-[10px] text-slate-500 mt-0.5">${date} · ${esc(scaleLabels[p.scale] || p.scale || '-')} · ${esc(natureLabels[p.nature] || p.nature || '-')}</p>
                ${p.business_context ? `<p class="text-[11px] text-slate-600 mt-1 line-clamp-1">${esc(p.business_context)}</p>` : ''}
                ${prdPreview ? `<p class="text-[10px] text-slate-700 mt-1 line-clamp-1 font-mono">${esc(prdPreview)}...</p>` : ''}
              </div>
            </div>
          </div>`;
      }).join('');

      // Visualizar projeto (modal/expandir) — carrega do Storage se disponível
      listEl.querySelectorAll('.project-view-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const prdPath = btn.getAttribute('data-prd-path') || '';
          const promptPath = btn.getAttribute('data-prompt-path') || '';
          const name = btn.getAttribute('data-name') || 'Projeto';

          let prd = decodeURIComponent(btn.getAttribute('data-prd') || '');
          let prompt = decodeURIComponent(btn.getAttribute('data-prompt') || '');

          // Busca do Storage se os paths existirem e o texto inline estiver vazio
          if (prdPath && !prd) {
            try {
              const { data: { session: s } } = await supabase.auth.getSession();
              if (s) {
                const sbUrl = import.meta.env.PUBLIC_SUPABASE_URL;
                const headers = { 'apikey': import.meta.env.PUBLIC_SUPABASE_ANON_KEY, 'Authorization': 'Bearer ' + s.access_token };
                const [prdRes, promptRes] = await Promise.all([
                  prdPath ? fetch(sbUrl + '/storage/v1/object/prd-files/' + prdPath, { headers }) : null,
                  promptPath ? fetch(sbUrl + '/storage/v1/object/prd-files/' + promptPath, { headers }) : null,
                ]);
                if (prdRes?.ok) prd = await prdRes.text();
                if (promptRes?.ok) prompt = await promptRes.text();
              }
            } catch (e) { console.error('[Storage] Erro ao carregar PRD:', e); }
          }

          const htmlContent = buildProjectViewHtml(name, prd, prompt);
          const w = window.open('', '_blank');
          if (w) { w.document.write(htmlContent); w.document.close(); }
        });
      });

      // Excluir projeto
      listEl.querySelectorAll('.project-delete-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = btn.getAttribute('data-id');
          if (!id || !confirm('Deseja excluir este projeto?')) return;
          await deleteProject(id);
          const card = btn.closest('[data-project-id]');
          if (card) card.remove();
          // Atualiza contador
          const remaining = listEl.querySelectorAll('[data-project-id]').length;
          if (countBadge) countBadge.textContent = String(remaining);
          if (remaining === 0) {
            if (countBadge) countBadge.classList.add('hidden');
            listEl.innerHTML = `
              <div class="flex flex-col items-center justify-center py-8 text-center">
                <span class="material-symbols-outlined text-3xl text-slate-700 mb-2">folder_off</span>
                <p class="text-sm text-slate-500">Nenhum projeto salvo ainda</p>
                <p class="text-[10px] text-slate-600 mt-1">Crie um projeto no Arquiteto de Software e salve aqui</p>
              </div>`;
          }
        });
      });
    } catch (err) {
      console.error('[Projects]', err);
    }
  }

  function buildProjectViewHtml(name: string, prd: string, prompt: string) {
    const date = new Date().toLocaleDateString('pt-BR');
    const safeName = esc(name);
    return `<!DOCTYPE html><html><head><meta charset="utf-8"><title>${safeName} - BuildCode</title>
    <style>
      body{font-family:"Segoe UI",Helvetica,sans-serif;max-width:900px;margin:40px auto;padding:0 30px;color:#e2e8f0;background:#0a0a0a;line-height:1.7;font-size:14px}
      .header{background:linear-gradient(135deg,#0d1b2a,#1b3a4b);padding:30px 40px;margin:-40px -30px 30px;border-radius:0 0 12px 12px}
      .header h1{color:#fff;font-size:24px;margin:0;letter-spacing:0.5px}.header p{color:#a8c5d6;margin:4px 0 0;font-size:13px}
      h1{font-size:24px;color:#fff;border-bottom:2px solid #2E748B;padding-bottom:12px;margin-top:40px}
      h2{font-size:18px;color:#94a3b8;border-bottom:1px solid #1e293b;padding-bottom:8px;margin-top:28px}
      h3{font-size:15px;color:#2E748B;margin-top:16px}
      pre{background:#111;border:1px solid #1e293b;border-radius:8px;padding:16px;overflow-x:auto;font-size:13px;color:#a8c5d6}
      .tabs{display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid #1e293b;padding-bottom:0}
      .tab{padding:10px 20px;cursor:pointer;color:#64748b;font-weight:600;font-size:13px;border-bottom:2px solid transparent;transition:all 0.2s}
      .tab.active{color:#2E748B;border-bottom-color:#2E748B}
      .tab:hover{color:#94a3b8}
      .content{display:none;white-space:pre-wrap;font-family:monospace;font-size:13px;line-height:1.8;color:#cbd5e1}
      .content.active{display:block}
      .footer{text-align:center;margin-top:60px;padding:20px;border-top:1px solid #1e293b;color:#475569;font-size:11px}
    </style></head><body>
    <div class="header"><h1>${safeName}</h1><p>BuildCode AI Engine — Gerado em ${date}</p></div>
    <div class="tabs">
      <div class="tab active" onclick="switchTab(0)">PRD</div>
      <div class="tab" onclick="switchTab(1)">Prompt Base</div>
    </div>
    <div class="content active" id="tab-0">${prd.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</div>
    <div class="content" id="tab-1">${prompt.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</div>
    <div class="footer">BuildCode AI Engine v2.1 — buildcode.app</div>
    <script>function switchTab(i){document.querySelectorAll('.content').forEach((e,j)=>{e.classList.toggle('active',j===i)});document.querySelectorAll('.tab').forEach((e,j)=>{e.classList.toggle('active',j===i)})}<\/script>
    </body></html>`;
  }

