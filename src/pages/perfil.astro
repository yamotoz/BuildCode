---
import Layout from '../layouts/Layout.astro';

export const prerender = false;
---

<Layout title="BuildCode | Meu Perfil" noindex={true}>
  <div id="main-content" class="min-h-screen bg-background-dark relative">
    <!-- Background glows -->
    <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[150px] pointer-events-none"></div>
    <div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-cta/5 rounded-full blur-[120px] pointer-events-none"></div>

    <!-- Top bar -->
    <header class="sticky top-0 z-40 glass-panel border-b border-border-color px-6 py-4">
      <div class="max-w-5xl mx-auto flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 text-slate-100 hover:opacity-80 transition-opacity">
          <img id="perfil-logo" src="/logo_backofff.png" data-dark="/logo_backofff.png" data-light="/Logowhitemodeloff.png" alt="BuildCode" class="h-8 w-auto object-contain" />
          <h2 class="font-display text-xl font-bold tracking-tight text-white hidden sm:block">BuildCode</h2>
        </a>
        <div class="flex items-center gap-3">
          <a href="/app" class="text-sm text-slate-400 hover:text-white transition-colors font-medium" data-i18n="nav.acessar">Acessar Sistema</a>
        </div>
      </div>
    </header>

    <!-- Loading state -->
    <div id="profile-loading" class="flex items-center justify-center py-32">
      <div class="flex flex-col items-center gap-4">
        <span class="material-symbols-outlined text-4xl text-primary animate-spin">progress_activity</span>
        <p class="text-slate-400 text-sm" data-i18n="perfil.loading">Carregando perfil...</p>
      </div>
    </div>

    <!-- Not authenticated -->
    <div id="profile-unauth" class="hidden flex-col items-center justify-center py-32 text-center">
      <span class="material-symbols-outlined text-6xl text-slate-600 mb-4">lock</span>
      <h2 class="text-2xl font-bold text-white mb-2" data-i18n="perfil.unauth.title">Acesso necessário</h2>
      <p class="text-slate-400 mb-6" data-i18n="perfil.unauth.desc">Faça login para acessar seu perfil.</p>
      <a href="/login" class="px-6 py-3 rounded-xl bg-primary text-white font-semibold hover:bg-primary-dark transition-colors" data-i18n="perfil.unauth.login">Fazer Login</a>
    </div>

    <!-- Profile content -->
    <main id="profile-content" class="hidden max-w-5xl mx-auto px-6 py-12">
      <div class="space-y-8">

        <!-- Profile card -->
        <div class="rounded-2xl p-8 relative overflow-hidden" style="background: #121212; border: 1px solid #2A3135;">
          <div class="absolute -top-20 -right-20 w-60 h-60 bg-primary/5 rounded-full blur-[80px] pointer-events-none"></div>

          <div class="relative z-10 flex flex-col sm:flex-row items-center gap-8">
            <!-- Avatar -->
            <div class="relative group">
              <div id="avatar-container" class="w-28 h-28 rounded-full border-2 border-primary/30 overflow-hidden bg-surface-dark flex items-center justify-center shadow-[0_0_30px_rgba(46,116,139,0.15)]">
                <img id="avatar-img" src="" alt="Avatar" class="w-full h-full object-cover hidden" />
                <span id="avatar-initials" class="text-3xl font-bold text-primary"></span>
              </div>
              <label for="avatar-input" class="absolute inset-0 rounded-full bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center cursor-pointer">
                <span class="material-symbols-outlined text-white text-xl">photo_camera</span>
              </label>
              <input id="avatar-input" type="file" accept="image/*" class="hidden" aria-label="Upload de avatar" />
            </div>

            <!-- Name + Email + Badge -->
            <div class="flex-1 text-center sm:text-left">
              <h1 id="profile-name" class="text-2xl font-bold text-white mb-1"></h1>
              <p id="profile-email" class="text-slate-400 text-sm mb-3"></p>
              <div class="flex items-center gap-2 justify-center sm:justify-start flex-wrap">
                <!-- Seniority badge -->
                <div id="profile-badge" class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-primary/10 text-primary border border-primary/20">
                  <span class="material-symbols-outlined text-xs">workspace_premium</span>
                  <span id="badge-text">Junior</span>
                </div>
                <!-- Plan badge -->
                <div id="plan-badge" class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
                  <span class="material-symbols-outlined text-xs">credit_card</span>
                  <span id="plan-badge-text">Explorador</span>
                </div>
                <!-- Role badge (hidden by default, shown for master/admin) -->
                <div id="role-badge" class="hidden items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider">
                  <span class="material-symbols-outlined text-xs">shield</span>
                  <span id="role-badge-text"></span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Tab navigation removed — Perfil and Plano are now separate pages via header dropdown -->

        <!-- TAB: Perfil -->
        <div id="tab-perfil" class="space-y-8">

        <!-- Settings grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

          <!-- Dados pessoais -->
          <div class="rounded-2xl p-6 space-y-5" style="background: #121212; border: 1px solid #2A3135;">
            <div class="flex items-center gap-2 mb-2">
              <span class="material-symbols-outlined text-primary text-lg">person</span>
              <h3 class="text-lg font-bold text-white" data-i18n="perfil.dados">Dados Pessoais</h3>
            </div>

            <div class="space-y-4">
              <div>
                <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1.5 block" data-i18n="perfil.nome">Nome completo</label>
                <input id="input-name" type="text" aria-label="Nome completo" class="w-full rounded-xl border border-border-color bg-surface-dark/50 px-4 py-3 text-sm text-white focus:border-primary/60 focus:ring-1 focus:ring-primary/40 outline-none transition-all" placeholder="Seu nome" />
              </div>

              <div>
                <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1.5 block">E-mail</label>
                <input id="input-email" type="email" disabled aria-label="E-mail" class="w-full rounded-xl border border-border-color bg-surface-dark/30 px-4 py-3 text-sm text-slate-500 cursor-not-allowed" />
              </div>

              <button id="btn-save-name" type="button" class="w-full py-3 rounded-xl bg-primary/10 text-primary border border-primary/20 font-semibold text-sm hover:bg-primary/20 transition-all cursor-pointer flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-sm">save</span>
                <span data-i18n="perfil.salvar">Salvar Nome</span>
              </button>
            </div>
          </div>

          <!-- Preferências -->
          <div class="rounded-2xl p-6 space-y-5" style="background: #121212; border: 1px solid #2A3135;">
            <div class="flex items-center gap-2 mb-2">
              <span class="material-symbols-outlined text-cta text-lg">tune</span>
              <h3 class="text-lg font-bold text-white" data-i18n="perfil.prefs">Preferências</h3>
            </div>

            <div class="space-y-5">
              <!-- Seniority -->
              <div>
                <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-2 block" data-i18n="perfil.senioridade">Senioridade</label>
                <div class="grid grid-cols-3 gap-2">
                  <button data-seniority="junior" class="seniority-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border text-center">Junior</button>
                  <button data-seniority="pleno" class="seniority-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border text-center">Pleno</button>
                  <button data-seniority="senior" class="seniority-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border text-center">Senior</button>
                </div>
              </div>

              <!-- Theme -->
              <div>
                <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-2 block" data-i18n="perfil.tema">Tema</label>
                <div class="grid grid-cols-2 gap-2">
                  <button data-theme="dark" class="theme-btn py-3 rounded-xl text-sm font-bold transition-all cursor-pointer border flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-sm">dark_mode</span> <span data-i18n="perfil.tema.escuro">Escuro</span>
                  </button>
                  <button data-theme="light" class="theme-btn py-3 rounded-xl text-sm font-bold transition-all cursor-pointer border flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-sm">light_mode</span> <span data-i18n="perfil.tema.claro">Claro</span>
                  </button>
                </div>
              </div>

              <!-- Language -->
              <div>
                <div class="flex items-center gap-1.5 mb-2">
                  <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500" data-i18n="perfil.idioma">Idioma</label>
                  <div class="relative group/tip">
                    <span class="material-symbols-outlined text-slate-600 text-xs cursor-help">info</span>
                    <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-56 p-2.5 rounded-lg text-[11px] text-slate-300 leading-relaxed opacity-0 invisible group-hover/tip:opacity-100 group-hover/tip:visible transition-all z-20 pointer-events-none" style="background: #1a1a1a; border: 1px solid #2A3135;">
                      <span data-i18n="perfil.idioma.tooltip">Este idioma será usado na interface do sistema. O idioma do prompt gerado é configurado separadamente no wizard.</span>
                      <div class="absolute top-full left-1/2 -translate-x-1/2 w-2 h-2 rotate-45" style="background: #1a1a1a; border-right: 1px solid #2A3135; border-bottom: 1px solid #2A3135;"></div>
                    </div>
                  </div>
                </div>
                <div class="grid grid-cols-2 gap-2">
                  <button data-lang="pt" class="lang-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border flex items-center justify-center gap-2">
                    <span class="text-base">🇧🇷</span> Português
                  </button>
                  <button data-lang="en" class="lang-btn py-2.5 rounded-xl text-sm font-bold transition-all cursor-pointer border flex items-center justify-center gap-2">
                    <span class="text-base">🇺🇸</span> English
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>

        </div><!-- /tab-perfil -->

        <!-- TAB: Plano -->
        <div id="tab-plano" class="hidden space-y-8">

        <!-- ══════════════════════════════════════════════ -->
        <!-- USAGE / PLAN INFO -->
        <!-- ══════════════════════════════════════════════ -->
        <div class="rounded-2xl p-6 space-y-5 relative overflow-hidden" style="background: #121212; border: 1px solid #2A3135;">
          <div class="absolute -top-20 -left-20 w-60 h-60 bg-primary/5 rounded-full blur-[80px] pointer-events-none"></div>
          <div class="flex items-center gap-2 mb-2 relative z-10">
            <span class="material-symbols-outlined text-primary text-lg">monitoring</span>
            <h3 class="text-lg font-bold text-white" data-i18n="perfil.uso">Uso</h3>
          </div>

          <!-- Plan card -->
          <div class="relative z-10 rounded-xl p-5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4" style="background: rgba(46,116,139,0.06); border: 1px solid rgba(46,116,139,0.15);">
            <div>
              <p class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1" data-i18n="perfil.uso.plano">Plano Atual</p>
              <div class="flex items-center gap-2">
                <span id="usage-plan-name" class="text-xl font-bold text-white">Explorador</span>
                <span id="usage-plan-badge" class="text-[9px] px-2 py-0.5 rounded-full font-bold uppercase tracking-wider bg-emerald-500/15 text-emerald-400 border border-emerald-500/20">Free</span>
              </div>
              <p id="usage-plan-period" class="text-xs text-slate-500 mt-1"></p>
              <!-- Master plan switcher (hidden by default, shown via JS for master role) -->
              <div id="master-plan-switcher" class="hidden mt-2 flex items-center gap-2">
                <select id="master-plan-select" aria-label="Selecionar plano" class="text-xs px-3 py-1.5 rounded-lg bg-surface-dark border border-white/10 text-white cursor-pointer">
                  <option value="explorador">Explorador</option>
                  <option value="consultor">Consultor</option>
                  <option value="arquiteto">Arquiteto</option>
                  <option value="vip">⬡ VIP</option>
                </select>
                <button id="master-plan-apply" class="text-[10px] px-3 py-1.5 rounded-lg bg-cta/20 text-cta border border-cta/30 font-bold hover:bg-cta/30 transition-all cursor-pointer">Trocar</button>
                <button id="master-credits-reset" class="text-[10px] px-3 py-1.5 rounded-lg bg-emerald-500/20 text-emerald-400 border border-emerald-500/30 font-bold hover:bg-emerald-500/30 transition-all cursor-pointer">Resetar Créditos</button>
              </div>
            </div>
            <a href="/precos" class="px-4 py-2 rounded-xl bg-primary/10 text-primary border border-primary/20 text-sm font-semibold hover:bg-primary/20 transition-all">
              Ver Planos
            </a>
          </div>

          <!-- Contadores de créditos -->
          <div class="relative z-10 rounded-xl p-5 space-y-4" style="background: rgba(168,85,247,0.04); border: 1px solid rgba(168,85,247,0.12);">
            <div class="flex items-center justify-between">
              <p class="text-[10px] uppercase tracking-widest font-bold text-slate-500">Créditos Disponíveis</p>
              <a href="/precos#recarga" class="text-[10px] text-purple-400 font-bold hover:text-purple-300 transition-colors uppercase tracking-wider">+ Recarregar</a>
            </div>
            <!-- Plano (reseta todo mês) -->
            <div>
              <p class="text-[9px] uppercase tracking-widest font-bold text-slate-600 mb-2">Plano <span id="credits-plan-label" class="text-slate-500">(mensal)</span></p>
              <div class="grid grid-cols-3 gap-2">
                <div class="rounded-lg p-2.5 text-center" style="background: rgba(52,211,153,0.06); border: 1px solid rgba(52,211,153,0.12);">
                  <p id="credits-plan-eco" class="text-lg font-bold text-emerald-400">0</p>
                  <p class="text-[8px] text-slate-600 uppercase font-bold">Econômica</p>
                </div>
                <div class="rounded-lg p-2.5 text-center" style="background: rgba(251,191,36,0.06); border: 1px solid rgba(251,191,36,0.12);">
                  <p id="credits-plan-mid" class="text-lg font-bold text-amber-400">0</p>
                  <p class="text-[8px] text-slate-600 uppercase font-bold">Média</p>
                </div>
                <div class="rounded-lg p-2.5 text-center" style="background: rgba(168,85,247,0.06); border: 1px solid rgba(168,85,247,0.12);">
                  <p id="credits-plan-elite" class="text-lg font-bold text-purple-400">0</p>
                  <p class="text-[8px] text-slate-600 uppercase font-bold">Elite</p>
                </div>
              </div>
            </div>
            <!-- Independentes / Recarga (acumulativos) -->
            <div>
              <p class="text-[9px] uppercase tracking-widest font-bold text-slate-600 mb-2">Recarga <span class="text-purple-400/60">(acumulativo)</span></p>
              <div class="grid grid-cols-3 gap-2">
                <div class="rounded-lg p-2.5 text-center" style="background: rgba(52,211,153,0.04); border: 1px solid rgba(52,211,153,0.08);">
                  <p id="credits-indie-eco" class="text-lg font-bold text-emerald-400/80">0</p>
                  <p class="text-[8px] text-slate-600 uppercase font-bold">Econômica</p>
                </div>
                <div class="rounded-lg p-2.5 text-center" style="background: rgba(251,191,36,0.04); border: 1px solid rgba(251,191,36,0.08);">
                  <p id="credits-indie-mid" class="text-lg font-bold text-amber-400/80">0</p>
                  <p class="text-[8px] text-slate-600 uppercase font-bold">Média</p>
                </div>
                <div class="rounded-lg p-2.5 text-center" style="background: rgba(168,85,247,0.04); border: 1px solid rgba(168,85,247,0.08);">
                  <p id="credits-indie-elite" class="text-lg font-bold text-purple-400/80">0</p>
                  <p class="text-[8px] text-slate-600 uppercase font-bold">Elite</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Stats grid -->
          <div class="grid grid-cols-3 gap-3 relative z-10">
            <div class="rounded-xl p-4 text-center" style="background: rgba(255,255,255,0.02); border: 1px solid #2A3135;">
              <span class="material-symbols-outlined text-primary text-xl mb-1">description</span>
              <p id="usage-prd-count" class="text-2xl font-bold text-white">0</p>
              <p class="text-[10px] text-slate-500 uppercase tracking-wider font-bold" data-i18n="perfil.uso.geracoes">Gerações PRD</p>
            </div>
            <div class="rounded-xl p-4 text-center" style="background: rgba(255,255,255,0.02); border: 1px solid #2A3135;">
              <span class="material-symbols-outlined text-cta text-xl mb-1">chat</span>
              <p id="usage-chat-count" class="text-2xl font-bold text-white">0</p>
              <p class="text-[10px] text-slate-500 uppercase tracking-wider font-bold" data-i18n="perfil.uso.chats">Chats</p>
            </div>
            <div class="rounded-xl p-4 text-center" style="background: rgba(255,255,255,0.02); border: 1px solid #2A3135;">
              <span class="material-symbols-outlined text-purple-400 text-xl mb-1">volume_up</span>
              <p id="usage-tts-count" class="text-2xl font-bold text-white">0</p>
              <p class="text-[10px] text-slate-500 uppercase tracking-wider font-bold" data-i18n="perfil.uso.audios">Áudios TTS</p>
            </div>
          </div>

          <!-- Usage by model (bar chart) -->
          <div class="relative z-10">
            <p class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-3" data-i18n="perfil.uso.grafico">Uso por Modelo</p>
            <div id="usage-model-bars" class="space-y-2">
              <p class="text-xs text-slate-600 italic">Nenhum uso registrado ainda.</p>
            </div>
          </div>

          <!-- Usage over time (interactive chart) -->
          <div class="relative z-10 mt-4">
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2 mb-3">
              <p class="text-[10px] uppercase tracking-widest font-bold text-slate-500">Histórico de Uso</p>
              <div class="flex items-center gap-2 flex-wrap">
                <!-- Period selector -->
                <div class="flex rounded-lg overflow-hidden border border-white/10">
                  <button data-chart-period="dias" class="chart-period-btn text-[9px] px-2.5 py-1 font-bold uppercase tracking-wider bg-primary/15 text-primary cursor-pointer transition-all">Dias</button>
                  <button data-chart-period="semanas" class="chart-period-btn text-[9px] px-2.5 py-1 font-bold uppercase tracking-wider text-slate-500 hover:text-white cursor-pointer transition-all">Semanas</button>
                  <button data-chart-period="meses" class="chart-period-btn text-[9px] px-2.5 py-1 font-bold uppercase tracking-wider text-slate-500 hover:text-white cursor-pointer transition-all">Meses</button>
                </div>
                <!-- Chart type selector -->
                <div class="flex rounded-lg overflow-hidden border border-white/10">
                  <button data-chart-type="line" class="chart-type-btn text-[9px] px-2 py-1 cursor-pointer transition-all bg-primary/15 text-primary" title="Linha">
                    <span class="material-symbols-outlined text-sm">show_chart</span>
                  </button>
                  <button data-chart-type="bar" class="chart-type-btn text-[9px] px-2 py-1 cursor-pointer transition-all text-slate-500 hover:text-white" title="Barras">
                    <span class="material-symbols-outlined text-sm">bar_chart</span>
                  </button>
                  <button data-chart-type="area" class="chart-type-btn text-[9px] px-2 py-1 cursor-pointer transition-all text-slate-500 hover:text-white" title="Área">
                    <span class="material-symbols-outlined text-sm">area_chart</span>
                  </button>
                </div>
              </div>
            </div>
            <div id="usage-line-chart" class="w-full rounded-xl p-4" style="background: rgba(255,255,255,0.02); border: 1px solid #2A3135; min-height: 220px;">
              <p class="text-xs text-slate-600 italic">Carregando...</p>
            </div>
          </div>
        </div>

        <!-- ══════════════════════════════════════════════ -->
        <!-- AGENT SELECTION (Champion Select) — inside Plano tab -->
        <!-- ══════════════════════════════════════════════ -->
        <div class="rounded-2xl p-6 space-y-5 relative overflow-hidden" style="background: #121212; border: 1px solid #2A3135;">
          <div class="absolute -top-20 -right-20 w-60 h-60 bg-primary/5 rounded-full blur-[80px] pointer-events-none"></div>
          <div class="flex items-center gap-2 mb-2 relative z-10">
            <span class="material-symbols-outlined text-primary text-lg">smart_toy</span>
            <h3 class="text-lg font-bold text-white" data-i18n="perfil.agente">Agente</h3>
          </div>

          <div id="agent-grid" class="grid grid-cols-2 lg:grid-cols-4 gap-3 relative z-10">
            <button type="button" data-agent="theboss" class="agent-card group relative rounded-xl overflow-hidden border-2 border-transparent hover:border-[#C0392B]/60 transition-all duration-300 cursor-pointer aspect-[3/4] bg-black">
              <img src="/agentes/Theboss.png" alt="The Boss" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
              <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 p-3 sm:p-4">
                <h4 class="text-white font-bold text-sm sm:text-base tracking-wide">The Boss</h4>
                <p class="text-slate-400 text-[10px] sm:text-xs font-medium mt-0.5">O Arquiteto Pragmatico</p>
                <p class="text-slate-500 text-[9px] sm:text-[10px] mt-2 leading-relaxed opacity-0 group-hover:opacity-100 transition-opacity duration-300 hidden sm:block">"Voce quer um software ou um brinquedo?"</p>
              </div>
              <div class="agent-check absolute top-2 right-2 w-6 h-6 rounded-full bg-[#C0392B] items-center justify-center hidden">
                <span class="material-symbols-outlined text-white text-sm">check</span>
              </div>
            </button>

            <button type="button" data-agent="azrael" class="agent-card group relative rounded-xl overflow-hidden border-2 border-transparent hover:border-[#8E44AD]/60 transition-all duration-300 cursor-pointer aspect-[3/4] bg-black">
              <img src="/agentes/Azrael.png" alt="Azrael" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
              <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 p-3 sm:p-4">
                <h4 class="text-white font-bold text-sm sm:text-base tracking-wide">Azrael</h4>
                <p class="text-slate-400 text-[10px] sm:text-xs font-medium mt-0.5">O Visionario Obsessivo</p>
