  function renderAgentSelection(selectedId: string) {
    document.querySelectorAll('.agent-card').forEach(card => {
      const id = (card as HTMLElement).dataset.agent;
      const check = card.querySelector('.agent-check');
      if (id === selectedId) {
        card.classList.add('ring-2');
        (card as HTMLElement).style.borderColor = agentColors[id] || '#2E748B';
        (card as HTMLElement).style.boxShadow = `0 0 20px ${agentColors[id]}40`;
        if (check) { check.classList.remove('hidden'); check.classList.add('flex'); }
      } else {
        card.classList.remove('ring-2');
        (card as HTMLElement).style.borderColor = 'transparent';
        (card as HTMLElement).style.boxShadow = 'none';
        if (check) { check.classList.add('hidden'); check.classList.remove('flex'); }
      }
    });
  }

  function showAgentLoadingScreen(selectedId: string) {
    const screen = document.getElementById('agent-loading-screen')!;
    screen.classList.remove('hidden');
    document.body.style.overflow = 'hidden';

    // Highlight selected agent + play video
    document.querySelectorAll('.agent-loading-col').forEach(col => {
      const id = (col as HTMLElement).dataset.loadingAgent;
      const vid = col.querySelector('.agent-load-vid') as HTMLVideoElement | null;
      const img = col.querySelector('.agent-load-img') as HTMLElement | null;

      if (id === selectedId) {
        col.classList.remove('opacity-30', 'grayscale');
        col.classList.add('opacity-100');
        const border = col.querySelector('.relative') as HTMLElement;
        if (border) border.style.borderColor = agentColors[id] || '#2E748B';

        // Play video for selected agent
        if (vid) {
          vid.currentTime = 0;
          vid.play().catch(() => {});
          vid.style.opacity = '1';
        }
        if (img) img.style.opacity = '0';
      } else {
        col.classList.add('opacity-30', 'grayscale');
        col.classList.remove('opacity-100');

        // Keep others as static image
        if (vid) { vid.pause(); vid.style.opacity = '0'; }
        if (img) img.style.opacity = '1';
      }
    });

    // Show random tip
    const tips = agentTips[selectedId] || agentTips.theboss;
    const tipEl = document.getElementById('loading-tip')!;
    tipEl.textContent = '"' + tips[Math.floor(Math.random() * tips.length)] + '"';

    // Animate progress bars
    setTimeout(() => {
      document.querySelectorAll('.agent-load-bar').forEach(bar => {
        (bar as HTMLElement).style.width = '100%';
      });
    }, 100);

    // Close after 4 seconds — stop all videos
    setTimeout(() => {
      screen.classList.add('hidden');
      document.body.style.overflow = '';
      document.querySelectorAll('.agent-load-vid').forEach(v => {
        const vid = v as HTMLVideoElement;
        vid.pause();
        vid.style.opacity = '0';
      });
      document.querySelectorAll('.agent-load-img').forEach(img => {
        (img as HTMLElement).style.opacity = '1';
      });
      // Reset progress bars for next time
      document.querySelectorAll('.agent-load-bar').forEach(bar => {
        (bar as HTMLElement).style.width = '0%';
      });
    }, 4200);
  }

  // Handle card clicks
  document.querySelectorAll('.agent-card').forEach(card => {
    card.addEventListener('click', async () => {
      const agentId = (card as HTMLElement).dataset.agent!;
      if (currentProfile?.agent === agentId) return;

      // Explorador só pode usar The Boss
      const userPlan = (window as any).__bcPlan || 'explorador';
      if (userPlan === 'explorador' && agentId !== 'theboss') {
        const agentNames: Record<string, string> = { azrael: 'Azrael', rizler: 'Rizler', anastasia: 'Anastasia' };
        showUpgradeToast('Agente Premium', `O agente ${agentNames[agentId] || agentId} está disponível apenas para planos Consultor e Arquiteto. Faça upgrade para desbloquear!`);
        return;
      }

      // Save to DB and localStorage
      await updateProfile(currentUserId, { agent: agentId } as Partial<Profile>);
      localStorage.setItem('bc-agent', agentId);
      if (currentProfile) (currentProfile as any).agent = agentId;

      renderAgentSelection(agentId);
      showAgentLoadingScreen(agentId);
      showFeedback();
    });
  });

  // Render initial selection
  function initAgentSelection() {
    const saved = (currentProfile as any)?.agent || localStorage.getItem('bc-agent') || 'theboss';
    localStorage.setItem('bc-agent', saved);
    renderAgentSelection(saved);

    // Apply plan restrictions — add lock overlay for Explorador users
    const userPlan = (window as any).__bcPlan || 'explorador';
    if (userPlan === 'explorador') {
      document.querySelectorAll('.agent-card').forEach(card => {
        const id = (card as HTMLElement).dataset.agent;
        if (id && id !== 'theboss') {
          // Add lock overlay
          const lock = document.createElement('div');
          lock.className = 'absolute inset-0 bg-black/60 backdrop-blur-[2px] flex flex-col items-center justify-center z-20 rounded-xl';
          lock.innerHTML = '<span class="material-symbols-outlined text-3xl text-slate-400 mb-1">lock</span><span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">Plano Pro+</span>';
          (card as HTMLElement).style.position = 'relative';
          card.appendChild(lock);
        }
      });
    }
  }

  // ══════════════════════════════
  //  LLM MODEL SELECTION
  // ══════════════════════════════

  const llmTierColors: Record<string, string> = {
    budget: '#10B981',
    mid: '#F59E0B',
    pro: '#A855F7',
  };

  const llmModelNames: Record<string, string> = {
    'google/gemma-3-4b-it:free': 'Gemma 3 4B',
    'meta-llama/llama-3.1-8b-instruct:free': 'Llama 3.1 8B',
    'mistralai/mistral-small-3.1-24b-instruct:free': 'Mistral Small 3.1',
    'google/gemini-2.0-flash-001': 'Gemini 2.0 Flash',
    'openai/gpt-4o-mini': 'GPT-4o Mini',
    'anthropic/claude-3.5-haiku': 'Claude 3.5 Haiku',
    'anthropic/claude-sonnet-4': 'Claude Sonnet 4',
    'openai/gpt-4o': 'GPT-4o',
    'google/gemini-2.5-pro-preview': 'Gemini 2.5 Pro',
  };

  function renderLlmSelection(selectedId: string) {
    document.querySelectorAll('.llm-card').forEach(card => {
      const id = (card as HTMLElement).dataset.llm;
      const tier = (card as HTMLElement).dataset.tier || 'budget';
      const check = card.querySelector('.llm-check');
      if (id === selectedId) {
        const color = llmTierColors[tier];
        (card as HTMLElement).style.borderColor = color + '60';
        (card as HTMLElement).style.boxShadow = `0 0 15px ${color}20`;
        if (check) { check.classList.remove('hidden'); check.classList.add('flex'); }
      } else {
        (card as HTMLElement).style.borderColor = 'transparent';
        (card as HTMLElement).style.boxShadow = 'none';
        if (check) { check.classList.add('hidden'); check.classList.remove('flex'); }
      }
    });

    // Update info bar
    const nameEl = document.getElementById('llm-selected-name');
    const providerEl = document.getElementById('llm-selected-provider');
    if (nameEl) nameEl.textContent = llmModelNames[selectedId] || selectedId;
    const selectedCard = document.querySelector(`[data-llm="${selectedId}"]`) as HTMLElement;
    if (providerEl && selectedCard) providerEl.textContent = selectedCard.dataset.provider || '';
  }

  // LLM card clicks
  document.querySelectorAll('.llm-card').forEach(card => {
    card.addEventListener('click', async () => {
      const llmId = (card as HTMLElement).dataset.llm!;
      const tier = (card as HTMLElement).dataset.tier || 'budget';
      const currentLlm = (currentProfile as any)?.llm_model;
      if (currentLlm === llmId) return;

      // Explorador só pode usar modelos econômicos (budget)
      const userPlan = (window as any).__bcPlan || 'explorador';
      if (userPlan === 'explorador' && tier !== 'budget') {
        showUpgradeToast('Modelo Premium', 'Modelos intermediários e profissionais estão disponíveis apenas para planos Consultor e Arquiteto. Faça upgrade para desbloquear!');
        return;
      }

      await updateProfile(currentUserId, { llm_model: llmId } as Partial<Profile>);
      localStorage.setItem('bc-llm-model', llmId);
      if (currentProfile) (currentProfile as any).llm_model = llmId;

      renderLlmSelection(llmId);
      showFeedback();
    });
  });

  // LLM search filter
  const llmSearchInput = document.getElementById('llm-search') as HTMLInputElement;
  if (llmSearchInput) {
    llmSearchInput.addEventListener('input', () => {
      const query = llmSearchInput.value.toLowerCase().trim();
      document.querySelectorAll('.llm-card').forEach(card => {
        const el = card as HTMLElement;
        const text = el.textContent?.toLowerCase() || '';
        const provider = (el.dataset.provider || '').toLowerCase();
        const tier = (el.dataset.tier || '').toLowerCase();
        const match = !query || text.includes(query) || provider.includes(query) || tier.includes(query);
        el.style.display = match ? '' : 'none';
      });
    });
  }

  // Inicialização LLM selection
  function initLlmSelection() {
    const saved = (currentProfile as any)?.llm_model || localStorage.getItem('bc-llm-model') || 'google/gemma-3-4b-it:free';
    localStorage.setItem('bc-llm-model', saved);
    renderLlmSelection(saved);

    // Apply plan restrictions — lock mid/pro for Explorador
    const userPlan = (window as any).__bcPlan || 'explorador';
    if (userPlan === 'explorador') {
      document.querySelectorAll('.llm-card').forEach(card => {
        const tier = (card as HTMLElement).dataset.tier || 'budget';
        if (tier !== 'budget') {
          const lock = document.createElement('div');
          lock.className = 'absolute inset-0 bg-black/60 backdrop-blur-[2px] flex flex-col items-center justify-center z-20 rounded-xl';
          lock.innerHTML = '<span class="material-symbols-outlined text-2xl text-slate-400 mb-1">lock</span><span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">Plano Pro+</span>';
          (card as HTMLElement).style.position = 'relative';
          card.appendChild(lock);
        }
      });
    }
  }

  document.getElementById('btn-confirm-add')!.addEventListener('click', async () => {
    const name = (document.getElementById('new-user-name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('new-user-email') as HTMLInputElement).value.trim();
    const role = (document.getElementById('new-user-role') as HTMLSelectElement).value as 'user' | 'admin';
    const plan = (document.getElementById('new-user-plan') as HTMLSelectElement).value;
    const canAccessDashboard = (document.getElementById('new-user-dashboard') as HTMLInputElement).checked;
    const msgEl = document.getElementById('add-user-msg')!;

    if (!name || !email) {
      msgEl.className = 'rounded-lg px-3 py-2 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
      msgEl.textContent = 'Preencha nome e e-mail.';
      return;
    }

    msgEl.className = 'rounded-lg px-3 py-2 text-sm font-medium bg-primary/10 text-primary border border-primary/20';
    msgEl.textContent = 'Criando usuário...';

    const { error } = await inviteUser(email, name, role, plan, canAccessDashboard);
    if (error) {
      msgEl.className = 'rounded-lg px-3 py-2 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
      msgEl.textContent = 'Erro: ' + error.message;
    } else {
      msgEl.className = 'rounded-lg px-3 py-2 text-sm font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/20';
      msgEl.textContent = 'Usuário criado! Um e-mail de redefinição de senha foi enviado.';
      (document.getElementById('new-user-name') as HTMLInputElement).value = '';
      (document.getElementById('new-user-email') as HTMLInputElement).value = '';
      loadUsers();
      setTimeout(() => {
        document.getElementById('add-user-form')!.classList.add('hidden');
        msgEl.className = 'hidden';
      }, 3000);
    }
  });

  // Logo swap for light/dark theme
  function updatePageLogo() {
    document.querySelectorAll('img[data-dark][data-light]').forEach(el => {
      const isLight = document.documentElement.classList.contains('light');
      el.setAttribute('src', isLight ? (el.getAttribute('data-light') || '') : (el.getAttribute('data-dark') || ''));
    });
  }
  updatePageLogo();
  new MutationObserver(updatePageLogo).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
</script>
