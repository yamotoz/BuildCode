          <p class="text-primary text-xs font-semibold">Ultima atualizacao: Marco de 2026 · Versao 1.0</p>
          <p class="text-slate-500 text-[10px] mt-1">Este documento foi elaborado em conformidade com a Lei Geral de Protecao de Dados (LGPD - Lei 13.709/2018), Marco Civil da Internet (Lei 12.965/2014) e Codigo de Defesa do Consumidor (Lei 8.078/1990).</p>
        </div>
      </div>

      <!-- Footer (sticky) -->
      <div class="px-6 py-4 border-t border-white/[0.05] shrink-0 space-y-3">
        <div id="terms-scroll-hint" class="flex items-center justify-center gap-2 text-[11px] text-amber-400/80">
          <span class="material-symbols-outlined text-sm animate-bounce">expand_more</span>
          Role ate o final para habilitar o botao de aceite
        </div>
        <div class="flex items-center gap-3">
          <button type="button" id="btn-decline-terms" class="flex-1 py-3 rounded-xl border border-red-500/20 text-red-400 text-sm font-semibold hover:bg-red-500/10 transition-all cursor-pointer">
            Nao Aceito
          </button>
          <button type="button" id="btn-accept-terms" disabled class="flex-1 py-3 rounded-xl border border-emerald-500/30 bg-emerald-500/10 text-emerald-400 text-sm font-semibold hover:bg-emerald-500/20 transition-all cursor-pointer disabled:opacity-30 disabled:cursor-not-allowed">
            <span class="material-symbols-outlined text-sm align-middle mr-1">check_circle</span>
            Aceito os Termos
          </button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  @keyframes shimmer { 100% { transform: translateX(100%); } }

  /* Fix password reveal eye icon (browser-native) for dark backgrounds */
  input[type="password"]::-ms-reveal,
  input[type="password"]::-ms-clear {
    filter: invert(1);
  }
  input[type="text"]::-ms-reveal,
  input[type="text"]::-ms-clear {
    filter: invert(1);
  }
  /* Chrome/Edge Chromium */
  input::-webkit-credentials-auto-fill-button {
    filter: invert(1);
  }

  /* Custom password toggle button */
  .pw-toggle {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: #64748b;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
    z-index: 2;
  }
  .pw-toggle:hover {
    color: #94a3b8;
  }
</style>

<script>
  import { supabase, signInWithEmail, signInWithGoogle, getProfile } from '../lib/supabase';

  // ═══════════════════════════════════════════
  //  PASSWORD TOGGLE (eye icon)
  // ═══════════════════════════════════════════
  document.querySelectorAll('.pw-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = (btn as HTMLElement).dataset.target!;
      const input = document.getElementById(targetId) as HTMLInputElement;
      const icon = btn.querySelector('.material-symbols-outlined')!;
      if (input.type === 'password') {
        input.type = 'text';
        icon.textContent = 'visibility_off';
      } else {
        input.type = 'password';
        icon.textContent = 'visibility';
      }
    });
  });

  // ═══════════════════════════════════════════
  //  BRUTE FORCE PROTECTION (client-side tracking)
  // ═══════════════════════════════════════════
  const LOGIN_LIMITS = [
    { attempts: 10, blockSeconds: 3600 },   // 10+ fails → 1 hora
    { attempts: 5, blockSeconds: 900 },     // 5+ fails → 15 min
    { attempts: 3, blockSeconds: 60 },      // 3+ fails → 1 min
  ];

  function getLoginAttempts(): { count: number; lastFail: number } {
    try {
      const raw = localStorage.getItem('_bf_guard');
      if (raw) return JSON.parse(raw);
    } catch {}
    return { count: 0, lastFail: 0 };
  }

  function setLoginAttempts(count: number) {
    localStorage.setItem('_bf_guard', JSON.stringify({ count, lastFail: Date.now() }));
  }

  function clearLoginAttempts() {
    localStorage.removeItem('_bf_guard');
  }

  function checkBruteForce(): { blocked: boolean; retryAfter?: number; message?: string } {
    const { count, lastFail } = getLoginAttempts();
    if (count < 3) return { blocked: false };

    for (const limit of LOGIN_LIMITS) {
      if (count >= limit.attempts) {
        const elapsed = (Date.now() - lastFail) / 1000;
        if (elapsed < limit.blockSeconds) {
          const remaining = Math.ceil(limit.blockSeconds - elapsed);
          const mins = Math.floor(remaining / 60);
          const secs = remaining % 60;
          const timeStr = mins > 0 ? `${mins}min ${secs}s` : `${secs}s`;
          return {
            blocked: true,
            retryAfter: remaining,
            message: `Muitas tentativas falhas (${count}). Tente novamente em ${timeStr}.`,
          };
        }
        break;
      }
    }
    return { blocked: false };
  }

  const formLogin = document.getElementById('form-login')! as HTMLFormElement;
  const formSignup = document.getElementById('form-signup')! as HTMLFormElement;
  const formRecovery = document.getElementById('form-recovery')! as HTMLFormElement;
  const authGoogle = document.getElementById('auth-google')!;
  const authMsg = document.getElementById('auth-msg')!;
  const btnForgot = document.getElementById('btn-forgot')!;
  const btnGoogle = document.getElementById('btn-google')!;
  const btnShowEmail = document.getElementById('btn-show-email')!;
  const btnShowSignup = document.getElementById('btn-show-signup')!;
  const btnBackGoogle = document.getElementById('btn-back-google')!;
  const btnBackSignup = document.getElementById('btn-back-signup')!;
  const headerTitle = document.getElementById('auth-title')!;
  const headerDesc = document.getElementById('auth-desc')!;

  let isRecoveryMode = false;

  function showMsg(text: string, type: 'error' | 'success') {
    authMsg.textContent = text;
    authMsg.className = `rounded-xl px-4 py-3 text-sm font-medium ${
      type === 'error'
        ? 'bg-red-500/10 text-red-400 border border-red-500/20'
        : 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20'
    }`;
  }

  function hideMsg() {
    authMsg.className = 'hidden';
  }

  function showLoginToast(message: string, type: 'success' | 'error' = 'success') {
    const existing = document.getElementById('bc-toast');
    if (existing) existing.remove();
    const toast = document.createElement('div');
    toast.id = 'bc-toast';
    const icon = type === 'success' ? 'check_circle' : 'error';
    const bg = type === 'success'
      ? 'linear-gradient(135deg, #059669, #10B981)'
      : 'linear-gradient(135deg, #DC2626, #EF4444)';
    toast.innerHTML = `<span class="material-symbols-outlined" style="font-size:20px">${icon}</span><span>${message}</span>`;
    Object.assign(toast.style, {
      position: 'fixed', bottom: '24px', right: '24px', zIndex: '99999',
      display: 'flex', alignItems: 'center', gap: '10px',
      background: bg, color: '#fff',
      padding: '14px 24px', borderRadius: '14px',
      fontSize: '14px', fontWeight: '600',
      boxShadow: '0 8px 32px rgba(0,0,0,0.3)',
      transform: 'translateY(20px)', opacity: '0',
      transition: 'all 0.4s cubic-bezier(0.16,1,0.3,1)',
      maxWidth: '400px',
    });
    document.body.appendChild(toast);
    requestAnimationFrame(() => { toast.style.transform = 'translateY(0)'; toast.style.opacity = '1'; });
    setTimeout(() => {
      toast.style.transform = 'translateY(20px)'; toast.style.opacity = '0';
      setTimeout(() => toast.remove(), 400);
    }, 4000);
  }

  function showPanel(panel: 'google' | 'login' | 'signup' | 'recovery') {
    authGoogle.classList.add('hidden');
    formLogin.classList.add('hidden');
    formSignup.classList.add('hidden');
    formRecovery.classList.add('hidden');
    hideMsg();

    if (panel === 'google') {
      authGoogle.classList.remove('hidden');
      headerTitle.textContent = 'Seja bem-vindo ao Futuro.';
      headerDesc.textContent = 'Crie sua conta ou entre com o Google para começar.';
    } else if (panel === 'login') {
      formLogin.classList.remove('hidden');
      headerTitle.textContent = 'Entrar no Sistema';
      headerDesc.textContent = 'Use seu e-mail e senha para acessar.';
    } else if (panel === 'signup') {
      formSignup.classList.remove('hidden');
      headerTitle.textContent = 'Criar Nova Conta';
      headerDesc.textContent = 'Preencha os dados abaixo para se cadastrar.';
    } else if (panel === 'recovery') {
      formRecovery.classList.remove('hidden');
      headerTitle.textContent = 'Redefinir sua senha';
      headerDesc.textContent = 'Escolha uma nova senha segura para sua conta.';
    }
  }

  function enterRecoveryMode() {
    isRecoveryMode = true;
    showPanel('recovery');
    showMsg('Link de recuperação validado! Defina sua nova senha abaixo.', 'success');
  }

  // Navigation
  btnShowEmail.addEventListener('click', () => showPanel('login'));
  btnShowSignup.addEventListener('click', () => showPanel('signup'));
  btnBackGoogle.addEventListener('click', () => showPanel('google'));
  btnBackSignup.addEventListener('click', () => showPanel('google'));

  // ═══════════════════════════════════════════
  //  PASSWORD STRENGTH METER
  // ═══════════════════════════════════════════
  const signupPassword = document.getElementById('signup-password') as HTMLInputElement;
  const signupConfirm = document.getElementById('signup-confirm') as HTMLInputElement;
  const btnSignup = document.getElementById('btn-signup') as HTMLButtonElement;
  const pwStrengthWrap = document.getElementById('pw-strength-wrap')!;
  const pwBars = [1, 2, 3, 4].map(i => document.getElementById(`pw-bar-${i}`)!);
  const pwLabel = document.getElementById('pw-strength-label')!;
  const pwTip = document.getElementById('pw-strength-tip')!;

  const checks = {
    length: document.getElementById('pw-check-length')!,
    upper: document.getElementById('pw-check-upper')!,
    lower: document.getElementById('pw-check-lower')!,
    number: document.getElementById('pw-check-number')!,
    symbol: document.getElementById('pw-check-symbol')!,
  };

  function updateCheck(el: HTMLElement, pass: boolean) {
    const icon = el.querySelector('.material-symbols-outlined')!;
    const text = el.querySelector('span:last-child')!;
    if (pass) {
      icon.textContent = 'check_circle';
      icon.className = 'material-symbols-outlined text-[12px] text-emerald-400';
      text.className = 'text-[10px] text-emerald-400';
    } else {
      icon.textContent = 'circle';
      icon.className = 'material-symbols-outlined text-[12px] text-slate-700';
      text.className = 'text-[10px] text-slate-600';
    }
  }

  function evaluatePassword(pw: string) {
    const has = {
      length: pw.length >= 8,
      upper: /[A-Z]/.test(pw),
      lower: /[a-z]/.test(pw),
      number: /[0-9]/.test(pw),
      symbol: /[^A-Za-z0-9]/.test(pw),
    };

    updateCheck(checks.length, has.length);
    updateCheck(checks.upper, has.upper);
    updateCheck(checks.lower, has.lower);
    updateCheck(checks.number, has.number);
    updateCheck(checks.symbol, has.symbol);

    const score = Object.values(has).filter(Boolean).length;

    // Colors
    const colors = ['#EF4444', '#F59E0B', '#F59E0B', '#2E748B', '#10B981'];
    const labels = ['Forte pra Caralho!', 'Fraca', 'Media', 'Forte', 'Muito forte'];
    const tips = ['Adicione mais requisitos', 'Falta pouco...', 'Quase la!', 'Boa senha!', 'Excelente!'];
    const color = colors[score] || colors[0];
    const label = labels[score] || labels[0];

    pwBars.forEach((bar, i) => {
      bar.style.background = i < score ? color : 'rgba(255,255,255,0.06)';
    });
    pwLabel.textContent = label;
    pwLabel.style.color = color;
    pwTip.textContent = tips[score] || '';

    return { score, allPassed: score === 5 };
  }

  function validateSignupForm() {
    const pw = signupPassword.value;
    const confirm = signupConfirm.value;
    const email = (document.getElementById('signup-email') as HTMLInputElement).value;
    const { allPassed } = evaluatePassword(pw);
    const passwordsMatch = pw === confirm && confirm.length > 0;
    const emailValid = email.includes('@') && email.includes('.');

    btnSignup.disabled = !(allPassed && passwordsMatch && emailValid);
  }

  signupPassword.addEventListener('input', () => {
    if (signupPassword.value.length > 0) {
      pwStrengthWrap.classList.remove('hidden');
    } else {
      pwStrengthWrap.classList.add('hidden');
    }
    evaluatePassword(signupPassword.value);
    validateSignupForm();
  });

  signupConfirm.addEventListener('input', validateSignupForm);
  document.getElementById('signup-email')?.addEventListener('input', validateSignupForm);

  // ═══════════════════════════════════════════
  //  SIGNUP SUBMIT
  // ═══════════════════════════════════════════
  formSignup.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideMsg();

    const email = (document.getElementById('signup-email') as HTMLInputElement).value;
    const password = signupPassword.value;
    const confirm = signupConfirm.value;

    if (password !== confirm) {
      showMsg('As senhas nao coincidem.', 'error');
      return;
    }

    const btnText = document.getElementById('btn-signup-text')!;
    btnText.textContent = 'Criando conta...';
    btnSignup.disabled = true;

    try {
      const res = await fetch('/api/signup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password }),
      });

      const data = await res.json();

      if (!res.ok) {
        showMsg(data.error || 'Erro ao criar conta.', 'error');
        btnText.textContent = 'Criar Conta';
        btnSignup.disabled = false;
        return;
      }

      // Success - now sign in
      showMsg('Conta criada com sucesso! Entrando...', 'success');
      const { error: loginError } = await signInWithEmail(email, password);
      if (loginError) {
        showMsg('Conta criada! Faça login com suas credenciais.', 'success');
        setTimeout(() => showPanel('login'), 1500);
      }
      // onAuthStateChange will handle redirect + terms
    } catch (err) {
      showMsg('Erro de conexao. Tente novamente.', 'error');
      btnText.textContent = 'Criar Conta';
      btnSignup.disabled = false;
    }
  });

  // ═══════════════════════════════════════════
  //  TERMS MODAL
  // ═══════════════════════════════════════════
  const termsModal = document.getElementById('terms-modal')!;
  const termsContent = document.getElementById('terms-content')!;
  const btnAcceptTerms = document.getElementById('btn-accept-terms') as HTMLButtonElement;
  const btnDeclineTerms = document.getElementById('btn-decline-terms')!;
  const termsScrollHint = document.getElementById('terms-scroll-hint')!;

  // Enable accept button only after scrolling to bottom
  termsContent.addEventListener('scroll', () => {
    const nearBottom = termsContent.scrollTop + termsContent.clientHeight >= termsContent.scrollHeight - 50;
    if (nearBottom) {
      btnAcceptTerms.disabled = false;
      termsScrollHint.classList.add('hidden');
    }
  });

  function showTermsModal() {
    termsModal.classList.remove('hidden');
    termsModal.classList.add('flex');
    btnAcceptTerms.disabled = true;
    termsScrollHint.classList.remove('hidden');
    termsContent.scrollTop = 0;
  }

  btnDeclineTerms.addEventListener('click', async () => {
    // If they decline, sign them out and redirect
    await supabase.auth.signOut();
    termsModal.classList.add('hidden');
    termsModal.classList.remove('flex');
    showMsg('Voce precisa aceitar os termos para utilizar o BuildCode.', 'error');
    showPanel('google');
  });

  btnAcceptTerms.addEventListener('click', async () => {
    btnAcceptTerms.textContent = 'Registrando...';
    btnAcceptTerms.disabled = true;

    try {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        termsModal.classList.add('hidden');
        termsModal.classList.remove('flex');
        showMsg('Sessao expirada. Faca login novamente.', 'error');
        showPanel('google');
        return;
      }

      // Try server-side API first
      let accepted = false;
      try {
        const res = await fetch('/api/accept-terms', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': 'Bearer ' + session.access_token,
          },
        });
        if (res.ok) accepted = true;
      } catch { /* fallback below */ }

      // Fallback: update directly via Supabase client if API failed
      if (!accepted) {
        const { error: directErr } = await supabase
          .from('profiles')
          .update({
            terms_accepted_at: new Date().toISOString(),
            terms_version: '1.0',
          })
          .eq('id', session.user.id);

        if (directErr) {
          console.error('[Terms] Direct update error:', directErr);
          showLoginToast('Erro ao registrar aceite dos termos: ' + directErr.message, 'error');
          btnAcceptTerms.textContent = 'Aceito os Termos';
          btnAcceptTerms.disabled = false;
          return;
        }
      }

      // Success — redirect
      termsModal.classList.add('hidden');
      termsModal.classList.remove('flex');
      window.location.href = '/perfil';
    } catch (err: any) {
      console.error('[Terms] Error:', err);
      showLoginToast('Erro ao aceitar termos: ' + (err?.message || 'erro desconhecido'), 'error');
      btnAcceptTerms.textContent = 'Aceito os Termos';
      btnAcceptTerms.disabled = false;
    }
  });

  // ═══════════════════════════════════════════
  //  AUTH FLOW
  // ═══════════════════════════════════════════
  async function checkTermsAndRedirect() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return;

    const profile = await getProfile(session.user.id);

    // If user hasn't accepted terms, show modal
    if (!profile?.terms_accepted_at) {
      showTermsModal();
      return;
    }

    // Terms accepted, redirect
    window.location.href = '/perfil';
  }

  // Google OAuth
  btnGoogle.addEventListener('click', async () => {
    const btnText = document.getElementById('btn-google-text')!;
    btnText.textContent = 'Redirecionando...';
    const { error } = await signInWithGoogle();
    if (error) {
      showMsg('Erro ao conectar com Google: ' + error.message, 'error');
      btnText.textContent = 'Continuar com Google';
    }
  });

  // Listen for auth state changes
  supabase.auth.onAuthStateChange((event, _session) => {
    if (event === 'PASSWORD_RECOVERY') {
      enterRecoveryMode();
    } else if (event === 'SIGNED_IN' && !isRecoveryMode) {
      checkTermsAndRedirect();
    }
  });

  // Check if already logged in
  supabase.auth.getSession().then(({ data: { session } }) => {
    if (session && !isRecoveryMode && !window.location.hash.includes('type=recovery')) {
      checkTermsAndRedirect();
    }
  });

  // Forgot password
  btnForgot.addEventListener('click', async () => {
    const email = (document.getElementById('login-email') as HTMLInputElement).value;
    if (!email) {
      showMsg('Digite seu e-mail primeiro.', 'error');
      return;
    }
    btnForgot.textContent = 'Enviando...';
    const { error } = await supabase.auth.resetPasswordForEmail(email, {
      redirectTo: `${window.location.origin}/login`,
    });
    btnForgot.textContent = 'Esqueci minha senha';
    if (error) {
      showMsg(error.message, 'error');
    } else {
      showMsg('E-mail de recuperação enviado! Verifique sua caixa de entrada.', 'success');
    }
  });

  // Recovery form submit
  formRecovery.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideMsg();
    const newPassword = (document.getElementById('recovery-password') as HTMLInputElement).value;
    const confirmPassword = (document.getElementById('recovery-confirm') as HTMLInputElement).value;

    if (newPassword !== confirmPassword) {
      showMsg('As senhas não coincidem.', 'error');
      return;
    }

    if (newPassword.length < 6) {
      showMsg('A senha deve ter pelo menos 6 caracteres.', 'error');
      return;
    }

    const { error } = await supabase.auth.updateUser({ password: newPassword });
    if (error) {
      showMsg('Erro ao atualizar senha: ' + error.message, 'error');
    } else {
      showMsg('Senha atualizada com sucesso! Redirecionando...', 'success');
      setTimeout(() => { window.location.href = '/perfil'; }, 1500);
    }
  });

  // Email login submit (with brute force protection — client + server)
  formLogin.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideMsg();

    // Client-side brute force check (immediate feedback)
    const bf = checkBruteForce();
    if (bf.blocked) {
      showMsg(bf.message!, 'error');
      return;
    }

    const email = (document.getElementById('login-email') as HTMLInputElement).value;
    const password = (document.getElementById('login-password') as HTMLInputElement).value;
    const btnText = document.getElementById('btn-login-text')!;

    btnText.textContent = 'Entrando...';

    try {
      // Server-side login (has its own IP-based brute force tracking)
      const res = await fetch('/api/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password }),
      });

      const data = await res.json();

      if (!res.ok) {
        const { count } = getLoginAttempts();
        setLoginAttempts(count + 1);

        if (data.retryAfter) {
          const mins = Math.floor(data.retryAfter / 60);
          const secs = data.retryAfter % 60;
          const timeStr = mins > 0 ? `${mins}min ${secs}s` : `${secs}s`;
          showMsg(`Muitas tentativas falhas. Tente novamente em ${timeStr}.`, 'error');
        } else {
          showMsg(data.error || 'E-mail ou senha incorretos.', 'error');
        }
        btnText.textContent = 'Entrar no Sistema';
        return;
      }

      // Server returned session — set it in the client
      if (data.session) {
        await supabase.auth.setSession({
          access_token: data.session.access_token,
          refresh_token: data.session.refresh_token,
        });
        clearLoginAttempts();
      }
      // onAuthStateChange handles redirect + terms check
    } catch {
      // Fallback to client-side login if API fails
      const { error } = await signInWithEmail(email, password);
      if (error) {
        const { count } = getLoginAttempts();
        setLoginAttempts(count + 1);
        showMsg(error.message === 'Invalid login credentials'
          ? 'E-mail ou senha incorretos.'
          : error.message, 'error');
        btnText.textContent = 'Entrar no Sistema';
      } else {
        clearLoginAttempts();
      }
    }
  });

  // Logo swap for light/dark theme
  function updatePageLogo() {
    document.querySelectorAll('img[data-dark][data-light]').forEach(el => {
      const img = el as HTMLImageElement;
      const isLight = document.documentElement.classList.contains('light');
      img.src = isLight ? (img.dataset.light || img.src) : (img.dataset.dark || img.src);
    });
  }
  updatePageLogo();
  new MutationObserver(updatePageLogo).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
</script>
