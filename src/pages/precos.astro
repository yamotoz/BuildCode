---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout
  title="Precos e Planos - BuildCode | Explorador, Consultor e Arquiteto"
  description="Escolha o plano ideal para seu projeto. Explorador gratuito, Consultor R$35/mes e Arquiteto R$50/mes. 9 modelos de IA, exportacao em Markdown, PDF e DOCX."
  canonicalPath="/precos"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Precos e Planos - BuildCode",
    "description": "Planos de assinatura do BuildCode - Explorador, Consultor e Arquiteto",
    "url": "https://buildcode.com.br/precos"
  }}
>
  <Header />

  <main class="bg-background-dark min-h-screen">
    <!-- Hero Section -->
    <section class="pt-24 pb-16 px-4 sm:px-6 lg:px-24 text-center max-w-5xl mx-auto">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display font-bold tracking-tight text-white mb-6">
        <span data-i18n="precos.hero.title.1">Arquitete seu </span><span class="text-primary" data-i18n="precos.hero.title.highlight">Futuro</span>
      </h1>
      <p class="text-slate-400 text-lg sm:text-xl max-w-2xl mx-auto leading-relaxed mb-12" data-i18n="precos.hero.subtitle">
        Software de precisão para o arquiteto técnico moderno. Escolha o plano que escala com sua ambição.
      </p>

      <!-- Billing Toggle -->
      <div class="inline-flex items-center gap-3 rounded-full border border-border-color bg-surface-dark p-1.5">
        <label class="cursor-pointer">
          <input type="radio" name="billing-cycle" value="monthly" checked class="sr-only peer" />
          <span class="peer-checked:bg-primary peer-checked:text-background-dark px-5 py-2 rounded-full text-sm font-semibold text-slate-400 transition-all" data-i18n="precos.billing.monthly">
            Mensal
          </span>
        </label>
        <label class="cursor-pointer">
          <input type="radio" name="billing-cycle" value="yearly" class="sr-only peer" />
          <span class="peer-checked:bg-primary peer-checked:text-background-dark px-5 py-2 rounded-full text-sm font-semibold text-slate-400 transition-all">
            <span data-i18n="precos.billing.yearly">Anual</span> <span class="text-xs opacity-80" data-i18n="precos.billing.discount">(-20%)</span>
          </span>
        </label>
      </div>
    </section>

    <!-- Pricing Cards -->
    <section class="px-4 sm:px-6 lg:px-24 pb-24 max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 items-stretch">

        <!-- Card 1: Explorador (Free) -->
        <div class="glass-panel rounded-2xl p-8 flex flex-col">
          <div class="mb-6">
            <h3 class="text-xl font-bold text-white mb-1" data-i18n="precos.plan.explorer">Explorador</h3>
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest" data-i18n="precos.plan.explorer.tag">Free</p>
          </div>
          <div class="mb-4">
            <span class="text-5xl font-bold text-white" data-price-monthly="R$ 0" data-price-yearly="R$ 0">R$ 0</span>
            <span class="text-slate-500 text-sm ml-1">/mês</span>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed mb-6 min-h-[48px]" data-i18n="precos.plan.explorer.desc">
            Perfeito para quem quer explorar o sistema e entender o poder da arquitetura assistida por IA.
          </p>
          <a href="/app" class="block text-center rounded-full border border-white/10 bg-white/5 px-6 py-3.5 text-sm font-semibold text-white hover:bg-white/10 hover:border-white/20 transition-all mb-8" data-i18n="precos.plan.explorer.cta" id="btn-free">
            Começar Grátis
          </a>
          <ul class="space-y-4 mt-auto">
            <li class="flex items-center gap-3">
              <span class="material-symbols-outlined text-primary text-lg shrink-0">smart_toy</span>
              <span class="text-slate-300 text-sm"><span data-i18n="precos.plan.explorer.f1">Apenas agente</span> <strong class="text-white">The Boss</strong></span>
            </li>
            <li class="flex items-center gap-3">
              <span class="material-symbols-outlined text-primary text-lg shrink-0">save</span>
              <span class="text-slate-300 text-sm">Até <strong class="text-white">3 PRDs</strong> <span data-i18n="precos.plan.explorer.f2">e Prompt Bases salvos</span></span>
            </li>
            <li class="flex items-center gap-3">
              <span class="material-symbols-outlined text-primary text-lg shrink-0">token</span>
              <span class="text-slate-300 text-sm"><strong class="text-white">50 requisições/mês</strong> <span data-i18n="precos.plan.explorer.f3">de IA econômica</span></span>
            </li>
            <li class="flex items-center gap-3">
              <span class="material-symbols-outlined text-slate-600 text-lg shrink-0">block</span>
              <span class="text-slate-500 text-sm" data-i18n="precos.plan.explorer.f4">LLMs médias e Elites bloqueadas</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="material-symbols-outlined text-primary text-lg shrink-0">short_text</span>
              <span class="text-slate-300 text-sm"><span data-i18n="precos.plan.explorer.f5">Prompt Base até</span> <strong class="text-white">10.000 chars</strong></span>
            </li>
            <li class="flex items-center gap-3">
              <span class="material-symbols-outlined text-slate-600 text-lg shrink-0">volume_off</span>
              <span class="text-slate-500 text-sm" data-i18n="precos.plan.explorer.f6">Sem resumo em áudio</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="material-symbols-outlined text-slate-600 text-lg shrink-0">block</span>
              <span class="text-slate-500 text-sm" data-i18n="precos.plan.explorer.f7">Sem exportação de arquivos</span>
            </li>
          </ul>
        </div>

        <!-- Card 2: Consultor (Pro) — Highlighted -->
        <div class="relative rounded-2xl p-8 flex flex-col border-2 border-primary/40 bg-surface-dark" style="box-shadow: 0 0 40px rgba(46,116,139,0.15), 0 0 80px rgba(46,116,139,0.05);">
          <div class="mb-6">
            <h3 class="text-xl font-bold text-white mb-1" data-i18n="precos.plan.pro">Consultor</h3>
            <p class="text-xs font-semibold text-primary uppercase tracking-widest" data-i18n="precos.plan.pro.tag">Pro</p>
          </div>
          <div class="mb-4">
            <span class="text-5xl font-bold text-white" data-price-monthly="R$ 35" data-price-yearly="R$ 28">R$ 35</span>
            <span class="text-slate-500 text-sm ml-1">/mês</span>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed mb-6 min-h-[48px]" data-i18n="precos.plan.pro.desc">
            Ideal para desenvolvedores em crescimento e consultores freelance que precisam de mais poder.
          </p>
          <button type="button" class="btn-checkout block w-full text-center rounded-full bg-primary px-6 py-3.5 text-sm font-bold text-background-dark hover:bg-secondary transition-all shadow-[0_0_20px_rgba(46,116,139,0.3)] mb-8 cursor-pointer" data-plan="consultor" data-i18n="precos.plan.pro.cta">
            Upgrade para Pro
          </button>
          <ul class="space-y-4 mt-auto">
            <li class="flex items-center gap-3">
              <span class="material-symbols-outlined text-primary text-lg shrink-0">groups</span>
              <span class="text-slate-300 text-sm"><strong class="text-white" data-i18n="precos.agents.all">Todos os agentes</strong> <span data-i18n="precos.plan.pro.f1">liberados</span></span>
            </li>
            <li class="flex items-center gap-3">
              <span class="material-symbols-outlined text-primary text-lg shrink-0">save</span>
              <span class="text-slate-300 text-sm">Até <strong class="text-white">15 PRDs</strong> <span data-i18n="precos.plan.pro.f2">e Prompt Bases salvos</span></span>
            </li>
            <li class="flex items-center gap-3">
              <span class="material-symbols-outlined text-primary text-lg shrink-0">all_inclusive</span>
              <span class="text-slate-300 text-sm">LLMs econômicas e médias <strong class="text-white" data-i18n="precos.plan.pro.f3">ilimitadas</strong></span>
            </li>
            <li class="flex items-center gap-3">
              <span class="material-symbols-outlined text-primary text-lg shrink-0">bolt</span>
              <span class="text-slate-300 text-sm"><strong class="text-white">20 chamadas/mês</strong> <span data-i18n="precos.plan.pro.f4">em LLMs de Elite</span></span>
            </li>
            <li class="flex items-center gap-3">
              <span class="material-symbols-outlined text-primary text-lg shrink-0">notes</span>
              <span class="text-slate-300 text-sm"><span data-i18n="precos.plan.pro.f5">Prompt Base até</span> <strong class="text-white">25.000 chars</strong></span>
            </li>
            <li class="flex items-center gap-3">
              <span class="material-symbols-outlined text-primary text-lg shrink-0">download</span>
              <span class="text-slate-300 text-sm"><span data-i18n="precos.plan.pro.f6">Exportação em</span> <strong class="text-white">.md</strong></span>
            </li>
            <li class="flex items-center gap-3">
              <span class="material-symbols-outlined text-primary text-lg shrink-0">volume_up</span>
              <span class="text-slate-300 text-sm"><span data-i18n="precos.audio">Resumo em</span> <strong class="text-white" data-i18n="precos.audio.word">áudio</strong> <span data-i18n="precos.plan.pro.f7">da IA</span></span>
            </li>
          </ul>
        </div>

        <!-- Card 3: Arquiteto (Elite) -->
        <div class="relative rounded-2xl p-8 flex flex-col bg-surface-dark border border-cta/20" style="box-shadow: 0 0 40px rgba(242,171,109,0.08);">
          <div class="absolute top-4 right-4 bg-cta/10 border border-cta/30 text-cta text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full" data-i18n="precos.plan.elite.badge">
            Recomendado
          </div>
          <div class="mb-6">
            <h3 class="text-xl font-bold text-white mb-1" data-i18n="precos.plan.elite">Arquiteto</h3>
            <p class="text-xs font-semibold text-cta uppercase tracking-widest" data-i18n="precos.plan.elite.tag">Elite</p>
          </div>
          <div class="mb-4">
            <span class="text-5xl font-bold text-white" data-price-monthly="R$ 50" data-price-yearly="R$ 40">R$ 50</span>
            <span class="text-slate-500 text-sm ml-1">/mês</span>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed mb-6 min-h-[48px]" data-i18n="precos.plan.elite.desc">
            O kit definitivo poder absoluto para arquitetos que exigem o máximo do sistema.
          </p>
          <button type="button" class="btn-checkout block w-full text-center rounded-full px-6 py-3.5 text-sm font-bold text-background-dark transition-all shadow-[0_0_20px_rgba(242,171,109,0.25)] mb-8 cursor-pointer" style="background: linear-gradient(135deg, #F2AB6D, #D4894A);" data-plan="arquiteto" data-i18n="precos.plan.elite.cta">
            Começar Agora
          </button>
          <ul class="space-y-4 mt-auto">
            <li class="flex items-center gap-3">
              <span class="material-symbols-outlined text-cta text-lg shrink-0">groups</span>
              <span class="text-slate-300 text-sm"><strong class="text-white" data-i18n="precos.agents.all">Todos os agentes</strong> <span data-i18n="precos.plan.elite.f1">liberados</span></span>
            </li>
            <li class="flex items-center gap-3">
              <span class="material-symbols-outlined text-cta text-lg shrink-0">all_inclusive</span>
              <span class="text-slate-300 text-sm">PRDs e <span data-i18n="precos.promptbases">Prompt Bases</span> <strong class="text-white" data-i18n="precos.plan.elite.f2">ilimitados</strong></span>
            </li>
            <li class="flex items-center gap-3">
              <span class="material-symbols-outlined text-cta text-lg shrink-0">all_inclusive</span>
              <span class="text-slate-300 text-sm">LLMs econômicas e médias <strong class="text-white" data-i18n="precos.plan.elite.f3">ilimitadas</strong></span>
            </li>
            <li class="flex items-center gap-3">
              <span class="material-symbols-outlined text-cta text-lg shrink-0">bolt</span>
              <span class="text-slate-300 text-sm"><strong class="text-white">50 chamadas/mês</strong> <span data-i18n="precos.plan.elite.f4">em LLMs de Elite</span></span>
            </li>
            <li class="flex items-center gap-3">
              <span class="material-symbols-outlined text-cta text-lg shrink-0">description</span>
              <span class="text-slate-300 text-sm"><span data-i18n="precos.plan.elite.f5">Prompt Base até</span> <strong class="text-white">80.000 chars</strong></span>
            </li>
            <li class="flex items-center gap-3">
              <span class="material-symbols-outlined text-cta text-lg shrink-0">download</span>
              <span class="text-slate-300 text-sm">Exportação em <strong class="text-white">PDF, .md, Word</strong> <span data-i18n="precos.plan.elite.f6">e mais</span></span>
            </li>
            <li class="flex items-center gap-3">
              <span class="material-symbols-outlined text-cta text-lg shrink-0">volume_up</span>
              <span class="text-slate-300 text-sm"><span data-i18n="precos.audio">Resumo em</span> <strong class="text-white" data-i18n="precos.audio.word">áudio</strong> <span data-i18n="precos.plan.elite.f7">da IA</span></span>
            </li>
          </ul>
        </div>

      </div>
    </section>

    <!-- Por que BuildCode? — Marketing Heavy -->
    <section class="px-4 sm:px-6 lg:px-24 pb-16 max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-white mb-6">
          <span data-i18n="precos.why.title.1">Por que </span><span class="text-primary" data-i18n="precos.why.title.2">BuildCode</span><span data-i18n="precos.why.title.3">?</span>
        </h2>
        <p class="text-slate-400 text-lg max-w-2xl mx-auto" data-i18n="precos.why.subtitle">
          Porque escolher a stack errada no início custa meses de retrabalho. BuildCode elimina esse risco antes da primeira linha de código.
        </p>
      </div>

      <!-- Stat bar -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
        <div class="glass-panel rounded-2xl p-6 text-center">
          <p class="text-3xl sm:text-4xl font-bold text-primary mb-1">200+</p>
          <p class="text-slate-400 text-xs sm:text-sm" data-i18n="precos.why.stat1">Tecnologias mapeadas</p>
        </div>
        <div class="glass-panel rounded-2xl p-6 text-center">
          <p class="text-3xl sm:text-4xl font-bold text-primary mb-1">&lt; 3 min</p>
          <p class="text-slate-400 text-xs sm:text-sm" data-i18n="precos.why.stat2">Para gerar um PRD completo</p>
        </div>
        <div class="glass-panel rounded-2xl p-6 text-center">
          <p class="text-3xl sm:text-4xl font-bold text-primary mb-1">9</p>
          <p class="text-slate-400 text-xs sm:text-sm" data-i18n="precos.why.stat3">Modelos de IA disponíveis</p>
        </div>
        <div class="glass-panel rounded-2xl p-6 text-center">
          <p class="text-3xl sm:text-4xl font-bold text-primary mb-1">20</p>
          <p class="text-slate-400 text-xs sm:text-sm" data-i18n="precos.why.stat4">Decisões críticas cobertas</p>
        </div>
      </div>

      <!-- Bento Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <!-- Big card: Problem → Solution -->
        <div class="glass-panel rounded-2xl p-8 flex flex-col justify-between sm:col-span-2 lg:col-span-2 min-h-[240px]" style="background: linear-gradient(135deg, rgba(46,116,139,0.08), transparent);">
          <div>
            <span class="material-symbols-outlined text-primary text-4xl mb-4">dynamic_feed</span>
            <h3 class="text-xl font-bold text-white mb-3" data-i18n="precos.why.precision.title">Decisões Fundamentadas, Não Opiniões</h3>
            <p class="text-slate-400 text-sm leading-relaxed" data-i18n="precos.why.precision.desc">
              Consultorias de arquitetura cobram R$ 15.000 a R$ 80.000 por projeto — e ainda dependem da experiência subjetiva de quem está na sala. BuildCode analisa dados reais do GitHub, cruza com 200+ tecnologias mapeadas e gera recomendações com justificativa técnica. Sem achismo. Sem viés. Só dados.
            </p>
          </div>
        </div>

        <!-- PRD -->
        <div class="glass-panel rounded-2xl p-6 flex flex-col justify-end min-h-[240px]">
          <span class="material-symbols-outlined text-primary text-3xl mb-3">description</span>
          <h3 class="text-base font-bold text-white mb-2" data-i18n="precos.why.prd.title">PRD Profissional em Minutos</h3>
          <p class="text-slate-400 text-xs leading-relaxed" data-i18n="precos.why.prd.desc">Documento de requisitos com diagrama de arquitetura, estimativa de custos e justificativa por tecnologia escolhida. Pronto para levar ao time ou ao investidor.</p>
        </div>

        <!-- Agents -->
        <div class="glass-panel rounded-2xl p-6 flex flex-col justify-end min-h-[200px]">
          <span class="material-symbols-outlined text-primary text-3xl mb-3">smart_toy</span>
          <h3 class="text-base font-bold text-white mb-2" data-i18n="precos.why.agents.title">4 Mentores de IA ao seu Lado</h3>
          <p class="text-slate-400 text-xs leading-relaxed" data-i18n="precos.why.agents.desc">Agentes com personalidade e voz própria que te guiam em cada decisão. Como ter 4 arquitetos seniores disponíveis 24 horas por dia.</p>
        </div>

        <!-- Speed -->
        <div class="glass-panel rounded-2xl p-6 flex flex-col justify-end min-h-[200px]">
          <span class="material-symbols-outlined text-primary text-3xl mb-3">speed</span>
          <h3 class="text-base font-bold text-white mb-2" data-i18n="precos.why.speed.title">De Semanas para Minutos</h3>
          <p class="text-slate-400 text-xs leading-relaxed" data-i18n="precos.why.speed.desc">O que leva semanas avaliando ferramentas, BuildCode resolve em minutos. Seu time para de debater stacks e começa a construir.</p>
        </div>

        <!-- Prompt Base -->
        <div class="glass-panel rounded-2xl p-6 flex flex-col justify-end min-h-[200px]">
          <span class="material-symbols-outlined text-primary text-3xl mb-3">code</span>
          <h3 class="text-base font-bold text-white mb-2" data-i18n="precos.why.prompt.title">Prompt Base Otimizado</h3>
          <p class="text-slate-400 text-xs leading-relaxed" data-i18n="precos.why.prompt.desc">Prompts prontos para Claude, GPT e Gemini com boas práticas por tecnologia. Comece a codar com instruções perfeitas desde o primeiro minuto.</p>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- RECARGA REBELDE — Créditos avulsos com tom roxo    -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="px-4 sm:px-6 lg:px-24 pb-24 max-w-6xl mx-auto" id="recarga">
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 bg-purple-500/10 border border-purple-500/20 text-purple-400 text-[10px] font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-6">
          <span class="material-symbols-outlined text-sm">bolt</span>
          Exclusivo
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold text-white mb-4">
          Recarga <span class="text-purple-400">Rebelde</span>
        </h2>
        <p class="text-slate-400 text-base sm:text-lg max-w-2xl mx-auto">
          Créditos avulsos que não expiram. Compre quando quiser, use quando precisar. Acumulam com os créditos do seu plano.
        </p>
      </div>

      <!-- Combos Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-16">
        <!-- Combo Starter R$10 -->
        <div class="recharge-combo relative rounded-2xl p-6 flex flex-col border border-purple-500/15 bg-surface-dark cursor-pointer transition-all hover:border-purple-500/40 hover:shadow-[0_0_30px_rgba(168,85,247,0.08)]" data-combo="starter" data-price="10" data-eco="20" data-mid="5" data-elite="2">
          <div class="flex items-center justify-between mb-4">
            <span class="text-purple-300 text-xs font-bold uppercase tracking-widest">Starter</span>
            <span class="text-2xl font-bold text-white">R$ 10</span>
          </div>
          <ul class="space-y-2.5 mb-5 flex-1">
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
              <span class="text-slate-300 text-sm"><strong class="text-white">20</strong> econômicas</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-amber-400"></span>
              <span class="text-slate-300 text-sm"><strong class="text-white">5</strong> médias</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-purple-400"></span>
              <span class="text-slate-300 text-sm"><strong class="text-white">2</strong> elite</span>
            </li>
          </ul>
          <button type="button" class="btn-recharge w-full text-center rounded-full border border-purple-500/30 bg-purple-500/10 px-4 py-2.5 text-xs font-bold text-purple-300 hover:bg-purple-500/20 transition-all cursor-pointer">
            Recarregar
          </button>
        </div>

        <!-- Combo Turbo R$20 -->
        <div class="recharge-combo relative rounded-2xl p-6 flex flex-col border border-purple-500/15 bg-surface-dark cursor-pointer transition-all hover:border-purple-500/40 hover:shadow-[0_0_30px_rgba(168,85,247,0.08)]" data-combo="turbo" data-price="20" data-eco="50" data-mid="12" data-elite="5">
          <div class="flex items-center justify-between mb-4">
            <span class="text-purple-300 text-xs font-bold uppercase tracking-widest">Turbo</span>
            <span class="text-2xl font-bold text-white">R$ 20</span>
          </div>
          <ul class="space-y-2.5 mb-5 flex-1">
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
              <span class="text-slate-300 text-sm"><strong class="text-white">50</strong> econômicas</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-amber-400"></span>
              <span class="text-slate-300 text-sm"><strong class="text-white">12</strong> médias</span>
            </li>
