<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  // ── Toast notification system ──
  function showToast(message: string, type: 'success' | 'error' = 'success') {
    const existing = document.getElementById('bc-toast');
    if (existing) existing.remove();

    const toast = document.createElement('div');
    toast.id = 'bc-toast';
    const icon = type === 'success' ? 'check_circle' : 'error';
    const bg = type === 'success'
      ? 'linear-gradient(135deg, #059669, #10B981)'
      : 'linear-gradient(135deg, #DC2626, #EF4444)';
    toast.innerHTML = `
      <span class="material-symbols-outlined" style="font-size:20px">${icon}</span>
      <span>${message}</span>
    `;
    Object.assign(toast.style, {
      position: 'fixed', bottom: '24px', right: '24px', zIndex: '99999',
      display: 'flex', alignItems: 'center', gap: '10px',
      background: bg, color: '#fff',
      padding: '14px 24px', borderRadius: '14px',
      fontSize: '14px', fontWeight: '600',
      boxShadow: '0 8px 32px rgba(0,0,0,0.3)',
      transform: 'translateY(20px)', opacity: '0',
      transition: 'all 0.4s cubic-bezier(0.16,1,0.3,1)',
      maxWidth: '400px',
    });
    document.body.appendChild(toast);
    requestAnimationFrame(() => {
      toast.style.transform = 'translateY(0)';
      toast.style.opacity = '1';
    });
    setTimeout(() => {
      toast.style.transform = 'translateY(20px)';
      toast.style.opacity = '0';
      setTimeout(() => toast.remove(), 400);
    }, 4000);
  }

  // Expose globally so other scripts can use it
  (window as any).__bcToast = showToast;

  document.addEventListener('DOMContentLoaded', () => {
    // ── Billing toggle ──
    const radios = document.querySelectorAll<HTMLInputElement>('input[name="billing-cycle"]');
    const priceEls = document.querySelectorAll<HTMLElement>('[data-price-monthly]');

    function getSelectedCycle(): 'monthly' | 'yearly' {
      const checked = document.querySelector<HTMLInputElement>('input[name="billing-cycle"]:checked');
      return (checked?.value === 'yearly') ? 'yearly' : 'monthly';
    }

    radios.forEach(radio => {
      radio.addEventListener('change', () => {
        const isYearly = radio.value === 'yearly';
        priceEls.forEach(el => {
          el.textContent = isYearly ? el.dataset.priceYearly! : el.dataset.priceMonthly!;
        });
      });
    });

    // ── Detect current plan and mark button ──
    (async () => {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) return;

      try {
        const { data: sub } = await supabase
          .from('subscriptions')
          .select('plan')
          .eq('user_id', session.user.id)
          .in('status', ['active', 'trialing'])
          .single();

        const currentPlan = sub?.plan || 'explorador';

        // Mark the Explorador free button
        if (currentPlan === 'explorador') {
          const freeBtn = document.getElementById('btn-free') as HTMLElement | null;
          if (freeBtn) {
            freeBtn.textContent = 'Plano Atual';
            freeBtn.classList.remove('hover:bg-white/10', 'hover:border-white/20');
            freeBtn.classList.add('opacity-60', 'cursor-default');
            freeBtn.removeAttribute('href');
            freeBtn.style.pointerEvents = 'none';
          }
        }

        // Mark checkout buttons
        document.querySelectorAll<HTMLButtonElement>('.btn-checkout').forEach(btn => {
          if (btn.dataset.plan === currentPlan) {
            btn.textContent = 'Plano Atual';
            btn.disabled = true;
            btn.style.opacity = '0.6';
            btn.style.cursor = 'default';
            btn.style.background = '#374151';
            btn.style.boxShadow = 'none';
            btn.classList.remove('hover:bg-secondary');
          }
        });
      } catch {}
    })();

    // ── Plan config para o modal ──
    const PLAN_CONFIG: Record<string, {
      name: string; badge: string; badgeClass: string; glowColor: string;
      monthly: number; yearly: number; desc: string;
      benefits: string[]; agents: { name: string; role: string; img: string }[];
    }> = {
      consultor: {
        name: 'Consultor', badge: 'PRO', badgeClass: 'bg-primary/15 text-primary border-primary/25',
        glowColor: '#2E748B', monthly: 35, yearly: 28,
        desc: 'Para devs que querem velocidade real. Todos os agentes, modelos mid e mais geração.',
        benefits: [
          '15 projetos salvos', 'Todos os 4 agentes mentores', 'Economy + Mid ilimitados',
          '20 chamadas Elite por mês', 'Chat IA: 200 mensagens/mês',
          'Áudio TTS com voz de agente', 'Exportação em Markdown (.md)',
        ],
        agents: [
          { name: 'The Boss', role: 'Estratégia & Performance', img: '/agentes/Theboss.png' },
          { name: 'Azrael', role: 'UX & Visão de Produto', img: '/agentes/Azrael.png' },
          { name: 'Rizler', role: 'Segurança & Arquitetura', img: '/agentes/Rizler.png' },
          { name: 'Anastasia', role: 'Fullstack & Didática', img: '/agentes/Anastasia.png' },
        ],
      },
      arquiteto: {
        name: 'Arquiteto', badge: 'ELITE', badgeClass: 'bg-cta/15 text-cta border-cta/25',
        glowColor: '#F2AB6D', monthly: 50, yearly: 40,
        desc: 'Para quem constrói sem limites. Máximo de geração, todos os modelos e exportação completa.',
        benefits: [
          'Projetos ilimitados', 'Todos os 4 agentes mentores', 'Economy + Mid ilimitados',
          '50 chamadas Elite por mês', 'Chat IA ilimitado',
          'Áudio TTS com voz de agente', 'Exportação em .md, .pdf e .docx',
        ],
        agents: [
          { name: 'The Boss', role: 'Estratégia & Performance', img: '/agentes/Theboss.png' },
          { name: 'Azrael', role: 'UX & Visão de Produto', img: '/agentes/Azrael.png' },
          { name: 'Rizler', role: 'Segurança & Arquitetura', img: '/agentes/Rizler.png' },
          { name: 'Anastasia', role: 'Fullstack & Didática', img: '/agentes/Anastasia.png' },
        ],
      },
    };

    let checkoutPlan = '';
    let checkoutCycle: 'monthly' | 'yearly' = 'monthly';

    const checkoutModal = document.getElementById('modal-checkout')!;
    const payBtn = document.getElementById('btn-pay-now') as HTMLButtonElement;
    const checkoutMsg = document.getElementById('checkout-msg')!;

    function openCheckoutModal(plan: string, cycle: 'monthly' | 'yearly' = 'monthly') {
      const cfg = PLAN_CONFIG[plan];
      if (!cfg) return;
      checkoutPlan = plan;
      checkoutCycle = cycle;

      // Header
      document.getElementById('checkout-plan-name')!.textContent = cfg.name;
      document.getElementById('checkout-badge')!.textContent = cfg.badge;
      document.getElementById('checkout-badge')!.className = `text-[9px] px-2.5 py-1 rounded-full font-bold uppercase tracking-wider border ${cfg.badgeClass}`;
      (document.getElementById('checkout-glow') as HTMLElement).style.background = cfg.glowColor;
      document.getElementById('checkout-plan-desc')!.textContent = cfg.desc;

      // Prices
      (document.getElementById('modal-price-monthly') as HTMLElement).textContent = `R$ ${cfg.monthly}`;
      (document.getElementById('modal-price-yearly') as HTMLElement).textContent = `R$ ${cfg.yearly}`;

      // Billing cycle pre-select
      const monthlyRadio = document.querySelector<HTMLInputElement>('input[name="modal-billing"][value="monthly"]')!;
      const yearlyRadio = document.querySelector<HTMLInputElement>('input[name="modal-billing"][value="yearly"]')!;
      if (cycle === 'yearly') { yearlyRadio.checked = true; monthlyRadio.checked = false; }
      else { monthlyRadio.checked = true; yearlyRadio.checked = false; }
      updateModalPrices();

      // Benefits
      const benefitsList = document.getElementById('checkout-benefits')!;
      benefitsList.innerHTML = cfg.benefits.map(b => `
        <li class="flex items-start gap-2.5">
          <span class="material-symbols-outlined text-primary text-base mt-0.5 shrink-0">check_circle</span>
          <span class="text-sm text-slate-300">${b}</span>
        </li>
      `).join('');

      // Agents
      const agentsEl = document.getElementById('checkout-agents')!;
      agentsEl.innerHTML = cfg.agents.map(a => `
        <div class="rounded-2xl overflow-hidden relative group" style="background:#0d1214;border:1px solid #1e2a2e;">
          <div class="aspect-[3/4] overflow-hidden">
            <img src="${a.img}" alt="${a.name}" class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="p-3">
            <p class="text-white text-xs font-bold">${a.name}</p>
            <p class="text-slate-500 text-[10px] mt-0.5">${a.role}</p>
          </div>
        </div>
      `).join('');

      // Pay button style
      if (plan === 'arquiteto') {
        payBtn.style.background = 'linear-gradient(135deg, #F2AB6D 0%, #e8954a 100%)';
        payBtn.style.color = '#0D0D0D';
        payBtn.style.boxShadow = '0 0 30px rgba(242,171,109,0.25)';
      } else {
        payBtn.style.background = 'linear-gradient(135deg, #2E748B 0%, #1C4D5E 100%)';
        payBtn.style.color = '#ffffff';
        payBtn.style.boxShadow = '0 0 30px rgba(46,116,139,0.25)';
      }

      checkoutMsg.className = 'hidden';
      payBtn.disabled = false;
      (document.getElementById('btn-pay-label') as HTMLElement).textContent = 'Ir para pagamento';

      checkoutModal.classList.remove('hidden');
      checkoutModal.classList.add('flex');
    }

    function updateModalPrices() {
      const cfg = PLAN_CONFIG[checkoutPlan];
      if (!cfg) return;
      const isYearly = (document.querySelector<HTMLInputElement>('input[name="modal-billing"]:checked')?.value === 'yearly');
      checkoutCycle = isYearly ? 'yearly' : 'monthly';
      const price = isYearly ? cfg.yearly : cfg.monthly;
      const headerPrice = document.getElementById('checkout-price-display')!;
      const note = document.getElementById('checkout-billing-note')!;
      headerPrice.textContent = `R$ ${price}`;
      if (isYearly) {
        note.textContent = `(R$ ${cfg.yearly * 12}/ano)`;
        note.classList.remove('hidden');
        const saved = (cfg.monthly - cfg.yearly) * 12;
        document.getElementById('checkout-savings-box')!.classList.remove('hidden');
        document.getElementById('checkout-savings-text')!.textContent = `Você economiza R$ ${saved}/ano no plano anual`;
      } else {
        note.classList.add('hidden');
        document.getElementById('checkout-savings-box')!.classList.add('hidden');
      }
      (document.getElementById('summary-plan-name') as HTMLElement).textContent = cfg.name;
      (document.getElementById('summary-price') as HTMLElement).textContent = `R$ ${price}/mês`;
      (document.getElementById('summary-cycle') as HTMLElement).textContent = isYearly ? 'Anual (cobrado anualmente)' : 'Mensal (cobrado mensalmente)';
    }

    function closeCheckoutModal() {
      checkoutModal.classList.add('hidden');
      checkoutModal.classList.remove('flex');
    }

    document.getElementById('btn-close-checkout')!.addEventListener('click', closeCheckoutModal);
    checkoutModal.addEventListener('click', (e) => { if (e.target === checkoutModal) closeCheckoutModal(); });

    document.querySelectorAll<HTMLInputElement>('input[name="modal-billing"]').forEach(r => {
      r.addEventListener('change', updateModalPrices);
    });

    // ── Checkout buttons → abre modal ──
    document.querySelectorAll<HTMLButtonElement>('.btn-checkout').forEach(btn => {
      btn.addEventListener('click', async () => {
        const plan = btn.dataset.plan;
        if (!plan) return;
        const { data: { session } } = await supabase.auth.getSession();
        if (!session) {
          sessionStorage.setItem('pendingPlan', plan);
          sessionStorage.setItem('pendingCycle', getSelectedCycle());
          window.location.href = '/login';
          return;
        }
        openCheckoutModal(plan, getSelectedCycle());
      });
    });

    // ── Pay button → chama Asaas ──
    payBtn.addEventListener('click', async () => {
      const cfg = PLAN_CONFIG[checkoutPlan];
      if (!cfg) return;
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) { window.location.href = '/login'; return; }

      payBtn.disabled = true;
      (document.getElementById('btn-pay-label') as HTMLElement).textContent = 'Processando...';
      checkoutMsg.className = 'hidden';

      const cpfRaw = (document.getElementById('checkout-cpf') as HTMLInputElement).value.replace(/\D/g, '');
      if (cpfRaw.length !== 11) {
        checkoutMsg.className = 'rounded-xl px-4 py-3 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
        checkoutMsg.textContent = 'Preencha um CPF válido (11 dígitos) para continuar.';
        checkoutMsg.classList.remove('hidden');
        payBtn.disabled = false;
        (document.getElementById('btn-pay-label') as HTMLElement).textContent = 'Ir para pagamento';
        return;
      }

      try {
        const res = await fetch('/api/asaas/create-checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${session.access_token}` },
          body: JSON.stringify({ plan: checkoutPlan, billingCycle: checkoutCycle, cpfCnpj: cpfRaw || undefined }),
        });
        let data: any;
        try { data = await res.json(); } catch { throw new Error('Resposta inválida do servidor. Tente novamente.'); }
        if (!res.ok) throw new Error(data.error || 'Erro ao criar assinatura');

        if (data.invoiceUrl) {
          (document.getElementById('btn-pay-label') as HTMLElement).textContent = 'Redirecionando...';
          window.location.href = data.invoiceUrl;
        } else {
          throw new Error('URL de pagamento não disponível. Tente novamente.');
        }
      } catch (err: any) {
        checkoutMsg.className = 'rounded-xl px-4 py-3 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
        checkoutMsg.textContent = err.message;
        checkoutMsg.classList.remove('hidden');
        payBtn.disabled = false;
        (document.getElementById('btn-pay-label') as HTMLElement).textContent = 'Ir para pagamento';
      }
    });

    // CPF mask
    const cpfInput = document.getElementById('checkout-cpf') as HTMLInputElement;
    cpfInput.addEventListener('input', () => {
      let v = cpfInput.value.replace(/\D/g, '').slice(0, 11);
      if (v.length > 9) v = v.replace(/(\d{3})(\d{3})(\d{3})(\d{1,2})/, '$1.$2.$3-$4');
      else if (v.length > 6) v = v.replace(/(\d{3})(\d{3})(\d{1,3})/, '$1.$2.$3');
      else if (v.length > 3) v = v.replace(/(\d{3})(\d{1,3})/, '$1.$2');
      cpfInput.value = v;
    });

    // ── Resume pending checkout after login redirect ──
    (async () => {
      const pendingPlan = sessionStorage.getItem('pendingPlan');
      const pendingCycle = sessionStorage.getItem('pendingCycle') as 'monthly' | 'yearly' | null;
      if (!pendingPlan) return;
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) return;
      sessionStorage.removeItem('pendingPlan');
      sessionStorage.removeItem('pendingCycle');
      setTimeout(() => openCheckoutModal(pendingPlan, pendingCycle || 'monthly'), 500);
    })();
  });
</script>

<script>
  // ── Recarga Rebelde: calculadora personalizada ──
  import { createClient as createRechargeClient } from '@supabase/supabase-js';

  const rechargeSupabase = createRechargeClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  document.addEventListener('DOMContentLoaded', () => {
    const PRICE_ECO = 0.055;
    const PRICE_MID = 0.55;
    const PRICE_ELITE = 3.85;

    // Sliders
    const ecoSlider = document.getElementById('custom-eco') as HTMLInputElement;
    const midSlider = document.getElementById('custom-mid') as HTMLInputElement;
    const eliteSlider = document.getElementById('custom-elite') as HTMLInputElement;
    const ecoCount = document.getElementById('custom-eco-count')!;
    const midCount = document.getElementById('custom-mid-count')!;
    const eliteCount = document.getElementById('custom-elite-count')!;
    const totalEl = document.getElementById('custom-total')!;
    const btnCustom = document.getElementById('btn-custom-recharge') as HTMLButtonElement;

    function updateCustomTotal() {
      const eco = parseInt(ecoSlider.value) || 0;
      const mid = parseInt(midSlider.value) || 0;
      const elite = parseInt(eliteSlider.value) || 0;
      const total = (eco * PRICE_ECO) + (mid * PRICE_MID) + (elite * PRICE_ELITE);

      ecoCount.textContent = String(eco);
      midCount.textContent = String(mid);
      eliteCount.textContent = String(elite);
      totalEl.textContent = `R$ ${total.toFixed(2).replace('.', ',')}`;
      btnCustom.disabled = total <= 0;
    }

    [ecoSlider, midSlider, eliteSlider].forEach(s => {
      if (s) s.addEventListener('input', updateCustomTotal);
    });

    // ── Recharge CPF modal ──
    let pendingRechargeData: { type: string; comboName: string | null; eco: number; mid: number; elite: number; amount: number } | null = null;

    const rechargeCpfModal = document.getElementById('modal-recharge-cpf')!;
    const rechargeCpfInput = document.getElementById('recharge-cpf-input') as HTMLInputElement;
    const rechargeCpfMsg = document.getElementById('recharge-cpf-msg')!;
    const rechargePayBtn = document.getElementById('btn-recharge-pay') as HTMLButtonElement;
    const rechargePayLabel = document.getElementById('btn-recharge-pay-label')!;

    rechargeCpfInput.addEventListener('input', () => {
      let v = rechargeCpfInput.value.replace(/\D/g, '').slice(0, 11);
      if (v.length > 9) v = v.replace(/(\d{3})(\d{3})(\d{3})(\d{1,2})/, '$1.$2.$3-$4');
      else if (v.length > 6) v = v.replace(/(\d{3})(\d{3})(\d{1,3})/, '$1.$2.$3');
      else if (v.length > 3) v = v.replace(/(\d{3})(\d{1,3})/, '$1.$2');
      rechargeCpfInput.value = v;
    });

    document.getElementById('btn-close-recharge-cpf')!.addEventListener('click', () => {
      rechargeCpfModal.classList.add('hidden');
      rechargeCpfModal.classList.remove('flex');
    });
    rechargeCpfModal.addEventListener('click', (e) => {
      if (e.target === rechargeCpfModal) {
        rechargeCpfModal.classList.add('hidden');
        rechargeCpfModal.classList.remove('flex');
      }
    });

    function openRechargeCpfModal(data: typeof pendingRechargeData) {
      pendingRechargeData = data;
      const label = data!.comboName
        ? `Combo ${data!.comboName.charAt(0).toUpperCase() + data!.comboName.slice(1)} — R$ ${data!.amount}`
        : `${data!.eco} eco + ${data!.mid} mid + ${data!.elite} elite — R$ ${data!.amount.toFixed(2).replace('.', ',')}`;
      document.getElementById('recharge-cpf-summary')!.textContent = label;
      rechargeCpfInput.value = '';
      rechargeCpfMsg.className = 'hidden';
      rechargePayBtn.disabled = false;
      rechargePayLabel.textContent = 'Ir para pagamento';
      rechargeCpfModal.classList.remove('hidden');
      rechargeCpfModal.classList.add('flex');
    }

    rechargePayBtn.addEventListener('click', async () => {
      if (!pendingRechargeData) return;
      const cpfRaw = rechargeCpfInput.value.replace(/\D/g, '');
      if (cpfRaw.length !== 11) {
        rechargeCpfMsg.className = 'rounded-xl px-4 py-3 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
        rechargeCpfMsg.textContent = 'Preencha um CPF válido (11 dígitos).';
        rechargeCpfMsg.classList.remove('hidden');
        return;
      }
      const { data: { session } } = await rechargeSupabase.auth.getSession();
      if (!session) { window.location.href = '/login'; return; }

      rechargePayBtn.disabled = true;
      rechargePayLabel.textContent = 'Processando...';
      rechargeCpfMsg.className = 'hidden';

      const r = pendingRechargeData;
      try {
        const res = await fetch('/api/asaas/create-recharge', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${session.access_token}` },
          body: JSON.stringify({
            rechargeType: r.type,
            comboName: r.comboName,
            creditsEconomy: r.eco,
            creditsMid: r.mid,
            creditsElite: r.elite,
            amountBrl: r.amount,
            cpfCnpj: cpfRaw,
          }),
        });
        let data: any;
        try { data = await res.json(); } catch { throw new Error('Resposta inválida do servidor.'); }
        if (!res.ok) throw new Error(data.error || 'Erro ao processar recarga');
        if (data.invoiceUrl) {
          rechargePayLabel.textContent = 'Redirecionando...';
          window.location.href = data.invoiceUrl;
        } else {
          throw new Error('URL de pagamento não disponível.');
        }
      } catch (err: any) {
        rechargeCpfMsg.className = 'rounded-xl px-4 py-3 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
        rechargeCpfMsg.textContent = err.message;
        rechargeCpfMsg.classList.remove('hidden');
        rechargePayBtn.disabled = false;
        rechargePayLabel.textContent = 'Ir para pagamento';
      }
    });

    // Botões de combo
    document.querySelectorAll<HTMLButtonElement>('.btn-recharge').forEach(btn => {
      btn.addEventListener('click', async () => {
        const parent = btn.closest<HTMLElement>('[data-combo]');
        if (!parent) return;
        const { data: { session } } = await rechargeSupabase.auth.getSession();
        if (!session) {
          const name = parent.dataset.combo!;
          const price = parseFloat(parent.dataset.price || '0');
          const eco = parseInt(parent.dataset.eco || '0');
          const mid = parseInt(parent.dataset.mid || '0');
          const elite = parseInt(parent.dataset.elite || '0');
          sessionStorage.setItem('pendingRecharge', JSON.stringify({ type: 'combo', comboName: name, eco, mid, elite, amount: price }));
          window.location.href = '/login';
          return;
        }
        openRechargeCpfModal({
          type: 'combo',
          comboName: parent.dataset.combo!,
          price: parseFloat(parent.dataset.price || '0'),
          eco: parseInt(parent.dataset.eco || '0'),
          mid: parseInt(parent.dataset.mid || '0'),
          elite: parseInt(parent.dataset.elite || '0'),
          amount: parseFloat(parent.dataset.price || '0'),
        } as any);
      });
    });

    // Botão custom
    if (btnCustom) {
      btnCustom.addEventListener('click', async () => {
        const eco = parseInt(ecoSlider.value) || 0;
        const mid = parseInt(midSlider.value) || 0;
        const elite = parseInt(eliteSlider.value) || 0;
        const total = (eco * PRICE_ECO) + (mid * PRICE_MID) + (elite * PRICE_ELITE);
        if (total <= 0) return;
        const { data: { session } } = await rechargeSupabase.auth.getSession();
        if (!session) {
          sessionStorage.setItem('pendingRecharge', JSON.stringify({ type: 'custom', comboName: null, eco, mid, elite, amount: parseFloat(total.toFixed(2)) }));
          window.location.href = '/login';
          return;
        }
        openRechargeCpfModal({ type: 'custom', comboName: null, eco, mid, elite, amount: parseFloat(total.toFixed(2)) });
      });
    }

    // Retomar recarga pendente após login
    const pendingRecharge = sessionStorage.getItem('pendingRecharge');
    if (pendingRecharge) {
      sessionStorage.removeItem('pendingRecharge');
      (async () => {
        const { data: { session } } = await rechargeSupabase.auth.getSession();
        if (!session) return;
        const r = JSON.parse(pendingRecharge);
        openRechargeCpfModal(r);
      })();
    }
  });
</script>

<script>
  // Logo swap for light/dark theme
  function updatePageLogo() {
    document.querySelectorAll('img[data-dark][data-light]').forEach(el => {
      const isLight = document.documentElement.classList.contains('light');
      el.setAttribute('src', isLight ? (el.getAttribute('data-light') || '') : (el.getAttribute('data-dark') || ''));
    });
  }
  updatePageLogo();
  new MutationObserver(updatePageLogo).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
</script>

<style>
  /* Remove default marker from details/summary */
  details summary::-webkit-details-marker {
    display: none;
  }

  /* Sliders da recarga personalizada */
  .recharge-slider {
    -webkit-appearance: none;
    appearance: none;
    height: 6px;
    border-radius: 3px;
    background: #1e1e22;
    outline: none;
  }
  .recharge-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    cursor: pointer;
    border: 2px solid rgba(255,255,255,0.1);
  }
  #custom-eco::-webkit-slider-thumb { background: #34d399; }
  #custom-mid::-webkit-slider-thumb { background: #fbbf24; }
