<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  // ── Toast notification system ──
  function showToast(message: string, type: 'success' | 'error' = 'success') {
    const existing = document.getElementById('bc-toast');
    if (existing) existing.remove();

    const toast = document.createElement('div');
    toast.id = 'bc-toast';
    const icon = type === 'success' ? 'check_circle' : 'error';
    const bg = type === 'success'
      ? 'linear-gradient(135deg, #059669, #10B981)'
      : 'linear-gradient(135deg, #DC2626, #EF4444)';
    toast.innerHTML = `
      <span class="material-symbols-outlined" style="font-size:20px">${icon}</span>
      <span>${message}</span>
    `;
    Object.assign(toast.style, {
      position: 'fixed', bottom: '24px', right: '24px', zIndex: '99999',
      display: 'flex', alignItems: 'center', gap: '10px',
      background: bg, color: '#fff',
      padding: '14px 24px', borderRadius: '14px',
      fontSize: '14px', fontWeight: '600',
      boxShadow: '0 8px 32px rgba(0,0,0,0.3)',
      transform: 'translateY(20px)', opacity: '0',
      transition: 'all 0.4s cubic-bezier(0.16,1,0.3,1)',
      maxWidth: '400px',
    });
    document.body.appendChild(toast);
    requestAnimationFrame(() => {
      toast.style.transform = 'translateY(0)';
      toast.style.opacity = '1';
    });
    setTimeout(() => {
      toast.style.transform = 'translateY(20px)';
      toast.style.opacity = '0';
      setTimeout(() => toast.remove(), 400);
    }, 4000);
  }

  // Expose globally so other scripts can use it
  (window as any).__bcToast = showToast;

  document.addEventListener('DOMContentLoaded', () => {
    // ── Billing toggle ──
    const radios = document.querySelectorAll<HTMLInputElement>('input[name="billing-cycle"]');
    const priceEls = document.querySelectorAll<HTMLElement>('[data-price-monthly]');

    function getSelectedCycle(): 'monthly' | 'yearly' {
      const checked = document.querySelector<HTMLInputElement>('input[name="billing-cycle"]:checked');
      return (checked?.value === 'yearly') ? 'yearly' : 'monthly';
    }

    radios.forEach(radio => {
      radio.addEventListener('change', () => {
        const isYearly = radio.value === 'yearly';
        priceEls.forEach(el => {
          el.textContent = isYearly ? el.dataset.priceYearly! : el.dataset.priceMonthly!;
        });
      });
    });

    // ── Detect current plan and mark button ──
    (async () => {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) return;

      try {
        const { data: sub } = await supabase
          .from('subscriptions')
          .select('plan')
          .eq('user_id', session.user.id)
          .single();

        const currentPlan = sub?.plan || 'explorador';

        // Mark the Explorador free button
        if (currentPlan === 'explorador') {
          const freeBtn = document.getElementById('btn-free') as HTMLElement | null;
          if (freeBtn) {
            freeBtn.textContent = 'Plano Atual';
            freeBtn.classList.remove('hover:bg-white/10', 'hover:border-white/20');
            freeBtn.classList.add('opacity-60', 'cursor-default');
            freeBtn.removeAttribute('href');
            freeBtn.style.pointerEvents = 'none';
          }
        }

        // Mark checkout buttons
        document.querySelectorAll<HTMLButtonElement>('.btn-checkout').forEach(btn => {
          if (btn.dataset.plan === currentPlan) {
            btn.textContent = 'Plano Atual';
            btn.disabled = true;
            btn.style.opacity = '0.6';
            btn.style.cursor = 'default';
            btn.style.background = '#374151';
            btn.style.boxShadow = 'none';
            btn.classList.remove('hover:bg-secondary');
          }
        });
      } catch {}
    })();

    // ── Checkout buttons ──
    const checkoutButtons = document.querySelectorAll<HTMLButtonElement>('.btn-checkout');

    checkoutButtons.forEach(btn => {
      btn.addEventListener('click', async () => {
        const plan = btn.dataset.plan;
        if (!plan) return;

        // Check auth
        const { data: { session } } = await supabase.auth.getSession();
        if (!session) {
          sessionStorage.setItem('pendingPlan', plan);
          sessionStorage.setItem('pendingCycle', getSelectedCycle());
          window.location.href = '/login';
          return;
        }

        // [TEST MODE] — troca plano diretamente sem pagamento
        const originalText = btn.textContent || '';
        btn.disabled = true;
        btn.textContent = 'Ativando...';
        btn.style.opacity = '0.7';

        try {
          const res = await fetch('/api/switch-plan', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${session.access_token}`,
            },
            body: JSON.stringify({ plan }),
          });

          if (res.ok) {
            btn.textContent = 'Plano ativado!';
            btn.style.background = '#10B981';
            showToast('Plano ativado com sucesso!', 'success');
            setTimeout(() => { window.location.href = '/perfil#plano'; }, 1500);
          } else {
            throw new Error('Erro ao trocar plano');
          }
        } catch (err: any) {
          showToast(err.message || 'Erro ao processar. Tente novamente.', 'error');
          btn.textContent = originalText;
          btn.disabled = false;
          btn.style.opacity = '1';
        }
      });
    });

    // ── Resume pending checkout after login redirect ──
    (async () => {
      const pendingPlan = sessionStorage.getItem('pendingPlan');
      const pendingCycle = sessionStorage.getItem('pendingCycle');
      if (!pendingPlan) return;

      const { data: { session } } = await supabase.auth.getSession();
      if (!session) return;

      // Clear stored plan
      sessionStorage.removeItem('pendingPlan');
      sessionStorage.removeItem('pendingCycle');

      // Auto-trigger checkout
      const btn = document.querySelector<HTMLButtonElement>(`.btn-checkout[data-plan="${pendingPlan}"]`);
      if (btn) {
        // Set the billing cycle first
        if (pendingCycle === 'yearly') {
          const yearlyRadio = document.querySelector<HTMLInputElement>('input[name="billing-cycle"][value="yearly"]');
          if (yearlyRadio) {
            yearlyRadio.checked = true;
            yearlyRadio.dispatchEvent(new Event('change'));
          }
        }
        // Small delay then click
        setTimeout(() => btn.click(), 500);
      }
    })();
  });
</script>

<script>
  // ── Recarga Rebelde: calculadora personalizada ──
  import { createClient as createRechargeClient } from '@supabase/supabase-js';

  const rechargeSupabase = createRechargeClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  document.addEventListener('DOMContentLoaded', () => {
    const PRICE_ECO = 0.055;
    const PRICE_MID = 0.55;
    const PRICE_ELITE = 3.85;

    // Sliders
    const ecoSlider = document.getElementById('custom-eco') as HTMLInputElement;
    const midSlider = document.getElementById('custom-mid') as HTMLInputElement;
    const eliteSlider = document.getElementById('custom-elite') as HTMLInputElement;
    const ecoCount = document.getElementById('custom-eco-count')!;
    const midCount = document.getElementById('custom-mid-count')!;
    const eliteCount = document.getElementById('custom-elite-count')!;
    const totalEl = document.getElementById('custom-total')!;
    const btnCustom = document.getElementById('btn-custom-recharge') as HTMLButtonElement;

    function updateCustomTotal() {
      const eco = parseInt(ecoSlider.value) || 0;
      const mid = parseInt(midSlider.value) || 0;
      const elite = parseInt(eliteSlider.value) || 0;
      const total = (eco * PRICE_ECO) + (mid * PRICE_MID) + (elite * PRICE_ELITE);

      ecoCount.textContent = String(eco);
      midCount.textContent = String(mid);
      eliteCount.textContent = String(elite);
      totalEl.textContent = `R$ ${total.toFixed(2).replace('.', ',')}`;
      btnCustom.disabled = total <= 0;
    }

    [ecoSlider, midSlider, eliteSlider].forEach(s => {
      if (s) s.addEventListener('input', updateCustomTotal);
    });

    // [TEST MODE] — Processar recarga direto no banco sem pagamento
    // TODO: restaurar integração Asaas quando for pro ar
    async function processRecharge(type: 'combo' | 'custom', comboName: string | null, eco: number, mid: number, elite: number, amount: number) {
      const { data: { session } } = await rechargeSupabase.auth.getSession();
      if (!session) {
        sessionStorage.setItem('pendingRecharge', JSON.stringify({ type, comboName, eco, mid, elite, amount }));
        window.location.href = '/login';
        return;
      }

      try {
        const res = await fetch('/api/test-recharge', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${session.access_token}`,
          },
          body: JSON.stringify({
            creditsEconomy: eco,
            creditsMid: mid,
            creditsElite: elite,
          }),
        });

        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Erro ao processar recarga');

        const toast = (window as any).__bcToast;
        if (toast) toast('Recarga aplicada com sucesso!', 'success');
        setTimeout(() => { window.location.href = '/perfil#plano'; }, 1500);
      } catch (err: any) {
        const toast = (window as any).__bcToast;
        if (toast) toast(err.message || 'Erro ao processar recarga.', 'error');
      }
    }

    // Botões de combo
    document.querySelectorAll<HTMLButtonElement>('.btn-recharge').forEach(btn => {
      btn.addEventListener('click', async () => {
        const parent = btn.closest<HTMLElement>('[data-combo]');
        if (!parent) return;

        const name = parent.dataset.combo!;
        const price = parseFloat(parent.dataset.price || '0');
        const eco = parseInt(parent.dataset.eco || '0');
        const mid = parseInt(parent.dataset.mid || '0');
        const elite = parseInt(parent.dataset.elite || '0');

        const originalText = btn.textContent || '';
        btn.disabled = true;
        btn.textContent = 'Processando...';

        await processRecharge('combo', name, eco, mid, elite, price);

        btn.textContent = originalText;
        btn.disabled = false;
      });
    });

    // Botão custom
    if (btnCustom) {
      btnCustom.addEventListener('click', async () => {
        const eco = parseInt(ecoSlider.value) || 0;
        const mid = parseInt(midSlider.value) || 0;
        const elite = parseInt(eliteSlider.value) || 0;
        const total = (eco * PRICE_ECO) + (mid * PRICE_MID) + (elite * PRICE_ELITE);
        if (total <= 0) return;

        const originalText = btnCustom.textContent || '';
        btnCustom.disabled = true;
        btnCustom.textContent = 'Processando...';

        await processRecharge('custom', null, eco, mid, elite, parseFloat(total.toFixed(2)));

        btnCustom.textContent = originalText;
        btnCustom.disabled = false;
      });
    }

    // Retomar recarga pendente após login
    const pendingRecharge = sessionStorage.getItem('pendingRecharge');
    if (pendingRecharge) {
      sessionStorage.removeItem('pendingRecharge');
      (async () => {
        const { data: { session } } = await rechargeSupabase.auth.getSession();
        if (!session) return;
        const r = JSON.parse(pendingRecharge);
        await processRecharge(r.type, r.comboName, r.eco, r.mid, r.elite, r.amount);
      })();
    }
  });
</script>

<script>
  // Logo swap for light/dark theme
  function updatePageLogo() {
    document.querySelectorAll('img[data-dark][data-light]').forEach(el => {
      const isLight = document.documentElement.classList.contains('light');
      el.setAttribute('src', isLight ? (el.getAttribute('data-light') || '') : (el.getAttribute('data-dark') || ''));
    });
  }
  updatePageLogo();
  new MutationObserver(updatePageLogo).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
</script>

