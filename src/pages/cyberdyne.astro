<!-- ═══════════════ STYLES ═══════════════ -->
<style>
  /* Scanline effect */
  .cd-scanline::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(220, 38, 38, 0.4), transparent);
    animation: cd-scan 4s linear infinite;
  }
  @keyframes cd-scan {
    0% { top: 0; opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { top: 100%; opacity: 0; }
  }

  /* Fade up animation for hero elements */
  .cd-fade-up {
    opacity: 0;
    transform: translateY(30px);
    animation: cd-fade-up 0.8s ease-out forwards;
  }
  @keyframes cd-fade-up {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Smooth scroll */
  html { scroll-behavior: smooth; }

  /* Section reveal on scroll */
  .cd-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  .cd-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Glow line separator */
  .cd-glow-line {
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(220,38,38,0.3) 50%, transparent 100%);
  }
</style>

<!-- Scroll reveal observer -->
<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

  document.querySelectorAll('section:not(#hero)').forEach(section => {
    section.classList.add('cd-reveal');
    observer.observe(section);
  });
</script>

</Layout>
