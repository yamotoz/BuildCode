   window.__openEditTech = function(tech) {
     document.getElementById('at-edit-id').value = tech.id;
     document.getElementById('at-modal-title').textContent = 'Editar Tecnologia';
     document.getElementById('at-name').value = tech.name || '';
     document.getElementById('at-category').value = tech.category || 'frontend';
     document.getElementById('at-tagline').value = tech.tagline || '';
     document.getElementById('at-description').value = tech.description || '';
     document.getElementById('at-language').value = tech.language || '';
     document.getElementById('at-role').value = tech.role || '';
     document.getElementById('at-pros').value = (tech.pros || []).join('\n');
     document.getElementById('at-cons').value = (tech.cons || []).join('\n');
     document.getElementById('at-logo').value = tech.logo || '';
     document.getElementById('at-website').value = tech.website || '';
     document.getElementById('at-usecases').value = tech.use_cases || '';
     document.getElementById('at-icon').value = tech.type_icon || 'code';
     // Highlight selected icon
     if (iconGrid) {
       iconGrid.querySelectorAll('button').forEach(function(b) { b.classList.remove('border-primary/40', 'bg-primary/10', 'text-primary'); b.classList.add('border-transparent', 'text-slate-500'); });
       var sel = iconGrid.querySelector('[data-icon="' + (tech.type_icon || 'code') + '"]');
       if (sel) { sel.classList.add('border-primary/40', 'bg-primary/10', 'text-primary'); sel.classList.remove('border-transparent', 'text-slate-500'); }
     }
     // IA sem censura checkbox
     var uncCb = document.getElementById('at-uncensored');
     var uncWrap = document.getElementById('at-uncensored-wrap');
     if (uncCb) uncCb.checked = !!tech.uncensored_ai;
     if (uncWrap) {
       if (tech.category === 'ai') uncWrap.classList.remove('hidden');
       else uncWrap.classList.add('hidden');
     }
     var submitBtn = document.getElementById('at-submit');
     if (submitBtn) submitBtn.innerHTML = '<span class="material-symbols-outlined text-base">save</span> Salvar Alterações';
     var modal = document.getElementById('modal-add-tech');
     if (modal) modal.classList.remove('hidden');
