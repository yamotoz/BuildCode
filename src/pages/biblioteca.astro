---
import Layout from '../layouts/Layout.astro';
import { categories } from '../data/categories';
import { technologies } from '../data/technologies';
---

<Layout
  title="Biblioteca Tecnica - 200+ Tecnologias | BuildCode"
  description="Catalogo curado com mais de 200 tecnologias em 9 categorias: frontend, backend, banco de dados, infraestrutura, bibliotecas, DevEx, IA, design e MCP. Busca e filtros avancados."
  canonicalPath="/biblioteca"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Biblioteca Tecnica - BuildCode",
    "description": "Catalogo curado de 200+ tecnologias para desenvolvimento de software",
    "url": "https://buildcode.com.br/biblioteca"
  }}
>
  <!-- Digital Grain Background para estética premium -->
  <div class="fixed inset-0 pointer-events-none bg-grain opacity-[0.03] z-[9999]"></div>
  
  <div class="flex h-screen overflow-hidden w-full relative bg-background-dark text-slate-200">
    
    <!-- LEFT SIDEBAR: Nav colapsável (hidden on mobile, shown via toggle) -->
    <aside id="sidebar" class="group/sidebar hidden md:flex w-[80px] hover:w-[260px] transition-all duration-500 ease-[cubic-bezier(0.2,0.8,0.2,1)] bg-surface-dark/80 backdrop-blur-3xl border-r border-border-color flex-col z-40 shrink-0">
      <div class="p-5 mb-4 flex items-center overflow-hidden shrink-0 mt-2">
        <a href="/" class="min-w-[40px] size-10 bg-primary/10 rounded-xl flex items-center justify-center border border-primary/20 shadow-[0_0_15px_rgba(46,116,139,0.15)] group-hover/sidebar:shadow-[0_0_20px_rgba(46,116,139,0.3)] transition-all">
          <img id="bib-logo" src="/logo_backofff.png" data-dark="/logo_backofff.png" data-light="/Logowhitemodeloff.png" alt="BuildCode" class="w-6 h-6 object-contain" width="136" height="32" />
        </a>
        <div class="ml-4 opacity-0 group-hover/sidebar:opacity-100 transition-opacity duration-300 whitespace-nowrap">
          <h1 class="font-display font-bold text-lg text-white tracking-tight">BuildCode</h1>
        </div>
      </div>

      <nav class="flex-1 px-4 space-y-1.5 overflow-y-auto custom-scrollbar pb-4">
        <button data-cat="all" class="cat-btn active w-full flex items-center gap-4 px-3 py-2.5 rounded-xl bg-primary/10 text-primary border border-primary/20 cursor-pointer overflow-hidden transition-all shadow-[0_0_10px_rgba(46,116,139,0.05)]">
          <span class="material-symbols-outlined min-w-[24px]">apps</span>
          <span class="font-bold text-sm opacity-0 group-hover/sidebar:opacity-100 transition-opacity whitespace-nowrap" data-i18n="bib.todas">Todas as Stacks</span>
        </button>
        {categories.map(cat => (
          <button data-cat={cat.id} class="cat-btn w-full flex items-center gap-4 px-3 py-2.5 rounded-xl text-slate-400 hover:bg-surface-light hover:text-white border border-transparent transition-all cursor-pointer overflow-hidden">
            <span class="material-symbols-outlined min-w-[24px]">{cat.icon}</span>
            <span class="font-medium text-sm opacity-0 group-hover/sidebar:opacity-100 transition-opacity whitespace-nowrap">{cat.name}</span>
          </button>
        ))}
      </nav>

      <div class="p-4 border-t border-border-color shrink-0">
         <a href="/analytics" class="w-full flex items-center gap-4 px-3 py-3 rounded-xl bg-cta/10 text-cta border border-cta/20 hover:bg-cta hover:text-background-dark hover:shadow-[0_0_20px_rgba(242,171,109,0.3)] transition-all duration-300 cursor-pointer overflow-hidden group/cta">
            <span class="material-symbols-outlined min-w-[24px] group-hover/cta:animate-bounce">analytics</span>
            <span class="font-bold text-sm opacity-0 group-hover/sidebar:opacity-100 transition-opacity whitespace-nowrap" data-i18n="bib.analytics">Visualizar Analytics</span>
         </a>
      </div>
    </aside>

    <!-- MOBILE: Bottom category bar -->
    <div id="mobile-cats" class="md:hidden fixed bottom-0 left-0 right-0 z-50 bg-surface-dark/95 backdrop-blur-xl border-t border-border-color overflow-x-auto custom-scrollbar">
      <div class="flex gap-2 px-4 py-3 min-w-max">
        <button data-cat="all" class="cat-btn active shrink-0 flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 text-primary border border-primary/20 text-xs font-bold">
          <span class="material-symbols-outlined text-sm">apps</span> Todas
        </button>
        {categories.map(cat => (
          <button data-cat={cat.id} class="cat-btn shrink-0 flex items-center gap-2 px-4 py-2 rounded-full text-slate-400 border border-transparent text-xs font-medium hover:bg-surface-light hover:text-white">
            <span class="material-symbols-outlined text-sm">{cat.icon}</span> {cat.name}
          </button>
        ))}
      </div>
    </div>

    <!-- MAIN CONTENT: Search & Grid -->
    <main id="main-content" class="flex-1 flex flex-col h-full overflow-y-auto overflow-x-hidden custom-scrollbar relative bg-[#06070a]">
      <!-- Background glows -->
      <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[150px] pointer-events-none"></div>
      
      <header class="sticky top-0 z-30 px-8 py-8 bg-[#06070a]/80 backdrop-blur-xl border-b border-white/[0.04] flex flex-col gap-8 transition-all duration-300">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 max-w-[1600px] mx-auto w-full">
          <div>
            <h2 class="font-display text-3xl font-black text-white tracking-tight"><span data-i18n="bib.title">Biblioteca </span><span id="category-title" class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary" data-i18n="bib.title.highlight">Técnica</span></h2>
            <p class="text-slate-400 text-sm mt-1 font-medium" data-i18n="bib.subtitle">Explore as ferramentas mais consolidadas do mercado e saiba exatamente quando usar.</p>
          </div>
          <div class="flex items-center gap-3 shrink-0">
            <button id="btn-add-tech" class="hidden items-center gap-1.5 px-4 py-2.5 rounded-xl bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 hover:bg-emerald-500/20 transition-all text-sm font-bold cursor-pointer" title="Adicionar tecnologia">
              <span class="material-symbols-outlined text-base">add_circle</span>
              <span class="hidden sm:inline">Adicionar</span>
            </button>
            <div class="flex items-center gap-4 bg-surface-dark px-5 py-3 rounded-2xl border border-border-color shadow-inner">
               <div class="flex flex-col items-center">
                 <span id="tech-count" class="font-display text-2xl font-black text-white leading-none">{technologies.length}</span>
                 <span class="text-[9px] text-slate-300 uppercase tracking-widest font-bold mt-1" data-i18n="bib.tecnologias">Tecnologias</span>
               </div>
               <div class="w-px h-8 bg-border-color mx-2"></div>
               <div class="flex flex-col items-center">
                 <span class="font-display text-2xl font-black text-white leading-none">{categories.length}</span>
                 <span class="text-[9px] text-slate-300 uppercase tracking-widest font-bold mt-1" data-i18n="bib.categorias">Categorias</span>
               </div>
            </div>
          </div>
        </div>
        
        <div class="relative w-full max-w-[1600px] mx-auto">
          <div class="rounded-2xl flex items-center px-6 py-4 transition-all bg-surface-dark border border-white/[0.06] focus-within:border-primary/50 focus-within:shadow-[0_0_30px_rgba(46,116,139,0.1)] group">
            <span class="material-symbols-outlined text-primary mr-4 group-focus-within:animate-pulse">search</span>
            <input id="search-input" aria-label="Buscar tecnologias" class="bg-transparent border-none focus:ring-0 text-white placeholder:text-slate-600 text-lg w-full font-body tracking-wide outline-none focus:outline-none" placeholder="Qual stack ou ferramenta você quer entender hoje?" data-i18n-placeholder="bib.search" type="text" autocomplete="off" spellcheck="false" />
            <div class="hidden md:flex items-center gap-1.5 opacity-40 shrink-0 pointer-events-none">
              <kbd class="px-2 py-0.5 rounded bg-surface-light border border-border-color text-[10px] font-mono font-bold text-slate-300">Ctrl</kbd>
              <kbd class="px-2 py-0.5 rounded bg-surface-light border border-border-color text-[10px] font-mono font-bold text-slate-300">K</kbd>
            </div>
          </div>
        </div>
      </header>

      <div class="p-4 md:p-8 pb-24 md:pb-8 w-full flex-1 max-w-[1600px] mx-auto">
        <div id="tech-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5 gap-4 md:gap-6">
           {technologies.map((tech, index) => (
             <div class="tech-card p-6 rounded-3xl border border-white/[0.04] bg-gradient-to-b from-[#0D1117] to-[#0A0C12] group cursor-pointer relative flex flex-col h-[260px] hover:-translate-y-1 hover:border-primary/40 hover:from-[#12161E] hover:to-[#0D1117] transition-all duration-300 hover:shadow-[0_10px_40px_rgba(0,0,0,0.5)]" data-index={index} data-name={tech.name.toLowerCase()} data-cat={tech.category}>
                
                <div class="flex justify-between items-start mb-6 relative z-10">
                  <div class="size-12 rounded-xl bg-black border border-white/5 group-hover:border-primary/30 group-hover:shadow-[0_0_20px_rgba(46,116,139,0.15)] transition-all overflow-hidden relative">
                    <img src={tech.logo} alt={tech.name} loading="lazy" class="absolute inset-1.5 w-[calc(100%-12px)] h-[calc(100%-12px)] object-contain" width="36" height="36" />
                  </div>
                  <div class="flex flex-col items-end gap-1.5">
                    <span class="text-[9px] text-slate-400 font-bold uppercase tracking-widest px-2 py-1 inline-flex items-center justify-center rounded-lg bg-white/[0.02] border border-white/[0.05] group-hover:bg-primary/10 group-hover:text-primary group-hover:border-primary/20 transition-all">{tech.language}</span>
                    {tech.tags && tech.tags.map(tag => (
                      <span class="text-[8px] font-extrabold uppercase tracking-widest px-2 py-0.5 rounded-md bg-red-500/15 text-red-400 border border-red-500/30 flex items-center gap-1 animate-pulse">
                        <span class="material-symbols-outlined text-[10px]">lock_open</span>
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
                
                <div class="mb-4 relative z-10 flex-1">
                  <div class="flex flex-col gap-1.5 mb-2">
                    <h3 class="font-display text-xl font-bold text-white tracking-tight leading-none group-hover:text-primary transition-colors">{tech.name}</h3>
                    <span class="text-[10px] text-secondary font-bold tracking-widest uppercase">{tech.tagline}</span>
                  </div>
                  <p class="text-slate-400 text-xs leading-relaxed font-body line-clamp-3 mt-3 opacity-80 group-hover:opacity-100 transition-opacity">{tech.description}</p>
                </div>
                
                <div class="mt-auto pt-4 border-t border-white/[0.03] flex items-center justify-between relative z-10">
                  <div class="flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-primary/50 group-hover:bg-cta group-hover:animate-pulse"></span>
                    <span class="text-[10px] text-slate-300 font-bold uppercase tracking-tighter italic">{tech.role}</span>
                  </div>
                  <span class="material-symbols-outlined text-sm text-primary opacity-0 group-hover:opacity-100 -translate-x-2 group-hover:translate-x-0 transition-all">arrow_forward</span>
                </div>
             </div>
           ))}
        </div>
        
        <div id="empty-state" class="hidden flex-col items-center justify-center py-20 opacity-60">
           <span class="material-symbols-outlined text-6xl text-slate-600 mb-4">search_off</span>
           <h3 class="font-display text-xl font-bold text-slate-300" data-i18n="bib.empty.title">Nenhuma tecnologia encontrada</h3>
           <p class="text-slate-500 text-sm mt-2" data-i18n="bib.empty.desc">Tente buscar por um termo diferente ou mude a categoria.</p>
        </div>
      </div>
    </main>

    <!-- MODAL: Adicionar Tecnologia -->
    <div id="modal-add-tech" class="hidden fixed inset-0 z-[9999] flex items-center justify-center bg-black/70 backdrop-blur-sm p-4">
      <div class="w-full max-w-lg rounded-2xl border border-border-color bg-[#0e1214] shadow-2xl max-h-[90vh] overflow-y-auto">
        <div class="flex items-center justify-between px-6 py-4 border-b border-border-color">
          <h3 id="at-modal-title" class="font-display text-lg font-bold text-white">Adicionar Tecnologia</h3>
          <button id="close-add-tech" class="text-slate-500 hover:text-white p-1 cursor-pointer"><span class="material-symbols-outlined">close</span></button>
        </div>
        <input type="hidden" id="at-edit-id" value="" />
        <div class="p-6 space-y-4">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1 block">Nome *</label>
              <input id="at-name" type="text" aria-label="Nome da tecnologia" placeholder="React" class="w-full rounded-lg border border-border-color bg-surface-dark/50 px-3 py-2 text-sm text-white outline-none focus:border-primary/60" />
            </div>
            <div>
              <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1 block">Categoria *</label>
              <select id="at-category" aria-label="Categoria" class="w-full rounded-lg border border-border-color bg-surface-dark/50 px-3 py-2 text-sm text-white outline-none focus:border-primary/60">
                <option value="frontend">Frontend</option><option value="backend">Backend</option>
                <option value="data">Dados</option><option value="infra">Infra</option>
                <option value="libs">Bibliotecas</option><option value="devex">DevEx</option>
                <option value="ai">IA</option><option value="design">Design</option>
                <option value="mcp">MCP</option>
              </select>
            </div>
          </div>
          <div>
            <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1 block">Tagline *</label>
            <input id="at-tagline" type="text" aria-label="Tagline" placeholder="Biblioteca JavaScript para interfaces" class="w-full rounded-lg border border-border-color bg-surface-dark/50 px-3 py-2 text-sm text-white outline-none focus:border-primary/60" />
          </div>
          <div>
            <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1 block">Descrição *</label>
            <textarea id="at-description" rows="3" aria-label="Descrição" placeholder="Descrição completa..." class="w-full rounded-lg border border-border-color bg-surface-dark/50 px-3 py-2 text-sm text-white outline-none focus:border-primary/60 resize-none"></textarea>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1 block">Linguagem</label>
              <input id="at-language" type="text" aria-label="Linguagem" placeholder="JavaScript" class="w-full rounded-lg border border-border-color bg-surface-dark/50 px-3 py-2 text-sm text-white outline-none focus:border-primary/60" />
            </div>
            <div>
              <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1 block">Role</label>
              <input id="at-role" type="text" aria-label="Role" placeholder="UI Library" class="w-full rounded-lg border border-border-color bg-surface-dark/50 px-3 py-2 text-sm text-white outline-none focus:border-primary/60" />
            </div>
          </div>
          <div>
            <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1 block">Prós (um por linha)</label>
            <textarea id="at-pros" rows="2" aria-label="Prós" placeholder="Performance excelente&#10;Comunidade ativa" class="w-full rounded-lg border border-border-color bg-surface-dark/50 px-3 py-2 text-sm text-white outline-none focus:border-primary/60 resize-none"></textarea>
          </div>
          <div>
            <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1 block">Contras (um por linha)</label>
            <textarea id="at-cons" rows="2" aria-label="Contras" placeholder="Curva de aprendizado&#10;Bundle size" class="w-full rounded-lg border border-border-color bg-surface-dark/50 px-3 py-2 text-sm text-white outline-none focus:border-primary/60 resize-none"></textarea>
          </div>
          <!-- Icon selector -->
          <div>
            <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-2 block">Ícone do Card</label>
            <input type="hidden" id="at-icon" value="code" />
            <div id="icon-grid" class="grid grid-cols-8 gap-1.5 p-2 rounded-xl border border-border-color bg-surface-dark/30 max-h-[120px] overflow-y-auto">
              <!-- Icons populated by JS below -->
            </div>
            <p class="text-[10px] text-slate-600 mt-1">Selecione um ícone ou use a Logo URL abaixo (Logo URL tem prioridade)</p>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1 block">Logo URL</label>
              <input id="at-logo" type="url" aria-label="URL do logo" placeholder="https://..." class="w-full rounded-lg border border-border-color bg-surface-dark/50 px-3 py-2 text-sm text-white outline-none focus:border-primary/60" />
            </div>
            <div>
              <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1 block">Website</label>
              <input id="at-website" type="url" aria-label="Website" placeholder="https://..." class="w-full rounded-lg border border-border-color bg-surface-dark/50 px-3 py-2 text-sm text-white outline-none focus:border-primary/60" />
            </div>
          </div>
          <div>
            <label class="text-[10px] uppercase tracking-widest font-bold text-slate-500 mb-1 block">Casos de Uso</label>
            <input id="at-usecases" type="text" aria-label="Casos de uso" placeholder="SPAs, dashboards, mobile apps" class="w-full rounded-lg border border-border-color bg-surface-dark/50 px-3 py-2 text-sm text-white outline-none focus:border-primary/60" />
          </div>
          <!-- Checkbox IA sem censura (aparece só quando categoria = ia) -->
          <div id="at-uncensored-wrap" class="hidden">
            <label class="flex items-center gap-3 px-3 py-2.5 rounded-xl border border-red-500/20 bg-red-500/5 cursor-pointer hover:bg-red-500/10 transition-all">
              <input id="at-uncensored" type="checkbox" class="w-4 h-4 accent-red-500 cursor-pointer" />
              <div>
                <span class="text-sm font-bold text-red-400">IA sem censura?</span>
                <p class="text-[10px] text-slate-500 mt-0.5">Marque se esta IA opera sem filtros de conteudo</p>
              </div>
            </label>
          </div>
          <div id="at-msg" class="hidden rounded-lg px-3 py-2 text-sm font-medium"></div>
          <button id="at-submit" class="w-full py-3 rounded-xl bg-emerald-500/15 text-emerald-400 border border-emerald-500/25 hover:bg-emerald-500/25 transition-all text-sm font-bold cursor-pointer flex items-center justify-center gap-2">
            <span class="material-symbols-outlined text-base">add</span>
            Adicionar à Biblioteca
          </button>
        </div>
      </div>
    </div>

    <!-- RIGHT SIDEBAR: Painel de Visão Detalhada -->
    <aside id="detail-sidebar" class="w-0 shrink-0 opacity-0 overflow-hidden border-l border-white/[0.05] bg-black/60 backdrop-blur-3xl flex flex-col z-50 transition-all duration-[400ms] ease-[cubic-bezier(0.2,0.8,0.2,1)] absolute right-0 top-0 h-full md:relative">
      <div class="p-6 border-b border-white/[0.05] flex justify-between items-center bg-black/20 shrink-0">
        <h2 class="font-display text-[10px] uppercase tracking-[0.25em] font-extrabold text-slate-400" data-i18n="bib.detail.title">Visão Detalhada</h2>
        <button id="close-detail" class="text-slate-500 hover:text-white bg-white/[0.03] hover:bg-white/[0.08] p-2 rounded-xl transition-all border border-transparent hover:border-white/10" aria-label="Fechar detalhes">
          <span class="material-symbols-outlined text-sm">close</span>
        </button>
      </div>
      
      <div class="flex-1 overflow-y-auto p-8 custom-scrollbar relative" id="detail-content">
        <!-- Injetado magicamente via JS para ultra-velocidade -->
      </div>
    </aside>

  </div>
</Layout>

<style>
  /* Tipografia garantida pelas definições em global.css */
  .custom-scrollbar::-webkit-scrollbar {
      width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
      background: rgba(255, 255, 255, 0.1);
      border-radius: 10px;
  }
  .bg-grain {
      background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuD9NIKu1eMtRCsTKT7BAKjW5vNbqTx_kCS1c4ZUa7z934FhzTzEf77HBIWQx35UKSAnLAmmq6YX5HTlH4rdFIf1x6zGwfyIZyL7vuBeUzHc3Ml9QwwY8xYFVEI646SBtSCW3lqIe3lbxXb6V3QvAYd8G9_QrbjFyrPBWC9VmCBmu3dZ_lNsZMs1EdJTkPpqT0hnAJPpo3oiuRABGFaSVjl6qmx4KpgWQXCFXLdVu8GeXfy99AX35rGoUKb9ovpwCO7kMOY7CY8qgwLb");
  }
  
  /* State para right-sidebar ativa */
  .detail-open {
      width: 100%;
      opacity: 1;
  }
  @media (min-width: 768px) {
      .detail-open {
          width: 420px;
      }
  }

  /* Micro-animação para entrada dos cards */
  .tech-card {
      animation: fadeIn 0.4s ease-out backwards;
  }
  @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
  }
  .tech-card:nth-child(n) { animation-delay: calc(var(--grid-index, 0) * 0.03s); }
</style>

<script define:vars={{ techData: technologies }}>
   const cards = document.querySelectorAll('.tech-card');
   const sidebar = document.getElementById('detail-sidebar');
   const closeBtn = document.getElementById('close-detail');
   const detailContent = document.getElementById('detail-content');
   const searchInput = document.getElementById('search-input');
   const catBtns = document.querySelectorAll('.cat-btn');
   const emptyState = document.getElementById('empty-state');
   const categoryTitle = document.getElementById('category-title');
  
   let activeCategory = 'all';

   // Inject index var for stagger animations
   cards.forEach((card, i) => {
       card.style.setProperty('--grid-index', i % 20); // limits delay scaling
   });

   // Close Sidebar Logic
   function closeSidebar() {
      sidebar.classList.remove('detail-open');
      cards.forEach(c => c.classList.remove('ring-1', 'ring-primary', 'border-transparent', 'shadow-[0_0_30px_rgba(46,116,139,0.15)]'));
   }

   closeBtn.addEventListener('click', closeSidebar);
   document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeSidebar(); });

   // Open Sidebar & Render details
   cards.forEach(card => {
      card.addEventListener('click', () => {
         const index = card.getAttribute('data-index');
         const tech = techData[index];
         
         // Select state feedback
         cards.forEach(c => c.classList.remove('ring-1', 'ring-primary', 'border-transparent', 'shadow-[0_0_30px_rgba(46,116,139,0.15)]'));
         card.classList.add('ring-1', 'ring-primary', 'border-transparent', 'shadow-[0_0_30px_rgba(46,116,139,0.15)]');

         // Populate details panel injected markup (tailored to colors and typography of BC)
         detailContent.innerHTML = `
            <div class="flex flex-col items-center mb-8 text-center animate-[fadeIn_0.3s_ease-out]">
              <!-- Logo grande no painel de detalhes -->
