       if (msgEl) msgEl.classList.add('hidden');
       modal.classList.remove('hidden');
     });
     closeModal.addEventListener('click', function() { modal.classList.add('hidden'); });
     modal.addEventListener('click', function(e) { if (e.target === modal) modal.classList.add('hidden'); });
   }

   // Show/hide "IA sem censura?" checkbox based on category
   var atCategory = document.getElementById('at-category');
   var atUncensoredWrap = document.getElementById('at-uncensored-wrap');
   if (atCategory && atUncensoredWrap) {
     atCategory.addEventListener('change', function() {
       if (atCategory.value === 'ai') {
         atUncensoredWrap.classList.remove('hidden');
       } else {
         atUncensoredWrap.classList.add('hidden');
         var cb = document.getElementById('at-uncensored');
         if (cb) cb.checked = false;
       }
     });
   }

   if (submitBtn) {
     submitBtn.addEventListener('click', async function() {
       var msgEl = document.getElementById('at-msg');
       var name = document.getElementById('at-name').value.trim();
       var category = document.getElementById('at-category').value;
       var tagline = document.getElementById('at-tagline').value.trim();
       var description = document.getElementById('at-description').value.trim();

       if (!name || !tagline || !description) {
         msgEl.className = 'rounded-lg px-3 py-2 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
         msgEl.textContent = 'Preencha nome, tagline e descrição.';
         msgEl.classList.remove('hidden');
         return;
       }

       submitBtn.disabled = true;
       submitBtn.textContent = 'Salvando...';

       try {
         var session = window.__bibSession || null;

         if (!session) {
           msgEl.className = 'rounded-lg px-3 py-2 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
           msgEl.textContent = 'Faça login primeiro.';
           msgEl.classList.remove('hidden');
           submitBtn.disabled = false;
           submitBtn.innerHTML = '<span class="material-symbols-outlined text-base">add</span> Adicionar à Biblioteca';
           return;
         }

         var editId = document.getElementById('at-edit-id').value;
         var isEdit = !!editId;
         var body = {
           name: name,
           category: category,
           tagline: tagline,
           description: description,
           language: document.getElementById('at-language').value.trim(),
           role: document.getElementById('at-role').value.trim(),
           pros: document.getElementById('at-pros').value.trim(),
           cons: document.getElementById('at-cons').value.trim(),
           logo: document.getElementById('at-logo').value.trim(),
           website: document.getElementById('at-website').value.trim(),
           use_cases: document.getElementById('at-usecases').value.trim(),
           type_icon: document.getElementById('at-icon').value || 'code',
           uncensored_ai: document.getElementById('at-uncensored')?.checked || false,
         };
         if (isEdit) body.id = editId;

         var res = await fetch('/api/biblioteca', {
           method: isEdit ? 'PUT' : 'POST',
           headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + session.access_token },
           body: JSON.stringify(body),
         });

         var result = await res.json();

         if (!res.ok) {
           msgEl.className = 'rounded-lg px-3 py-2 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
           msgEl.textContent = result.error || 'Erro ao salvar.';
           msgEl.classList.remove('hidden');
         } else {
           if (isEdit) {
             // Update in-memory and reload
             var idx = customTechs.findIndex(function(t) { return t.id === editId; });
             if (idx >= 0) customTechs[idx] = result;
             // Reload all custom cards
             document.querySelectorAll('.tech-card[data-index^="c"]').forEach(function(el) { el.remove(); });
             customTechs.forEach(function(t, i) { addCustomCardToGrid(t, i); });
             applyFilters();
           } else {
             addCustomCardToGrid(result, customTechs.length);
             customTechs.push(result);
             var countEl = document.getElementById('tech-count');
             if (countEl) countEl.textContent = String(techData.length + customTechs.length);
           }
           msgEl.className = 'rounded-lg px-3 py-2 text-sm font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/20';
           msgEl.textContent = isEdit ? 'Tecnologia atualizada!' : 'Tecnologia adicionada com sucesso!';
           msgEl.classList.remove('hidden');
           // Clear form
           ['at-name','at-tagline','at-description','at-language','at-role','at-pros','at-cons','at-logo','at-website','at-usecases'].forEach(function(id) { document.getElementById(id).value = ''; });
           document.getElementById('at-edit-id').value = '';
           document.getElementById('at-icon').value = 'code';
           document.getElementById('at-modal-title').textContent = 'Adicionar Tecnologia';
           setTimeout(function() { modal.classList.add('hidden'); msgEl.classList.add('hidden'); }, 1500);
         }
       } catch(e) {
         msgEl.className = 'rounded-lg px-3 py-2 text-sm font-medium bg-red-500/10 text-red-400 border border-red-500/20';
         msgEl.textContent = 'Erro de rede.';
         msgEl.classList.remove('hidden');
       }
       submitBtn.disabled = false;
       submitBtn.innerHTML = '<span class="material-symbols-outlined text-base">add</span> Adicionar à Biblioteca';
     });
   }
</script>

<!-- Module script to check permission and show add button -->
<script>
  import { supabase, getProfile } from '../lib/supabase';
  async function checkBibPerm() {
    try {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) return;
      (window as any).__bibSession = session;
      const profile = await getProfile(session.user.id);
      if (profile && (profile.role === 'master' || profile.can_edit_biblioteca)) {
        const btn = document.getElementById('btn-add-tech');
        if (btn) { btn.classList.remove('hidden'); btn.classList.add('flex'); }
        // Show edit buttons on custom cards
        document.querySelectorAll('.cd-edit-tech').forEach(el => {
          el.classList.remove('hidden');
          el.classList.add('inline-flex');
        });
        // Store permission flag for dynamically added cards
        (window as any).__canEditBib = true;
      }
    } catch {}
  }
  checkBibPerm();
</script>
