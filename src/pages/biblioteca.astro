     document.querySelectorAll('img[data-dark][data-light]').forEach(el => {
       const img = el;
       const isLight = document.documentElement.classList.contains('light');
       img.setAttribute('src', isLight ? (img.getAttribute('data-light') || '') : (img.getAttribute('data-dark') || ''));
     });
   }
   updatePageLogo();
   new MutationObserver(updatePageLogo).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

