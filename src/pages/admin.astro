---
import Layout from '../layouts/Layout.astro';
import AdminWrapper from '../components/analytics/AdminWrapper';

export const prerender = false;
---

<Layout title="Dashboard Admin - BuildCode | Metricas e Gestao" description="Painel administrativo do BuildCode. Metricas SaaS, gestao de usuarios, acompanhamento de receita e analise de performance." noindex={true}>
  <div class="min-h-screen bg-background-dark relative w-full max-w-[100vw] overflow-x-hidden">
    <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[150px] pointer-events-none"></div>

    <!-- Top bar -->
    <header class="sticky top-0 z-40 glass-panel border-b border-border-color px-6 py-4">
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 text-slate-100 hover:opacity-80 transition-opacity">
          <img id="admin-logo" src="/logo_backofff.png" data-dark="/logo_backofff.png" data-light="/Logowhitemodeloff.png" alt="BuildCode" class="h-8 w-auto object-contain" width="136" height="32" />
          <h2 class="font-display text-xl font-bold tracking-tight text-white hidden sm:block">BuildCode</h2>
        </a>
        <div class="flex items-center gap-3">
          <span class="text-[10px] text-purple-400 uppercase tracking-widest font-bold flex items-center gap-1">
            <span class="material-symbols-outlined text-xs">shield</span>
            <span data-i18n="admin.badge">Admin Dashboard</span>
          </span>
          <a href="/perfil" class="text-sm text-slate-400 hover:text-white transition-colors font-medium flex items-center gap-1">
            <span class="material-symbols-outlined text-sm">arrow_back</span>
            <span data-i18n="admin.back">Voltar ao Perfil</span>
          </a>
        </div>
      </div>
    </header>

    <!-- Dashboard (React island) -->
    <main id="main-content" class="max-w-7xl mx-auto px-6 py-8">
      <h1 class="sr-only">Painel de Administração</h1>
      <AdminWrapper client:load />
    </main>
  </div>
</Layout>

<script>
  // Logo swap for light/dark theme
  function updatePageLogo() {
    document.querySelectorAll('img[data-dark][data-light]').forEach(el => {
      const isLight = document.documentElement.classList.contains('light');
      el.setAttribute('src', isLight ? (el.getAttribute('data-light') || '') : (el.getAttribute('data-dark') || ''));
    });
  }
  updatePageLogo();
  new MutationObserver(updatePageLogo).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
</script>
