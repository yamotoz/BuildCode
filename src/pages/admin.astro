---
import Layout from '../layouts/Layout.astro';

export const prerender = false;
---

<Layout title="BuildCode | Dashboard Admin">
  <div class="min-h-screen bg-background-dark relative">
    <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[150px] pointer-events-none"></div>

    <!-- Top bar -->
    <header class="sticky top-0 z-40 glass-panel border-b border-border-color px-6 py-4">
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 text-slate-100 hover:opacity-80 transition-opacity">
          <img src="/logo_backofff.png" alt="BuildCode" class="h-8 w-auto object-contain" />
          <h2 class="font-display text-xl font-bold tracking-tight text-white hidden sm:block">BuildCode</h2>
        </a>
        <div class="flex items-center gap-3">
          <span class="text-[10px] text-purple-400 uppercase tracking-widest font-bold flex items-center gap-1">
            <span class="material-symbols-outlined text-xs">shield</span>
            Admin Dashboard
          </span>
          <a href="/perfil" class="text-sm text-slate-400 hover:text-white transition-colors font-medium flex items-center gap-1">
            <span class="material-symbols-outlined text-sm">arrow_back</span>
            Voltar ao Perfil
          </a>
        </div>
      </div>
    </header>

    <!-- Loading -->
    <div id="admin-loading" class="flex items-center justify-center py-32">
      <div class="flex flex-col items-center gap-4">
        <span class="material-symbols-outlined text-4xl text-primary animate-spin">progress_activity</span>
        <p class="text-slate-400 text-sm">Carregando dashboard...</p>
      </div>
    </div>

    <!-- Unauthorized -->
    <div id="admin-unauth" class="hidden flex-col items-center justify-center py-32 text-center">
      <span class="material-symbols-outlined text-6xl text-slate-600 mb-4">lock</span>
      <h2 class="text-2xl font-bold text-white mb-2">Acesso Restrito</h2>
      <p class="text-slate-400 mb-6">Apenas administradores podem acessar esta página.</p>
      <a href="/perfil" class="px-6 py-3 rounded-xl bg-primary text-white font-semibold hover:bg-primary-dark transition-colors">Voltar ao Perfil</a>
    </div>

    <!-- Dashboard container -->
    <main id="admin-content" class="hidden max-w-7xl mx-auto px-6 py-8">
      <div id="dashboard-mount"></div>
    </main>
  </div>
</Layout>

<script>
  import { supabase, getProfile } from '../lib/supabase';
  import { createElement } from 'react';
  import { createRoot } from 'react-dom/client';
  import AdminDashboard from '../components/analytics/AdminDashboard';

  const loadingEl = document.getElementById('admin-loading')!;
  const unauthEl = document.getElementById('admin-unauth')!;
  const contentEl = document.getElementById('admin-content')!;

  async function init() {
    const { data: { session } } = await supabase.auth.getSession();

    if (!session) {
      loadingEl.classList.add('hidden');
      unauthEl.classList.remove('hidden');
      unauthEl.classList.add('flex');
      return;
    }

    const profile = await getProfile(session.user.id);

    if (!profile || !['master', 'admin'].includes(profile.role)) {
      loadingEl.classList.add('hidden');
      unauthEl.classList.remove('hidden');
      unauthEl.classList.add('flex');
      return;
    }

    // Fetch metrics data
    const metrics = await fetchMetrics();

    loadingEl.classList.add('hidden');
    contentEl.classList.remove('hidden');

    // Mount React dashboard
    const mount = document.getElementById('dashboard-mount');
    if (mount) {
      const root = createRoot(mount);
      root.render(createElement(AdminDashboard, { metrics }));
    }
  }

  async function fetchMetrics() {
    // Fetch subscriptions
    const { data: subs } = await supabase.from('subscriptions').select('plan, status');
    const activeSubs = (subs || []).filter(s => s.status === 'active');

    const planPrices: Record<string, number> = { explorador: 0, consultor: 35, arquiteto: 50 };
    const mrr = activeSubs.reduce((sum, s) => sum + (planPrices[s.plan] || 0), 0);

    const planDistribution = [
      { plan: 'Explorador', count: activeSubs.filter(s => s.plan === 'explorador').length || 0 },
      { plan: 'Consultor', count: activeSubs.filter(s => s.plan === 'consultor').length || 0 },
      { plan: 'Arquiteto', count: activeSubs.filter(s => s.plan === 'arquiteto').length || 0 },
    ];

    // Fetch usage logs for cost aggregation
    const { data: costs } = await supabase.from('api_costs').select('*').order('period_date', { ascending: true }).limit(180);

    const apiCosts = [
      { provider: 'OpenAI', cost: 0 },
      { provider: 'OpenRouter', cost: 0 },
      { provider: 'Supabase', cost: 0 },
      { provider: 'Vercel', cost: 0 },
    ];

    (costs || []).forEach(c => {
      const entry = apiCosts.find(a => a.provider.toLowerCase() === c.provider);
      if (entry) entry.cost += Number(c.total_cost_usd) || 0;
    });

    // Fetch profiles for segmentation
    const { data: profiles } = await supabase.from('profiles').select('seniority');
    const userSegmentation = [
      { seniority: 'Junior', count: (profiles || []).filter(p => p.seniority === 'junior').length },
      { seniority: 'Pleno', count: (profiles || []).filter(p => p.seniority === 'pleno').length },
      { seniority: 'Senior', count: (profiles || []).filter(p => p.seniority === 'senior').length },
    ];

    // Build revenue history (last 6 months placeholder from api_costs)
    const months = ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun'];
    const revenueHistory = months.map(month => ({
      month,
      revenue: mrr + Math.floor(Math.random() * 200 - 100),
      cost: apiCosts.reduce((s, a) => s + a.cost, 0) / 6 + Math.floor(Math.random() * 20),
    }));

    const totalUsers = (profiles || []).length;
    const arpu = totalUsers > 0 ? mrr / totalUsers : 0;

    return {
      mrr,
      mrrTrend: 12.5,
      churnRate: 3.2,
      churnTrend: -0.5,
      arpu,
      ltv: arpu * 12,
      totalUsers,
      apiCosts,
      planDistribution,
      revenueHistory,
      userSegmentation,
    };
  }

  init();
</script>
